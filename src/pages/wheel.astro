---
import Base from '../layouts/Base.astro';
---
<Base title="Raffle wheel">
  <main class="wheel-main" id="wheel-root">
    <p class="loading">Loading the wheel…</p>
  </main>
</Base>

<script>
  // The wheel page is a single bundle in two modes:
  //   /wheel?slug=…              — viewer (audience). Subscribes to the
  //     Realtime channel raffle:<slug> and animates whenever the host
  //     broadcasts a spin. No spin button.
  //   /wheel?slug=…&key=…        — controller (host). Same as viewer plus
  //     a Spin button that (a) calls manage-raffle action='draw' to mark
  //     a real winner server-side, (b) broadcasts the winner_id + spin
  //     duration so every connected phone animates in sync.
  //
  // Sync model: each client starts the local animation the moment it
  // receives the broadcast. Network drift is ~50–200ms in a single room,
  // imperceptible against a 7-second spin. v0.2 could send a server
  // timestamp and have viewers fast-forward, but the simple version
  // looks great in practice.
  import { callFunction, getConfig, fetchRafflePrizes } from '../lib/supabase.js';
  import { eventUrl } from '../lib/urls.js';
  import { createClient } from '@supabase/supabase-js';

  type PoolEntry = { id: string; first_name: string };
  type Winner = { id: string; first_name: string; prize_won: string | null };
  type Prize = {
    id: string; name: string; photo_url: string | null;
    is_grand: boolean;
    quantity: number;
    drawn_count: number;
    drawn_winner_id: string | null;
  };

  const root = document.getElementById('wheel-root')!;
  const base = import.meta.env.BASE_URL;
  const params = new URLSearchParams(window.location.search);
  const slug = params.get('slug');
  const key = params.get('key');
  const isHost = !!key;

  function escapeHtml(s: unknown): string {
    return String(s ?? '').replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!)
    );
  }

  // Slice colors cycle through a small palette so adjacent slices contrast.
  const SLICE_COLORS = ['#f39c12', '#e67e22', '#d35400', '#c0392b', '#8e44ad', '#2980b9', '#27ae60', '#16a085'];

  const SPIN_DURATION_MS = 7000;
  const EXTRA_FULL_TURNS = 6; // how many full rotations before settling

  let pool: PoolEntry[] = [];
  let winners: Winner[] = [];
  let prizes: Prize[] = [];
  let eventInfo: { name: string; accent_color: string | null; raffle_prize: string | null } = {
    name: '',
    accent_color: null,
    raffle_prize: null,
  };
  let currentRotation = 0; // current canvas rotation in radians
  let spinning = false;
  let canvas: HTMLCanvasElement | null = null;
  let ctx: CanvasRenderingContext2D | null = null;
  // Tracks the prize we're currently spinning for, populated by the
  // incoming broadcast payload. Drives the "Spinning for: X" header
  // and the post-spin winner overlay's prize line.
  let currentSpinPrize: { name: string | null; is_grand: boolean } | null = null;

  if (!slug) {
    root.innerHTML = '<p class="loading err">No event specified.</p>';
  } else {
    init();
  }

  async function init() {
    try {
      const data = await callFunction('get-raffle-pool', { slug });
      pool = data.pool as PoolEntry[];
      winners = data.winners as Winner[];
      prizes = (data.prizes || []) as Prize[];
      eventInfo = data.event;
      const accent = eventInfo.accent_color || '#f39c12';
      document.documentElement.style.setProperty('--accent', accent);
      document.title = `Wheel — ${eventInfo.name}`;
      render();
      drawWheel();
      subscribeRealtime();
    } catch (err) {
      root.innerHTML = `<p class="loading err">${escapeHtml((err as Error).message)}</p>`;
    }
  }

  function render() {
    const winnersBlock = winners.length
      ? `<section class="winners-block">
          <h2>Winners so far</h2>
          <ul>${winners.map((w) =>
            `<li>🏆 <strong>${escapeHtml(w.first_name)}</strong>${w.prize_won ? ` — ${escapeHtml(w.prize_won)}` : ''}</li>`
          ).join('')}</ul>
        </section>`
      : '';

    // Multi-prize raffle: prize ladder shows what's still up for grabs
    // (and what's already been won) so attendees can see the stakes
    // between spins. Hidden in legacy single-prize mode (prizes is []).
    const prizeLadderBlock = prizes.length > 0
      ? `<section class="wheel-prize-ladder">
          <h2>Today's prizes</h2>
          <ul>${prizes.map((p) => {
            const qty = p.quantity || 1;
            const drawn = p.drawn_count || 0;
            const allDrawn = drawn >= qty;
            // Multi-quantity status: "1 of 3 drawn", "all 3 drawn", or the
            // single-quantity "✓ won" / "— up for grabs" labels.
            let status = '— up for grabs';
            if (allDrawn) {
              status = qty > 1 ? `✓ all ${qty} drawn` : '✓ won';
            } else if (drawn > 0) {
              status = `${drawn} of ${qty} drawn`;
            }
            return `
              <li class="${p.is_grand ? 'grand' : ''} ${allDrawn ? 'won' : ''}">
                ${p.photo_url
                  ? `<img src="${escapeHtml(p.photo_url)}" alt="" />`
                  : '<span class="ph"></span>'}
                <span class="pname">
                  ${escapeHtml(p.name)}${qty > 1 ? ` <span class="qty">× ${qty}</span>` : ''}
                  ${p.is_grand ? '<span class="badge">GRAND</span>' : ''}
                </span>
                <span class="pstatus">${status}</span>
              </li>`;
          }).join('')}</ul>
        </section>`
      : '';

    // Local-mode Spin button only renders in single-prize legacy mode.
    // When prizes are defined, the host launches each spin from the live
    // dashboard (which broadcasts to this page). Multi-prize mode shows a
    // dim hint instead.
    const spinControls = !isHost ? '' : (
      prizes.length > 0
        ? `<div class="controls multi-prize-hint">
            <p class="status" id="spin-status" role="status" aria-live="polite"></p>
            <p class="multi-prize-note">🎯 This event uses multiple prizes — launch each draw from the <strong>Live dashboard</strong> on your phone. The wheel here animates automatically when you do.</p>
          </div>`
        : `<div class="controls">
            <button id="spin-btn" type="button" ${pool.length === 0 ? 'disabled' : ''}>🎲 Spin the Wheel</button>
            <p class="status" id="spin-status" role="status" aria-live="polite"></p>
          </div>`
    );

    // Header prize line: in single-prize mode show the legacy text; in
    // multi-prize mode the prize ladder below carries this info instead.
    const headerPrize = (prizes.length === 0 && eventInfo.raffle_prize)
      ? `<p class="prize">🎁 <strong>${escapeHtml(eventInfo.raffle_prize)}</strong></p>`
      : '';

    root.innerHTML = `
      <header class="top">
        <p class="eyebrow">Live Drawing</p>
        <h1>${escapeHtml(eventInfo.name)}</h1>
        ${headerPrize}
        <p id="spin-for" class="spin-for" style="display:none;"></p>
      </header>

      <div class="wheel-stage">
        <div class="pointer">▼</div>
        <canvas id="wheel-canvas" width="600" height="600"></canvas>
      </div>
      <p class="entry-count">${pool.length} ${pool.length === 1 ? 'entry' : 'entries'} eligible</p>

      ${spinControls}
      ${prizeLadderBlock}
      ${winnersBlock}

      <div class="footer-cta">
        <a class="secondary" href="${eventUrl(base, slug!)}">← Back to the event</a>
      </div>
    `;
    canvas = document.getElementById('wheel-canvas') as HTMLCanvasElement;
    ctx = canvas.getContext('2d');
    if (isHost && prizes.length === 0) {
      document.getElementById('spin-btn')!.addEventListener('click', handleSpin);
    }
  }

  function drawWheel() {
    if (!canvas || !ctx) return;
    const w = canvas.width;
    const h = canvas.height;
    const cx = w / 2;
    const cy = h / 2;
    const radius = Math.min(w, h) / 2 - 10;
    ctx.clearRect(0, 0, w, h);

    if (pool.length === 0) {
      ctx.fillStyle = '#95a5a6';
      ctx.font = '20px -apple-system, BlinkMacSystemFont, sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText('No eligible entries', cx, cy);
      return;
    }

    const sliceAngle = (Math.PI * 2) / pool.length;
    ctx.save();
    ctx.translate(cx, cy);
    ctx.rotate(currentRotation);
    pool.forEach((entry, i) => {
      const startAngle = i * sliceAngle - Math.PI / 2; // start at top
      const endAngle = startAngle + sliceAngle;
      ctx!.beginPath();
      ctx!.moveTo(0, 0);
      ctx!.arc(0, 0, radius, startAngle, endAngle);
      ctx!.closePath();
      ctx!.fillStyle = SLICE_COLORS[i % SLICE_COLORS.length];
      ctx!.fill();
      ctx!.strokeStyle = 'rgba(0,0,0,0.30)';
      ctx!.lineWidth = 2;
      ctx!.stroke();

      // Label: rotated to slice middle, drawn radially outward.
      ctx!.save();
      ctx!.rotate(startAngle + sliceAngle / 2);
      ctx!.textAlign = 'right';
      ctx!.textBaseline = 'middle';
      ctx!.fillStyle = '#1a252f';
      const fontSize = pool.length > 24 ? 12 : pool.length > 14 ? 14 : 18;
      ctx!.font = `700 ${fontSize}px -apple-system, BlinkMacSystemFont, sans-serif`;
      const label = entry.first_name.length > 14 ? entry.first_name.slice(0, 13) + '…' : entry.first_name;
      ctx!.fillText(label, radius - 14, 0);
      ctx!.restore();
    });

    // Center hub
    ctx.beginPath();
    ctx.arc(0, 0, 22, 0, Math.PI * 2);
    ctx.fillStyle = '#1a252f';
    ctx.fill();
    ctx.lineWidth = 3;
    ctx.strokeStyle = 'var(--accent, #f39c12)';
    ctx.strokeStyle = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim() || '#f39c12';
    ctx.stroke();
    ctx.restore();
  }

  // Spin to land winner index at the top (under the pointer).
  // Cubic ease-out for the slow-down; same params on every client → same spin.
  function animateSpin(winnerIndex: number, durationMs: number, onDone: () => void) {
    if (!canvas || !ctx) return onDone();
    if (pool.length === 0) return onDone();

    spinning = true;
    const sliceAngle = (Math.PI * 2) / pool.length;
    // Where we want winner's center to end up: directly under pointer
    // (which is at angle = -PI/2 in canvas coords). Solve for rotation.
    const winnerCenter = winnerIndex * sliceAngle + sliceAngle / 2 - Math.PI / 2;
    // Final rotation = some full turns + (-winnerCenter) so that point is at top.
    const targetRotation = currentRotation
      + EXTRA_FULL_TURNS * Math.PI * 2
      + ((-winnerCenter - currentRotation) % (Math.PI * 2));
    const startRotation = currentRotation;
    const startTime = performance.now();

    function frame(now: number) {
      const elapsed = now - startTime;
      const t = Math.min(1, elapsed / durationMs);
      // Cubic ease-out: 1 - (1-t)^3
      const eased = 1 - Math.pow(1 - t, 3);
      currentRotation = startRotation + (targetRotation - startRotation) * eased;
      drawWheel();
      if (t < 1) {
        requestAnimationFrame(frame);
      } else {
        currentRotation = targetRotation;
        drawWheel();
        spinning = false;
        onDone();
      }
    }
    requestAnimationFrame(frame);
  }

  function showWinnerOverlay(winner: {
    first_name: string; prize_won?: string | null; is_grand?: boolean;
  }) {
    const overlay = document.createElement('div');
    overlay.className = 'winner-overlay' + (winner.is_grand ? ' grand' : '');
    const headline = winner.is_grand ? '🏆 GRAND PRIZE WINNER!' : '🎉 Winner!';
    overlay.innerHTML = `
      <div class="winner-card ${winner.is_grand ? 'grand' : ''}">
        <p class="big">${headline}</p>
        <p class="winner-name">${escapeHtml(winner.first_name)}</p>
        ${winner.prize_won ? `<p class="winner-prize">${escapeHtml(winner.prize_won)}</p>` : ''}
        <button type="button" class="winner-close">Close</button>
      </div>`;
    document.body.appendChild(overlay);
    overlay.querySelector('.winner-close')!.addEventListener('click', () => overlay.remove());
    // Grand prize gets longer auto-dismiss so the moment lands.
    setTimeout(() => overlay.remove(), winner.is_grand ? 18000 : 12000);
  }

  // Channel reused for both directions; viewers receive, hosts also send.
  let channel: ReturnType<ReturnType<typeof createClient>['channel']> | null = null;
  function subscribeRealtime() {
    const cfg = getConfig();
    if (!cfg.url || !cfg.anonKey) return;
    const client = createClient(cfg.url, cfg.anonKey);
    channel = client.channel(`raffle:${slug}`, { config: { broadcast: { self: false } } });
    channel.on('broadcast', { event: 'spin' }, ({ payload }) => {
      handleIncomingSpin(payload);
    });
    channel.subscribe();
  }

  async function handleSpin() {
    if (spinning || !isHost) return;
    const btn = document.getElementById('spin-btn') as HTMLButtonElement;
    const status = document.getElementById('spin-status')!;
    btn.disabled = true;
    status.textContent = 'Drawing…';
    try {
      const res = await callFunction('manage-raffle', {
        slug, edit_token: key, action: 'draw',
      });
      const winner = res.winner as { id: string; name: string; prize_won: string | null };
      const winnerIndex = pool.findIndex((p) => p.id === winner.id);
      if (winnerIndex < 0) {
        // The winner isn't in the local pool (e.g., another host added an entry
        // since we last loaded). Refresh and try to find them again.
        const data = await callFunction('get-raffle-pool', { slug });
        pool = data.pool as PoolEntry[];
        drawWheel();
        const i2 = pool.findIndex((p) => p.id === winner.id);
        if (i2 < 0) {
          status.textContent = 'Winner already removed from pool — wheel out of sync, reloading.';
          location.reload();
          return;
        }
        broadcastSpin(winner, i2);
      } else {
        broadcastSpin(winner, winnerIndex);
      }
      status.textContent = '';
    } catch (err) {
      status.textContent = (err as Error).message;
      btn.disabled = false;
    }
  }

  function broadcastSpin(
    winner: { id: string; name: string; prize_won: string | null },
    winnerIndex: number
  ) {
    const firstName = (winner.name || '').trim().split(/\s+/)[0] || 'Anon';
    const payload = {
      winner_id: winner.id,
      winner_first_name: firstName,
      winner_prize: winner.prize_won,
      duration_ms: SPIN_DURATION_MS,
    };
    if (channel) {
      channel.send({ type: 'broadcast', event: 'spin', payload });
    }
    // Run the animation locally too — broadcast self:false above doesn't
    // round-trip our own message back, so we drive the local wheel here.
    runSpin(payload, winnerIndex);
  }

  type SpinPayload = {
    winner_id: string;
    winner_first_name: string;
    winner_prize: string | null;
    prize_id?: string | null;
    prize_name?: string | null;
    is_grand?: boolean;
    duration_ms: number;
  };

  function handleIncomingSpin(payload: SpinPayload) {
    const winnerIndex = pool.findIndex((p) => p.id === payload.winner_id);
    if (winnerIndex < 0) {
      // Pool drift — refetch then animate based on the refreshed state.
      callFunction('get-raffle-pool', { slug }).then((data) => {
        pool = data.pool as PoolEntry[];
        drawWheel();
        const i2 = pool.findIndex((p) => p.id === payload.winner_id);
        if (i2 >= 0) runSpin(payload, i2);
      });
      return;
    }
    runSpin(payload, winnerIndex);
  }

  function runSpin(payload: SpinPayload, winnerIndex: number) {
    // Surface the "Spinning for: X" header for the duration of the spin.
    currentSpinPrize = {
      name: payload.prize_name || payload.winner_prize || null,
      is_grand: !!payload.is_grand,
    };
    const spinFor = document.getElementById('spin-for');
    if (spinFor && currentSpinPrize.name) {
      const grandBadge = currentSpinPrize.is_grand ? ' <span class="grand-badge">GRAND PRIZE</span>' : '';
      spinFor.innerHTML = `Spinning for: <strong>${escapeHtml(currentSpinPrize.name)}</strong>${grandBadge}`;
      spinFor.style.display = '';
      spinFor.classList.toggle('grand', !!currentSpinPrize.is_grand);
    }
    animateSpin(winnerIndex, payload.duration_ms, async () => {
      showWinnerOverlay({
        first_name: payload.winner_first_name,
        prize_won: payload.prize_name || payload.winner_prize,
        is_grand: !!payload.is_grand,
      });
      // Refresh pool + winners + prize-ladder state after the spin so the
      // next round renders with the winner removed, the winners-so-far
      // list updated, and the just-won prize marked ✓ on the ladder.
      try {
        const data = await callFunction('get-raffle-pool', { slug });
        pool = data.pool as PoolEntry[];
        winners = data.winners as Winner[];
        prizes = (data.prizes || []) as Prize[];
        currentRotation = 0;
        currentSpinPrize = null;
        render();
        drawWheel();
      } catch {
        /* non-fatal */
      }
    });
  }
</script>

<style is:global>
  :root { --accent: #f39c12; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: #1a252f; color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  body { padding: 18px 12px 40px; line-height: 1.45; }
  main.wheel-main { max-width: 640px; margin: 0 auto; text-align: center; }

  .top .eyebrow {
    font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--accent); font-weight: 700; margin-bottom: 6px;
  }
  .top h1 { font-size: 24px; }
  .top .prize {
    margin-top: 8px;
    font-size: 14px; color: #ecf0f1;
  }
  .top .prize strong { color: var(--accent); }

  /* "Spinning for: <prize name>" header — set by runSpin during a spin
     and cleared after the post-spin refresh. */
  .spin-for {
    margin-top: 10px;
    font-size: 16px; color: #ecf0f1; line-height: 1.4;
  }
  .spin-for strong { color: var(--accent); }
  .spin-for.grand {
    color: #f1c40f; font-weight: 700; font-size: 18px;
  }
  .spin-for.grand strong { color: #f1c40f; }
  .spin-for .grand-badge {
    display: inline-block;
    font-size: 10px; font-weight: 800; letter-spacing: 1.2px;
    padding: 2px 8px; margin-left: 6px;
    border-radius: 999px;
    background: rgba(241,196,15,0.18);
    color: #f1c40f;
    border: 1px solid rgba(241,196,15,0.5);
    vertical-align: middle;
  }

  .multi-prize-hint {
    background: rgba(243,156,18,0.06);
    border: 1px dashed rgba(243,156,18,0.4);
    border-radius: 8px;
    padding: 10px 14px;
  }
  .multi-prize-note {
    font-size: 12px; color: #bdc3c7;
    line-height: 1.5; margin: 6px 0 0;
  }
  .multi-prize-note strong { color: var(--accent); }

  /* Prize ladder (multi-prize mode) — shown beneath the wheel so
     attendees see what's still up for grabs between spins. */
  .wheel-prize-ladder {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 14px 16px; margin: 16px 0 0;
    text-align: left;
  }
  .wheel-prize-ladder h2 {
    font-size: 12px; color: var(--accent);
    text-transform: uppercase; letter-spacing: 1.5px;
    margin-bottom: 10px;
  }
  .wheel-prize-ladder ul { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; }
  .wheel-prize-ladder li {
    display: grid;
    grid-template-columns: 36px 1fr auto;
    gap: 10px; align-items: center;
    padding: 6px 8px; border-radius: 6px;
    background: rgba(0,0,0,0.20);
    font-size: 13px; color: #ecf0f1;
  }
  .wheel-prize-ladder li.grand {
    background: rgba(243,156,18,0.08);
    border: 1px solid rgba(243,156,18,0.4);
  }
  .wheel-prize-ladder li.won { opacity: 0.55; }
  .wheel-prize-ladder li img {
    width: 36px; height: 36px; border-radius: 4px;
    object-fit: cover; background: rgba(0,0,0,0.4);
  }
  .wheel-prize-ladder li .ph {
    width: 36px; height: 36px; border-radius: 4px;
    border: 1px dashed rgba(255,255,255,0.14);
    display: block;
  }
  .wheel-prize-ladder li .pname { font-weight: 700; color: #ecf0f1; }
  .wheel-prize-ladder li .pname .badge {
    display: inline-block; margin-left: 4px;
    font-size: 9px; font-weight: 800; letter-spacing: 1px;
    padding: 1px 6px; border-radius: 999px;
    background: rgba(243,156,18,0.20); color: var(--accent);
    border: 1px solid rgba(243,156,18,0.5);
  }
  .wheel-prize-ladder li .pname .qty {
    display: inline-block;
    font-size: 10px; font-weight: 700; letter-spacing: 0.3px;
    padding: 1px 6px; border-radius: 6px;
    background: rgba(255,255,255,0.10); color: #ecf0f1;
    border: 1px solid rgba(255,255,255,0.18);
  }
  .wheel-prize-ladder li .pstatus {
    font-size: 11px; color: #95a5a6; font-style: italic;
  }
  .wheel-prize-ladder li.won .pstatus { color: #2ecc71; font-style: normal; font-weight: 700; }

  .wheel-stage {
    position: relative;
    margin: 16px auto 8px;
    width: 100%;
    max-width: 460px;
  }
  .wheel-stage canvas {
    width: 100%; height: auto; display: block;
    background: rgba(0,0,0,0.10);
    border-radius: 50%;
    box-shadow: 0 8px 30px rgba(0,0,0,0.4);
  }
  .wheel-stage .pointer {
    position: absolute;
    top: -4px; left: 50%; transform: translateX(-50%);
    color: var(--accent); font-size: 30px;
    line-height: 1; pointer-events: none;
    text-shadow: 0 2px 6px rgba(0,0,0,0.6);
    z-index: 2;
  }
  p.entry-count { font-size: 13px; color: #95a5a6; margin: 4px 0 14px; }

  .controls { margin: 14px 0 18px; }
  .controls button {
    padding: 14px 28px; font-size: 17px; font-weight: 800;
    background: var(--accent); color: #1a252f; border: none;
    border-radius: 10px; cursor: pointer;
  }
  .controls button:disabled { opacity: 0.45; cursor: not-allowed; }
  .controls .status { font-size: 13px; color: #95a5a6; margin-top: 6px; min-height: 18px; }

  .winners-block {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 14px 16px;
    text-align: left;
    margin-top: 16px;
  }
  .winners-block h2 {
    font-size: 12px; color: var(--accent);
    text-transform: uppercase; letter-spacing: 1.5px;
    margin-bottom: 8px;
  }
  .winners-block ul { list-style: none; padding: 0; }
  .winners-block li {
    font-size: 14px; color: #ecf0f1;
    padding: 4px 0;
  }

  .footer-cta { margin-top: 22px; }
  .footer-cta a {
    display: inline-block; padding: 10px 18px;
    background: transparent; color: #ecf0f1;
    border: 1px solid rgba(255,255,255,0.20);
    border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 13px;
  }

  .winner-overlay {
