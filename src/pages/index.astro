---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;
---
<Base title="Coach Hub Template">
  <main class="landing">
    <section class="hero">
      <p class="eyebrow">For Fitness & Wellness Coaches</p>
      <h1>Your transformations, on a phone-friendly hub.</h1>
      <p class="lede">
        Drop your client photos and biometric data into a form. Get a
        shareable URL with branded before/after stories and a dual-axis
        chart that auto-renders. No signup, no monthly fee.
      </p>
      <a class="cta" href={`${base}build`}>Build Yours →</a>
    </section>

    <section class="how">
      <h2>How it works</h2>
      <ol>
        <li>Fill in your hub: name, accent color, optional email.</li>
        <li>Add transformations: photos + paste-in weight / BF% / lean data.</li>
        <li>Hit Build. You get a public URL and a private edit URL — bookmark both.</li>
      </ol>
    </section>
  </main>
</Base>

<style>
  :root { --accent: #f39c12; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: #1a252f; color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  body { padding: 40px 18px; line-height: 1.5; }
  main.landing { max-width: 640px; margin: 0 auto; }
  .eyebrow {
    font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--accent); font-weight: 700; margin-bottom: 10px;
  }
  h1 { font-size: 32px; line-height: 1.2; margin-bottom: 14px; }
  .lede { color: #bdc3c7; font-size: 16px; margin-bottom: 22px; }
  a.cta {
    display: inline-block; padding: 14px 22px;
    background: var(--accent); color: #1a252f;
    font-weight: 800; text-decoration: none; border-radius: 8px;
    font-size: 16px;
  }
  section.how { margin-top: 44px; }
  section.how h2 {
    font-size: 18px; color: #ecf0f1;
    text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 14px;
  }
  section.how ol { padding-left: 22px; color: #bdc3c7; font-size: 15px; }
  section.how li { margin-bottom: 8px; }
</style>
