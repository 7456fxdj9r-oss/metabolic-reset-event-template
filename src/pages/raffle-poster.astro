---
// Printable raffle poster. Letter portrait, white background. Vertical
// stack: event title up top, grand prize photo in the dominant middle,
// big QR (raffle-entry URL) at the bottom so the eye flows from "what
// is this?" → "what do I win?" → "how do I enter?".
//
// Pulls the grand prize from raffle_prizes (falls back to legacy
// event.raffle_prize fields for events that haven't migrated to the
// multi-prize model). Renders even if no prize is defined — useful for
// set-up before entries open.
import Base from '../layouts/Base.astro';
---
<Base title="Raffle poster">
  <div class="page-controls" id="page-controls">
    <a class="back" id="back-link" href="#">← Back</a>
    <button id="print-btn" type="button">🖨 Print or Save as PDF</button>
    <p class="hint">
      Tip: in the print dialog, set <strong>Background graphics</strong> ON so
      the orange stripe prints. <strong>Portrait</strong> orientation, US Letter.
      Use <strong>Save as PDF</strong> if you want a file to take to the print shop.
    </p>
  </div>

  <main class="poster" id="poster-root">
    <p class="loading">Loading…</p>
  </main>
</Base>

<script>
  import { fetchEventBySlug, callFunction, fetchRafflePrizes } from '../lib/supabase.js';
  import { eventUrl, editUrl, raffleUrl } from '../lib/urls.js';
  import QRCode from 'qrcode';

  type Prize = {
    id: string; name: string; description: string | null;
    photo_url: string | null;
    is_grand: boolean;
  };

  const root = document.getElementById('poster-root')!;
  const base = import.meta.env.BASE_URL;
  const params = new URLSearchParams(window.location.search);
  const slug = params.get('slug');
  const key = params.get('key'); // optional — sets up the back link

  function escapeHtml(s: unknown): string {
    return String(s ?? '').replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!)
    );
  }

  function fmtEventDate(d: string | null): string {
    if (!d) return '';
    const dt = new Date(d + 'T00:00:00');
    if (isNaN(dt.getTime())) return d;
    return dt.toLocaleDateString(undefined, {
      weekday: 'long', month: 'long', day: 'numeric', year: 'numeric',
    });
  }

  if (!slug) {
    root.innerHTML = '<p class="loading err">No event specified.</p>';
  } else {
    (async () => {
      try {
        const event = await fetchEventBySlug(slug);
        if (!event) {
          root.innerHTML = '<p class="loading err">Event not found.</p>';
          return;
        }
        document.title = `Raffle poster — ${event.name}`;
        const accent = event.accent_color || '#d35400';
        document.documentElement.style.setProperty('--accent', accent);

        // Back link goes to edit page if we have a key, else the public event.
        const back = document.getElementById('back-link') as HTMLAnchorElement;
        back.href = key ? editUrl(base, slug, key) : eventUrl(base, slug);
        back.textContent = key ? '← Back to edit page' : '← Back to event';

        // Prizes + hosts are independent reads; fire them in parallel so
        // poster open is one round-trip instead of three.
        const [prizesRes, hostsRes] = await Promise.all([
          fetchRafflePrizes(event.id).catch(() => [] as Prize[]),
          callFunction('get-event-hosts', { slug }).catch(() => null),
        ]);

        // Pick the grand prize (or first prize) for the headline image +
        // name. Falls back to the legacy event.raffle_prize columns for
        // events that haven't migrated to multi-prize.
        let prizePhotoUrl: string | null = event.raffle_prize_photo_url || null;
        let prizeName: string | null = event.raffle_prize || null;
        const prizes = prizesRes as Prize[];
        if (prizes.length > 0) {
          const headline = prizes.find((p) => p.is_grand) || prizes[0];
          prizePhotoUrl = headline.photo_url || prizePhotoUrl;
          prizeName = headline.name;
        }

        let primary: { name: string | null; phone: string | null } = { name: null, phone: null };
        const primaryHost = (hostsRes?.hosts || []).find((h: { primary?: boolean }) => h.primary);
        if (primaryHost) primary = { name: primaryHost.name, phone: primaryHost.phone };

        const datePretty = fmtEventDate(event.event_date);

        // QR encodes the raffle entry URL (not the event hub) — this poster
        // exists to drive entries, so scan should land on the entry form.
        const qrTarget = `${window.location.origin}${raffleUrl(base, slug)}`;

        root.innerHTML = `
          <article class="sheet">
            <header class="sheet-top">
              <p class="kicker">Metabolic Reset Event</p>
              <h1>${escapeHtml(event.name)}</h1>
              ${event.host_line ? `<p class="loc">📍 ${escapeHtml(event.host_line)}</p>` : ''}
              ${datePretty ? `<p class="date">${escapeHtml(datePretty)}</p>` : ''}
            </header>

            <section class="prize-block">
              ${prizePhotoUrl
                ? `<img class="prize-photo" src="${escapeHtml(prizePhotoUrl)}" alt="${escapeHtml(prizeName || 'Prize')}" />`
                : '<div class="prize-photo placeholder">Prize photo</div>'}
              <span class="prize-label">Grand Prize</span>
              <p class="prize-name">${escapeHtml(prizeName || '—')}</p>
            </section>

            <section class="qr-block">
              <canvas id="qr-canvas"></canvas>
              <p class="scan-cta">📱 Scan to enter</p>
              <p class="qr-url">${escapeHtml(qrTarget)}</p>
            </section>

            <footer class="sheet-bottom">
              ${primary.name ? `<p class="hosted-by">Hosted by ${escapeHtml(primary.name)}${primary.phone ? ` · ${escapeHtml(primary.phone)}` : ''}</p>` : ''}
            </footer>
          </article>
        `;

        const canvas = document.getElementById('qr-canvas') as HTMLCanvasElement;
        QRCode.toCanvas(canvas, qrTarget, {
          width: 600, margin: 2,
          color: { dark: '#1a252f', light: '#ffffff' },
        }).catch(() => {});

        document.getElementById('print-btn')!.addEventListener('click', () => window.print());
      } catch (err) {
        root.innerHTML = `<p class="loading err">${escapeHtml((err as Error).message)}</p>`;
      }
    })();
  }
</script>

<style is:global>
  :root { --accent: #d35400; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: #2c3e50; color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  body { padding: 20px 14px 60px; line-height: 1.4; }

  /* Screen-only controls; hidden when printing */
  .page-controls {
    max-width: 720px; margin: 0 auto 16px;
    background: rgba(0,0,0,0.30);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 10px; padding: 14px 16px;
    display: flex; flex-wrap: wrap; align-items: center; gap: 10px;
  }
  .page-controls .back {
    color: #ecf0f1; text-decoration: none;
    padding: 8px 14px; font-size: 13px; font-weight: 600;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.15); border-radius: 6px;
  }
  .page-controls #print-btn {
    padding: 10px 18px; font-size: 14px; font-weight: 800;
    background: var(--accent); color: #fff;
    border: none; border-radius: 8px; cursor: pointer;
  }
  .page-controls .hint {
    flex-basis: 100%;
    font-size: 12px; color: #95a5a6; line-height: 1.5;
  }
  .page-controls .hint strong { color: #ecf0f1; }

  /* Letter portrait sheet — vertical stack: title → prize → QR → footer */
  main.poster { display: flex; justify-content: center; }
  .sheet {
    width: 8.5in;
    min-height: 11in;
    background: #ffffff;
    color: #2c3e50;
    padding: 0.55in 0.6in 0.45in;
    box-shadow: 0 8px 30px rgba(0,0,0,0.35);
    display: flex; flex-direction: column;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  /* Accent stripes top and bottom */
  .sheet::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0;
    height: 14px; background: var(--accent);
  }
  .sheet::after {
    content: '';
    position: absolute; bottom: 0; left: 0; right: 0;
    height: 8px; background: var(--accent);
  }

  .sheet-top { margin-top: 10px; }
  .sheet-top .kicker {
    font-size: 12px; letter-spacing: 4px;
    text-transform: uppercase; color: var(--accent);
    font-weight: 800; margin-bottom: 8px;
  }
  .sheet-top h1 {
    font-size: 38px; line-height: 1.1;
    color: #1a252f; font-weight: 800;
    letter-spacing: -0.5px;
    margin-bottom: 6px;
  }
  .sheet-top .loc {
    font-size: 14px; color: #34495e;
    margin-top: 4px; font-weight: 600;
  }
  .sheet-top .date {
    font-size: 13px; color: #7f8c8d; font-style: italic;
    margin-top: 2px;
  }

  /* Prize block: dominant visual element, sits in the upper-middle */
  .prize-block {
    margin: 0.3in auto 0;
    max-width: 6in;
  }
  .prize-photo {
    display: block;
    width: 100%;
    max-height: 4.4in;
    object-fit: contain;
    border-radius: 14px;
    background: #f5f5f5;
    box-shadow: 0 10px 28px rgba(0,0,0,0.12);
    padding: 10px;
  }
  .prize-photo.placeholder {
    height: 3.6in;
    display: flex; align-items: center; justify-content: center;
    color: #bdc3c7; font-style: italic; font-size: 16px;
    border: 2px dashed #bdc3c7;
  }
  .prize-label {
    display: inline-block;
    margin: 14px 0 6px;
    padding: 5px 14px;
    font-size: 12px; font-weight: 800;
    letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, white);
    border-radius: 12px;
  }
  .prize-name {
    font-size: 22px; font-weight: 700;
    color: #1a252f; line-height: 1.25;
    overflow-wrap: anywhere;
  }

  /* QR block: bottom of the sheet, mid-size QR to keep prize dominant */
  .qr-block {
    margin: 0.3in auto 0;
  }
  .qr-block canvas {
    display: block;
    width: 2.6in !important;
    height: 2.6in !important;
    margin: 0 auto;
    padding: 8px;
    background: #fff;
    border: 3px solid #1a252f;
    border-radius: 10px;
  }
  .scan-cta {
    margin-top: 12px;
    font-size: 24px; font-weight: 800;
    letter-spacing: 1.5px;
    color: var(--accent);
  }
  .qr-url {
    margin-top: 4px;
    font-size: 11px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    color: #7f8c8d;
    overflow-wrap: anywhere; word-break: break-all;
  }

  .sheet-bottom {
    margin-top: auto;
    padding-top: 14px;
    border-top: 1px solid #ecf0f1;
  }
  .sheet-bottom .hosted-by {
    font-size: 13px; color: #34495e;
    letter-spacing: 0.5px; font-weight: 600;
  }

  .loading { color: #95a5a6; text-align: center; padding: 60px 0; font-size: 14px; }
  .loading.err { color: #e74c3c; }

  /* Print rules: hide the screen controls, drop the dark page chrome,
     let the .sheet fill the page. */
  @media print {
    @page { size: letter portrait; margin: 0; }
    html, body { background: #fff !important; padding: 0 !important; }
    .page-controls { display: none !important; }
    main.poster { display: block; }
    .sheet {
      box-shadow: none;
      width: 100%;
      min-height: 100vh;
      padding: 0.5in 0.55in 0.4in;
      page-break-after: avoid;
    }
    .sheet::before { height: 18px; }
  }

  /* Tighten on tablet-ish previews (still > sheet width but small) */
  @media (max-width: 9in) {
    .sheet { width: 100%; padding: 0.5in 0.4in; }
    .sheet-top h1 { font-size: 32px; }
    .prize-photo { max-height: 3.8in; }
    .qr-block canvas { width: 2.4in !important; height: 2.4in !important; }
    .scan-cta { font-size: 20px; }
  }
</style>
