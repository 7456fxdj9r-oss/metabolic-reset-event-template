---
import Base from '../layouts/Base.astro';
---
<Base title="Event">
  <main class="event" id="event-root">
    <p class="loading">Loading event…</p>
  </main>
</Base>

<script>
  import { fetchEventBySlug, fetchTransformations, fetchSpeakers, callFunction } from '../lib/supabase.js';
  import QRCode from 'qrcode';

  const root = document.getElementById('event-root')!;
  const base = import.meta.env.BASE_URL;
  const params = new URLSearchParams(window.location.search);
  const slug = params.get('slug');

  function escapeHtml(s: unknown): string {
    return String(s ?? '').replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!)
    );
  }

  if (!slug) {
    root.innerHTML = '<p class="loading">No event specified.</p>';
  } else {
    (async () => {
      try {
        const event = await fetchEventBySlug(slug);
        if (!event) {
          root.innerHTML = '<p class="loading">Event not found.</p>';
          return;
        }
        document.title = event.name;
        const accent = event.accent_color || '#f39c12';
        document.documentElement.style.setProperty('--accent', accent);

        const [transformations, speakers, hostsRes] = await Promise.all([
          fetchTransformations(event.id),
          fetchSpeakers(event.id),
          callFunction('get-event-hosts', { slug }).catch(() => ({ hosts: [] })),
        ]);
        const teamHosts = (hostsRes.hosts || []) as Array<{
          name: string | null; phone: string | null;
          email?: string | null; website?: string | null; bio?: string | null;
          primary?: boolean;
        }>;

        // Auto-close: even if raffle_status is 'open', hide the CTA after
        // the event date.
        const today = new Date().toISOString().slice(0, 10);
        const raffleAutoClosed = event.event_date && today > event.event_date;
        const raffleOpen = event.raffle_status === 'open' && !raffleAutoClosed;

        // Button stack mirrors the Spokane reference index layout: each
        // entity becomes a single full-width button, not a card.
        const buttons: string[] = [];
        if (raffleOpen) {
          buttons.push(
            `<a class="event-btn raffle" href="${base}raffle?slug=${encodeURIComponent(slug)}">🎟️ Enter the Raffle${event.raffle_prize ? ` — ${escapeHtml(event.raffle_prize)}` : ''}</a>`
          );
        }
        for (const t of transformations) {
          const tHref = `${base}t?slug=${encodeURIComponent(slug)}&t=${encodeURIComponent(t.slug)}`;
          buttons.push(`<a class="event-btn story" href="${tHref}">📊 ${escapeHtml(t.name)}'s Story</a>`);
        }
        if (speakers.length > 0) {
          buttons.push(
            `<a class="event-btn speakers" href="${base}speakers?slug=${encodeURIComponent(slug)}">🎤 Speaker Bios</a>`
          );
        }
        buttons.push(
          `<a class="event-btn science" href="${base}science?slug=${encodeURIComponent(slug)}">🧠 Why It Works (the science)</a>`
        );

        // Connect-with-the-team panel: list every host with name + phone so
        // attendees can pick someone to call. Primary host gets the extra
        // bio/email/website fields rendered if filled. Panel hides if no
        // host has any info at all.
        const teamHtml = teamHosts.length === 0 ? '' : `
          <section class="team">
            <h2>Connect with the team</h2>
            <ul class="team-list">
              ${teamHosts.map((h) => {
                const tagged = h.primary ? '<span class="host-tag">organizer</span>' : '';
                const phoneRow = h.phone
                  ? `<a class="host-phone" href="tel:${escapeHtml(h.phone)}">📞 ${escapeHtml(h.phone)}</a>`
                  : '';
                const extras: string[] = [];
                if (h.email) extras.push(`<a href="mailto:${escapeHtml(h.email)}">✉️ ${escapeHtml(h.email)}</a>`);
                if (h.website) extras.push(`<a href="${escapeHtml(h.website)}" target="_blank" rel="noopener">🌐 Website</a>`);
                return `
                  <li class="host-card">
                    <div class="host-head">
                      <strong>${escapeHtml(h.name || 'Co-host')}</strong>
                      ${tagged}
                    </div>
                    ${h.bio ? `<p class="host-bio">${escapeHtml(h.bio)}</p>` : ''}
                    ${phoneRow}
                    ${extras.length ? `<div class="host-extras">${extras.join('')}</div>` : ''}
                  </li>`;
              }).join('')}
            </ul>
          </section>`;
        const organizerPanel = teamHtml;

        root.innerHTML = `
          <header class="top">
            <h1>${escapeHtml(event.name)}</h1>
            ${event.host_line ? `<p class="host">📍 ${escapeHtml(event.host_line)}</p>` : ''}
          </header>
          <div class="qr-block">
            <canvas id="event-qr"></canvas>
            <p class="qr-caption">Scan to share this with a friend</p>
          </div>
          <div class="event-buttons">
            ${buttons.join('')}
          </div>
          ${organizerPanel}
        `;

        const canvas = document.getElementById('event-qr') as HTMLCanvasElement;
        QRCode.toCanvas(canvas, window.location.href, {
          width: 200, margin: 1,
          color: { dark: '#ffffff', light: '#1a252f' },
        }).catch(() => {});
      } catch (err) {
        root.innerHTML = `<p class="loading err">${escapeHtml((err as Error).message)}</p>`;
      }
    })();
  }
</script>

<style is:global>
  :root { --accent: #f39c12; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: #1a252f; color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  body { padding: 26px 14px 50px; line-height: 1.45; }
  main.event { max-width: 540px; margin: 0 auto; }

  .top { text-align: center; margin-bottom: 18px; }
  .top h1 { font-size: 28px; color: var(--accent); }
  .top .host { color: #bdc3c7; font-style: italic; margin-top: 6px; font-size: 14px; }

  .qr-block { text-align: center; margin: 14px 0 22px; }
  .qr-block canvas {
    background: #1a252f;
    padding: 6px;
    border-radius: 8px;
  }
  .qr-block .qr-caption {
    margin-top: 4px;
    font-size: 12px; color: #95a5a6; font-style: italic;
  }

  .event-buttons { display: grid; gap: 10px; }
  a.event-btn {
    display: block; padding: 16px 14px;
    text-align: center; text-decoration: none;
    border-radius: 10px;
    font-weight: 700; font-size: 15px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.10);
    color: #ecf0f1;
  }
  a.event-btn:hover { background: rgba(255,255,255,0.08); }
  a.event-btn.raffle {
    background: var(--accent); color: #1a252f;
    border-color: var(--accent);
    font-weight: 800;
  }
  a.event-btn.raffle:hover { filter: brightness(1.07); background: var(--accent); }

  .empty { color: #95a5a6; font-style: italic; text-align: center; padding: 30px 0; }
  .loading { color: #95a5a6; text-align: center; padding: 40px 0; font-size: 14px; }
  .loading.err { color: #e74c3c; }

  section.team {
    margin-top: 28px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 18px;
  }
  section.team h2 {
    font-size: 12px; color: var(--accent);
    text-transform: uppercase; letter-spacing: 1.5px;
    margin-bottom: 14px;
  }
  ul.team-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 4px; }
  .host-card {
    background: rgba(0,0,0,0.20);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 6px;
    padding: 6px 10px;
    display: flex; align-items: center; gap: 8px;
    flex-wrap: wrap;
  }
  .host-head {
    display: flex; align-items: center; gap: 6px;
    flex-wrap: wrap;
  }
  .host-head strong { font-size: 12px; color: #fff; }
  .host-tag {
    font-size: 8px; padding: 1px 5px; border-radius: 6px;
    background: rgba(243,156,18,0.20); color: var(--accent);
    text-transform: uppercase; letter-spacing: 0.8px; font-weight: 700;
  }
  .host-bio {
    font-size: 11px; color: #bdc3c7; line-height: 1.4;
    flex-basis: 100%;
  }
  .host-phone {
    display: inline-block;
    padding: 3px 8px;
    background: rgba(243,156,18,0.18); color: var(--accent);
    border: 1px solid rgba(243,156,18,0.5);
    border-radius: 4px; text-decoration: none;
    font-weight: 700; font-size: 11px;
    margin-left: auto;
  }
  .host-phone:hover { background: rgba(243,156,18,0.28); }
  .host-extras {
    display: flex; flex-wrap: wrap; gap: 4px;
    flex-basis: 100%;
  }
  .host-extras a {
    display: inline-block;
    padding: 3px 7px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 4px;
    color: #ecf0f1; text-decoration: none;
    font-size: 10px; font-weight: 600;
  }
  .host-extras a:hover { background: rgba(255,255,255,0.10); }
</style>
