---
import Base from '../layouts/Base.astro';
---
<Base title="Event">
  <main class="event" id="event-root">
    <p class="loading">Loading event…</p>
  </main>
</Base>

<script>
  import { fetchEventBySlug, fetchTransformations, fetchSpeakers, callFunction, getConfig } from '../lib/supabase.js';
  import {
    eventUrl, raffleUrl, wheelUrl, storiesUrl, speakersUrl,
    journeyUrl, scienceUrl, hostsUrl,
  } from '../lib/urls.js';
  import { createClient } from '@supabase/supabase-js';
  import QRCode from 'qrcode';

  const root = document.getElementById('event-root')!;
  const base = import.meta.env.BASE_URL;
  const params = new URLSearchParams(window.location.search);
  const slug = params.get('slug');
  const adminKey = params.get('key'); // present when master visits via their edit token

  function escapeHtml(s: unknown): string {
    return String(s ?? '').replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!)
    );
  }

  // Audience-hub popup: render whatever the presenter pushed. Stays up
  // until the presenter advances (replacing it) or the attendee taps ✕.
  // Lives outside the main render() flow so it survives event-hub re-renders.
  function dismissAudienceOverlay(): void {
    document.getElementById('audience-overlay')?.remove();
  }
  function renderAudienceOverlay(payload: {
    kind: 'speaker' | 'multi' | 'transformation';
    speaker?: { name: string; photo_url: string | null };
    topic?: string;
    speakers?: Array<{ name: string; photo_url: string | null }>;
    segment?: string;
    transformation?: {
      name: string;
      before_photo_url: string | null;
      after_photo_url: string | null;
      headline_lb_loss: number | null;
      headline_bf_delta_pts: number | null;
      headline_lean_kept_pct: number | null;
      takeaway_text: string | null;
    };
  }): void {
    let body = '';
    if (payload.kind === 'speaker' && payload.speaker) {
      const sp = payload.speaker;
      const photo = sp.photo_url
        ? `<img class="aud-photo" src="${escapeHtml(sp.photo_url)}" alt="${escapeHtml(sp.name)}" />`
        : '<div class="aud-photo empty">📷</div>';
      body = `
        <p class="aud-eyebrow">Now on stage</p>
        ${photo}
        <p class="aud-name">${escapeHtml(sp.name)}</p>
        ${payload.topic ? `<p class="aud-topic">${escapeHtml(payload.topic)}</p>` : ''}`;
    } else if (payload.kind === 'multi' && payload.speakers) {
      const tiles = payload.speakers.map((sp) => {
        const ph = sp.photo_url
          ? `<img class="aud-mini-photo" src="${escapeHtml(sp.photo_url)}" alt="${escapeHtml(sp.name)}" />`
          : '<div class="aud-mini-photo empty">📷</div>';
        return `<div class="aud-mini-tile">${ph}<p class="aud-mini-name">${escapeHtml(sp.name)}</p></div>`;
      }).join('');
      body = `
        <p class="aud-eyebrow">Now on stage</p>
        <div class="aud-mini-grid">${tiles}</div>
        ${payload.segment ? `<p class="aud-topic">${escapeHtml(payload.segment)}</p>` : ''}`;
    } else if (payload.kind === 'transformation' && payload.transformation) {
      const t = payload.transformation;
      const stats: string[] = [];
      if (t.headline_lb_loss != null) stats.push(`−${t.headline_lb_loss} lb`);
      if (t.headline_bf_delta_pts != null) stats.push(`−${t.headline_bf_delta_pts} BF`);
      if (t.headline_lean_kept_pct != null) stats.push(`${t.headline_lean_kept_pct}% lean kept`);
      const before = t.before_photo_url
        ? `<img class="aud-ba-photo" src="${escapeHtml(t.before_photo_url)}" alt="Before" />`
        : '<div class="aud-ba-photo empty">Before</div>';
      const after = t.after_photo_url
        ? `<img class="aud-ba-photo" src="${escapeHtml(t.after_photo_url)}" alt="After" />`
        : '<div class="aud-ba-photo empty">After</div>';
      body = `
        <p class="aud-eyebrow">Transformation story</p>
        <p class="aud-name">${escapeHtml(t.name)}</p>
        ${stats.length ? `<p class="aud-stats">${stats.join(' · ')}</p>` : ''}
        <div class="aud-ba-pair">
          <div class="aud-ba"><span class="aud-ba-label">BEFORE</span>${before}</div>
          <div class="aud-ba"><span class="aud-ba-label">AFTER</span>${after}</div>
        </div>
        ${t.takeaway_text ? `<p class="aud-takeaway">${escapeHtml(t.takeaway_text)}</p>` : ''}`;
    } else {
      return; // unknown kind — ignore
    }
    // Replace any existing overlay rather than stacking.
    dismissAudienceOverlay();
    const overlay = document.createElement('div');
    overlay.id = 'audience-overlay';
    overlay.className = 'audience-overlay';
    overlay.innerHTML = `
      <div class="audience-card">
        <button type="button" class="audience-close" aria-label="Dismiss">×</button>
        ${body}
      </div>`;
    overlay.querySelector('.audience-close')!.addEventListener('click', dismissAudienceOverlay);
    document.body.appendChild(overlay);
  }

  // PWA manifest — SYNCHRONOUS, from URL params. iOS captures the manifest
  // the instant the user taps "Add to Home Screen", which can happen before
  // the async event fetch finishes. If the per-event manifest hasn't been
  // installed yet, iOS falls back to the static manifest with start_url:"./",
  // which means the home-screen icon opens the marketing landing page
  // ("Your transformations, on a phone-friendly event page…") and the user
  // thinks they're being asked to build a new event. Setting a minimal
  // per-event manifest right now (no name/accent yet — those come post-fetch)
  // closes the race window: even an instant tap captures the right start_url.
  if (slug) {
    try {
      const startUrl = `${window.location.origin}${base}event?slug=${encodeURIComponent(slug)}`;
      const iconBase = `${window.location.origin}${base}`;
      const minimalManifest = {
        name: 'Event',
        short_name: 'Event',
        start_url: startUrl,
        scope: window.location.origin + base,
        display: 'standalone',
        orientation: 'portrait',
        background_color: '#1a252f',
        theme_color: '#1a252f',
        icons: [
          { src: iconBase + 'icon-192.png', sizes: '192x192', type: 'image/png', purpose: 'any maskable' },
          { src: iconBase + 'icon-512.png', sizes: '512x512', type: 'image/png', purpose: 'any maskable' },
        ],
      };
      const blob = new Blob([JSON.stringify(minimalManifest)], { type: 'application/manifest+json' });
      const link = document.getElementById('manifest-link') as HTMLLinkElement | null;
      if (link) link.href = URL.createObjectURL(blob);
    } catch { /* non-fatal */ }
  }

  if (!slug) {
    root.innerHTML = '<p class="loading">No event specified.</p>';
  } else {
    (async () => {
      try {
        const event = await fetchEventBySlug(slug);
        if (!event) {
          root.innerHTML = '<p class="loading">Event not found.</p>';
          return;
        }
        document.title = event.name;
        const accent = event.accent_color || '#f39c12';
        document.documentElement.style.setProperty('--accent', accent);

        const [transformations, speakers, hostsRes] = await Promise.all([
          fetchTransformations(event.id),
          fetchSpeakers(event.id),
          callFunction('get-event-hosts', { slug }).catch(() => ({ hosts: [] })),
        ]);
        const teamHosts = (hostsRes.hosts || []) as Array<{
          name: string | null; phone: string | null;
          email?: string | null; website?: string | null; bio?: string | null;
          primary?: boolean;
        }>;

        // Auto-close: even if raffle_status is 'open', hide the CTA after
        // the event date.
        const today = new Date().toISOString().slice(0, 10);
        const raffleAutoClosed = event.event_date && today > event.event_date;
        const raffleOpen = event.raffle_status === 'open' && !raffleAutoClosed;

        // Button stack mirrors the Spokane reference index layout: each
        // entity becomes a single full-width button, not a card.
        const buttons: string[] = [];
        if (raffleOpen) {
          buttons.push(
            `<a class="event-btn raffle" href="${raffleUrl(base, slug)}">🎟️ Enter the Raffle${event.raffle_prize ? ` — ${escapeHtml(event.raffle_prize)}` : ''}</a>`
          );
        }
        // Audience-mode raffle wheel: visible whenever the raffle has any
        // status configured (open, drawing, closed). The wheel page handles
        // its own "waiting for the host to spin" / "winners" empty states.
        // No ?key= here — that's the host controller; attendees just watch.
        if (event.raffle_status) {
          buttons.push(
            `<a class="event-btn wheel" href="${wheelUrl(base, slug)}">🎡 Go to the raffle wheel</a>`
          );
        }
        // Transformations collapse into a single index button so the hub
        // stays a clean stack even with many stories. The /stories page
        // lists each person; tapping one opens the /t deep-dive.
        if (transformations.length > 0) {
          buttons.push(
            `<a class="event-btn story" href="${storiesUrl(base, slug)}">🎯 Today's Transformation Stories</a>`
          );
        }
        if (speakers.length > 0) {
          buttons.push(
            `<a class="event-btn speakers" href="${speakersUrl(base, slug)}">🎤 Speaker Bios</a>`
          );
        }
        buttons.push(
          `<a class="event-btn journey" href="${journeyUrl(base, slug)}">🌱 Reset · Refine · Renew</a>`
        );
        buttons.push(
          `<a class="event-btn science" href="${scienceUrl(base, slug)}">🧠 Why It Works (the science)</a>`
        );
        // Connect-with-the-hosts moved off the main event page into its own
        // route so the hub stays clean. The button preserves the admin key
        // when present so the master keeps the inline-toggle affordance on
        // the next screen.
        if (teamHosts.length > 0) {
          buttons.push(`<a class="event-btn hosts" href="${hostsUrl(base, slug, adminKey || undefined)}">📞 Connect with the hosts</a>`);
        }

        root.innerHTML = `
          <header class="top">
            <h1>${escapeHtml(event.name)}</h1>
            ${event.host_line ? `<p class="host">📍 ${escapeHtml(event.host_line)}</p>` : ''}
          </header>
          <div class="qr-block">
            <canvas id="event-qr"></canvas>
            <p class="qr-caption">Scan to share this with a friend</p>
          </div>
          <div class="event-buttons">
            ${buttons.join('')}
          </div>
        `;

        const canvas = document.getElementById('event-qr') as HTMLCanvasElement;
        // QR encodes the clean form (/event/<slug>) so it reads cleanly
        // off a poster. The 404.html SPA-redirect handles the dispatch.
        const cleanShareUrl = window.location.origin + eventUrl(base, slug!);
        QRCode.toCanvas(canvas, cleanShareUrl, {
          width: 200, margin: 1,
          color: { dark: '#ffffff', light: '#1a252f' },
        }).catch(() => {});

        // ----- PWA: per-event manifest + iOS Add-to-Home-Screen hint -----
        // Each event gets its own short-lived manifest blob so the home-
        // screen install picks up the event's name + accent color instead
        // of the template default. iOS Safari mostly ignores manifests but
        // reads the apple-mobile-web-app-title meta tag, so we update both.
        try {
          const accent = event.accent_color || '#f39c12';
          // Query-string form (not /event/<slug>) so a PWA launch lands
          // directly on the page without bouncing through the 404 SPA
          // redirect. Matches the synchronous setup above.
          const startUrl = `${window.location.origin}${base}event?slug=${encodeURIComponent(slug!)}`;
          const iconBase = `${window.location.origin}${base}`;
          const eventManifest = {
            name: event.name || 'Metabolic Reset Event',
            short_name: (event.name || 'MR Event').slice(0, 12),
            description: event.host_line || 'Metabolic Reset Event',
            start_url: startUrl,
            scope: startUrl,
            display: 'standalone',
            orientation: 'portrait',
            background_color: '#1a252f',
            theme_color: accent,
            icons: [
              { src: iconBase + 'icon-192.png', sizes: '192x192', type: 'image/png', purpose: 'any maskable' },
              { src: iconBase + 'icon-512.png', sizes: '512x512', type: 'image/png', purpose: 'any maskable' },
            ],
          };
          const blob = new Blob([JSON.stringify(eventManifest)], { type: 'application/manifest+json' });
          const blobUrl = URL.createObjectURL(blob);
          const link = document.getElementById('manifest-link') as HTMLLinkElement | null;
          if (link) link.href = blobUrl;
          const titleMeta = document.getElementById('apple-app-title') as HTMLMetaElement | null;
          if (titleMeta) titleMeta.setAttribute('content', eventManifest.short_name);
          const themeMeta = document.querySelector('meta[name="theme-color"]') as HTMLMetaElement | null;
          if (themeMeta) themeMeta.setAttribute('content', accent);
        } catch { /* non-fatal */ }

        // ----- Audience-hub popup driven by the presenter console -----
        // The presenter's /deck-console/ broadcasts 'audience' events on
        // the deck:<slug> realtime channel when their "Display to audience
        // phones" toggle is on. Payload tells us what to render (speaker /
        // multi-speaker / transformation) or to dismiss the current popup.
        try {
          const cfg = getConfig();
          if (cfg.url && cfg.anonKey) {
            const client = createClient(cfg.url, cfg.anonKey);
            const audienceChannel = client.channel(`deck:${slug}`, {
              config: { broadcast: { self: false } },
            });
            audienceChannel.on('broadcast', { event: 'audience' }, ({ payload }) => {
              if (!payload || payload.show !== true) {
                dismissAudienceOverlay();
                return;
              }
              renderAudienceOverlay(payload);
            });
            audienceChannel.subscribe();
          }
        } catch { /* non-fatal */ }

        // Add-to-Home-Screen hint, iOS Safari only (Chrome shows its own
        // install prompt; other iOS browsers don't support installing).
        // Dismissed-by-user state is per-slug in localStorage.
        try {
          const ua = navigator.userAgent;
          const isIOS = /iPhone|iPad|iPod/.test(ua) && !(/CriOS|FxiOS|EdgiOS/.test(ua));
          const isStandalone = (window.navigator as { standalone?: boolean }).standalone === true
            || window.matchMedia('(display-mode: standalone)').matches;
          const dismissKey = `a2hs-dismissed:${slug}`;
          const alreadyDismissed = localStorage.getItem(dismissKey) === '1';
          if (isIOS && !isStandalone && !alreadyDismissed) {
            const banner = document.createElement('aside');
            banner.className = 'a2hs-banner';
            banner.innerHTML = `
              <button type="button" class="a2hs-close" aria-label="Dismiss">×</button>
              <p class="a2hs-line">📲 <strong>Save this to your phone</strong></p>
              <p class="a2hs-detail">Tap the <strong>Share</strong> button below, then <strong>Add to Home Screen</strong> — keeps the event one tap away.</p>
            `;
            document.body.appendChild(banner);
            banner.querySelector('.a2hs-close')!.addEventListener('click', () => {
              localStorage.setItem(dismissKey, '1');
              banner.remove();
            });
          }
        } catch { /* non-fatal */ }
      } catch (err) {
        root.innerHTML = `<p class="loading err">${escapeHtml((err as Error).message)}</p>`;
      }
    })();
  }
</script>

<style is:global>
  :root { --accent: #f39c12; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: #1a252f; color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  body { padding: 26px 14px 50px; line-height: 1.45; }
  main.event { max-width: 540px; margin: 0 auto; }

  .top { text-align: center; margin-bottom: 18px; }
  .top h1 { font-size: 28px; color: var(--accent); }
  .top .host { color: #bdc3c7; font-style: italic; margin-top: 6px; font-size: 14px; }

  .qr-block { text-align: center; margin: 14px 0 22px; }
  .qr-block canvas {
    background: #1a252f;
    padding: 6px;
    border-radius: 8px;
  }
  .qr-block .qr-caption {
    margin-top: 4px;
    font-size: 12px; color: #95a5a6; font-style: italic;
  }

  .event-buttons { display: grid; gap: 10px; }
  a.event-btn {
    display: block; padding: 16px 14px;
    text-align: center; text-decoration: none;
    border-radius: 10px;
    font-weight: 700; font-size: 15px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.10);
    color: #ecf0f1;
  }
  a.event-btn:hover { background: rgba(255,255,255,0.08); }
  a.event-btn.raffle {
    background: var(--accent); color: #1a252f;
    border-color: var(--accent);
    font-weight: 800;
  }
  a.event-btn.raffle:hover { filter: brightness(1.07); background: var(--accent); }

  .empty { color: #95a5a6; font-style: italic; text-align: center; padding: 30px 0; }
  .loading { color: #95a5a6; text-align: center; padding: 40px 0; font-size: 14px; }
  .loading.err { color: #e74c3c; }

  /* Audience-hub popup — pushed by the presenter console. Full-screen
     overlay; stays up until presenter pushes the next item or attendee
     taps the ✕. */
  .audience-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.92);
    z-index: 60;
    display: flex; align-items: center; justify-content: center;
    padding: 18px 14px;
    overflow-y: auto;
    animation: audienceIn 0.25s ease-out;
  }
  @keyframes audienceIn {
    from { opacity: 0; transform: scale(0.96); }
    to   { opacity: 1; transform: scale(1); }
  }
  .audience-card {
    width: 100%; max-width: 480px;
    background: #1a252f;
    border: 1px solid color-mix(in srgb, var(--accent) 35%, transparent);
    border-radius: 14px;
    padding: 22px 18px 24px;
    text-align: center;
    position: relative;
    box-shadow: 0 20px 60px rgba(0,0,0,0.7);
  }
  .audience-close {
    position: absolute;
    top: 6px; right: 8px;
    width: 32px; height: 32px;
    background: transparent; color: #95a5a6;
    border: none; border-radius: 16px;
    font-size: 24px; line-height: 1;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
  }
  .audience-close:hover { background: rgba(255,255,255,0.08); color: #fff; }
  .aud-eyebrow {
    font-size: 11px; letter-spacing: 4px; text-transform: uppercase;
    color: var(--accent); font-weight: 800; margin-bottom: 14px;
  }
  .aud-photo {
    width: 70%; max-width: 240px;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 14px;
    background: rgba(255,255,255,0.05);
    box-shadow: 0 10px 24px rgba(0,0,0,0.5);
    margin: 0 auto 14px;
    display: block;
  }
  .aud-photo.empty {
    display: flex; align-items: center; justify-content: center;
    font-size: 50px; color: rgba(255,255,255,0.25);
    border: 2px dashed rgba(255,255,255,0.15);
  }
  .aud-name {
    font-size: 22px; font-weight: 800; color: #fff;
    line-height: 1.2; margin-bottom: 6px;
    overflow-wrap: anywhere;
  }
  .aud-topic {
    font-size: 16px; color: var(--accent); font-weight: 700;
    line-height: 1.3;
    overflow-wrap: anywhere;
  }
  /* Multi-speaker: 2-up grid of compact avatars */
  .aud-mini-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
    gap: 12px;
    margin-bottom: 14px;
    justify-items: center;
  }
  .aud-mini-tile { display: flex; flex-direction: column; gap: 6px; align-items: center; max-width: 140px; }
  .aud-mini-photo {
    width: 100%; aspect-ratio: 1 / 1;
    object-fit: cover; border-radius: 10px;
    background: rgba(255,255,255,0.05);
  }
  .aud-mini-photo.empty {
    display: flex; align-items: center; justify-content: center;
    font-size: 26px; color: rgba(255,255,255,0.25);
    border: 1px dashed rgba(255,255,255,0.15);
  }
  .aud-mini-name {
    font-size: 13px; font-weight: 700; color: #ecf0f1;
    line-height: 1.2;
    overflow-wrap: anywhere;
  }
  /* Transformation: stats + before/after pair */
  .aud-stats {
    font-size: 14px; color: var(--accent); font-weight: 700;
    margin-bottom: 14px;
    letter-spacing: 0.5px;
  }
  .aud-ba-pair {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 14px;
  }
  .aud-ba { display: flex; flex-direction: column; gap: 6px; }
  .aud-ba-label {
    font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
    color: #95a5a6; font-weight: 700;
  }
  .aud-ba-photo {
    width: 100%; aspect-ratio: 3 / 4;
    object-fit: cover; border-radius: 8px;
    background: rgba(255,255,255,0.04);
  }
  .aud-ba-photo.empty {
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; color: #95a5a6; font-style: italic;
    border: 1px dashed rgba(255,255,255,0.15);
  }
  .aud-takeaway {
    font-size: 13px; color: #bdc3c7;
    line-height: 1.5; font-style: italic;
    margin-top: 8px;
  }

  /* Add to Home Screen hint — iOS Safari only, dismissable */
  .a2hs-banner {
    position: fixed;
    left: 12px; right: 12px; bottom: 14px;
    background: #1a252f;
    border: 1px solid var(--accent, #f39c12);
    border-radius: 12px;
    padding: 14px 36px 14px 16px;
    color: #ecf0f1;
    box-shadow: 0 12px 30px rgba(0,0,0,0.55);
    z-index: 50;
    max-width: 540px; margin: 0 auto;
  }
  .a2hs-banner .a2hs-line {
    font-size: 14px; margin-bottom: 4px;
  }
  .a2hs-banner .a2hs-line strong { color: var(--accent, #f39c12); }
  .a2hs-banner .a2hs-detail {
    font-size: 12px; color: #bdc3c7; line-height: 1.45;
  }
  .a2hs-banner .a2hs-detail strong { color: #fff; font-weight: 700; }
  .a2hs-banner .a2hs-close {
    position: absolute;
    top: 6px; right: 8px;
    width: 28px; height: 28px;
    background: transparent; color: #95a5a6;
    border: none; border-radius: 14px;
    font-size: 22px; line-height: 1;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
  }
  .a2hs-banner .a2hs-close:hover { background: rgba(255,255,255,0.06); color: #fff; }
</style>
