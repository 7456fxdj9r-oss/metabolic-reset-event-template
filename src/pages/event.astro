---
import Base from '../layouts/Base.astro';
---
<Base title="Event">
  <main class="event" id="event-root">
    <p class="loading">Loading event…</p>
  </main>
</Base>

<script>
  import { fetchEventBySlug, fetchTransformations, fetchSpeakers } from '../lib/supabase.js';
  import QRCode from 'qrcode';

  const root = document.getElementById('event-root')!;
  const base = import.meta.env.BASE_URL;
  const params = new URLSearchParams(window.location.search);
  const slug = params.get('slug');

  function escapeHtml(s: unknown): string {
    return String(s ?? '').replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!)
    );
  }

  if (!slug) {
    root.innerHTML = '<p class="loading">No event specified.</p>';
  } else {
    (async () => {
      try {
        const event = await fetchEventBySlug(slug);
        if (!event) {
          root.innerHTML = '<p class="loading">Event not found.</p>';
          return;
        }
        document.title = event.name;
        const accent = event.accent_color || '#f39c12';
        document.documentElement.style.setProperty('--accent', accent);

        const [transformations, speakers] = await Promise.all([
          fetchTransformations(event.id),
          fetchSpeakers(event.id),
        ]);

        // Auto-close: even if raffle_status is 'open', hide the CTA after
        // the event date.
        const today = new Date().toISOString().slice(0, 10);
        const raffleAutoClosed = event.event_date && today > event.event_date;
        const raffleOpen = event.raffle_status === 'open' && !raffleAutoClosed;

        // Button stack mirrors the Spokane reference index layout: each
        // entity becomes a single full-width button, not a card.
        const buttons: string[] = [];
        if (raffleOpen) {
          buttons.push(
            `<a class="event-btn raffle" href="${base}raffle?slug=${encodeURIComponent(slug)}">🎟️ Enter the Raffle${event.raffle_prize ? ` — ${escapeHtml(event.raffle_prize)}` : ''}</a>`
          );
        }
        for (const t of transformations) {
          const tHref = `${base}t?slug=${encodeURIComponent(slug)}&t=${encodeURIComponent(t.slug)}`;
          buttons.push(`<a class="event-btn story" href="${tHref}">📊 ${escapeHtml(t.name)}'s Story</a>`);
        }
        if (speakers.length > 0) {
          buttons.push(
            `<a class="event-btn speakers" href="${base}speakers?slug=${encodeURIComponent(slug)}">🎤 Speaker Bios</a>`
          );
        }
        buttons.push(
          `<a class="event-btn science" href="${base}science?slug=${encodeURIComponent(slug)}">🧠 Why It Works (the science)</a>`
        );

        // Organizer panel: only renders when at least one field has a value.
        const hasContact = event.organizer_name || event.organizer_email
          || event.organizer_phone || event.organizer_website
          || event.organizer_bio;

        const organizerPanel = hasContact ? `
          <section class="organizer">
            <h2>Connect with the host</h2>
            ${event.organizer_name ? `<p class="org-name">${escapeHtml(event.organizer_name)}</p>` : ''}
            ${event.organizer_bio ? `<p class="org-bio">${escapeHtml(event.organizer_bio)}</p>` : ''}
            <div class="org-contact">
              ${event.organizer_email ? `<a href="mailto:${escapeHtml(event.organizer_email)}">✉️ ${escapeHtml(event.organizer_email)}</a>` : ''}
              ${event.organizer_phone ? `<a href="tel:${escapeHtml(event.organizer_phone)}">📞 ${escapeHtml(event.organizer_phone)}</a>` : ''}
              ${event.organizer_website ? `<a href="${escapeHtml(event.organizer_website)}" target="_blank" rel="noopener">🌐 Website</a>` : ''}
            </div>
          </section>` : '';

        root.innerHTML = `
          <header class="top">
            <h1>${escapeHtml(event.name)}</h1>
            ${event.host_line ? `<p class="host">${escapeHtml(event.host_line)}</p>` : ''}
          </header>
          <div class="qr-block">
            <canvas id="event-qr"></canvas>
            <p class="qr-caption">Scan to share this with a friend</p>
          </div>
          <div class="event-buttons">
            ${buttons.join('')}
          </div>
          ${organizerPanel}
        `;

        const canvas = document.getElementById('event-qr') as HTMLCanvasElement;
        QRCode.toCanvas(canvas, window.location.href, {
          width: 200, margin: 1,
          color: { dark: '#ffffff', light: '#1a252f' },
        }).catch(() => {});
      } catch (err) {
        root.innerHTML = `<p class="loading err">${escapeHtml((err as Error).message)}</p>`;
      }
    })();
  }
</script>

<style is:global>
  :root { --accent: #f39c12; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: #1a252f; color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  body { padding: 26px 14px 50px; line-height: 1.45; }
  main.event { max-width: 540px; margin: 0 auto; }

  .top { text-align: center; margin-bottom: 18px; }
  .top h1 { font-size: 28px; color: var(--accent); }
  .top .host { color: #bdc3c7; font-style: italic; margin-top: 6px; font-size: 14px; }

  .qr-block { text-align: center; margin: 14px 0 22px; }
  .qr-block canvas {
    background: #1a252f;
    padding: 6px;
    border-radius: 8px;
  }
  .qr-block .qr-caption {
    margin-top: 4px;
    font-size: 12px; color: #95a5a6; font-style: italic;
  }

  .event-buttons { display: grid; gap: 10px; }
  a.event-btn {
    display: block; padding: 16px 14px;
    text-align: center; text-decoration: none;
    border-radius: 10px;
    font-weight: 700; font-size: 15px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.10);
    color: #ecf0f1;
  }
  a.event-btn:hover { background: rgba(255,255,255,0.08); }
  a.event-btn.raffle {
    background: var(--accent); color: #1a252f;
    border-color: var(--accent);
    font-weight: 800;
  }
  a.event-btn.raffle:hover { filter: brightness(1.07); background: var(--accent); }

  .empty { color: #95a5a6; font-style: italic; text-align: center; padding: 30px 0; }
  .loading { color: #95a5a6; text-align: center; padding: 40px 0; font-size: 14px; }
  .loading.err { color: #e74c3c; }

  section.organizer {
    margin-top: 28px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 18px;
  }
  section.organizer h2 {
    font-size: 12px; color: var(--accent);
    text-transform: uppercase; letter-spacing: 1.5px;
    margin-bottom: 12px;
  }
  section.organizer .org-name {
    font-size: 17px; color: #fff; font-weight: 700;
    margin-bottom: 4px;
  }
  section.organizer .org-bio {
    font-size: 13px; color: #bdc3c7; line-height: 1.55;
    margin-bottom: 14px;
  }
  section.organizer .org-contact {
    display: flex; flex-wrap: wrap; gap: 6px;
    margin-top: 6px;
  }
  section.organizer a {
    display: inline-block;
    padding: 8px 12px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    color: #ecf0f1; text-decoration: none;
    font-size: 12px; font-weight: 600;
  }
  section.organizer a:hover { background: rgba(255,255,255,0.10); }
</style>
