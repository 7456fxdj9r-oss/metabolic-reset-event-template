---
import Base from '../layouts/Base.astro';
---
<Base title="Event">
  <main class="event" id="event-root">
    <p class="loading">Loading event…</p>
  </main>
</Base>

<script>
  import { fetchEventBySlug, fetchTransformations, fetchSpeakers, callFunction } from '../lib/supabase.js';
  import { cleanUrl } from '../lib/urls.js';
  import QRCode from 'qrcode';

  const root = document.getElementById('event-root')!;
  const base = import.meta.env.BASE_URL;
  const params = new URLSearchParams(window.location.search);
  const slug = params.get('slug');
  const adminKey = params.get('key'); // present when master visits via their edit token
  let isMaster = false; // proven by manage-hosts list response below

  function escapeHtml(s: unknown): string {
    return String(s ?? '').replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!)
    );
  }

  // PWA manifest — SYNCHRONOUS, from URL params. iOS captures the manifest
  // the instant the user taps "Add to Home Screen", which can happen before
  // the async event fetch finishes. If the per-event manifest hasn't been
  // installed yet, iOS falls back to the static manifest with start_url:"./",
  // which means the home-screen icon opens the marketing landing page
  // ("Your transformations, on a phone-friendly event page…") and the user
  // thinks they're being asked to build a new event. Setting a minimal
  // per-event manifest right now (no name/accent yet — those come post-fetch)
  // closes the race window: even an instant tap captures the right start_url.
  if (slug) {
    try {
      const startUrl = `${window.location.origin}${base}event?slug=${encodeURIComponent(slug)}`;
      const iconBase = `${window.location.origin}${base}`;
      const minimalManifest = {
        name: 'Event',
        short_name: 'Event',
        start_url: startUrl,
        scope: window.location.origin + base,
        display: 'standalone',
        orientation: 'portrait',
        background_color: '#1a252f',
        theme_color: '#1a252f',
        icons: [
          { src: iconBase + 'icon-192.png', sizes: '192x192', type: 'image/png', purpose: 'any maskable' },
          { src: iconBase + 'icon-512.png', sizes: '512x512', type: 'image/png', purpose: 'any maskable' },
        ],
      };
      const blob = new Blob([JSON.stringify(minimalManifest)], { type: 'application/manifest+json' });
      const link = document.getElementById('manifest-link') as HTMLLinkElement | null;
      if (link) link.href = URL.createObjectURL(blob);
    } catch { /* non-fatal */ }
  }

  if (!slug) {
    root.innerHTML = '<p class="loading">No event specified.</p>';
  } else {
    (async () => {
      try {
        const event = await fetchEventBySlug(slug);
        if (!event) {
          root.innerHTML = '<p class="loading">Event not found.</p>';
          return;
        }
        document.title = event.name;
        const accent = event.accent_color || '#f39c12';
        document.documentElement.style.setProperty('--accent', accent);

        const [transformations, speakers, hostsRes] = await Promise.all([
          fetchTransformations(event.id),
          fetchSpeakers(event.id),
          callFunction('get-event-hosts', { slug }).catch(() => ({ hosts: [] })),
        ]);
        const teamHosts = (hostsRes.hosts || []) as Array<{
          name: string | null; phone: string | null;
          email?: string | null; website?: string | null; bio?: string | null;
          primary?: boolean;
        }>;

        // Auto-close: even if raffle_status is 'open', hide the CTA after
        // the event date.
        const today = new Date().toISOString().slice(0, 10);
        const raffleAutoClosed = event.event_date && today > event.event_date;
        const raffleOpen = event.raffle_status === 'open' && !raffleAutoClosed;

        // Button stack mirrors the Spokane reference index layout: each
        // entity becomes a single full-width button, not a card.
        const buttons: string[] = [];
        if (raffleOpen) {
          buttons.push(
            `<a class="event-btn raffle" href="${base}raffle?slug=${encodeURIComponent(slug)}">🎟️ Enter the Raffle${event.raffle_prize ? ` — ${escapeHtml(event.raffle_prize)}` : ''}</a>`
          );
        }
        for (const t of transformations) {
          const tHref = `${base}t?slug=${encodeURIComponent(slug)}&t=${encodeURIComponent(t.slug)}`;
          buttons.push(`<a class="event-btn story" href="${tHref}">🎯 ${escapeHtml(t.name)}'s Story</a>`);
        }
        if (speakers.length > 0) {
          buttons.push(
            `<a class="event-btn speakers" href="${base}speakers?slug=${encodeURIComponent(slug)}">🎤 Speaker Bios</a>`
          );
        }
        buttons.push(
          `<a class="event-btn journey" href="${base}journey?slug=${encodeURIComponent(slug)}">🌱 Reset · Refine · Renew</a>`
        );
        buttons.push(
          `<a class="event-btn science" href="${base}science?slug=${encodeURIComponent(slug)}">🧠 Why It Works (the science)</a>`
        );

        // Connect-with-the-hosts panel. Master can pass the ORGANIZER
        // title by tapping pills on this page when ?key= is in the URL —
        // see renderTeamList + organizer-toggle click handler below.
        type TeamHost = {
          name: string | null; phone: string | null;
          email?: string | null; website?: string | null; bio?: string | null;
          primary?: boolean; is_master?: boolean; id?: string;
        };
        function renderTeamList(hosts: TeamHost[], adminMode: boolean): string {
          if (hosts.length === 0) return '';
          return `
            <section class="team">
              <h2>Connect with the hosts</h2>
              <ul class="team-list">
                ${hosts.map((h) => {
                  // Badge: orange "organizer" pill on the primary, optional
                  // ghost "+ organizer" placeholder on every non-primary when
                  // in admin mode. Tap toggles via the inline-toggle handler.
                  let badge = '';
                  if (h.primary) {
                    badge = adminMode
                      ? `<button type="button" class="host-tag toggle" data-org="clear" title="Tap to remove the organizer title">organizer ×</button>`
                      : '<span class="host-tag">organizer</span>';
                  } else if (adminMode) {
                    const idAttr = h.is_master ? 'data-org="master"' : `data-org="cohost" data-host-id="${escapeHtml(h.id || '')}"`;
                    badge = `<button type="button" class="host-tag toggle ghost" ${idAttr} title="Tap to make this person the organizer">+ organizer</button>`;
                  }
                  const phoneRow = h.phone
                    ? `<a class="host-phone" href="tel:${escapeHtml(h.phone)}">📞 ${escapeHtml(h.phone)}</a>`
                    : '';
                  const extras: string[] = [];
                  if (h.email) extras.push(`<a href="mailto:${escapeHtml(h.email)}">✉️ ${escapeHtml(h.email)}</a>`);
                  if (h.website) extras.push(`<a href="${escapeHtml(h.website)}" target="_blank" rel="noopener">🌐 Website</a>`);
                  return `
                    <li class="host-card">
                      <div class="host-head">
                        <strong>${escapeHtml(h.name || 'Co-host')}</strong>
                        ${badge}
                      </div>
                      ${h.bio ? `<p class="host-bio">${escapeHtml(h.bio)}</p>` : ''}
                      ${phoneRow}
                      ${extras.length ? `<div class="host-extras">${extras.join('')}</div>` : ''}
                    </li>`;
                }).join('')}
              </ul>
              ${adminMode ? '<p class="team-admin-hint">You’re viewing this with your edit link. Tap a pill above to change which host wears the ORGANIZER title.</p>' : ''}
            </section>`;
        }
        const organizerPanel = renderTeamList(teamHosts as TeamHost[], false);

        root.innerHTML = `
          <header class="top">
            <h1>${escapeHtml(event.name)}</h1>
            ${event.host_line ? `<p class="host">📍 ${escapeHtml(event.host_line)}</p>` : ''}
          </header>
          <div class="qr-block">
            <canvas id="event-qr"></canvas>
            <p class="qr-caption">Scan to share this with a friend</p>
          </div>
          <div class="event-buttons">
            ${buttons.join('')}
          </div>
          ${organizerPanel}
        `;

        const canvas = document.getElementById('event-qr') as HTMLCanvasElement;
        // QR encodes the clean form (/event/<slug>) so it reads cleanly
        // off a poster. The 404.html SPA-redirect handles the dispatch.
        const cleanShareUrl = cleanUrl(base, 'event', slug!);
        QRCode.toCanvas(canvas, cleanShareUrl, {
          width: 200, margin: 1,
          color: { dark: '#ffffff', light: '#1a252f' },
        }).catch(() => {});

        // ----- Inline organizer toggle on the public team panel -----
        // When ?key= is in the URL AND the key belongs to the master,
        // each host's organizer pill becomes interactive. Tapping the
        // current organizer's "organizer ×" clears it (master takes it
        // back); tapping a "+ organizer" ghost on a non-primary host
        // sets that host as primary. Co-hosts viewing with their own
        // token get 403 from manage-hosts and the controls stay hidden.
        if (adminKey) {
          (async () => {
            try {
              const res = await callFunction('manage-hosts', {
                slug, edit_token: adminKey, action: 'list',
              });
              isMaster = !!res.you_are_master;
              if (!isMaster) return; // co-host: keep static badges

              // Re-render the team panel in admin mode + wire the click handler.
              function reRenderTeam(hosts: TeamHost[]) {
                const teamSection = document.querySelector('section.team');
                if (!teamSection) return;
                const wrapper = document.createElement('div');
                wrapper.innerHTML = renderTeamList(hosts, true);
                const next = wrapper.querySelector('section.team');
                if (next) teamSection.replaceWith(next);
              }
              const refreshed = await callFunction('get-event-hosts', { slug });
              reRenderTeam((refreshed.hosts || []) as TeamHost[]);

              // Click delegate scoped to the document — the team section gets
              // replaced on every toggle so a per-element listener would die.
              document.addEventListener('click', async (clickEv) => {
                const target = clickEv.target as HTMLElement;
                if (!target.classList.contains('toggle')) return;
                const action = target.getAttribute('data-org');
                if (!action) return;
                target.setAttribute('disabled', 'true');
                try {
                  let hostId: string | null = null;
                  if (action === 'cohost') hostId = target.getAttribute('data-host-id');
                  if (action === 'master') hostId = null;
                  if (action === 'clear') hostId = null;
                  await callFunction('manage-hosts', {
                    slug, edit_token: adminKey, action: 'set_primary', host_id: hostId,
                  });
                  const r = await callFunction('get-event-hosts', { slug });
                  reRenderTeam((r.hosts || []) as TeamHost[]);
                } catch (err) {
                  alert('Could not change organizer: ' + (err as Error).message);
                  target.removeAttribute('disabled');
                }
              });
            } catch { /* non-fatal: not a master, stay read-only */ }
          })();
        }

        // ----- PWA: per-event manifest + iOS Add-to-Home-Screen hint -----
        // Each event gets its own short-lived manifest blob so the home-
        // screen install picks up the event's name + accent color instead
        // of the template default. iOS Safari mostly ignores manifests but
        // reads the apple-mobile-web-app-title meta tag, so we update both.
        try {
          const accent = event.accent_color || '#f39c12';
          // Query-string form (not /event/<slug>) so a PWA launch lands
          // directly on the page without bouncing through the 404 SPA
          // redirect. Matches the synchronous setup above.
          const startUrl = `${window.location.origin}${base}event?slug=${encodeURIComponent(slug!)}`;
          const iconBase = `${window.location.origin}${base}`;
          const eventManifest = {
            name: event.name || 'Metabolic Reset Event',
            short_name: (event.name || 'MR Event').slice(0, 12),
            description: event.host_line || 'Metabolic Reset Event',
            start_url: startUrl,
            scope: startUrl,
            display: 'standalone',
            orientation: 'portrait',
            background_color: '#1a252f',
            theme_color: accent,
            icons: [
              { src: iconBase + 'icon-192.png', sizes: '192x192', type: 'image/png', purpose: 'any maskable' },
              { src: iconBase + 'icon-512.png', sizes: '512x512', type: 'image/png', purpose: 'any maskable' },
            ],
          };
          const blob = new Blob([JSON.stringify(eventManifest)], { type: 'application/manifest+json' });
          const blobUrl = URL.createObjectURL(blob);
          const link = document.getElementById('manifest-link') as HTMLLinkElement | null;
          if (link) link.href = blobUrl;
          const titleMeta = document.getElementById('apple-app-title') as HTMLMetaElement | null;
          if (titleMeta) titleMeta.setAttribute('content', eventManifest.short_name);
          const themeMeta = document.querySelector('meta[name="theme-color"]') as HTMLMetaElement | null;
          if (themeMeta) themeMeta.setAttribute('content', accent);
        } catch { /* non-fatal */ }

        // Add-to-Home-Screen hint, iOS Safari only (Chrome shows its own
        // install prompt; other iOS browsers don't support installing).
        // Dismissed-by-user state is per-slug in localStorage.
        try {
          const ua = navigator.userAgent;
          const isIOS = /iPhone|iPad|iPod/.test(ua) && !(/CriOS|FxiOS|EdgiOS/.test(ua));
          const isStandalone = (window.navigator as { standalone?: boolean }).standalone === true
            || window.matchMedia('(display-mode: standalone)').matches;
          const dismissKey = `a2hs-dismissed:${slug}`;
          const alreadyDismissed = localStorage.getItem(dismissKey) === '1';
          if (isIOS && !isStandalone && !alreadyDismissed) {
            const banner = document.createElement('aside');
            banner.className = 'a2hs-banner';
            banner.innerHTML = `
              <button type="button" class="a2hs-close" aria-label="Dismiss">×</button>
              <p class="a2hs-line">📲 <strong>Save this to your phone</strong></p>
              <p class="a2hs-detail">Tap the <strong>Share</strong> button below, then <strong>Add to Home Screen</strong> — keeps the event one tap away.</p>
            `;
            document.body.appendChild(banner);
            banner.querySelector('.a2hs-close')!.addEventListener('click', () => {
              localStorage.setItem(dismissKey, '1');
              banner.remove();
            });
          }
        } catch { /* non-fatal */ }
      } catch (err) {
        root.innerHTML = `<p class="loading err">${escapeHtml((err as Error).message)}</p>`;
      }
    })();
  }
</script>

<style is:global>
  :root { --accent: #f39c12; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: #1a252f; color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  body { padding: 26px 14px 50px; line-height: 1.45; }
  main.event { max-width: 540px; margin: 0 auto; }

  .top { text-align: center; margin-bottom: 18px; }
  .top h1 { font-size: 28px; color: var(--accent); }
  .top .host { color: #bdc3c7; font-style: italic; margin-top: 6px; font-size: 14px; }

  .qr-block { text-align: center; margin: 14px 0 22px; }
  .qr-block canvas {
    background: #1a252f;
    padding: 6px;
    border-radius: 8px;
  }
  .qr-block .qr-caption {
    margin-top: 4px;
    font-size: 12px; color: #95a5a6; font-style: italic;
  }

  .event-buttons { display: grid; gap: 10px; }
  a.event-btn {
    display: block; padding: 16px 14px;
    text-align: center; text-decoration: none;
    border-radius: 10px;
    font-weight: 700; font-size: 15px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.10);
    color: #ecf0f1;
  }
  a.event-btn:hover { background: rgba(255,255,255,0.08); }
  a.event-btn.raffle {
    background: var(--accent); color: #1a252f;
    border-color: var(--accent);
    font-weight: 800;
  }
  a.event-btn.raffle:hover { filter: brightness(1.07); background: var(--accent); }

  .empty { color: #95a5a6; font-style: italic; text-align: center; padding: 30px 0; }
  .loading { color: #95a5a6; text-align: center; padding: 40px 0; font-size: 14px; }
  .loading.err { color: #e74c3c; }

  section.team {
    margin-top: 28px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 18px;
  }
  section.team h2 {
    font-size: 12px; color: var(--accent);
    text-transform: uppercase; letter-spacing: 1.5px;
    margin-bottom: 14px;
  }
  ul.team-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; }
  .host-card {
    background: rgba(0,0,0,0.20);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 8px 12px;
    display: flex; align-items: center; gap: 8px;
    flex-wrap: wrap;
  }
  .host-head {
    display: flex; align-items: center; gap: 6px;
    flex-wrap: wrap; min-width: 0;
  }
  .host-head strong { font-size: 14px; color: #fff; }
  .host-tag {
    font-size: 10px; padding: 1px 6px; border-radius: 8px;
    background: rgba(243,156,18,0.20); color: var(--accent);
    text-transform: uppercase; letter-spacing: 1px; font-weight: 700;
  }
  button.host-tag {
    border: 1px solid rgba(243,156,18,0.45);
    cursor: pointer; font-family: inherit;
  }
  button.host-tag.toggle:hover { background: rgba(243,156,18,0.30); }
  button.host-tag.toggle.ghost {
    background: transparent;
    color: rgba(243,156,18,0.7);
    border: 1px dashed rgba(243,156,18,0.45);
  }
  button.host-tag.toggle.ghost:hover {
    background: rgba(243,156,18,0.10);
    color: var(--accent);
    border-style: solid;
  }
  button.host-tag.toggle[disabled] { opacity: 0.4; cursor: wait; }
  p.team-admin-hint {
    font-size: 11px; color: #95a5a6;
    margin-top: 10px; font-style: italic;
    line-height: 1.45;
  }
  .host-bio {
    font-size: 13px; color: #bdc3c7; line-height: 1.45;
    flex-basis: 100%;
  }
  .host-phone {
    display: inline-flex; align-items: center;
    padding: 8px 14px;
    min-height: 40px;
    background: rgba(243,156,18,0.18); color: var(--accent);
    border: 1px solid rgba(243,156,18,0.5);
    border-radius: 8px; text-decoration: none;
    font-weight: 700; font-size: 13px;
    margin-left: auto;
    overflow-wrap: anywhere;
  }
  .host-phone:hover { background: rgba(243,156,18,0.28); }
  .host-extras {
    display: flex; flex-wrap: wrap; gap: 6px;
    flex-basis: 100%;
  }
  .host-extras a {
    display: inline-flex; align-items: center;
    padding: 6px 12px;
    min-height: 36px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 6px;
    color: #ecf0f1; text-decoration: none;
    font-size: 12px; font-weight: 600;
    overflow-wrap: anywhere; word-break: break-all;
  }
  .host-extras a:hover { background: rgba(255,255,255,0.10); }

  /* Add to Home Screen hint — iOS Safari only, dismissable */
  .a2hs-banner {
    position: fixed;
    left: 12px; right: 12px; bottom: 14px;
    background: #1a252f;
    border: 1px solid var(--accent, #f39c12);
    border-radius: 12px;
    padding: 14px 36px 14px 16px;
    color: #ecf0f1;
    box-shadow: 0 12px 30px rgba(0,0,0,0.55);
    z-index: 50;
    max-width: 540px; margin: 0 auto;
  }
  .a2hs-banner .a2hs-line {
    font-size: 14px; margin-bottom: 4px;
  }
  .a2hs-banner .a2hs-line strong { color: var(--accent, #f39c12); }
  .a2hs-banner .a2hs-detail {
    font-size: 12px; color: #bdc3c7; line-height: 1.45;
  }
  .a2hs-banner .a2hs-detail strong { color: #fff; font-weight: 700; }
  .a2hs-banner .a2hs-close {
    position: absolute;
    top: 6px; right: 8px;
    width: 28px; height: 28px;
    background: transparent; color: #95a5a6;
    border: none; border-radius: 14px;
    font-size: 22px; line-height: 1;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
  }
  .a2hs-banner .a2hs-close:hover { background: rgba(255,255,255,0.06); color: #fff; }
</style>
