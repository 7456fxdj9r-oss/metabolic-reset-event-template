---
import Base from '../layouts/Base.astro';
---
<Base title="Event">
  <main class="event" id="event-root">
    <p class="loading">Loading event…</p>
  </main>
</Base>

<script>
  import { fetchEventBySlug, fetchTransformations } from '../lib/supabase.js';

  const root = document.getElementById('event-root')!;
  const base = import.meta.env.BASE_URL;
  const params = new URLSearchParams(window.location.search);
  const slug = params.get('slug');

  function escapeHtml(s: unknown): string {
    return String(s ?? '').replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!)
    );
  }

  if (!slug) {
    root.innerHTML = '<p class="loading">No event specified.</p>';
  } else {
    (async () => {
      try {
        const event = await fetchEventBySlug(slug);
        if (!event) {
          root.innerHTML = '<p class="loading">Event not found.</p>';
          return;
        }
        document.title = event.name;
        const accent = event.accent_color || '#f39c12';
        root.style.setProperty('--accent', accent);

        const transformations = await fetchTransformations(event.id);

        const cards = transformations.map((t: any) => {
          const tHref = `${base}t?slug=${encodeURIComponent(slug)}&t=${encodeURIComponent(t.slug)}`;
          const photo = t.before_photo_url || t.after_photo_url || '';
          return `
            <a class="card" href="${tHref}">
              ${photo ? `<img src="${escapeHtml(photo)}" alt="" />` : '<div class="card-placeholder"></div>'}
              <div class="card-body">
                <h3>${escapeHtml(t.name)}</h3>
                ${t.headline_lb_loss != null
                  ? `<p class="stat">${escapeHtml(t.headline_lb_loss)} lb lost</p>`
                  : ''}
              </div>
            </a>`;
        }).join('');

        const scienceCta = `<a class="cta-btn science" href="${base}science?slug=${encodeURIComponent(slug)}">The Science →</a>`;
        const raffleCta = event.raffle_status === 'open'
          ? `<a class="cta-btn raffle" href="${base}raffle?slug=${encodeURIComponent(slug)}">🎟️ Enter the Raffle${event.raffle_prize ? ` — ${escapeHtml(event.raffle_prize)}` : ''}</a>`
          : '';

        // Organizer-contact panel: each row only shows if its field has a
        // value, the whole panel hides if everything is empty. Lets the host
        // turn this on incrementally without weird placeholder rows.
        const socialHandle = (raw: string | null | undefined, urlBuilder: (h: string) => string): string | null => {
          if (!raw) return null;
          const t = raw.trim();
          if (!t) return null;
          if (/^https?:\/\//i.test(t)) return t;
          return urlBuilder(t.replace(/^@/, ''));
        };
        const socials: Array<[string, string, string]> = [
          ['Instagram', socialHandle(event.social_instagram, (h) => `https://instagram.com/${h}`) || '', '📷'],
          ['Facebook', socialHandle(event.social_facebook, (h) => `https://facebook.com/${h}`) || '', '👤'],
          ['TikTok', socialHandle(event.social_tiktok, (h) => `https://tiktok.com/@${h}`) || '', '🎵'],
          ['YouTube', socialHandle(event.social_youtube, (h) => `https://youtube.com/@${h}`) || '', '▶️'],
          ['LinkedIn', socialHandle(event.social_linkedin, (h) => `https://linkedin.com/in/${h}`) || '', '💼'],
        ].filter((row) => row[1]);

        const hasContact = event.organizer_name || event.organizer_email
          || event.organizer_phone || event.organizer_website
          || event.organizer_bio || socials.length > 0;

        const organizerPanel = hasContact ? `
          <section class="organizer">
            <h2>Connect with the host</h2>
            ${event.organizer_name ? `<p class="org-name">${escapeHtml(event.organizer_name)}</p>` : ''}
            ${event.organizer_bio ? `<p class="org-bio">${escapeHtml(event.organizer_bio)}</p>` : ''}
            <div class="org-contact">
              ${event.organizer_email ? `<a href="mailto:${escapeHtml(event.organizer_email)}">✉️ ${escapeHtml(event.organizer_email)}</a>` : ''}
              ${event.organizer_phone ? `<a href="tel:${escapeHtml(event.organizer_phone)}">📞 ${escapeHtml(event.organizer_phone)}</a>` : ''}
              ${event.organizer_website ? `<a href="${escapeHtml(event.organizer_website)}" target="_blank" rel="noopener">🌐 Website</a>` : ''}
            </div>
            ${socials.length ? `
              <div class="org-social">
                ${socials.map(([label, url, icon]) =>
                  `<a href="${escapeHtml(url)}" target="_blank" rel="noopener" title="${label}">${icon} ${label}</a>`
                ).join('')}
              </div>` : ''}
          </section>` : '';

        root.innerHTML = `
          <header class="top">
            <h1>${escapeHtml(event.name)}</h1>
            ${event.host_line ? `<p class="host">${escapeHtml(event.host_line)}</p>` : ''}
          </header>
          <section class="cards">
            ${cards || '<p class="empty">No transformations added yet.</p>'}
          </section>
          <div class="cta-stack">
            ${raffleCta}
            ${scienceCta}
          </div>
          ${organizerPanel}
        `;
      } catch (err) {
        root.innerHTML = `<p class="loading err">${escapeHtml((err as Error).message)}</p>`;
      }
    })();
  }
</script>

<style is:global>
  :root { --accent: #f39c12; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: #1a252f; color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  body { padding: 26px 14px 50px; line-height: 1.45; }
  main.event { max-width: 540px; margin: 0 auto; }
  .top { text-align: center; margin-bottom: 22px; }
  .top h1 { font-size: 28px; }
  .top .host { color: #bdc3c7; font-style: italic; margin-top: 4px; font-size: 14px; }

  .cards { display: grid; gap: 12px; }
  .card {
    display: grid; grid-template-columns: 110px 1fr; gap: 12px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px; overflow: hidden; text-decoration: none; color: inherit;
  }
  .card img, .card-placeholder {
    width: 110px; height: 130px; object-fit: cover; background: #000;
  }
  .card-body { padding: 12px 12px 12px 0; align-self: center; }
  .card-body h3 { font-size: 16px; color: #ecf0f1; }
  .card-body .stat {
    font-size: 12px; font-weight: 700; color: var(--accent);
    margin-top: 4px; letter-spacing: 0.5px;
  }
  .empty { color: #95a5a6; font-style: italic; text-align: center; padding: 30px 0; }
  .loading { color: #95a5a6; text-align: center; padding: 40px 0; font-size: 14px; }
  .loading.err { color: #e74c3c; }

  .cta-stack { display: grid; gap: 10px; margin-top: 22px; }
  a.cta-btn {
    display: block; padding: 14px;
    text-align: center; text-decoration: none;
    border-radius: 10px;
    font-weight: 800; font-size: 14px;
    letter-spacing: 1.5px; text-transform: uppercase;
  }
  a.cta-btn.raffle {
    background: var(--accent); color: #1a252f;
    border: 1px solid var(--accent);
  }
  a.cta-btn.raffle:hover { filter: brightness(1.07); }
  a.cta-btn.science {
    background: rgba(243,156,18,0.10);
    border: 1px solid var(--accent);
    color: var(--accent);
  }
  a.cta-btn.science:hover { background: rgba(243,156,18,0.18); }

  section.organizer {
    margin-top: 28px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 18px;
  }
  section.organizer h2 {
    font-size: 12px; color: var(--accent);
    text-transform: uppercase; letter-spacing: 1.5px;
    margin-bottom: 12px;
  }
  section.organizer .org-name {
    font-size: 17px; color: #fff; font-weight: 700;
    margin-bottom: 4px;
  }
  section.organizer .org-bio {
    font-size: 13px; color: #bdc3c7; line-height: 1.55;
    margin-bottom: 14px;
  }
  section.organizer .org-contact, section.organizer .org-social {
    display: flex; flex-wrap: wrap; gap: 6px;
    margin-top: 6px;
  }
  section.organizer a {
    display: inline-block;
    padding: 8px 12px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    color: #ecf0f1; text-decoration: none;
    font-size: 12px; font-weight: 600;
  }
  section.organizer a:hover { background: rgba(255,255,255,0.10); }
</style>
