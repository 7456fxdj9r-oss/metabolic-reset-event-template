---
import Base from '../../layouts/Base.astro';
---
<Base title="Event created — save your edit link">
  <main class="success">
    <p class="eyebrow">⚠ Save this before you leave</p>
    <h1>Your event is live.</h1>
    <p class="lede">
      The edit URL below is the only way back into your event. There is no
      account and no password — anyone with this link can edit. Save it now.
    </p>

    <section class="link-card">
      <h3>Public event URL <span class="tag">share this</span></h3>
      <div class="row">
        <input type="text" id="public-url" readonly />
        <button data-copy="#public-url">Copy</button>
      </div>
      <canvas id="public-qr"></canvas>
      <button id="public-qr-dl">Download QR</button>
    </section>

    <section class="link-card private">
      <h3>Private edit URL <span class="tag warn">keep secret</span></h3>
      <div class="row">
        <input type="text" id="edit-url" readonly />
        <button data-copy="#edit-url">Copy</button>
      </div>
      <div class="row">
        <button id="email-edit">Email me this link</button>
        <button id="download-edit">Download as .txt</button>
      </div>
    </section>

    <p class="next">
      Next: open your edit URL and start adding transformations.
    </p>
  </main>
</Base>

<script>
  import QRCode from 'qrcode';

  const params = new URLSearchParams(window.location.search);
  const slug = params.get('slug');
  const key = params.get('key');
  const base = import.meta.env.BASE_URL;

  if (!slug || !key) {
    document.querySelector('main.success')!.innerHTML =
      '<p>Missing slug or key in the URL. Was the event created successfully?</p>';
  } else {
    const origin = window.location.origin;
    const publicUrl = `${origin}${base}event?slug=${encodeURIComponent(slug)}`;
    const editUrl = `${origin}${base}edit?slug=${encodeURIComponent(slug)}&key=${encodeURIComponent(key)}`;
    (document.getElementById('public-url') as HTMLInputElement).value = publicUrl;
    (document.getElementById('edit-url') as HTMLInputElement).value = editUrl;

    const canvas = document.getElementById('public-qr') as HTMLCanvasElement;
    QRCode.toCanvas(canvas, publicUrl, { width: 220, margin: 1, color: { dark: '#ffffff', light: '#1a252f' } });

    document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const sel = btn.getAttribute('data-copy')!;
        const input = document.querySelector<HTMLInputElement>(sel)!;
        await navigator.clipboard.writeText(input.value);
        const orig = btn.textContent;
        btn.textContent = 'Copied!';
        setTimeout(() => (btn.textContent = orig), 1200);
      });
    });

    document.getElementById('public-qr-dl')?.addEventListener('click', () => {
      const url = canvas.toDataURL('image/png');
      const a = document.createElement('a');
      a.href = url;
      a.download = `${slug}-qr.png`;
      a.click();
    });

    document.getElementById('email-edit')?.addEventListener('click', () => {
      const subj = encodeURIComponent('Edit link for my coach event');
      const body = encodeURIComponent(
        `Save this — it's the only way back into your event.\n\nEdit URL:\n${editUrl}\n\nPublic URL:\n${publicUrl}\n`
      );
      window.location.href = `mailto:?subject=${subj}&body=${body}`;
    });

    document.getElementById('download-edit')?.addEventListener('click', () => {
      const txt = `Metabolic Reset Event — edit link\n\nEdit URL (KEEP SECRET):\n${editUrl}\n\nPublic URL (share):\n${publicUrl}\n`;
      const blob = new Blob([txt], { type: 'text/plain' });
      const a = document.createElement('a');
      a.href = URL.createObjectURL(blob);
      a.download = `metabolic-reset-event-${slug}-edit-link.txt`;
      a.click();
    });
  }
</script>

<style>
  * { box-sizing: border-box; }
  html, body {
    background: #1a252f; color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    margin: 0;
  }
  body { padding: 30px 18px 60px; }
  main.success { max-width: 540px; margin: 0 auto; }
  .eyebrow {
    font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    color: #e74c3c; font-weight: 800; margin-bottom: 8px;
  }
  h1 { font-size: 26px; margin-bottom: 8px; }
  p.lede { color: #bdc3c7; font-size: 14px; margin-bottom: 22px; line-height: 1.45; }

  .link-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 10px; padding: 14px; margin-bottom: 16px;
  }
  .link-card.private {
    border-color: rgba(231, 76, 60, 0.5);
    background: rgba(231, 76, 60, 0.06);
  }
  .link-card h3 {
    font-size: 14px; margin-bottom: 10px; color: #ecf0f1;
    display: flex; align-items: center; gap: 8px;
  }
  .tag {
    font-size: 10px; padding: 2px 8px; border-radius: 10px;
    background: rgba(46, 204, 113, 0.18); color: #2ecc71;
    text-transform: uppercase; letter-spacing: 1.2px; font-weight: 700;
  }
  .tag.warn { background: rgba(231, 76, 60, 0.2); color: #e74c3c; }
  .row { display: flex; gap: 8px; margin-bottom: 10px; }
  .row input {
    flex: 1; background: rgba(0,0,0,0.3); border: 1px solid rgba(255,255,255,0.15);
    color: #fff; padding: 9px 10px; border-radius: 6px; font-size: 13px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  .row button, button#public-qr-dl {
    background: #f39c12; color: #1a252f; border: none; padding: 9px 14px;
    border-radius: 6px; font-weight: 700; font-size: 13px; cursor: pointer;
  }
  canvas { display: block; margin: 10px auto; background: #1a252f; border-radius: 4px; }
  p.next { color: #95a5a6; font-size: 13px; text-align: center; margin-top: 18px; }
</style>
