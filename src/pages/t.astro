---
import Base from '../layouts/Base.astro';
import '../styles/story.css';
---
<Base title="Transformation">
  <main class="wrap" id="t-root">
    <p class="loading">Loading…</p>
  </main>
</Base>

<script>
  import { drawMultiChart } from '../lib/chart.js';
  import {
    fetchEventBySlug,
    fetchTransformationBySlug,
    fetchDataPoints,
  } from '../lib/supabase.js';

  const root = document.getElementById('t-root')!;
  const base = import.meta.env.BASE_URL;
  const params = new URLSearchParams(window.location.search);
  const slug = params.get('slug');
  const tslug = params.get('t');

  function escapeHtml(s: unknown): string {
    return String(s ?? '').replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!)
    );
  }
  function fmtDate(s: string): string {
    const d = new Date(s);
    return (d.getMonth() + 1) + '/' + String(d.getFullYear()).slice(2);
  }

  if (!slug || !tslug) {
    root.innerHTML = '<p class="loading">Missing slug or transformation id.</p>';
  } else {
    (async () => {
      try {
        const event = await fetchEventBySlug(slug);
        if (!event) {
          root.innerHTML = '<p class="loading">Event not found.</p>';
          return;
        }
        const t = await fetchTransformationBySlug(event.id, tslug);
        if (!t) {
          root.innerHTML = '<p class="loading">Transformation not found.</p>';
          return;
        }
        document.title = `${t.name} — ${event.name}`;
        const accent = event.accent_color || '#f39c12';
        document.documentElement.style.setProperty('--accent', accent);

        const points = await fetchDataPoints(t.id);
        const byMetric: Record<string, Array<[string, number]>> = { weight: [], bf: [], lean: [] };
        points.forEach((p: any) => {
          if (byMetric[p.metric]) byMetric[p.metric].push([p.date, Number(p.value)]);
        });

        // If no time-series data points exist but we DO have before/after
        // snapshots, synthesize a *realistic-looking* curve per metric so
        // the chart still tells the story. Each metric uses ~22 points
        // between the dates with a curve shape that matches real
        // metabolic-reset trajectories: weight + BF crash fast early then
        // plateau (cubic ease-out), lean barely budges (near-flat with
        // tiny natural jitter). Deterministic noise keeps the curve stable
        // across renders — same transformation always renders the same
        // chart. A "Estimated" tag + note discloses it's not granular.
        const totalRealPoints = points.length;
        const haveBeforeAfterDates = !!(t.before_date && t.after_date);
        const isEstimated = totalRealPoints === 0 && haveBeforeAfterDates;

        function synthCurve(
          startDate: string, endDate: string,
          startVal: number, endVal: number,
          shape: 'eased' | 'flat', noise: number,
          steps = 22,
        ): Array<[string, number]> {
          const out: Array<[string, number]> = [];
          const t0 = new Date(startDate + 'T00:00:00').getTime();
          const t1 = new Date(endDate + 'T00:00:00').getTime();
          if (!isFinite(t0) || !isFinite(t1) || t1 <= t0) {
            return [[startDate, startVal], [endDate, endVal]];
          }
          const span = t1 - t0;
          for (let i = 0; i <= steps; i++) {
            const p = i / steps;
            const curve = shape === 'eased' ? 1 - Math.pow(1 - p, 3) : p;
            let val = startVal + (endVal - startVal) * curve;
            // Deterministic pseudo-random in ±noise — same seed per index
            // so re-renders are identical and the curve doesn't jitter
            // between page loads.
            if (i > 0 && i < steps) {
              const seed = Math.sin((i + 1) * 12.9898 + startVal * 0.31) * 43758.5453;
              const rnd = seed - Math.floor(seed); // 0..1
              val += (rnd - 0.5) * 2 * noise;
            }
            const date = new Date(t0 + span * p).toISOString().slice(0, 10);
            out.push([date, Math.round(val * 10) / 10]);
          }
          return out;
        }

        if (isEstimated) {
          if (t.before_weight != null && t.after_weight != null) {
            byMetric.weight = synthCurve(
              t.before_date, t.after_date,
              Number(t.before_weight), Number(t.after_weight),
              'eased', 0.6,
            );
          }
          if (t.before_bf != null && t.after_bf != null) {
            byMetric.bf = synthCurve(
              t.before_date, t.after_date,
              Number(t.before_bf), Number(t.after_bf),
              'eased', 0.3,
            );
          }
          if (t.before_lean != null && t.after_lean != null) {
            byMetric.lean = synthCurve(
              t.before_date, t.after_date,
              Number(t.before_lean), Number(t.after_lean),
              'flat', 0.4,
            );
          }
        }

        // Duration badge in the chart-head (only when we have both dates)
        function durationLabel(d1: string, d2: string): string {
          const a = new Date(d1 + 'T00:00:00');
          const b = new Date(d2 + 'T00:00:00');
          if (isNaN(a.getTime()) || isNaN(b.getTime()) || b <= a) return '';
          const days = Math.round((b.getTime() - a.getTime()) / 86400000);
          if (days < 60) return `${days} days`;
          const months = Math.round(days / 30);
          if (months < 24) return `${months} months`;
          const years = (days / 365).toFixed(1).replace(/\.0$/, '');
          return `${years} years`;
        }
        const durationTxt = (t.before_date && t.after_date)
          ? durationLabel(t.before_date, t.after_date)
          : '';

        const stats = `
          <div class="headline-stats">
            ${t.headline_lb_loss != null ? `
              <div class="h-stat">
                <span class="num">−${escapeHtml(t.headline_lb_loss)} lb</span>
                <span class="label">Total<br>weight loss</span>
              </div>` : ''}
            ${t.headline_lean_kept_pct != null ? `
              <div class="h-stat">
                <span class="num">${escapeHtml(t.headline_lean_kept_pct)}%</span>
                <span class="label">Lean Mass<br>kept</span>
              </div>` : ''}
            ${t.headline_bf_delta_pts != null ? `
              <div class="h-stat">
                <span class="num">−${escapeHtml(t.headline_bf_delta_pts)}</span>
                <span class="label">Body Fat<br>% points</span>
              </div>` : ''}
          </div>`;

        root.innerHTML = `
          <div class="top">
            <div class="eyebrow">Real Person · Real Numbers</div>
            <h1>${escapeHtml(t.name)}</h1>
          </div>

          <div class="photos">
            ${t.before_photo_url ? `
              <figure>
                <img src="${escapeHtml(t.before_photo_url)}" alt="Before" />
                <figcaption>Before · ${fmtDate(t.before_date)}</figcaption>
              </figure>` : ''}
            ${t.after_photo_url ? `
              <figure>
                <img src="${escapeHtml(t.after_photo_url)}" alt="After" />
                <figcaption>After · ${fmtDate(t.after_date)}</figcaption>
              </figure>` : ''}
          </div>

          ${stats}

          <div class="chart-card">
            <div class="chart-head">
              <h3>Metabolic Transformation</h3>
              ${durationTxt ? `<span class="delta neg">${escapeHtml(durationTxt)}</span>` : ''}
              ${isEstimated ? '<span class="chart-tag">Estimated</span>' : ''}
            </div>
            <svg class="chart" id="comboChart" preserveAspectRatio="none" style="height:300px;"></svg>
            <div class="legend">
              <span class="legend-item"><span class="dot" style="background:#f39c12"></span>Weight</span>
              <span class="legend-item"><span class="dot" style="background:#e74c3c"></span>Body Fat</span>
              <span class="legend-item"><span class="dot" style="background:#2ecc71"></span>Lean Mass</span>
            </div>
            ${isEstimated ? '<p class="chart-note">Estimated trajectory shape (fast initial loss, slower plateau) interpolated from the before/after snapshots — actual week-by-week values not recorded.</p>' : ''}
          </div>

          ${t.takeaway_text ? `<p class="takeaway">${escapeHtml(t.takeaway_text)}</p>` : ''}

          <div class="footer-cta">
            <a href="${base}science?slug=${encodeURIComponent(slug)}">The Science →</a>
            <a href="${base}event?slug=${encodeURIComponent(slug)}" class="secondary">← Back to the event</a>
          </div>
        `;

        const svg = document.getElementById('comboChart') as unknown as SVGSVGElement;
        const series: Array<{ name: string; color: string; suffix: string; axis: 'left' | 'right'; data: Array<[string, number]> }> = [];
        if (byMetric.weight.length) series.push({ name: 'Weight',   color: '#f39c12', suffix: ' lb', axis: 'left',  data: byMetric.weight });
        if (byMetric.lean.length)   series.push({ name: 'Lean',     color: '#2ecc71', suffix: ' lb', axis: 'left',  data: byMetric.lean });
        if (byMetric.bf.length)     series.push({ name: 'Body Fat', color: '#e74c3c', suffix: '%',   axis: 'right', data: byMetric.bf });
        if (series.length) drawMultiChart(svg, series);
      } catch (err) {
        root.innerHTML = `<p class="loading err">${escapeHtml((err as Error).message)}</p>`;
      }
    })();
  }
</script>

<style>
  .loading { color: #95a5a6; text-align: center; padding: 40px 0; font-size: 14px; }
  .loading.err { color: #e74c3c; }
</style>
