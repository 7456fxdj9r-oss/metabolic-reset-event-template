---
import Base from '../layouts/Base.astro';
---
<Base title="Enter the Raffle">
  <main class="raffle" id="raffle-root">
    <p class="loading">Loading…</p>
  </main>
</Base>

<script>
  import { fetchEventBySlug, callFunction, fetchRafflePrizes } from '../lib/supabase.js';
  import { eventUrl, raffleMeUrl } from '../lib/urls.js';
  import { escapeHtml } from '../lib/html.js';

  type Prize = {
    id: string; name: string; description: string | null;
    photo_url: string | null;
    is_grand: boolean;
    quantity?: number;
  };

  const root = document.getElementById('raffle-root')!;
  const base = import.meta.env.BASE_URL;
  const params = new URLSearchParams(window.location.search);
  const slug = params.get('slug');


  if (!slug) {
    root.innerHTML = '<p class="loading err">No event specified.</p>';
  } else {
    (async () => {
      try {
        const event = await fetchEventBySlug(slug);
        if (!event) {
          root.innerHTML = '<p class="loading err">Event not found.</p>';
          return;
        }
        document.title = `Raffle — ${event.name}`;
        const accent = event.accent_color || '#f39c12';
        document.documentElement.style.setProperty('--accent', accent);

        // Multi-prize raffle: pull the grand prize for the headline image
        // + name (top of the page) and the rest as spot prizes for a full
        // "what you could win" gallery below the headline. Falls back to
        // the legacy event.raffle_prize / raffle_prize_photo_url fields
        // if no raffle_prizes rows exist (events created before the
        // multi-prize migration).
        let prizeImageUrl: string | null = event.raffle_prize_photo_url || null;
        let headlinePrizeName: string | null = event.raffle_prize || null;
        let spotPrizes: Prize[] = [];
        try {
          const prizes = (await fetchRafflePrizes(event.id)) as Prize[];
          if (prizes.length > 0) {
            const grand = prizes.find((p) => p.is_grand);
            if (grand) {
              prizeImageUrl = grand.photo_url || prizeImageUrl;
              headlinePrizeName = grand.name;
              spotPrizes = prizes.filter((p) => !p.is_grand);
            } else {
              // No grand designated — promote the first prize to headline.
              prizeImageUrl = prizes[0].photo_url || prizeImageUrl;
              headlinePrizeName = prizes[0].name;
              spotPrizes = prizes.slice(1);
            }
          }
        } catch { /* non-fatal — fall back to legacy fields */ }

        const today = new Date().toISOString().slice(0, 10);
        const autoClosed = event.event_date && today > event.event_date;
        if (event.raffle_status !== 'open' || autoClosed) {
          root.innerHTML = `
            <header class="top">
              <p class="eyebrow">Raffle</p>
              <h1>${escapeHtml(event.name)}</h1>
            </header>
            <div class="closed-card">
              <h2>Entries are closed</h2>
              <p>The raffle for this event isn't accepting new entries right now.</p>
              <a class="back" href="${eventUrl(base, slug)}">← Back to the event</a>
            </div>`;
          return;
        }

        // Spot-prize gallery — full list with thumbnails + quantity badges,
        // shown below the headline grand prize. Renders only when there
        // are non-headline prizes; events with only a grand drop this
        // section entirely.
        const spotGallery = spotPrizes.length === 0 ? '' : `
          <section class="prize-gallery" aria-label="Other prizes drawn live">
            <h2>Also up for grabs (drawn live)</h2>
            <ul>
              ${spotPrizes.map((p) => {
                const qty = p.quantity && p.quantity > 1 ? `<span class="qty">× ${p.quantity}</span>` : '';
                const thumb = p.photo_url
                  ? `<img class="thumb" src="${escapeHtml(p.photo_url)}" alt="" />`
                  : '<div class="thumb empty" aria-hidden="true"></div>';
                const desc = p.description
                  ? `<span class="desc">${escapeHtml(p.description.length > 80 ? p.description.slice(0, 80) + '…' : p.description)}</span>`
                  : '';
                return `
                  <li>
                    ${thumb}
                    <div class="info">
                      <strong>${escapeHtml(p.name)}${qty}</strong>
                      ${desc}
                    </div>
                  </li>`;
              }).join('')}
            </ul>
          </section>`;

        root.innerHTML = `
          <header class="top">
            <p class="eyebrow">Raffle Entry</p>
            <h1>🎟️ ${escapeHtml(event.name)}</h1>
            ${prizeImageUrl
              ? `<img class="prize-photo" src="${escapeHtml(prizeImageUrl)}" alt="${escapeHtml(headlinePrizeName || 'Prize')}" />`
              : ''}
            ${headlinePrizeName
              ? `<p class="prize">🏆 <strong>${escapeHtml(headlinePrizeName)}</strong></p>`
              : ''}
            <p class="lede">Enter to win — and tell us a bit about where you're at.</p>
          </header>

          ${spotGallery}

          <form id="entry-form" class="card" novalidate>
            <h2>Your info</h2>
            <label>
              Full name <span class="req">*</span>
              <input name="name" required maxlength="100" autocomplete="name" />
            </label>
            <label>
              Email <span class="req">*</span>
              <input type="email" name="email" required autocomplete="email" inputmode="email" />
            </label>
            <label>
              Phone <span class="opt">(optional)</span>
              <input type="tel" name="phone" autocomplete="tel" inputmode="tel" />
            </label>
            <label>
              Who invited you to this event? <span class="req">*</span>
              <input name="invited_by" required maxlength="100" />
            </label>

            <h2>Do you or someone close to you have…</h2>
            ${ynBlock('has_diabetes', '<strong>Diabetes</strong> or pre-diabetes?')}
            ${ynBlock('has_high_bp', '<strong>High blood pressure</strong>?')}
            ${ynBlock('has_high_cholesterol', '<strong>High cholesterol</strong>?')}

            <h2>How are you doing in these areas?</h2>
            <p class="hint">5 = doing great · 1 = really struggling</p>
            ${scaleRow('rate_energy', 'Energy')}
            ${scaleRow('rate_sleep', 'Sleep')}
            ${scaleRow('rate_weight', 'Weight')}
            ${scaleRow('rate_cravings', 'Cravings / blood sugar')}
            ${scaleRow('rate_mood', 'Mood / stress')}
            ${scaleRow('rate_digestion', 'Digestion')}
            ${scaleRow('rate_community', 'Community / connection')}

            <h2>Quick check — what do you know about metabolic health?</h2>
            <p class="hint">Pick the answer that feels right. We'll show you whether each is correct as you go.</p>
            <div id="quiz" class="quiz"></div>

            <h2>A couple more</h2>
            <label class="row-label">Tried a reset / cleanse / diet program before?</label>
            ${ynRow('tried_before')}

            <label>
              Anything else on your mind? <span class="opt">(optional)</span>
              <textarea name="goal_text" rows="3" maxlength="500"
                placeholder="What's on your mind?"></textarea>
            </label>

            <label class="checkbox-row">
              <input type="checkbox" name="newsletter_optin" checked />
              <span>Add me to the newsletter</span>
            </label>
            <label class="checkbox-row">
              <input type="checkbox" name="apprentice_optin" />
              <span><strong>I'm curious about metabolic coaching.</strong> Tell me more about the apprentice program.</span>
            </label>
            <label class="checkbox-row consult-row">
              <input type="checkbox" name="consultation_optin" />
              <span><strong>I'd like a free 1-on-1 Metabolic Consultation.</strong> I'm curious what this could look like for me.</span>
            </label>

            <p class="privacy">Your info goes to the event host and team only. We won't share or sell it.</p>

            <div class="row">
              <button type="submit" id="submit-btn">Enter the Raffle</button>
              <span id="entry-status" role="status" aria-live="polite"></span>
            </div>
          </form>

          <div class="footer-cta">
            <a class="secondary" href="${eventUrl(base, slug)}">← Back to the event</a>
          </div>
        `;

        const form = document.getElementById('entry-form') as HTMLFormElement;
        const status = document.getElementById('entry-status')!;
        const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
        const metabolicQuiz = mountMetabolicQuiz(document.getElementById('quiz')!);

        form.addEventListener('submit', async (submitEv) => {
          submitEv.preventDefault();
          status.textContent = '';
          status.className = '';

          const fd = new FormData(form);
          const requiredText = ['name', 'email', 'invited_by'];
          const missingText = requiredText.filter((k) => !String(fd.get(k) || '').trim());
          if (missingText.length) {
            status.textContent = 'Please fill in name, email, and who invited you.';
            status.className = 'err';
            window.scrollTo({ top: 0, behavior: 'smooth' });
            return;
          }

          const requiredRadios: Array<[string, string]> = [
            ['has_diabetes', 'Diabetes question'],
            ['has_high_bp', 'High blood pressure question'],
            ['has_high_cholesterol', 'High cholesterol question'],
            ['rate_energy', 'Energy rating'],
            ['rate_sleep', 'Sleep rating'],
            ['rate_weight', 'Weight rating'],
            ['rate_cravings', 'Cravings rating'],
            ['rate_mood', 'Mood / stress rating'],
            ['rate_digestion', 'Digestion rating'],
            ['rate_community', 'Community rating'],
            ['tried_before', 'Tried-before question'],
          ];
          const missing = requiredRadios.filter(([k]) => !fd.get(k));
          if (missing.length) {
            status.textContent = `Please answer all questions (${missing.length} left).`;
            status.className = 'err';
            const firstMissing = form.querySelector<HTMLInputElement>(`input[name="${missing[0][0]}"]`);
            const block = firstMissing?.closest('.yn-block, .scale-row, .yn-row');
            block?.scrollIntoView({ behavior: 'smooth', block: 'center' });
            return;
          }

          submitBtn.disabled = true;
          status.textContent = 'Submitting…';
          status.className = '';

          const quiz_answers: Record<string, string | number | null> = {};
          for (const [k] of requiredRadios) {
            const v = fd.get(k);
            // ratings come through as numeric strings; coerce
            const asNum = Number(v);
            quiz_answers[k] = Number.isInteger(asNum) && asNum >= 1 && asNum <= 5
              ? asNum
              : (v === 'yes' || v === 'no' ? v : null);
          }

          try {
            const res = await callFunction('submit-raffle-entry', {
              slug,
              name: fd.get('name'),
              email: fd.get('email'),
              phone: fd.get('phone') || null,
              invited_by: fd.get('invited_by'),
              goal_text: fd.get('goal_text') || null,
              newsletter_optin: fd.get('newsletter_optin') === 'on',
              apprentice_optin: fd.get('apprentice_optin') === 'on',
              consultation_optin: fd.get('consultation_optin') === 'on',
              quiz_answers: { ...quiz_answers, ...metabolicQuiz.answers() },
            });
            window.location.href = raffleMeUrl(base, slug!, res.entry_token);
          } catch (err) {
            status.textContent = (err as Error).message;
            status.className = 'err';
            submitBtn.disabled = false;
          }
        });
      } catch (err) {
        root.innerHTML = `<p class="loading err">${escapeHtml((err as Error).message)}</p>`;
      }
    })();
  }

  function ynBlock(name: string, question: string): string {
    return `
      <div class="yn-block">
        <span class="question">${question}</span>
        <div class="yn-options">
          <label><input type="radio" name="${name}" value="yes" /><span>Yes</span></label>
          <label><input type="radio" name="${name}" value="no" /><span>No</span></label>
        </div>
      </div>`;
  }

  function ynRow(name: string): string {
    return `
      <div class="yn-row">
        <label><input type="radio" name="${name}" value="yes" /><span>Yes</span></label>
        <label><input type="radio" name="${name}" value="no" /><span>No</span></label>
      </div>`;
  }

  function scaleRow(name: string, label: string): string {
    return `
      <label class="row-label">${label}</label>
      <div class="scale-row">
        ${[1, 2, 3, 4, 5].map((n) =>
          `<label><input type="radio" name="${name}" value="${n}" /><span>${n}</span></label>`
        ).join('')}
      </div>`;
  }

  // Metabolic-awareness quiz. Each question is a radio group; picking
  // any option triggers an inline reveal — green for the canonically
  // correct answer, amber for "good thought, here's the bigger picture."
  // The whole thing is optional — the form's required-field check
  // doesn't gate on it. Answers ride along in quiz_answers when the
  // attendee submits the raffle.
  type QuizOption = { value: string; label: string; correct?: boolean };
  type QuizQuestion = {
    id: string;
    prompt: string;
    options: QuizOption[];
    rightReveal: string;      // shown when they pick the correct one
    softReveal: string;       // shown when they pick a non-canonical answer
  };
  const METABOLIC_QUIZ: QuizQuestion[] = [
    {
      id: 'q_what_is',
      prompt: 'What is metabolic health?',
      options: [
        { value: 'a', label: 'How efficiently your body uses food for energy' },
        { value: 'b', label: 'Keeping blood sugar stable' },
        { value: 'c', label: 'Supporting muscle, hormones, and brain health' },
        { value: 'd', label: 'Managing inflammation and fat storage' },
        { value: 'all', label: 'All of the above', correct: true },
      ],
      rightReveal: "Right — metabolic health is how your body coordinates energy, blood sugar, muscle, hormones, and inflammation. They're all part of the same system.",
      softReveal: "That's one piece — and it's actually all of them together. Metabolic health is how your body coordinates energy, blood sugar, muscle, hormones, and inflammation.",
    },
    {
      id: 'q_dysfunction_signs',
      prompt: 'Which of these are signs of metabolic dysfunction?',
      options: [
        { value: 'a', label: 'Low or inconsistent energy' },
        { value: 'b', label: 'Stubborn weight, especially around the middle' },
        { value: 'c', label: 'Poor sleep or waking up tired' },
        { value: 'd', label: 'Brain fog or low motivation' },
        { value: 'e', label: 'Inflammation, aches, or pains' },
        { value: 'f', label: 'Blood sugar, cholesterol, or blood pressure concerns' },
        { value: 'wrong', label: 'Improved VO₂ max and faster recovery' },
        { value: 'all', label: 'All of the above (except the VO₂ one)', correct: true },
      ],
      rightReveal: "Yes — and even one of these is common. Change is possible.",
      softReveal: "That's one signal — and there are more. Even one is common; change is possible.",
    },
    {
      id: 'q_aging',
      prompt: 'These symptoms are an inevitable part of aging.',
      options: [
        { value: 'true', label: 'True — it just comes with age' },
        { value: 'false', label: 'False — these are not inevitable', correct: true },
      ],
      rightReveal: 'Exactly. Your body responds positively at any age when given the right support.',
      softReveal: 'These are often blamed on aging — but they are not inevitable. Your body responds positively at any age when given the right support.',
    },
    {
      id: 'q_habits',
      prompt: 'Which habits support metabolic health?',
      options: [
        { value: 'a', label: 'Balanced nutrition with adequate protein' },
        { value: 'b', label: 'Stable blood sugar through regular, balanced meals' },
        { value: 'c', label: 'Nutrient-dense, anti-inflammatory foods' },
        { value: 'd', label: 'Simple, sustainable routines (consistency over perfection)' },
        { value: 'all', label: 'All of the above', correct: true },
      ],
      rightReveal: 'Yes — consistency across nutrition, blood sugar, anti-inflammation, and sustainable routines beats perfection in any one area.',
      softReveal: "That's one — and they all matter together. Small, consistent habits create lasting results.",
    },
    {
      id: 'q_better_question',
      prompt: 'A better question than "How do I lose weight?" is…',
      options: [
        { value: 'a', label: '"How can I cut more calories?"' },
        { value: 'b', label: '"Which diet should I try?"' },
        { value: 'c', label: '"How fast can I see results?"' },
        { value: 'd', label: '"How do I help my body work with me again?"', correct: true },
      ],
      rightReveal: 'Exactly. When metabolic health improves, energy, clarity, strength, and weight follow naturally.',
      softReveal: "Closer to home is asking 'How do I help my body work with me again?' That reframe is where it starts.",
    },
  ];

  function mountMetabolicQuiz(host: HTMLElement) {
    const picked: Record<string, string> = {};
    host.innerHTML = METABOLIC_QUIZ.map((q, idx) => `
      <div class="quiz-q" data-q="${q.id}">
        <p class="quiz-prompt"><span class="quiz-num">${idx + 1}</span> ${q.prompt}</p>
        <div class="quiz-options">
          ${q.options.map((o) => `
            <label class="quiz-option">
              <input type="radio" name="quiz_${q.id}" value="${o.value}" />
              <span>${o.label}</span>
            </label>
          `).join('')}
        </div>
        <div class="quiz-reveal" data-reveal="${q.id}" hidden></div>
      </div>
    `).join('');

    host.addEventListener('change', (ev) => {
      const input = ev.target as HTMLInputElement;
      if (input.type !== 'radio' || !input.name.startsWith('quiz_')) return;
      const qid = input.name.slice('quiz_'.length);
      const q = METABOLIC_QUIZ.find((x) => x.id === qid);
      if (!q) return;
      const opt = q.options.find((o) => o.value === input.value);
      const isRight = !!opt?.correct;
      picked[qid] = input.value;
      const reveal = host.querySelector(`[data-reveal="${qid}"]`) as HTMLElement;
      reveal.hidden = false;
      reveal.className = 'quiz-reveal ' + (isRight ? 'right' : 'soft');
      reveal.innerHTML = `
        <p class="quiz-reveal-head">${isRight ? '✓ Good job!' : '💡 Worth knowing'}</p>
        <p class="quiz-reveal-body">${isRight ? q.rightReveal : q.softReveal}</p>`;
    });

    return { answers: () => ({ ...picked }) };
  }
</script>

<style is:global>
  :root { --accent: #f39c12; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: #1a252f; color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  body { padding: 26px 14px 50px; line-height: 1.45; }
  main.raffle { max-width: 540px; margin: 0 auto; }

  .top { text-align: center; margin-bottom: 22px; }
  .top .eyebrow {
    font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--accent); font-weight: 700; margin-bottom: 6px;
  }
  .top h1 { font-size: 26px; line-height: 1.2; }
  .top .lede { font-size: 14px; color: #95a5a6; font-style: italic; margin-top: 10px; }
  .top .prize-photo {
    display: block;
    margin: 14px auto 6px;
    width: 60%;
    max-width: 220px;
    height: auto;
    border-radius: 10px;
    background: #000;
  }
  .top .prize {
    margin-top: 14px;
    padding: 12px 14px;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 50%, transparent);
    border-radius: 10px;
    font-size: 15px; color: #ecf0f1;
  }
  .top .prize strong { color: var(--accent); }

  /* "Also up for grabs" gallery — compact rows beneath the grand-prize
     headline. Hidden entirely when the event has only a grand prize. */
  .prize-gallery {
    margin-bottom: 18px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 14px 16px;
  }
  .prize-gallery h2 {
    font-size: 11px; color: var(--accent);
    text-transform: uppercase; letter-spacing: 1.5px;
    font-weight: 700;
    margin-bottom: 10px;
  }
  .prize-gallery ul {
    list-style: none; padding: 0; margin: 0;
    display: grid; gap: 8px;
  }
  .prize-gallery li {
    display: grid;
    grid-template-columns: 48px 1fr;
    align-items: center; gap: 12px;
    padding: 6px 4px;
  }
  .prize-gallery .thumb {
    width: 48px; height: 48px;
    object-fit: cover;
    border-radius: 8px;
    background: rgba(0,0,0,0.35);
  }
  .prize-gallery .thumb.empty {
    border: 1px dashed rgba(255,255,255,0.18);
  }
  .prize-gallery .info {
    display: flex; flex-direction: column; gap: 2px;
    min-width: 0;
  }
  .prize-gallery .info strong {
    font-size: 14px; color: #ecf0f1; font-weight: 700;
    overflow-wrap: anywhere;
  }
  .prize-gallery .info .qty {
    display: inline-block; vertical-align: middle;
    margin-left: 6px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.3px;
    padding: 1px 7px; border-radius: 8px;
    background: rgba(243,156,18,0.18); color: var(--accent);
    border: 1px solid rgba(243,156,18,0.4);
  }
  .prize-gallery .info .desc {
    font-size: 12px; color: #95a5a6; line-height: 1.4;
  }

  .card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 18px; margin-bottom: 16px;
    display: grid; gap: 12px; grid-template-columns: minmax(0, 1fr);
  }
  .card h2 {
    font-size: 13px; color: var(--accent);
    text-transform: uppercase; letter-spacing: 1.5px;
    margin: 14px 0 -2px; font-weight: 700;
  }
  .card h2:first-child { margin-top: 0; }
  .card .hint, .card .privacy {
    font-size: 12px; color: #95a5a6;
    line-height: 1.5; font-style: italic;
    text-align: left;
  }
  .card .privacy { text-align: center; margin-top: 6px; }

  label { display: grid; gap: 6px; font-size: 13px; color: #ecf0f1; font-weight: 600; min-width: 0; }
  label.row-label { display: block; margin-top: 2px; }
  label .req { color: #e74c3c; font-weight: 700; }
  label .opt { color: #95a5a6; font-weight: 400; font-size: 12px; }
  input[type=text], input[type=email], input[type=tel], textarea, input:not([type]) {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px; padding: 12px;
    color: #fff; font-size: 16px; font-family: inherit;
    width: 100%; min-width: 0;
  }
  input:not([type=radio]):not([type=checkbox]):focus, textarea:focus {
    outline: 2px solid var(--accent); outline-offset: 1px;
  }
  textarea { resize: vertical; min-height: 64px; }

  /* Yes / No question card */
  .yn-block {
    margin: 4px 0;
    padding: 12px;
    background: rgba(0,0,0,0.20);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    display: grid; gap: 10px;
  }
  .yn-block .question { font-size: 14px; color: #ecf0f1; font-weight: 600; }
  .yn-block .question strong { color: #fff; font-weight: 800; }
  .yn-options, .yn-row {
    display: flex; gap: 8px;
  }
  .yn-options label, .yn-row label {
    flex: 1; margin: 0; padding: 0; cursor: pointer;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px; background: rgba(255,255,255,0.04);
    overflow: hidden; min-width: 0;
  }
  .yn-options input, .yn-row input { display: none; }
  .yn-options label span, .yn-row label span {
    display: block; padding: 12px 0;
    text-align: center; font-weight: 700; font-size: 14px;
    color: #ecf0f1;
  }
  .yn-options input:checked + span,
  .yn-row input:checked + span {
    background: var(--accent); color: #1a252f;
  }

  /* 1-5 scale rows */
  .scale-row {
    display: flex; gap: 6px;
  }
  .scale-row label {
    flex: 1; margin: 0; padding: 0; cursor: pointer;
    border: 1px solid rgba(255,255,255,0.15);
