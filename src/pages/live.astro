---
import Base from '../layouts/Base.astro';
---
<Base title="Raffle control">
  <main class="live-main" id="live-root">
    <p class="loading">Loading…</p>
  </main>
</Base>

<script>
  // Event-day cockpit: big QR for the raffle entry URL, live counts that
  // refresh every 5s, recent entries scroll, and quick actions for drawing
  // and opening the spinning wheel.
  //
  // Auth: same ?key= as the edit page. The page only loads when manage-raffle
  // accepts the token (master edit_token or a co-host's host_token).
  import { fetchEventBySlug, callFunction, getConfig } from '../lib/supabase.js';
  import { buildRaffleEntriesCsv, downloadCsv } from '../lib/csv.js';
  import { raffleUrl as raffleClean, wheelUrl, editUrl as editUrlOf, rafflePosterUrl } from '../lib/urls.js';
  import { createClient } from '@supabase/supabase-js';
  import QRCode from 'qrcode';
  import { escapeHtml } from '../lib/html.js';

  type Entry = {
    id: string; name: string; email: string; phone: string | null;
    risk_score: number | null;
    apprentice_optin: boolean | null;
    drawn: boolean; prize_won: string | null;
    prize_id: string | null;
    submitted_at: string;
  };
  type Prize = {
    id: string; name: string; description: string | null;
    photo_url: string | null;
    is_grand: boolean;
    quantity: number;
    drawn_count: number;
    drawn_winner_id: string | null;
    drawn_at: string | null;
  };

  const root = document.getElementById('live-root')!;
  const base = import.meta.env.BASE_URL;
  const params = new URLSearchParams(window.location.search);
  const slug = params.get('slug');
  const key = params.get('key');


  function fmtTime(iso: string): string {
    const d = new Date(iso);
    if (isNaN(d.getTime())) return '';
    return d.toLocaleTimeString(undefined, { hour: 'numeric', minute: '2-digit' });
  }

  if (!slug || !key) {
    root.innerHTML = '<p class="loading err">Raffle control requires both slug and key in the URL. Use the link from your edit page.</p>';
  } else {
    init();
  }

  let raffleUrl = '';
  let wheelHostUrl = '';
  let wheelViewerUrl = '';
  let editUrl = '';
  let pollTimer: number | undefined;
  let entriesCache: Entry[] = [];
  let prizesCache: Prize[] = [];
  // Realtime channel — when the host taps a Draw button on this dashboard
  // we broadcast a 'spin' event so any /wheel page subscribed to the same
  // channel animates in sync. Same payload shape the wheel page already
  // understands (winner_id + winner_first_name + duration_ms), plus
  // prize info so the wheel can render "Spinning for: X".
  let realtimeChannel: ReturnType<ReturnType<typeof createClient>['channel']> | null = null;
  const SPIN_DURATION_MS = 7000;
  const SPIN_DURATION_MS_GRAND = 10000;

  async function init() {
    try {
      const event = await fetchEventBySlug(slug);
      if (!event) {
        root.innerHTML = '<p class="loading err">Event not found.</p>';
        return;
      }
      const accent = event.accent_color || '#f39c12';
      document.documentElement.style.setProperty('--accent', accent);
      document.title = `Live · ${event.name}`;

      const origin = window.location.origin;
      // Public URLs use the clean /raffle/<slug>, /wheel/<slug> form so
      // they read cleanly when projected on a screen at the event.
      // Internal admin URLs keep ?slug=&key= since they carry secrets.
      raffleUrl = origin + raffleClean(base, slug!);
      wheelViewerUrl = origin + wheelUrl(base, slug!);
      wheelHostUrl = origin + wheelUrl(base, slug!, key!);
      editUrl = origin + editUrlOf(base, slug!, key!);

      renderShell(event);
      subscribeRealtime();

      const qrCanvas = document.getElementById('raffle-qr') as HTMLCanvasElement;
      QRCode.toCanvas(qrCanvas, raffleUrl, {
        width: 280, margin: 2,
        color: { dark: '#ffffff', light: '#1a252f' },
      }).catch(() => {});

      await refresh();
      // Visibility-gated polling: skip ticks while the tab is hidden so
      // the page doesn't burn battery / cellular when the host puts
      // their phone away. Resume fires an immediate catch-up refresh.
      pollTimer = window.setInterval(() => {
        if (document.visibilityState === 'visible') refresh();
      }, 5000);
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible') refresh();
      });

      wireActions();
    } catch (err) {
      root.innerHTML = `<p class="loading err">${escapeHtml((err as Error).message)}</p>`;
      if (pollTimer) clearInterval(pollTimer);
    }
  }

  function renderShell(event: { name: string; raffle_status: string; raffle_prize: string | null }) {
    const statusBadge = event.raffle_status === 'open'
      ? '<span class="status-pill open">Raffle OPEN</span>'
      : '<span class="status-pill closed">Raffle CLOSED</span>';
    root.innerHTML = `
      <header class="top">
        <p class="eyebrow">Live event control</p>
        <h1>${escapeHtml(event.name)}</h1>
        <p class="status-line">${statusBadge}${event.raffle_prize ? ` · 🎁 ${escapeHtml(event.raffle_prize)}` : ''}</p>
      </header>

      <section class="qr-card">
        <p class="qr-label">Scan to enter the raffle</p>
        <canvas id="raffle-qr"></canvas>
        <p class="qr-url">${escapeHtml(raffleUrl)}</p>
        <button type="button" id="copy-raffle-url" class="link-secondary">Copy URL</button>
      </section>

      <section class="stats" id="stats-block">
        <div class="stat"><span class="num" id="stat-total">—</span><span class="lbl">Entries</span></div>
        <div class="stat"><span class="num" id="stat-eligible">—</span><span class="lbl">Eligible</span></div>
        <div class="stat"><span class="num" id="stat-drawn">—</span><span class="lbl">Winners</span></div>
        <div class="stat"><span class="num" id="stat-apprentice">—</span><span class="lbl">Apprentice ⚑</span></div>
      </section>

      <section class="prize-ladder" id="prize-ladder">
        <h2>Prizes</h2>
        <div id="ladder-body"><p class="ladder-empty">Loading prizes…</p></div>
      </section>
      <p id="action-status" role="status" aria-live="polite"></p>

      <section class="actions">
        <a class="action wheel" href="${wheelHostUrl}" target="_blank" rel="noopener">🎡 Open the wheel (host)</a>
        <a class="action wheel-view" href="${wheelViewerUrl}" target="_blank" rel="noopener">👀 Audience wheel</a>
        <a class="action poster" href="${rafflePosterUrl(base, slug!, key!)}" target="_blank" rel="noopener">🖨 Print raffle poster</a>
        <button type="button" id="export-action" class="action export" disabled>📥 Export entries (CSV)</button>
        <a class="action edit" href="${editUrl}">⚙️ Full edit page</a>
      </section>

      <section class="recent">
        <h2>Recent entries</h2>
        <ul id="recent-list"><li class="empty">Waiting for entries…</li></ul>
      </section>
    `;
  }

  async function refresh() {
    try {
      // Pull entries + prizes in parallel.
      const [eRes, pRes] = await Promise.all([
        callFunction('manage-raffle', { slug, edit_token: key, action: 'list' }),
        callFunction('manage-raffle', { slug, edit_token: key, action: 'list_prizes' }),
      ]);
      entriesCache = (eRes.entries || []) as Entry[];
      prizesCache = (pRes.prizes || []) as Prize[];
      const entries = entriesCache;
      const total = entries.length;
      const drawn = entries.filter((e) => e.drawn).length;
      const eligible = total - drawn;
      const apprentice = entries.filter((e) => e.apprentice_optin).length;

      document.getElementById('stat-total')!.textContent = String(total);
      document.getElementById('stat-eligible')!.textContent = String(eligible);
      document.getElementById('stat-drawn')!.textContent = String(drawn);
      document.getElementById('stat-apprentice')!.textContent = String(apprentice);

      renderLadder(eligible);
      const exportBtn = document.getElementById('export-action') as HTMLButtonElement;
      exportBtn.disabled = total === 0;
      exportBtn.title = total === 0 ? 'Nothing to export' : `Download ${total} entries as CSV`;

      const recent = entries.slice(0, 8);
      const recentEl = document.getElementById('recent-list')!;
      if (recent.length === 0) {
        recentEl.innerHTML = '<li class="empty">No entries yet — share the QR.</li>';
      } else {
        recentEl.innerHTML = recent.map((e) => {
          const tags: string[] = [];
          if (e.drawn) tags.push('<span class="tag won">🏆 won</span>');
          if (e.apprentice_optin) tags.push('<span class="tag appr">⚑</span>');
          return `
            <li>
              <strong>${escapeHtml(e.name)}</strong>
              <span class="meta">${e.risk_score ?? 0}/3 · ${escapeHtml(fmtTime(e.submitted_at))}</span>
              ${tags.join(' ')}
            </li>`;
        }).join('');
      }
    } catch (err) {
      const msg = (err as Error).message;
      const status = document.getElementById('action-status');
      if (status) {
        status.textContent = msg.includes('403') ? 'Invalid edit link.' : msg;
        status.className = 'err';
      }
    }
  }

  function escapeAttr(s: string): string {
    return s.replace(/"/g, '&quot;');
  }

  function renderLadder(eligible: number) {
    const body = document.getElementById('ladder-body');
    if (!body) return;
    if (prizesCache.length === 0) {
      body.innerHTML = `
        <p class="ladder-empty">
          No prizes defined yet.
          <a href="${escapeAttr(editUrl)}#raffle" target="_blank" rel="noopener">Add prizes on the edit page →</a>
        </p>`;
      return;
    }
    // Sort: spot prizes first (display_order), grand last regardless.
    const sorted = [...prizesCache].sort((a, b) => {
      if (a.is_grand !== b.is_grand) return a.is_grand ? 1 : -1;
      return 0; // server already returned in display_order
    });
    body.innerHTML = sorted.map((p) => {
      const qty = p.quantity || 1;
      const drawn = p.drawn_count || 0;
      const remaining = Math.max(0, qty - drawn);
      const latestWinner = p.drawn_winner_id
        ? (entriesCache.find((e) => e.id === p.drawn_winner_id)?.name || '(winner)')
        : null;
      const allDrawn = drawn >= qty;
      const drawDisabled = !allDrawn && eligible === 0;
      // Buttons: Draw is shown until all are drawn; Re-draw is shown
      // whenever there's a latest winner (lets the host fix a no-show
      // at any point — final draw or any mid-stream one).
      const drawBtn = !allDrawn
        ? `<button type="button" class="ladder-btn draw ${p.is_grand ? 'grand' : ''}" data-prize-id="${escapeAttr(p.id)}" data-prize-name="${escapeHtml(p.name)}" data-is-grand="${p.is_grand ? '1' : '0'}" ${drawDisabled ? 'disabled' : ''}>${p.is_grand ? '🏆 DRAW GRAND' : (drawn > 0 ? `🎲 Draw next (${remaining} left)` : '🎲 Draw')}</button>`
        : '';
      const redrawBtn = latestWinner
        ? `<button type="button" class="ladder-btn redraw" data-prize-id="${escapeAttr(p.id)}" data-prize-name="${escapeHtml(p.name)}">↻ Re-draw last</button>`
        : '';
      // Status line: "✓ Sara (1 of 3)" mid-stream, "✓ All drawn" when done,
      // "— not drawn yet" when fresh. Plural-aware.
      let statusLine = '<span class="ladder-pending">— not drawn yet</span>';
      if (drawn > 0 && !allDrawn) {
        statusLine = `<span class="ladder-winner">✓ ${escapeHtml(latestWinner || '(winner)')} <span class="ladder-progress">(${drawn} of ${qty})</span></span>`;
      } else if (allDrawn) {
        statusLine = qty > 1
          ? `<span class="ladder-winner">✓ All ${qty} drawn (latest: ${escapeHtml(latestWinner || '(winner)')})</span>`
          : `<span class="ladder-winner">✓ ${escapeHtml(latestWinner || '(winner)')}</span>`;
      }
      return `
        <div class="ladder-row ${p.is_grand ? 'is-grand' : ''}">
          ${p.photo_url
            ? `<img class="ladder-thumb" src="${escapeHtml(p.photo_url)}" alt="" />`
            : '<div class="ladder-thumb empty"></div>'}
          <div class="ladder-info">
            <strong>${escapeHtml(p.name)}${qty > 1 ? ` <span class="ladder-qty">× ${qty}</span>` : ''}${p.is_grand ? ' <span class="ladder-grand">GRAND</span>' : ''}</strong>
            ${statusLine}
          </div>
          <div class="ladder-action">${drawBtn}${redrawBtn}</div>
        </div>`;
    }).join('');
  }

  function subscribeRealtime() {
    const cfg = getConfig();
    if (!cfg.url || !cfg.anonKey) return;
    const client = createClient(cfg.url, cfg.anonKey);
    realtimeChannel = client.channel(`raffle:${slug}`, {
      config: { broadcast: { self: false } },
    });
    realtimeChannel.subscribe();
  }

  function broadcastSpin(
    winner: { id: string; name: string; prize_won: string | null; prize_id: string | null },
    prize: Prize | null,
  ) {
    if (!realtimeChannel) return;
    const firstName = (winner.name || '').trim().split(/\s+/)[0] || 'Anon';
    realtimeChannel.send({
      type: 'broadcast', event: 'spin',
      payload: {
        winner_id: winner.id,
        winner_first_name: firstName,
        winner_prize: winner.prize_won,
        prize_id: winner.prize_id,
        prize_name: prize?.name || winner.prize_won || null,
        is_grand: !!prize?.is_grand,
        duration_ms: prize?.is_grand ? SPIN_DURATION_MS_GRAND : SPIN_DURATION_MS,
      },
    });
  }

  async function drawForPrize(prizeId: string, prizeName: string, isGrand: boolean) {
    const status = document.getElementById('action-status')!;
    const labelPrefix = isGrand ? '🏆 GRAND PRIZE: ' : '';
    if (!confirm(`Draw a random winner for ${labelPrefix}${prizeName}?\n\nThis broadcasts to every connected wheel page so attendees see the spin live.`)) return;
    status.textContent = `Drawing for ${prizeName}…`;
    status.className = '';
    try {
      const res = await callFunction('manage-raffle', {
        slug, edit_token: key, action: 'draw', prize_id: prizeId,
      });
      const winner = res.winner;
      const prize = (res.prize as Prize | null) || prizesCache.find((p) => p.id === prizeId) || null;
      broadcastSpin(winner, prize);
      status.textContent = `🏆 ${winner.name} won ${prizeName}`;
      status.className = 'ok';
      await refresh();
    } catch (err) {
      status.textContent = (err as Error).message;
      status.className = 'err';
    }
  }

  async function redrawPrize(prizeId: string, prizeName: string) {
    const status = document.getElementById('action-status')!;
    if (!confirm(`Re-draw the winner for "${prizeName}"?\n\nThe current winner will be returned to the eligible pool, then a new winner will be picked. Use this when a winner isn't in the room.`)) return;
    status.textContent = `Re-drawing ${prizeName}…`;
    status.className = '';
    try {
      const res = await callFunction('manage-raffle', {
        slug, edit_token: key, action: 'redraw_prize', prize_id: prizeId,
      });
      const winner = res.winner;
      const prize = (res.prize as Prize | null) || prizesCache.find((p) => p.id === prizeId) || null;
      broadcastSpin(winner, prize);
      status.textContent = `🏆 New winner for ${prizeName}: ${winner.name}`;
      status.className = 'ok';
      await refresh();
    } catch (err) {
      status.textContent = (err as Error).message;
      status.className = 'err';
    }
  }

  function wireActions() {
    const status = document.getElementById('action-status')!;
    // Ladder is event-delegated since it re-renders every refresh.
    document.getElementById('ladder-body')!.addEventListener('click', async (clickEv) => {
      const target = (clickEv.target as HTMLElement).closest('button.ladder-btn') as HTMLButtonElement | null;
      if (!target || target.disabled) return;
      const prizeId = target.getAttribute('data-prize-id') || '';
      const prizeName = target.getAttribute('data-prize-name') || '';
      const isGrand = target.getAttribute('data-is-grand') === '1';
      target.disabled = true;
      try {
        if (target.classList.contains('draw')) {
          await drawForPrize(prizeId, prizeName, isGrand);
        } else if (target.classList.contains('redraw')) {
          await redrawPrize(prizeId, prizeName);
        }
      } finally {
        target.disabled = false;
      }
    });
    document.getElementById('copy-raffle-url')!.addEventListener('click', async () => {
      await navigator.clipboard.writeText(raffleUrl);
      const btn = document.getElementById('copy-raffle-url') as HTMLButtonElement;
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => (btn.textContent = orig), 1200);
    });
    document.getElementById('export-action')!.addEventListener('click', () => {
      const csv = buildRaffleEntriesCsv(entriesCache);
      const stamp = new Date().toISOString().slice(0, 10);
      downloadCsv(`raffle-entries-${slug}-${stamp}.csv`, csv);
    });
  }
</script>

<style is:global>
  :root { --accent: #f39c12; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: #1a252f; color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  body { padding: 18px 14px 40px; line-height: 1.4; }
  main.live-main { max-width: 640px; margin: 0 auto; }

  .top { text-align: center; margin-bottom: 18px; }
  .top .eyebrow {
    font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--accent); font-weight: 700; margin-bottom: 6px;
  }
  .top h1 { font-size: 24px; }
  .top .status-line { font-size: 13px; color: #bdc3c7; margin-top: 8px; }
  .status-pill {
    display: inline-block; padding: 2px 10px; border-radius: 12px;
    font-size: 11px; font-weight: 800; letter-spacing: 1px;
  }
  .status-pill.open  { background: rgba(46,204,113,0.18); color: #2ecc71; }
  .status-pill.closed { background: rgba(255,255,255,0.06); color: #95a5a6; }

  .qr-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px; padding: 16px;
    text-align: center; margin-bottom: 14px;
  }
  .qr-card .qr-label {
    font-size: 12px; color: #95a5a6;
    text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px;
  }
  .qr-card canvas {
    display: block; margin: 0 auto 10px;
    background: #1a252f; border-radius: 6px;
  }
  .qr-card .qr-url {
    font-size: 12px; color: #ecf0f1; word-break: break-all;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    margin-bottom: 8px;
  }
  .qr-card button {
    padding: 8px 14px; font-size: 12px; font-weight: 700;
    background: rgba(255,255,255,0.08); color: #ecf0f1;
    border: 1px solid rgba(255,255,255,0.15); border-radius: 6px;
    cursor: pointer;
  }

  .stats {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px;
    margin-bottom: 14px;
  }
  .stat {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    padding: 12px 6px;
    text-align: center;
  }
  .stat .num {
    display: block; color: var(--accent);
    font-size: 28px; font-weight: 800; line-height: 1.1;
  }
  .stat .lbl {
    display: block; color: #95a5a6;
    font-size: 10px; text-transform: uppercase;
    letter-spacing: 1px; margin-top: 4px;
  }

  /* Prize ladder — one row per defined prize. Spot prizes first,
     grand prize last with a gold treatment. The "🎲 Draw" button on
     each row is what the host picks during the event to launch a
     wheel spin for that specific prize. */
  .prize-ladder {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px; padding: 14px 16px;
    margin-bottom: 14px;
  }
  .prize-ladder h2 {
    font-size: 11px; color: #95a5a6;
    text-transform: uppercase; letter-spacing: 1.5px;
    margin-bottom: 12px;
  }
  .ladder-row {
    display: grid;
    grid-template-columns: 48px 1fr auto;
    gap: 10px; align-items: center;
    padding: 8px 10px; margin-bottom: 6px;
    border-radius: 8px;
    background: rgba(0,0,0,0.20);
    border: 1px solid rgba(255,255,255,0.06);
  }
  .ladder-row:last-child { margin-bottom: 0; }
  .ladder-row.is-grand {
    background: rgba(243,156,18,0.08);
    border-color: rgba(243,156,18,0.45);
  }
  .ladder-thumb {
    width: 48px; height: 48px; border-radius: 6px;
    object-fit: cover; background: rgba(0,0,0,0.4);
  }
  .ladder-thumb.empty { border: 1px dashed rgba(255,255,255,0.14); }
  .ladder-info { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .ladder-info strong {
    color: #ecf0f1; font-size: 14px; font-weight: 700;
    overflow-wrap: anywhere;
  }
  .ladder-grand {
    display: inline-block;
    font-size: 9px; font-weight: 800; letter-spacing: 1px;
    padding: 1px 6px; border-radius: 999px;
    background: rgba(243,156,18,0.20); color: var(--accent);
    border: 1px solid rgba(243,156,18,0.5);
    margin-left: 4px;
  }
  .ladder-qty {
    display: inline-block;
    font-size: 11px; font-weight: 700; letter-spacing: 0.3px;
    padding: 1px 6px; border-radius: 6px;
    background: rgba(255,255,255,0.08); color: #ecf0f1;
    border: 1px solid rgba(255,255,255,0.14);
    margin-left: 4px;
  }
  .ladder-winner { color: #2ecc71; font-size: 12px; font-weight: 700; }
  .ladder-progress { color: #ecf0f1; font-weight: 600; opacity: 0.75; }
  .ladder-pending { color: #95a5a6; font-size: 12px; font-style: italic; }
  /* Stack Draw + Redraw vertically when both are present (multi-quantity
     mid-stream). Single-button cases display unchanged. */
  .ladder-action { display: flex; flex-direction: column; gap: 4px; align-items: stretch; }
  .ladder-action button.ladder-btn {
    padding: 9px 14px; font-size: 12px; font-weight: 800;
    border-radius: 6px; cursor: pointer;
    font-family: inherit;
    border: 1px solid rgba(255,255,255,0.10);
    background: rgba(255,255,255,0.06); color: #ecf0f1;
  }
  .ladder-action button.ladder-btn.draw {
    background: var(--accent); color: #1a252f; border-color: var(--accent);
  }
  .ladder-action button.ladder-btn.draw.grand {
    background: #f1c40f;
    border-color: #f1c40f;
    color: #1a252f;
    box-shadow: 0 0 10px rgba(241,196,15,0.4);
    font-size: 13px;
  }
  .ladder-action button.ladder-btn:disabled { opacity: 0.45; cursor: not-allowed; }
  .ladder-action button.ladder-btn.redraw {
    background: rgba(255,255,255,0.06);
    color: #95a5a6;
  }
  .ladder-empty { color: #95a5a6; font-style: italic; text-align: center; padding: 12px 0; font-size: 13px; }
  .ladder-empty a { color: var(--accent); text-decoration: none; font-weight: 700; }

  .actions {
    display: grid; gap: 8px; margin-bottom: 8px;
  }
  .action {
    display: block; padding: 14px;
    text-align: center; text-decoration: none;
