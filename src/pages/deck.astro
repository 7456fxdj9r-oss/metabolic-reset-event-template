---
// Projector slide deck — full-screen, dark background, one slide at a
// time driven by agenda items. The presenter's phone (deck-console.astro)
// drives navigation over Supabase realtime; this page is read-only except
// for keyboard arrow keys as a self-piloting fallback.
//
// Slides:
//   0           — cover slide (event name + date + location)
//   1..N        — agenda items in display_order
//
// Speaker photo resolution: case-insensitive EXACT match of
// agenda.speaker against speakers.name. Mismatches render a "section"
// slide layout (no photo) with just the segment title and time.
import Base from '../layouts/Base.astro';
---
<Base title="Slide deck">
  <main class="deck" id="deck-root">
    <p class="loading">Loading slide deck…</p>
  </main>
</Base>

<script>
  import { fetchEventBySlug, fetchSpeakers, fetchAgendaItems, callFunction, getConfig } from '../lib/supabase.js';
  import { createClient } from '@supabase/supabase-js';
  import { escapeHtml } from '../lib/html.js';

  type Speaker = {
    id: string; name: string;
    photo_url: string | null;
    bio: string | null;
  };
  type AgendaItem = {
    id: string;
    time_label: string;
    segment: string;
    speaker: string | null;
    details: string | null;
    duration_minutes: number;
    display_order: number;
  };
  type AgendaSlide = {
    id: string;
    agenda_item_id: string;
    title: string;
    body: string | null;
    image_url: string | null;
    display_order: number;
  };
  type Slide =
    | { kind: 'cover'; eventName: string; dateText: string; location: string | null }
    | { kind: 'speaker'; item: AgendaItem; speaker: Speaker }
    | { kind: 'multi'; item: AgendaItem; speakers: Speaker[] }
    | { kind: 'section'; item: AgendaItem }
    | { kind: 'content'; slide: AgendaSlide };

  const root = document.getElementById('deck-root')!;
  const params = new URLSearchParams(window.location.search);
  const slug = params.get('slug');
  const key = params.get('key');


  function fmtEventDate(d: string | null): string {
    if (!d) return '';
    const dt = new Date(d + 'T00:00:00');
    if (isNaN(dt.getTime())) return d;
    return dt.toLocaleDateString(undefined, {
      weekday: 'long', month: 'long', day: 'numeric', year: 'numeric',
    });
  }

  // Group-of-everyone placeholders that the host might type into an
  // agenda item's speaker field for breaks, mingles, raffles, etc.
  // Audience-facing section slides suppress these (they read as
  // chrome to attendees); the editor and cue sheet keep them so the
  // host can still see who's "owning" the segment.
  const GROUP_PLACEHOLDERS = new Set(['all', 'everyone', 'everybody', 'team', 'all team', 'group']);
  function isGroupPlaceholder(text: string | null): boolean {
    if (!text) return true;
    return GROUP_PLACEHOLDERS.has(text.trim().toLowerCase());
  }

  if (!slug || !key) {
    root.innerHTML = '<p class="loading err">Missing slug or key — open this from the edit page.</p>';
  } else {
    (async () => {
      try {
        const event = await fetchEventBySlug(slug);
        if (!event) {
          root.innerHTML = '<p class="loading err">Event not found.</p>';
          return;
        }
        document.title = `Slide deck — ${event.name}`;
        const accent = event.accent_color || '#f39c12';
        document.documentElement.style.setProperty('--accent', accent);

        const [speakers, agenda, subSlidesRes] = await Promise.all([
          fetchSpeakers(event.id) as Promise<Speaker[]>,
          fetchAgendaItems(event.id) as Promise<AgendaItem[]>,
          // Sub-slides are host-only data — fetch via the auth-gated
          // edge function. Non-fatal: missing sub-slides leave the deck
          // working with just the agenda items.
          callFunction('manage-agenda-slides', { slug, edit_token: key, action: 'list' })
            .catch(() => ({ slides: [] as AgendaSlide[] })),
        ]);
        const subSlidesByParent: Record<string, AgendaSlide[]> = {};
        for (const s of ((subSlidesRes.slides as AgendaSlide[]) || [])) {
          (subSlidesByParent[s.agenda_item_id] ||= []).push(s);
        }
        // Within each parent, ensure sub-slides are in display_order.
        for (const arr of Object.values(subSlidesByParent)) {
          arr.sort((a, b) => a.display_order - b.display_order);
        }

        // Resolve which speakers appear in an agenda item's free-text
        // speaker field. Strict-exact match against a speaker's full name
        // wins (one slide = one big photo). When the text instead mentions
        // 2+ speakers by first name (e.g. "Sarah & Nicole", "Matt or Tasha
        // (with Annie & Rhonda)") we surface all of them as a multi-photo
        // slide. Photo-less placeholder tiles render when a matched
        // speaker has no photo yet.
        function findMatchingSpeakers(agendaText: string | null): Speaker[] {
          if (!agendaText) return [];
          const text = agendaText.toLowerCase();
          // Exact-full-name takes priority: matches the historical strict
          // rule, used for items where the editor's autocomplete picked a
          // single speaker.
          for (const sp of speakers) {
            if (sp.name && sp.name.trim().toLowerCase() === text.trim()) {
              return [sp];
            }
          }
          // Otherwise scan each speaker's first name as a whole word.
          // Compound entries like "Rhonda & Craig Lauritzen" use "Rhonda"
          // as the first word, so they match when an agenda item mentions
          // Rhonda but not when it mentions only Craig.
          const matches: Speaker[] = [];
          const seen = new Set<string>();
          for (const sp of speakers) {
            if (!sp.name) continue;
            const firstWord = sp.name.trim().split(/\s+/)[0]?.replace(/[^a-zA-Z0-9]/g, '') || '';
            if (!firstWord) continue;
            const re = new RegExp(`\\b${firstWord.toLowerCase()}\\b`, 'i');
            if (re.test(text) && !seen.has(sp.id)) {
              matches.push(sp);
              seen.add(sp.id);
            }
          }
          return matches;
        }

        // Slide list: cover, then for each agenda item the auto-built
        // primary slide (speaker / multi / section) followed by any
        // sub-slides attached to that item in display_order. Flat list
        // so the existing index-based navigation just works.
        const slides: Slide[] = [
          {
            kind: 'cover',
            eventName: event.name,
            dateText: fmtEventDate(event.event_date),
            location: event.host_line || null,
          },
        ];
        for (const it of agenda) {
          const matched = findMatchingSpeakers(it.speaker);
          if (matched.length === 1) {
            slides.push({ kind: 'speaker', item: it, speaker: matched[0] });
          } else if (matched.length >= 2) {
            slides.push({ kind: 'multi', item: it, speakers: matched });
          } else {
            slides.push({ kind: 'section', item: it });
          }
          for (const sub of (subSlidesByParent[it.id] || [])) {
            slides.push({ kind: 'content', slide: sub });
          }
        }

        let currentIndex = 0;

        function renderSlide(): void {
          const slide = slides[currentIndex];
          let body = '';
          if (slide.kind === 'cover') {
            // Suppress the location line when its first word already
            // appears in the event title (avoids "Foo Event - Portland"
            // + "📍 Portland, OR" repetition).
            const titleLower = slide.eventName.toLowerCase();
            const locFirstWord = slide.location?.split(/[,\s]+/)[0]?.trim().toLowerCase() || '';
            const showLocation = !!slide.location && !!locFirstWord && !titleLower.includes(locFirstWord);
            body = `
              <div class="slide cover-slide">
                <p class="cover-kicker">Welcome to</p>
                <h1 class="cover-title">${escapeHtml(slide.eventName)}</h1>
                ${slide.dateText ? `<p class="cover-date">${escapeHtml(slide.dateText)}</p>` : ''}
                ${showLocation ? `<p class="cover-loc">📍 ${escapeHtml(slide.location)}</p>` : ''}
                <p class="cover-cta">Starting soon…</p>
              </div>`;
          } else if (slide.kind === 'speaker') {
            const sp = slide.speaker;
            const it = slide.item;
            const photo = sp.photo_url
              ? `<img class="speaker-photo" src="${escapeHtml(sp.photo_url)}" alt="${escapeHtml(sp.name)}" />`
              : '<div class="speaker-photo empty">📷</div>';
            body = `
              <div class="slide speaker-slide">
                ${photo}
                <div class="speaker-meta">
                  <h2 class="speaker-name">${escapeHtml(sp.name)}</h2>
                  <p class="speaker-topic">${escapeHtml(it.segment)}</p>
                </div>
              </div>`;
          } else if (slide.kind === 'multi') {
            const it = slide.item;
            const tiles = slide.speakers.map((sp) => {
              const ph = sp.photo_url
                ? `<img class="multi-photo" src="${escapeHtml(sp.photo_url)}" alt="${escapeHtml(sp.name)}" />`
                : '<div class="multi-photo empty">📷</div>';
              return `
                <div class="multi-tile">
                  ${ph}
                  <p class="multi-name">${escapeHtml(sp.name)}</p>
                </div>`;
            }).join('');
            body = `
              <div class="slide multi-slide" data-count="${slide.speakers.length}">
                <div class="multi-tiles">${tiles}</div>
                <h2 class="multi-topic">${escapeHtml(it.segment)}</h2>
              </div>`;
          } else if (slide.kind === 'content') {
            // Sub-slide: optional title + optional body + optional image.
            // When an image is present, the image is the hero — title and
            // body stack below it (no overlay). Text-only slides center
            // their title + body.
            const s = slide.slide;
            const hasImage = !!s.image_url;
            const hasBody = !!s.body;
            const hasTitle = !!(s.title && s.title.trim());
            const titleHtml = hasTitle ? `<h2 class="content-title">${escapeHtml(s.title)}</h2>` : '';
            const bodyHtml = hasBody ? `<p class="content-body">${escapeHtml(s.body!)}</p>` : '';
            if (hasImage) {
              // PDFs render via <embed type="application/pdf"> so the
              // projector shows the first page (most browsers display
              // an inline scroll-through too — the presenter can use
              // arrow keys / trackpad to flip pages mid-slide).
              const isPdf = /\.pdf(\?|$)/i.test(s.image_url!);
              const media = isPdf
                ? `<embed class="content-image content-pdf" src="${escapeHtml(s.image_url!)}#view=FitH&toolbar=0&navpanes=0" type="application/pdf" />`
                : `<img class="content-image" src="${escapeHtml(s.image_url!)}" alt="" />`;
              body = `
                <div class="slide content-slide layout-stacked">
                  ${media}
                  ${titleHtml}
                  ${bodyHtml}
                </div>`;
            } else {
              body = `
                <div class="slide content-slide layout-text">
                  ${titleHtml}
                  ${bodyHtml}
                </div>`;
            }
          } else {
            const it = slide.item;
            const showLead = it.speaker && !isGroupPlaceholder(it.speaker);
            body = `
              <div class="slide section-slide">
                <h2 class="section-title">${escapeHtml(it.segment)}</h2>
                ${showLead ? `<p class="section-lead">${escapeHtml(it.speaker)}</p>` : ''}
              </div>`;
          }
          root.innerHTML = `
            <div class="accent-stripe"></div>
            ${body}`;
        }

        function setIndex(i: number): void {
          const clamped = Math.max(0, Math.min(slides.length - 1, i));
          if (clamped === currentIndex) return;
          currentIndex = clamped;
          renderSlide();
        }

        renderSlide();

        // Keyboard fallback: arrow keys / space drive the slide locally
        // so the projector laptop can self-pilot if the presenter's phone
        // controller is unavailable.
        document.addEventListener('keydown', (ev) => {
          if (ev.key === 'ArrowRight' || ev.key === ' ' || ev.key === 'PageDown') {
            ev.preventDefault();
            setIndex(currentIndex + 1);
          } else if (ev.key === 'ArrowLeft' || ev.key === 'PageUp') {
            ev.preventDefault();
            setIndex(currentIndex - 1);
          } else if (ev.key === 'Home') {
            ev.preventDefault();
            setIndex(0);
          } else if (ev.key === 'End') {
            ev.preventDefault();
            setIndex(slides.length - 1);
          }
        });

        // Realtime: listen for advance events from deck-console.
        // Channel name mirrors raffle:<slug> for the wheel.
        const cfg = getConfig();
        if (cfg.url && cfg.anonKey) {
          const client = createClient(cfg.url, cfg.anonKey);
          const channel = client.channel(`deck:${slug}`, {
            config: { broadcast: { self: false } },
          });
          channel.on('broadcast', { event: 'advance' }, ({ payload }) => {
            if (typeof payload?.index === 'number') setIndex(payload.index);
          });
          channel.subscribe();
        }
      } catch (err) {
        root.innerHTML = `<p class="loading err">${escapeHtml((err as Error).message)}</p>`;
      }
    })();
  }
</script>

<style is:global>
  :root { --accent: #f39c12; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: #1a252f; color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    overflow: hidden;
  }
  html, body { height: 100%; }
  main.deck {
    width: 100vw; height: 100vh;
    display: flex; align-items: center; justify-content: center;
    padding: 0;
    position: relative;
  }
  .accent-stripe {
    position: absolute; top: 0; left: 0; right: 0;
    height: 8px; background: var(--accent);
  }

  /* Slide content lives inside .slide regardless of kind */
  .slide {
    max-width: 1400px;
    width: 100%;
    padding: 5vh 6vw;
    text-align: center;
  }

  /* Cover slide */
  .cover-slide { display: flex; flex-direction: column; gap: 18px; }
  .cover-kicker {
    font-size: clamp(14px, 2vh, 22px);
    letter-spacing: 6px; text-transform: uppercase;
    color: var(--accent); font-weight: 700;
  }
  .cover-title {
    font-size: clamp(40px, 8vh, 96px);
    line-height: 1.05; font-weight: 900;
    letter-spacing: -1px;
    color: #fff;
  }
  .cover-date {
    font-size: clamp(18px, 3vh, 32px);
    color: #ecf0f1; font-weight: 600;
    margin-top: 8px;
  }
  .cover-loc {
    font-size: clamp(16px, 2.4vh, 26px);
    color: #95a5a6;
  }
  .cover-cta {
    margin-top: 40px;
    font-size: clamp(16px, 2.4vh, 24px);
    color: var(--accent);
    letter-spacing: 4px; text-transform: uppercase; font-weight: 700;
  }

  /* Speaker slide: photo left, text right on landscape; stacked on narrow */
  .speaker-slide {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.3fr);
    align-items: center;
    gap: clamp(20px, 5vw, 80px);
  }
  .speaker-photo {
    width: 100%; max-width: 480px;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 24px;
    background: rgba(255,255,255,0.05);
    box-shadow: 0 20px 60px rgba(0,0,0,0.6);
    justify-self: end;
  }
  .speaker-photo.empty {
    display: flex; align-items: center; justify-content: center;
    font-size: 80px; color: rgba(255,255,255,0.25);
    border: 2px dashed rgba(255,255,255,0.15);
  }
  .speaker-meta { text-align: left; min-width: 0; }
  .speaker-name {
    font-size: clamp(32px, 6vh, 64px);
    font-weight: 900; line-height: 1.1; letter-spacing: -1px;
    color: #fff; margin-bottom: 14px;
    overflow-wrap: anywhere;
  }
  .speaker-topic {
    font-size: clamp(20px, 3.6vh, 40px);
    color: var(--accent); font-weight: 700; line-height: 1.2;
    overflow-wrap: anywhere;
  }
  @media (max-width: 900px), (orientation: portrait) {
    .speaker-slide { grid-template-columns: 1fr; gap: 30px; }
    .speaker-photo { justify-self: center; max-width: 50vh; }
    .speaker-meta { text-align: center; }
  }

  /* Multi-speaker slide: photos + names in a row, with time + topic
     above and below. Auto-shrinks photos for 3+ speakers. */
  .multi-slide {
    display: flex; flex-direction: column;
    align-items: center;
    gap: clamp(16px, 3vh, 30px);
  }
  .multi-tiles {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: clamp(14px, 2.5vw, 36px);
    width: 100%;
    max-width: 1100px;
    align-items: start; justify-items: center;
  }
  /* When there are exactly 2 speakers, force them side-by-side at
     larger sizes (avoids auto-fit stacking on widescreen projectors). */
  .multi-slide[data-count="2"] .multi-tiles {
    grid-template-columns: repeat(2, minmax(0, 320px));
    justify-content: center;
  }
  .multi-tile {
    /* Photo row + name row (uniform height) keeps photos aligned even
       when some names wrap to 2 lines (e.g. "Annie & David Burgeson"). */
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 10px;
    width: 100%;
    max-width: 320px;
    justify-items: center;
  }
  .multi-photo {
    width: 100%; aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 16px;
    background: rgba(255,255,255,0.05);
    box-shadow: 0 12px 30px rgba(0,0,0,0.5);
  }
  .multi-photo.empty {
    display: flex; align-items: center; justify-content: center;
    font-size: 52px; color: rgba(255,255,255,0.25);
    border: 2px dashed rgba(255,255,255,0.15);
  }
  .multi-name {
    font-size: clamp(16px, 2.4vh, 28px);
    font-weight: 800; color: #fff;
    line-height: 1.2;
    overflow-wrap: anywhere; text-align: center;
  }
  .multi-topic {
    font-size: clamp(26px, 5.5vh, 56px);
    color: var(--accent); font-weight: 900;
    line-height: 1.1; letter-spacing: -1px;
    text-align: center;
    overflow-wrap: anywhere;
  }

  /* Content slide (presenter-built sub-slide after an agenda item) */
  .content-slide {
    width: 100%;
    text-align: center;
  }
  /* Stacked layout: big image on top, title and body below — clean,
     no overlay. Image dominates the slide so the eye lands there first
     and the text sits in its own breathing room underneath. */
  .content-slide.layout-stacked {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: clamp(14px, 2.4vh, 28px);
  }
  .content-slide.layout-stacked .content-image {
    max-width: 92vw;
    max-height: 72vh;
    object-fit: contain;
    border-radius: 16px;
    background: rgba(255,255,255,0.04);
    box-shadow: 0 12px 32px rgba(0,0,0,0.5);
  }
  /* When no text follows the image, let it claim more vertical room. */
  .content-slide.layout-stacked .content-image:last-child {
    max-height: 88vh;
  }
  /* PDF sub-slide: <embed> doesn't respect object-fit, so size the
     element directly. White background since PDFs are typically
     light-themed and our deck background is dark — looks crisper.
     Display the same dimensions an image would. */
  .content-slide.layout-stacked .content-pdf {
    width: 92vw;
    height: 72vh;
    background: #fff;
  }
  .content-slide.layout-stacked .content-pdf:last-child {
    height: 88vh;
  }
  .content-slide.layout-stacked .content-title {
    font-size: clamp(26px, 4.8vh, 48px);
    font-weight: 900; line-height: 1.15; letter-spacing: -0.5px;
    color: #fff;
    overflow-wrap: anywhere;
    max-width: 38em;
  }
  .content-slide.layout-stacked .content-body {
    font-size: clamp(16px, 2.4vh, 24px);
    color: #ecf0f1; line-height: 1.5;
    max-width: 40em;
    white-space: pre-wrap;
  }
  /* Text-only centered slide */
  .content-slide.layout-text {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    gap: 24px;
  }
  .content-slide.layout-text .content-title {
    font-size: clamp(38px, 7vh, 80px);
    font-weight: 900; line-height: 1.1; letter-spacing: -1px;
    color: var(--accent, #f39c12);
    overflow-wrap: anywhere;
  }
  .content-slide.layout-text .content-body {
    font-size: clamp(20px, 3vh, 32px);
    color: #ecf0f1; line-height: 1.5;
    max-width: 36em;
    white-space: pre-wrap;
  }

  /* Section slide (no matched speaker) */
  .section-slide { display: flex; flex-direction: column; gap: 18px; }
  .section-title {
    font-size: clamp(40px, 9vh, 110px);
    font-weight: 900; line-height: 1.05; letter-spacing: -1px;
    color: #fff;
  }
  .section-lead {
    font-size: clamp(20px, 3.2vh, 36px);
    color: var(--accent); font-weight: 700;
  }

  .loading { color: #95a5a6; padding: 60px 20px; text-align: center; font-size: 14px; }
  .loading.err { color: #e74c3c; }
</style>
