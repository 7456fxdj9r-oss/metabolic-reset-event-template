---
// Projector slide deck — full-screen, dark background, one slide at a
// time driven by agenda items. The presenter's phone (deck-console.astro)
// drives navigation over Supabase realtime; this page is read-only except
// for keyboard arrow keys as a self-piloting fallback.
//
// Slides:
//   0           — cover slide (event name + date + location)
//   1..N        — agenda items in display_order
//
// Speaker photo resolution: case-insensitive EXACT match of
// agenda.speaker against speakers.name. Mismatches render a "section"
// slide layout (no photo) with just the segment title and time.
import Base from '../layouts/Base.astro';
---
<Base title="Slide deck">
  <main class="deck" id="deck-root">
    <p class="loading">Loading slide deck…</p>
  </main>
</Base>

<script>
  import { fetchEventBySlug, fetchSpeakers, fetchAgendaItems, getConfig } from '../lib/supabase.js';
  import { createClient } from '@supabase/supabase-js';

  type Speaker = {
    id: string; name: string;
    photo_url: string | null;
    bio: string | null;
  };
  type AgendaItem = {
    id: string;
    time_label: string;
    segment: string;
    speaker: string | null;
    details: string | null;
    display_order: number;
  };
  type Slide =
    | { kind: 'cover'; eventName: string; dateText: string; location: string | null }
    | { kind: 'speaker'; item: AgendaItem; speaker: Speaker }
    | { kind: 'section'; item: AgendaItem };

  const root = document.getElementById('deck-root')!;
  const params = new URLSearchParams(window.location.search);
  const slug = params.get('slug');
  const key = params.get('key');

  function escapeHtml(s: unknown): string {
    return String(s ?? '').replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!)
    );
  }

  function fmtEventDate(d: string | null): string {
    if (!d) return '';
    const dt = new Date(d + 'T00:00:00');
    if (isNaN(dt.getTime())) return d;
    return dt.toLocaleDateString(undefined, {
      weekday: 'long', month: 'long', day: 'numeric', year: 'numeric',
    });
  }

  if (!slug || !key) {
    root.innerHTML = '<p class="loading err">Missing slug or key — open this from the edit page.</p>';
  } else {
    (async () => {
      try {
        const event = await fetchEventBySlug(slug);
        if (!event) {
          root.innerHTML = '<p class="loading err">Event not found.</p>';
          return;
        }
        document.title = `Slide deck — ${event.name}`;
        const accent = event.accent_color || '#f39c12';
        document.documentElement.style.setProperty('--accent', accent);

        const [speakers, agenda] = await Promise.all([
          fetchSpeakers(event.id) as Promise<Speaker[]>,
          fetchAgendaItems(event.id) as Promise<AgendaItem[]>,
        ]);

        // Build the slide list once. Speaker resolution is case-insensitive
        // exact match — the autocomplete in the agenda form makes this
        // reliable enough; mismatches degrade to a section slide.
        const speakerByName = new Map<string, Speaker>();
        for (const sp of speakers) {
          if (sp.name) speakerByName.set(sp.name.trim().toLowerCase(), sp);
        }
        const slides: Slide[] = [
          {
            kind: 'cover',
            eventName: event.name,
            dateText: fmtEventDate(event.event_date),
            location: event.host_line || null,
          },
          ...agenda.map((it) => {
            const sp = it.speaker
              ? speakerByName.get(it.speaker.trim().toLowerCase())
              : null;
            return sp
              ? { kind: 'speaker' as const, item: it, speaker: sp }
              : { kind: 'section' as const, item: it };
          }),
        ];

        let currentIndex = 0;

        function renderSlide(): void {
          const slide = slides[currentIndex];
          const total = slides.length;
          const hint = currentIndex === 0
            ? `slide 1 of ${total}`
            : `slide ${currentIndex + 1} of ${total}`;
          let body = '';
          if (slide.kind === 'cover') {
            // Suppress the location line when its first word already
            // appears in the event title (avoids "Foo Event - Portland"
            // + "📍 Portland, OR" repetition).
            const titleLower = slide.eventName.toLowerCase();
            const locFirstWord = slide.location?.split(/[,\s]+/)[0]?.trim().toLowerCase() || '';
            const showLocation = !!slide.location && !!locFirstWord && !titleLower.includes(locFirstWord);
            body = `
              <div class="slide cover-slide">
                <p class="cover-kicker">Welcome to</p>
                <h1 class="cover-title">${escapeHtml(slide.eventName)}</h1>
                ${slide.dateText ? `<p class="cover-date">${escapeHtml(slide.dateText)}</p>` : ''}
                ${showLocation ? `<p class="cover-loc">📍 ${escapeHtml(slide.location)}</p>` : ''}
                <p class="cover-cta">Starting soon…</p>
              </div>`;
          } else if (slide.kind === 'speaker') {
            const sp = slide.speaker;
            const it = slide.item;
            const photo = sp.photo_url
              ? `<img class="speaker-photo" src="${escapeHtml(sp.photo_url)}" alt="${escapeHtml(sp.name)}" />`
              : '<div class="speaker-photo empty">📷</div>';
            body = `
              <div class="slide speaker-slide">
                ${photo}
                <div class="speaker-meta">
                  <p class="speaker-time">${escapeHtml(it.time_label)}</p>
                  <h2 class="speaker-name">${escapeHtml(sp.name)}</h2>
                  <p class="speaker-topic">${escapeHtml(it.segment)}</p>
                </div>
              </div>`;
          } else {
            const it = slide.item;
            body = `
              <div class="slide section-slide">
                <p class="section-time">${escapeHtml(it.time_label)}</p>
                <h2 class="section-title">${escapeHtml(it.segment)}</h2>
                ${it.speaker ? `<p class="section-lead">${escapeHtml(it.speaker)}</p>` : ''}
              </div>`;
          }
          root.innerHTML = `
            <div class="accent-stripe"></div>
            ${body}
            <p class="slide-hint">
              <span class="hint-side">← prev</span>
              <span class="hint-count">${escapeHtml(hint)}</span>
              <span class="hint-side">next →</span>
            </p>`;
        }

        function setIndex(i: number): void {
          const clamped = Math.max(0, Math.min(slides.length - 1, i));
          if (clamped === currentIndex) return;
          currentIndex = clamped;
          renderSlide();
        }

        renderSlide();

        // Keyboard fallback: arrow keys / space drive the slide locally
        // so the projector laptop can self-pilot if the presenter's phone
        // controller is unavailable.
        document.addEventListener('keydown', (ev) => {
          if (ev.key === 'ArrowRight' || ev.key === ' ' || ev.key === 'PageDown') {
            ev.preventDefault();
            setIndex(currentIndex + 1);
          } else if (ev.key === 'ArrowLeft' || ev.key === 'PageUp') {
            ev.preventDefault();
            setIndex(currentIndex - 1);
          } else if (ev.key === 'Home') {
            ev.preventDefault();
            setIndex(0);
          } else if (ev.key === 'End') {
            ev.preventDefault();
            setIndex(slides.length - 1);
          }
        });

        // Realtime: listen for advance events from deck-console.
        // Channel name mirrors raffle:<slug> for the wheel.
        const cfg = getConfig();
        if (cfg.url && cfg.anonKey) {
          const client = createClient(cfg.url, cfg.anonKey);
          const channel = client.channel(`deck:${slug}`, {
            config: { broadcast: { self: false } },
          });
          channel.on('broadcast', { event: 'advance' }, ({ payload }) => {
            if (typeof payload?.index === 'number') setIndex(payload.index);
          });
          channel.subscribe();
        }
      } catch (err) {
        root.innerHTML = `<p class="loading err">${escapeHtml((err as Error).message)}</p>`;
      }
    })();
  }
</script>

<style is:global>
  :root { --accent: #f39c12; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: #1a252f; color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    overflow: hidden;
  }
  html, body { height: 100%; }
  main.deck {
    width: 100vw; height: 100vh;
    display: flex; align-items: center; justify-content: center;
    padding: 0;
    position: relative;
  }
  .accent-stripe {
    position: absolute; top: 0; left: 0; right: 0;
    height: 8px; background: var(--accent);
  }

  /* Slide content lives inside .slide regardless of kind */
  .slide {
    max-width: 1400px;
    width: 100%;
    padding: 5vh 6vw;
    text-align: center;
  }

  /* Cover slide */
  .cover-slide { display: flex; flex-direction: column; gap: 18px; }
  .cover-kicker {
    font-size: clamp(14px, 2vh, 22px);
    letter-spacing: 6px; text-transform: uppercase;
    color: var(--accent); font-weight: 700;
  }
  .cover-title {
    font-size: clamp(40px, 8vh, 96px);
    line-height: 1.05; font-weight: 900;
    letter-spacing: -1px;
    color: #fff;
  }
  .cover-date {
    font-size: clamp(18px, 3vh, 32px);
    color: #ecf0f1; font-weight: 600;
    margin-top: 8px;
  }
  .cover-loc {
    font-size: clamp(16px, 2.4vh, 26px);
    color: #95a5a6;
  }
  .cover-cta {
    margin-top: 40px;
    font-size: clamp(16px, 2.4vh, 24px);
    color: var(--accent);
    letter-spacing: 4px; text-transform: uppercase; font-weight: 700;
  }

  /* Speaker slide: photo left, text right on landscape; stacked on narrow */
  .speaker-slide {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.3fr);
    align-items: center;
    gap: clamp(20px, 5vw, 80px);
  }
  .speaker-photo {
    width: 100%; max-width: 480px;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 24px;
    background: rgba(255,255,255,0.05);
    box-shadow: 0 20px 60px rgba(0,0,0,0.6);
    justify-self: end;
  }
  .speaker-photo.empty {
    display: flex; align-items: center; justify-content: center;
    font-size: 80px; color: rgba(255,255,255,0.25);
    border: 2px dashed rgba(255,255,255,0.15);
  }
  .speaker-meta { text-align: left; min-width: 0; }
  .speaker-time {
    font-size: clamp(14px, 2vh, 22px);
    letter-spacing: 4px; text-transform: uppercase;
    color: var(--accent); font-weight: 700; margin-bottom: 12px;
  }
  .speaker-name {
    font-size: clamp(32px, 6vh, 64px);
    font-weight: 900; line-height: 1.1; letter-spacing: -1px;
    color: #fff; margin-bottom: 14px;
    overflow-wrap: anywhere;
  }
  .speaker-topic {
    font-size: clamp(20px, 3.6vh, 40px);
    color: var(--accent); font-weight: 700; line-height: 1.2;
    overflow-wrap: anywhere;
  }
  @media (max-width: 900px), (orientation: portrait) {
    .speaker-slide { grid-template-columns: 1fr; gap: 30px; }
    .speaker-photo { justify-self: center; max-width: 50vh; }
    .speaker-meta { text-align: center; }
  }

  /* Section slide (no matched speaker) */
  .section-slide { display: flex; flex-direction: column; gap: 18px; }
  .section-time {
    font-size: clamp(16px, 2.6vh, 28px);
    letter-spacing: 4px; text-transform: uppercase;
    color: var(--accent); font-weight: 700;
  }
  .section-title {
    font-size: clamp(40px, 9vh, 110px);
    font-weight: 900; line-height: 1.05; letter-spacing: -1px;
    color: #fff;
  }
  .section-lead {
    font-size: clamp(20px, 3.2vh, 36px);
    color: var(--accent); font-weight: 700;
  }

  /* Bottom hint — slide N of M with prev/next directional cues */
  .slide-hint {
    position: absolute; bottom: 14px; left: 0; right: 0;
    display: flex; justify-content: center; gap: 22px;
    font-size: 12px; letter-spacing: 3px; text-transform: uppercase;
    color: rgba(255,255,255,0.40); font-weight: 600;
  }
  .slide-hint .hint-side { opacity: 0.7; }
  .slide-hint .hint-count {
    color: var(--accent);
  }

  .loading { color: #95a5a6; padding: 60px 20px; text-align: center; font-size: 14px; }
  .loading.err { color: #e74c3c; }
</style>
