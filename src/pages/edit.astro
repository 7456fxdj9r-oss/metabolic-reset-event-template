  ul.hosts-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 8px; }
  .hosts-loading, .hosts-empty {
    color: #95a5a6; font-size: 13px; font-style: italic; padding: 8px 0;
  }
  .hosts-empty.err { color: #e74c3c; font-style: normal; }
  /* Co-host rows reuse the .t-row chassis (speakers/transformations); the
     extras below add the shareable-link strip and the master-only buttons. */
  .host-row .host-link { display: flex; gap: 6px; margin-top: 6px; }
  .host-link { display: flex; gap: 6px; }
  .host-link input {
    flex: 1; min-width: 0;
    background: rgba(0,0,0,0.3);
    border: 1px solid rgba(255,255,255,0.15);
