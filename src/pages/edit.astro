  /* ---------- Setup checklist (top of admin page) ---------- */
  .checklist-card {
    background: linear-gradient(135deg, rgba(243,156,18,0.06), rgba(0,0,0,0.20));
    border: 1px solid color-mix(in srgb, var(--accent) 35%, rgba(255,255,255,0.10));
  }
  .checklist-head {
    display: flex; align-items: center; justify-content: space-between;
    gap: 10px; flex-wrap: wrap;
    margin-bottom: 10px;
  }
  .checklist-head h2 {
    font-size: 16px; color: #ecf0f1;
    margin: 0; font-weight: 800;
    display: flex; align-items: center; flex-wrap: wrap; gap: 6px;
  }
  .checklist-count {
    font-size: 11px; letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--accent); font-weight: 700;
