  }

  /* ---------- Tour (Take a tour button) ---------- */
  .tour-overlay {
    position: fixed; inset: 0;
    z-index: 9000;
    pointer-events: none;
    animation: tour-fadein 0.2s ease-out;
  }
  @keyframes tour-fadein { from { opacity: 0; } to { opacity: 1; } }
  /* Spotlight uses an enormous outward box-shadow as a fake cutout —
     everything outside the highlighted element is dimmed by the shadow. */
  .tour-spotlight {
    position: fixed;
    pointer-events: none;
    border-radius: 12px;
    box-shadow: 0 0 0 100vmax rgba(0,0,0,0.70);
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    transition: top 0.35s ease, left 0.35s ease, width 0.35s ease, height 0.35s ease;
  }
  .tour-tooltip {
    position: fixed;
    pointer-events: auto;
    background: #1a252f;
    border: 2px solid var(--accent);
    border-radius: 12px;
    padding: 16px 18px;
    max-width: min(360px, calc(100vw - 24px));
    box-shadow: 0 16px 50px rgba(0,0,0,0.7);
    color: #ecf0f1;
    transition: top 0.35s ease, left 0.35s ease;
    z-index: 9100;
  }
  .tour-step-meta {
    font-size: 10px; letter-spacing: 2.5px; text-transform: uppercase;
    color: var(--accent); font-weight: 800;
    margin-bottom: 6px;
  }
  .tour-step-meta .tour-step-num {
    background: var(--accent); color: #1a252f;
    padding: 1px 6px; border-radius: 4px;
    margin-right: 2px;
  }
  .tour-title {
    font-size: 17px; font-weight: 800;
    color: #fff; margin-bottom: 8px;
    line-height: 1.2;
  }
  .tour-body {
    font-size: 13px; color: #ecf0f1;
    line-height: 1.55; margin-bottom: 14px;
  }
  .tour-actions {
    display: flex; gap: 8px; justify-content: flex-end;
    flex-wrap: wrap;
  }
  .tour-actions button {
    padding: 8px 14px; font-size: 12px; font-weight: 700;
    border-radius: 6px; cursor: pointer; border: none;
    font-family: inherit;
  }
  .tour-prev, .tour-skip {
    background: rgba(255,255,255,0.06);
    color: #ecf0f1;
    border: 1px solid rgba(255,255,255,0.14);
  }
  .tour-next {
    background: var(--accent); color: #1a252f;
  }
  .tour-prev:disabled { opacity: 0.4; cursor: not-allowed; }
  .tour-skip { margin-right: auto; }

  .card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 18px 18px 20px;
    margin-bottom: 16px;
  }
  /* Collapsible card shell — wraps each card's content at runtime via
     collapsifyCards(). The summary IS the card's heading row; clicking
     it toggles the body. Chevron indicates state. */
  details.card-shell { display: block; }
  details.card-shell > summary.card-summary {
    list-style: none;
    cursor: pointer;
    user-select: none;
    position: relative;
    padding-right: 28px;
    /* h2 inside already has margin-bottom; when collapsed there's
       nothing below it, so we squash that bottom margin away. */
  }
  details.card-shell > summary.card-summary::-webkit-details-marker { display: none; }
  details.card-shell > summary.card-summary::after {
    content: '▾';
    position: absolute; right: 4px; top: 6px;
    color: rgba(255,255,255,0.45);
    font-size: 12px;
    transition: transform 0.2s ease;
  }
  details.card-shell[open] > summary.card-summary::after {
    transform: rotate(180deg);
  }
  details.card-shell > summary.card-summary:hover::after {
    color: var(--accent, #f39c12);
  }
  /* Collapsed state — drop the h2's bottom margin so the card hugs the
     header. Expanded state keeps the existing spacing under the h2. */
  details.card-shell:not([open]) > summary.card-summary h2 {
    margin-bottom: 0;
  }
  .card h2 {
    font-size: 13px; color: #ecf0f1;
    text-transform: uppercase; letter-spacing: 1.5px;
    margin-bottom: 14px;
    display: flex; align-items: center; gap: 8px;
    flex-wrap: wrap;
  }
  /* Audience tag — at-a-glance "where does this show up?" pill that
     rides on each card's h2. Green = visible to attendees on the
     public event page; gray = host-only (cue sheet, day-of toolkit). */
  .audience-tag {
    font-size: 9px; font-weight: 700;
    letter-spacing: 1px;
    padding: 2px 7px; border-radius: 999px;
    background: rgba(46, 204, 113, 0.18);
    color: #2ecc71;
    border: 1px solid rgba(46, 204, 113, 0.4);
    text-transform: uppercase;
  }
  .audience-tag.host-only {
    background: rgba(149, 165, 166, 0.18);
    color: #95a5a6;
    border-color: rgba(149, 165, 166, 0.4);
  }
  .audience-tag.mixed {
    background: rgba(155, 89, 182, 0.18);
    color: #c39bd3;
    border-color: rgba(155, 89, 182, 0.5);
  }

  /* Section guide — collapsible "where does each section appear publicly"
     map at the top of the edit page. Closed by default to keep the page
     scannable; tapping summary opens it. */
  details.section-guide {
    background: rgba(243, 156, 18, 0.08);
    border: 1px solid rgba(243, 156, 18, 0.30);
    border-radius: 10px;
    padding: 12px 16px;
    margin-bottom: 18px;
  }
  details.section-guide > summary {
    cursor: pointer;
    font-size: 13px; font-weight: 700;
    color: var(--accent, #f39c12);
    list-style: none;
  }
  details.section-guide > summary::-webkit-details-marker { display: none; }
  details.section-guide > summary::after {
    content: ' ▾'; opacity: 0.6;
  }
  details.section-guide[open] > summary::after { content: ' ▴'; }
  .guide-body { margin-top: 12px; }
  .guide-intro {
    font-size: 13px; color: #ecf0f1; line-height: 1.55; margin-bottom: 10px;
  }
  .guide-intro em { color: var(--accent, #f39c12); font-style: normal; font-weight: 700; }
  ul.guide-list {
    list-style: none; padding: 0; margin: 0 0 12px;
    display: grid; gap: 8px;
  }
  ul.guide-list li {
    font-size: 13px; line-height: 1.55; color: #ecf0f1;
    padding: 8px 12px;
    background: rgba(0,0,0,0.20);
    border-radius: 6px;
  }
  ul.guide-list strong { color: #fff; }
  ul.guide-list em {
    font-style: italic; color: #2ecc71;
  }
  .guide-overlap {
    font-size: 12px; color: #bdc3c7; line-height: 1.55;
    background: rgba(0,0,0,0.20);
    border-left: 3px solid var(--accent, #f39c12);
    padding: 8px 12px;
    border-radius: 0 6px 6px 0;
  }
  .guide-overlap strong { color: var(--accent, #f39c12); }

  form { display: grid; gap: 14px; grid-template-columns: minmax(0, 1fr); }
  label { display: grid; gap: 6px; font-size: 13px; color: #ecf0f1; font-weight: 600; min-width: 0; }
  label .opt { color: #95a5a6; font-weight: 400; font-size: 12px; }
  input, textarea {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 6px; padding: 10px 12px;
    color: #fff; font-size: 15px; font-family: inherit;
    width: 100%; min-width: 0;
  }
  textarea { resize: vertical; min-height: 64px; }
  input[type="color"] { padding: 4px; height: 40px; width: 64px; }
  input:focus, textarea:focus { outline: 2px solid #f39c12; outline-offset: 1px; }

  .row { display: flex; align-items: center; gap: 12px; margin-top: 4px; flex-wrap: wrap; }
  button {
    padding: 12px 22px; background: #f39c12; color: #1a252f;
    border: none; border-radius: 8px; font-weight: 800; font-size: 15px;
    cursor: pointer;
  }
  button:disabled { opacity: 0.55; cursor: not-allowed; }
  button.cancel {
    background: transparent; color: #ecf0f1;
    border: 1px solid rgba(255,255,255,0.2); font-weight: 600;
  }

  #save-status, .t-status, #organizer-save-status, #raffle-save-status, #add-host-status {
    font-size: 13px; color: #95a5a6;
  }
  #save-status.ok, .t-status.ok, #organizer-save-status.ok, #raffle-save-status.ok, #add-host-status.ok {
    color: #2ecc71; font-weight: 700;
  }
  #save-status.err, .t-status.err, #organizer-save-status.err, #raffle-save-status.err, #add-host-status.err {
    color: #e74c3c; font-weight: 600;
  }
  h3.social-h {
    margin-top: 14px; margin-bottom: 4px;
    font-size: 12px; color: #ecf0f1;
    text-transform: uppercase; letter-spacing: 1.5px;
  }
  .section-divider {
    margin: 18px 0 4px;
    height: 1px;
    background: rgba(255,255,255,0.10);
  }
  p.section-note {
    font-size: 12px; color: #95a5a6;
    line-height: 1.5;
    margin-bottom: 4px;
  }
  p.section-note strong {
    color: var(--accent, #f39c12);
    font-weight: 700;
  }
  label.checkbox-line {
    display: flex; align-items: center; gap: 8px;
    cursor: pointer; font-size: 13px; color: #ecf0f1;
    font-weight: 500;
  }
  label.checkbox-line input[type="checkbox"] {
    width: auto; min-width: 0; margin: 0;
    accent-color: var(--accent);
  }
  label.checkbox-line strong { color: var(--accent); font-weight: 800; letter-spacing: 0.5px; }

  /* Transformations section */
  button.add-btn {
    background: transparent; color: #f39c12;
    border: 1px dashed rgba(243,156,18,0.5);
    width: 100%; padding: 12px; margin-bottom: 14px;
    font-weight: 700;
  }
  button.add-btn:hover { background: rgba(243,156,18,0.06); }

  .agenda-actions { display: grid; gap: 8px; grid-template-columns: 1fr 1fr; margin-bottom: 14px; }
  .agenda-actions button.add-btn { margin-bottom: 0; }
  @media (max-width: 460px) { .agenda-actions { grid-template-columns: 1fr; } }
  button.add-btn.paste-btn {
    border-color: rgba(255,255,255,0.20);
    color: #ecf0f1;
  }
  form.paste-form {
    background: rgba(0,0,0,0.2);
    border: 1px solid rgba(243,156,18,0.4);
    border-radius: 10px; padding: 14px;
  }
  .paste-hint { font-size: 12px; color: #95a5a6; line-height: 1.5; margin: 4px 0; }
  .paste-hint strong { color: #ecf0f1; }
  textarea.paste-csv {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12px; min-height: 200px; white-space: pre;
    background: rgba(0,0,0,0.3);
  }
  .paste-hint code {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11px; padding: 1px 5px;
    background: rgba(0,0,0,0.35); border-radius: 4px;
    color: #ecf0f1;
  }
  .paste-preview { font-size: 12px; color: #95a5a6; min-height: 16px; }
  .paste-preview.ok { color: #2ecc71; font-weight: 700; }

  #t-form-host form.t-form {
    background: rgba(0,0,0,0.2);
    border: 1px solid rgba(243,156,18,0.4);
    border-radius: 10px; padding: 14px; margin-bottom: 14px;
  }
  form.t-form h3 {
    font-size: 13px; color: #f39c12;
    text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 12px;
  }
  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .grid-3 { display: grid; grid-template-columns: minmax(0, 1fr) 110px minmax(0, 1.4fr); gap: 10px; }
  @media (max-width: 520px) {
    .grid-3 { grid-template-columns: 1fr 1fr; }
    .grid-3 label:nth-child(3) { grid-column: 1 / -1; }
  }
  .cascade-hint {
    font-size: 11px; color: #95a5a6; font-style: italic;
    line-height: 1.5;
    background: rgba(243,156,18,0.04);
    border-left: 2px solid color-mix(in srgb, var(--accent) 40%, transparent);
    padding: 6px 10px;
    border-radius: 4px;
  }
  .cascade-hint strong { color: var(--accent); font-style: normal; }
  /* Duration stepper inside each agenda row (.t-info). Compact pill so
     it tucks in below the segment + speaker meta without dominating. */
  .duration-stepper {
    display: inline-flex; align-items: center; gap: 2px;
    margin-top: 4px;
    font-size: 11px; line-height: 1;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 999px;
    padding: 2px 2px;
    width: max-content;
  }
  .duration-stepper button {
    width: 22px; height: 22px;
    border-radius: 50%;
    background: transparent; color: var(--accent);
    border: none;
    font-weight: 800; font-size: 14px;
    cursor: pointer; font-family: inherit;
    padding: 0;
  }
  .duration-stepper button:hover { background: rgba(243,156,18,0.15); }
  .duration-stepper .dur-value {
    padding: 0 8px;
    color: #ecf0f1; font-weight: 700;
    letter-spacing: 0.3px;
    min-width: 60px; text-align: center;
  }
  .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }
  @media (max-width: 460px) { .grid-3 { grid-template-columns: 1fr; } }

  /* Before / After data grid */
  .ba-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media (max-width: 460px) { .ba-grid { grid-template-columns: 1fr; } }
  fieldset.ba-block {
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    padding: 10px 12px 12px;
    margin: 0;
    display: grid;
    gap: 10px;
    min-width: 0;
  }
  fieldset.ba-block legend {
    padding: 0 6px;
    font-size: 11px;
    color: #f39c12;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-weight: 700;
  }
  fieldset.ba-block label { font-size: 12px; }
  fieldset.ba-block input { padding: 8px 10px; font-size: 14px; }

  /* Computed read-only stats line */
  .computed-stats {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 8px;
    background: rgba(0,0,0,0.2);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    padding: 10px;
    margin-top: 4px;
  }
  .cstat { text-align: center; display: grid; gap: 2px; }
  .cstat .num {
    font-size: 18px; font-weight: 800; color: #f39c12;
    line-height: 1.1;
  }
  .cstat .lbl {
    font-size: 10px; color: #95a5a6;
    text-transform: uppercase; letter-spacing: 1px;
  }

  /* Photo slots */
  .photos-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
    margin-top: 4px;
  }
  .photo-slot { display: grid; gap: 6px; }
  .slot-label {
    font-size: 11px; color: #95a5a6;
    text-transform: uppercase; letter-spacing: 1px; font-weight: 600;
  }
  .photo-preview {
    aspect-ratio: 3/4;
    background: rgba(0,0,0,0.3);
    border: 1px dashed rgba(255,255,255,0.15);
    border-radius: 8px;
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }
  .photo-preview img { width: 100%; height: 100%; object-fit: cover; }
  .photo-preview .empty { color: #555; font-size: 11px; }

  /* Prize photo: arbitrary aspect ratio (a product shot, not a portrait). */
  .prize-photo-slot { display: grid; gap: 6px; margin-top: 4px; }

  /* Multi-prize raffle list — one row per defined prize, with thumbnail,
     name, grand-prize badge, and per-row edit/delete. Drawn-prize rows
     show "✓ Winner Name" inline; un-drawn show "— not drawn yet". */
  ul.prize-list {
    list-style: none; padding: 0; margin: 12px 0 0;
    display: grid; gap: 8px;
  }
  .prize-row {
    display: grid;
    grid-template-columns: 56px 1fr auto;
    gap: 12px; align-items: center;
    padding: 10px 12px;
    background: rgba(0,0,0,0.20);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
  }
  .prize-row.is-grand {
    border-color: rgba(243,156,18,0.5);
    background: rgba(243,156,18,0.06);
  }
  .prize-thumb {
    width: 56px; height: 56px; border-radius: 6px;
    object-fit: cover; background: rgba(0,0,0,0.4);
  }
  .prize-thumb.empty { border: 1px dashed rgba(255,255,255,0.14); }
  .prize-info {
    display: flex; flex-direction: column; gap: 4px; min-width: 0;
  }
  .prize-info strong {
    font-size: 14px; color: #ecf0f1; font-weight: 700;
    overflow-wrap: anywhere;
  }
  .prize-badge.grand {
    display: inline-block; align-self: flex-start;
    font-size: 9px; font-weight: 800; letter-spacing: 1px;
    padding: 2px 7px; border-radius: 999px;
    background: rgba(243,156,18,0.20); color: var(--accent, #f39c12);
    border: 1px solid rgba(243,156,18,0.5);
    margin-top: 1px;
  }
  /* "× 3" quantity badge next to the prize name when > 1 */
  .prize-badge.qty {
    display: inline-block; vertical-align: middle;
    margin-left: 6px;
    font-size: 11px; font-weight: 700; letter-spacing: 0.5px;
    padding: 1px 7px; border-radius: 8px;
    background: rgba(255,255,255,0.10); color: #ecf0f1;
    border: 1px solid rgba(255,255,255,0.18);
  }
  /* Quantity input + helper text inside the prize form */
  .prize-qty input[type="number"] {
    max-width: 7em;
  }
  .prize-qty input[disabled] { opacity: 0.5; cursor: not-allowed; }
  .prize-qty .qty-hint {
    display: block;
    font-size: 11px; color: #95a5a6; font-style: italic;
    margin-top: 4px; line-height: 1.4;
  }
  .prize-meta { font-size: 12px; color: #ecf0f1; }
  .prize-meta.dim { color: #95a5a6; font-style: italic; }
  .prize-meta.warn {
    color: #f39c12; font-weight: 600;
    background: rgba(243,156,18,0.10);
    border: 1px solid rgba(243,156,18,0.4);
    border-radius: 4px;
    padding: 3px 6px;
    align-self: flex-start;
    line-height: 1.35;
  }
  .prize-actions {
    display: flex; flex-direction: column; gap: 4px;
  }
  .prize-actions button {
    font-size: 11px; padding: 4px 8px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 4px; color: #ecf0f1; cursor: pointer;
    font-family: inherit;
  }
  .prize-actions button.del { color: #e74c3c; }
  .prize-empty {
    padding: 20px; text-align: center;
    color: #95a5a6; font-style: italic; font-size: 13px;
  }
  .prize-empty.err { color: #e74c3c; font-style: normal; }
  .prize-loading { padding: 16px; text-align: center; color: #95a5a6; font-size: 12px; }
  .photo-slot.prize-slot { margin-top: 4px; }
  .photo-preview.prize-preview {
    aspect-ratio: auto;
    min-height: 120px; max-height: 220px;
    padding: 8px;
  }
  .photo-preview.prize-preview img {
    width: auto; height: 100%; max-height: 200px;
    object-fit: contain;
    margin: 0 auto;
  }
  .upload-btn {
    display: block; padding: 8px 12px; text-align: center;
    background: rgba(255,255,255,0.08); color: #ecf0f1;
    border-radius: 6px; cursor: pointer;
    font-size: 12px; font-weight: 700;
  }
  .upload-btn:hover { background: rgba(255,255,255,0.14); }
  .upload-btn[disabled] { opacity: 0.5; cursor: wait; }
  .photo-actions {
    display: flex; flex-wrap: wrap; gap: 6px;
  }
  .photo-actions .upload-btn { flex: 1 1 auto; }
  button.recrop-btn {
    border: 1px solid rgba(243,156,18,0.4);
    background: rgba(243,156,18,0.10);
    color: var(--accent, #f39c12);
    font-family: inherit;
  }
  button.recrop-btn:hover { background: rgba(243,156,18,0.18); }
  .recrop-hint {
    display: block;
    font-size: 11px; color: #95a5a6;
    line-height: 1.45; font-style: italic;
    margin-top: 2px;
  }
  .upload-status {
    font-size: 11px; color: #95a5a6;
    min-height: 14px;
  }
  .upload-status.ok { color: #2ecc71; font-weight: 700; }
  .upload-status.err { color: #e74c3c; font-weight: 600; }

  /* Biometric data section */
  .biometrics { display: grid; gap: 8px; margin-top: 4px; }
  .bio-hint { font-size: 12px; color: #95a5a6; line-height: 1.4; }
  textarea.bio-textarea {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 12px; min-height: 130px; white-space: pre;
    background: rgba(0,0,0,0.3);
  }
  .bio-status { font-size: 12px; color: #95a5a6; min-height: 14px; }
  .bio-status.ok { color: #2ecc71; font-weight: 700; }
  .bio-status.err { color: #e74c3c; font-weight: 600; }
  svg.bio-chart {
    width: 100%; height: 200px;
    background: rgba(0,0,0,0.25); border-radius: 8px;
  }
  button.bio-save { background: #2ecc71; color: #1a252f; }
  button.bio-clear {
    background: transparent; color: #ecf0f1;
    border: 1px solid rgba(255,255,255,0.2); font-weight: 600;
  }
  .bio-result { font-size: 13px; color: #95a5a6; }
  .bio-result.ok { color: #2ecc71; font-weight: 700; }
  .bio-result.err { color: #e74c3c; font-weight: 600; }

  /* Transformation list */
  ul.t-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 8px; }
  .t-row {
    display: grid; grid-template-columns: 56px 1fr auto;
    align-items: center; gap: 10px; padding: 10px 12px;
    background: rgba(0,0,0,0.2);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
  }
  /* When a row carries a drag handle, the grid grows a 24px leftmost
     column for it. Agenda rows (no handle yet) keep the original layout. */
  .t-row:has(> .drag-handle) {
    grid-template-columns: 24px 56px 1fr auto;
  }
  .drag-handle {
    width: 24px; height: 100%;
    min-height: 36px;
    display: flex; align-items: center; justify-content: center;
    background: transparent; border: none;
    color: rgba(255,255,255,0.30);
    font-size: 14px; line-height: 1; font-weight: 700;
    cursor: grab; user-select: none; touch-action: none;
    padding: 0;
    border-radius: 4px;
  }
  .drag-handle:hover { color: rgba(255,255,255,0.65); background: rgba(255,255,255,0.05); }
  .drag-handle:active { cursor: grabbing; }
  /* Sortable.js state classes */
  .t-row.sortable-ghost  { opacity: 0.35; background: rgba(243,156,18,0.10); }
  .t-row.sortable-chosen { border-color: rgba(243,156,18,0.45); }
  .t-row.sortable-drag   { box-shadow: 0 10px 24px rgba(0,0,0,0.45); }

  /* Mobile layout: the per-row actions column (Edit/Delete/etc.) drops
     to its own row below the info, full-width, right-aligned. Otherwise
     names + dates get crushed against the buttons at narrow widths. */
  @media (max-width: 520px) {
    .t-row { grid-template-columns: 56px 1fr; }
    .t-row:has(> .drag-handle) { grid-template-columns: 24px 56px 1fr; }
    .t-row .t-actions {
      grid-column: 1 / -1;
      justify-content: flex-end;
      flex-wrap: wrap;
      padding-top: 8px;
      margin-top: 2px;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
  }
  .t-thumb {
    width: 56px; height: 72px; object-fit: cover;
    border-radius: 4px; background: rgba(0,0,0,0.4);
