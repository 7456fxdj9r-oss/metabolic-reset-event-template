---
import Base from '../layouts/Base.astro';
---
<Base title="Edit your event">
  <main class="edit" id="edit-root">
    <p class="loading">Loading edit form…</p>
  </main>

  <div class="crop-modal" id="crop-modal" style="display:none;">
    <div class="crop-modal-inner">
      <h3 id="crop-title">Adjust the photo</h3>
      <p class="crop-hint">Drag inside to reposition · pinch or scroll to zoom · use the buttons below for precise control</p>
      <div class="cropper-wrap">
        <img id="cropper-source" alt="" />
      </div>
      <div class="crop-zoom-controls">
        <button type="button" id="crop-zoom-out" class="crop-zoom-btn" aria-label="Zoom out">−</button>
        <button type="button" id="crop-reset" class="crop-zoom-btn crop-reset" aria-label="Reset zoom">Reset</button>
        <button type="button" id="crop-zoom-in" class="crop-zoom-btn" aria-label="Zoom in">+</button>
      </div>
      <div class="crop-actions">
        <button type="button" id="crop-cancel" class="crop-cancel">Cancel</button>
        <button type="button" id="crop-confirm" class="crop-confirm">Use this crop</button>
      </div>
    </div>
  </div>
</Base>

<script>
  import { fetchEventBySlug, fetchTransformations, fetchDataPoints, fetchSpeakers, fetchAgendaItems, callFunction as baseCallFunction } from '../lib/supabase.js';
  import { drawMultiChart } from '../lib/chart.js';
  import { buildRaffleEntriesCsv, downloadCsv } from '../lib/csv.js';
  import {
    eventUrl, editUrl as editUrlOf, liveUrl, wheelUrl,
    rafflePosterUrl, cueUrl, raffleUrl, deckUrl, deckConsoleUrl,
  } from '../lib/urls.js';
  import QRCode from 'qrcode';
  // cropperjs (~80KB JS) is dynamic-imported on first crop modal open.
  // The CSS (~5KB) stays static — build-time CSS bundling is cheap and
  // having the cropper styles ready avoids an FOUC on the first crop.
  import type Cropper from 'cropperjs';
  import 'cropperjs/dist/cropper.css';
  let CropperCtor: typeof Cropper | null = null;
  async function loadCropper(): Promise<typeof Cropper> {
    if (!CropperCtor) CropperCtor = (await import('cropperjs')).default;
    return CropperCtor;
  }
  import Sortable from 'sortablejs';
  import { escapeHtml } from '../lib/html.js';
  import { fmtError } from '../lib/errors.js';

  // Handle is the only draggable surface so edit/delete clicks elsewhere
  // on the row don't initiate drags.
  function dragHandleHtml(): string {
    return '<button type="button" class="drag-handle" aria-label="Drag to reorder" title="Drag to reorder">⋮⋮</button>';
  }

  function wireSortable(
    list: HTMLElement,
    onReorder: (order: Array<{ id: string; display_order: number }>) => void,
  ): Sortable {
    return Sortable.create(list, {
      handle: '.drag-handle',
      animation: 150,
      ghostClass: 'sortable-ghost',
      chosenClass: 'sortable-chosen',
      dragClass: 'sortable-drag',
      onEnd: () => {
        const items = Array.from(list.querySelectorAll(':scope > li[data-id]'))
          .map((li, idx) => ({
            id: (li as HTMLElement).getAttribute('data-id') || '',
            display_order: idx,
          }))
          .filter((x) => x.id);
        onReorder(items);
      },
    });
  }

  // Shared reorder-persist pattern: optimistically reorder the local
  // array, fire one PATCH per row in parallel, and on failure refetch +
  // re-render so the UI lines up with the server's truth. Each section
  // supplies its own patchOne builder (different manage-* shapes).
  type IdOrder = { id: string; display_order: number };
  async function applyReorder<T extends { id: string }>(opts: {
    order: IdOrder[];
    items: T[];
    setItems: (next: T[]) => void;
    patchOne: (o: IdOrder) => Promise<unknown>;
    onFailure: () => Promise<void> | void;
  }): Promise<void> {
    const byId = new Map(opts.items.map((it) => [it.id, it]));
    opts.setItems(opts.order.map((o) => ({
      ...byId.get(o.id)!,
      display_order: o.display_order,
    })));
    try {
      await Promise.all(opts.order.map(opts.patchOne));
    } catch (err) {
      console.error('Reorder failed:', err);
      await opts.onFailure();
    }
  }

  type DataPoint = { metric: 'weight' | 'bf' | 'lean'; date: string; value: number };

  // Parse a pasted CSV/TSV blob into structured data points.
  // Format expected:
  //   First row: column headers (must include "date" plus at least one of
  //   weight/bf/lean — synonyms accepted).
  //   Following rows: date in the date column, numeric values in the metric
  //   columns. Empty cells are skipped (a row may report only weight, etc.).
  function parsePastedData(text: string): { points: DataPoint[]; errors: string[] } {
    const errors: string[] = [];
    const points: DataPoint[] = [];
    const rawLines = text.split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
    if (rawLines.length === 0) return { points, errors };

    const sep = rawLines[0].includes('\t') ? '\t' : ',';
    const headers = rawLines[0].split(sep).map((h) => h.trim().toLowerCase());
    const dateIdx = headers.findIndex((h) => h === 'date' || h === 'day');
    if (dateIdx < 0) {
      errors.push('First row must include a "date" column header.');
      return { points, errors };
    }

    const metricCols: Array<{ metric: 'weight' | 'bf' | 'lean'; idx: number }> = [];
    headers.forEach((h, i) => {
      const norm = h.replace(/[\s%_-]/g, '');
      if (norm === 'weight' || norm === 'wt' || norm === 'lb' || norm === 'lbs') {
        metricCols.push({ metric: 'weight', idx: i });
      } else if (norm === 'bf' || norm === 'bodyfat' || norm === 'fat' || norm === 'bfpct') {
        metricCols.push({ metric: 'bf', idx: i });
      } else if (norm === 'lean' || norm === 'leanmass' || norm === 'lbm') {
        metricCols.push({ metric: 'lean', idx: i });
      }
    });
    if (metricCols.length === 0) {
      errors.push('No metric column found. Add at least one of: weight, bf, lean.');
      return { points, errors };
    }

    for (let i = 1; i < rawLines.length; i++) {
      const cols = rawLines[i].split(sep).map((c) => c.trim());
      const dateStr = cols[dateIdx] || '';
      const date = parseDate(dateStr);
      if (!date) {
        errors.push(`Row ${i + 1}: invalid date "${dateStr}"`);
        continue;
      }
      for (const { metric, idx } of metricCols) {
        const raw = cols[idx];
        if (!raw) continue;
        const num = Number(raw.replace('%', '').replace(/,/g, ''));
        if (!Number.isFinite(num)) {
          errors.push(`Row ${i + 1}, ${metric}: invalid number "${raw}"`);
          continue;
        }
        points.push({ metric, date, value: num });
      }
    }
    return { points, errors };
  }

  function parseDate(s: string): string | null {
    let m = s.match(/^(\d{4})-(\d{1,2})-(\d{1,2})$/);
    let y: number, mo: number, d: number;
    if (m) {
      y = +m[1]; mo = +m[2]; d = +m[3];
    } else if ((m = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})$/))) {
      mo = +m[1]; d = +m[2]; y = +m[3];
      if (y < 100) y += 2000;
    } else {
      return null;
    }
    if (mo < 1 || mo > 12 || d < 1 || d > 31) return null;
    return `${y}-${String(mo).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
  }

  function pointsToCsv(points: DataPoint[]): string {
    if (points.length === 0) return 'date,weight,bf,lean\n';
    const dates = Array.from(new Set(points.map((p) => p.date))).sort();
    const lookup = new Map<string, Record<string, number>>();
    for (const d of dates) lookup.set(d, {});
    for (const p of points) lookup.get(p.date)![p.metric] = p.value;
    const lines = ['date,weight,bf,lean'];
    for (const d of dates) {
      const row = lookup.get(d)!;
      lines.push([d, row.weight ?? '', row.bf ?? '', row.lean ?? ''].join(','));
    }
    return lines.join('\n') + '\n';
  }

  // Append a cache-busting ?r=<ts> to an arbitrary URL. Used after every
  // re-crop so the browser fetches the new bytes instead of showing the
  // cached old image. Tolerant of URLs that already carry query params.
  function appendCacheBust(url: string): string {
    return url + (url.includes('?') ? '&' : '?') + 'r=' + Date.now();
  }

  // Re-crop the photo at `currentUrl`: fetch it (cache-busted), drop it
  // into the crop modal, upload the cropped result via the caller-
  // supplied uploadCropped function, then update the preview/label/
  // status DOM in `slotEl`. Returns the new public URL on success, null
  // on cancel or failure. Caller is responsible for updating any local
  // entity cache (speakers[], hostsCache, etc.) with the returned URL.
  async function recropFromUrl(
    currentUrl: string,
    title: string,
    aspectRatio: number,
    uploadCropped: (cropped: Blob) => Promise<string>,
    slotEl: HTMLElement,
  ): Promise<string | null> {
    const previewEl = slotEl.querySelector('.photo-preview') as HTMLElement;
    const labelEl = slotEl.querySelector('.upload-label') as HTMLElement;
    const statusEl = slotEl.querySelector('.upload-status') as HTMLElement;
    const recropBtn = slotEl.querySelector(
      '[data-recrop-speaker], [data-recrop-host], [data-recrop-organizer]',
    ) as HTMLButtonElement | null;
    if (recropBtn) recropBtn.disabled = true;
    statusEl.textContent = 'Fetching current photo…';
    statusEl.className = 'upload-status';
    try {
      const fetched = await fetch(appendCacheBust(currentUrl));
      if (!fetched.ok) throw new Error('Could not load the saved photo (HTTP ' + fetched.status + ')');
      const blob = await fetched.blob();
      const file = new File([blob], 'photo.jpg', { type: blob.type || 'image/jpeg' });
      statusEl.textContent = 'Opening crop tool…';
      const cropped = await openCropModal(file, aspectRatio, title);
      if (!cropped) {
        statusEl.textContent = '';
        return null;
      }
      statusEl.textContent = 'Uploading…';
      const newUrl = await uploadCropped(cropped);
      previewEl.innerHTML = `<img src="${escapeHtml(appendCacheBust(newUrl))}" alt="" />`;
      labelEl.textContent = 'Replace photo';
      statusEl.textContent = 'Re-cropped ✓';
      statusEl.className = 'upload-status ok';
      return newUrl;
    } catch (err) {
      statusEl.textContent = String(fmtError(err));
      statusEl.className = 'upload-status err';
      return null;
    } finally {
      if (recropBtn) recropBtn.disabled = false;
    }
  }

  // Crop modal: opens cropper.js on a single shared <img>, returns the
  // cropped JPEG blob (already at the right aspect ratio + capped at
  // 1200x1600). User cancels → resolves null. Used for transformation
  // photos (3:4) and speaker headshots (1:1).
  //
  // Options:
  //   freeZoom — when true, viewMode=0 lets the user zoom way out so the
  //   image is smaller than the crop box (useful for transformation
  //   stories where context matters). viewMode=1 keeps the crop tight
  //   against the image edges (good for avatars).
  let activeCropper: Cropper | null = null;
  function openCropModal(
    file: File,
    aspectRatio: number,
    title: string,
    options: { freeZoom?: boolean } = {},
  ): Promise<Blob | null> {
    return new Promise((resolve) => {
      const modal = document.getElementById('crop-modal')!;
      const img = document.getElementById('cropper-source') as HTMLImageElement;
      const titleEl = document.getElementById('crop-title')!;
      const confirmBtn = document.getElementById('crop-confirm')!;
      const cancelBtn = document.getElementById('crop-cancel')!;
      const zoomInBtn = document.getElementById('crop-zoom-in')!;
      const zoomOutBtn = document.getElementById('crop-zoom-out')!;
      const resetBtn = document.getElementById('crop-reset')!;
      titleEl.textContent = title;

      const reader = new FileReader();
      reader.onload = async () => {
        img.src = reader.result as string;
        modal.style.display = 'flex';
        activeCropper?.destroy();
        // Lazy-load cropperjs on first use; cached for the page lifetime.
        const Cropper = await loadCropper();
        activeCropper = new Cropper(img, {
          aspectRatio,
          // 0 = no constraints (crop box can sit anywhere, image can be
          // scaled smaller than the crop box). 1 = crop box restricted
          // to canvas, which limits how far the user can zoom out.
          viewMode: options.freeZoom ? 0 : 1,
          // Slight inset on free-zoom so the user sees the crop box
          // distinctly framed against the image at first.
          autoCropArea: options.freeZoom ? 0.9 : 1,
          dragMode: 'move',
          background: false,
          modal: true,
          guides: false,
          highlight: false,
          movable: true,
          rotatable: false,
          scalable: true,
          zoomable: true,
          zoomOnTouch: true,
          zoomOnWheel: true,
          responsive: true,
          checkOrientation: true,
          // Zoom range: 0.1x to 5x in the free-zoom case so the user
          // can really get close on a face or zoom out to see context.
          minCropBoxWidth: options.freeZoom ? 50 : 0,
        });
      };
      reader.onerror = () => {
        cleanup();
        resolve(null);
      };
      reader.readAsDataURL(file);

      function cleanup() {
        activeCropper?.destroy();
        activeCropper = null;
        modal.style.display = 'none';
        img.src = '';
        confirmBtn.replaceWith(confirmBtn.cloneNode(true));
        cancelBtn.replaceWith(cancelBtn.cloneNode(true));
        zoomInBtn.replaceWith(zoomInBtn.cloneNode(true));
        zoomOutBtn.replaceWith(zoomOutBtn.cloneNode(true));
        resetBtn.replaceWith(resetBtn.cloneNode(true));
      }

      document.getElementById('crop-confirm')!.addEventListener('click', () => {
        if (!activeCropper) {
          cleanup();
          return resolve(null);
        }
        const canvas = activeCropper.getCroppedCanvas({
          maxWidth: 1200,
          maxHeight: 1600,
          imageSmoothingEnabled: true,
          imageSmoothingQuality: 'high',
        });
        canvas.toBlob(
          (blob) => {
            cleanup();
            resolve(blob);
          },
          'image/jpeg',
          0.9
        );
      });
      document.getElementById('crop-cancel')!.addEventListener('click', () => {
        cleanup();
        resolve(null);
      });
      // Explicit zoom controls — work alongside the native pinch/wheel
      // gestures. zoom(±0.1) maps to a comfortable per-click step.
      document.getElementById('crop-zoom-in')!.addEventListener('click', () => {
        activeCropper?.zoom(0.1);
      });
      document.getElementById('crop-zoom-out')!.addEventListener('click', () => {
        activeCropper?.zoom(-0.1);
      });
      document.getElementById('crop-reset')!.addEventListener('click', () => {
        activeCropper?.reset();
      });
    });
  }

  // Inline canvas-based image compressor. Reads the file, scales the longest
  // edge to maxDim, encodes JPEG at the given quality. Returns a Blob.
  // Avoids the browser-image-compression npm package and its web-worker setup.
  async function compressImage(file: File, maxDim = 1200, quality = 0.82): Promise<Blob> {
    const dataUrl = await new Promise<string>((resolve, reject) => {
      const r = new FileReader();
      r.onload = () => resolve(r.result as string);
      r.onerror = () => reject(new Error('Could not read file'));
      r.readAsDataURL(file);
    });
    const img = await new Promise<HTMLImageElement>((resolve, reject) => {
      const i = new Image();
      i.onload = () => resolve(i);
      i.onerror = () => reject(new Error('Could not decode image'));
      i.src = dataUrl;
    });
    const scale = Math.min(1, maxDim / Math.max(img.width, img.height));
    const w = Math.round(img.width * scale);
    const h = Math.round(img.height * scale);
    const canvas = document.createElement('canvas');
    canvas.width = w;
    canvas.height = h;
    const ctx = canvas.getContext('2d')!;
    ctx.drawImage(img, 0, 0, w, h);
    return new Promise<Blob>((resolve, reject) => {
      canvas.toBlob(
        (blob) => (blob ? resolve(blob) : reject(new Error('Compression failed'))),
        'image/jpeg',
        quality
      );
    });
  }

  type Transformation = {
    id: string;
    slug: string;
    name: string;
    before_date: string | null;
    after_date: string | null;
    before_photo_url: string | null;
    after_photo_url: string | null;
    before_weight: number | null;
    after_weight: number | null;
    before_bf: number | null;
    after_bf: number | null;
    before_lean: number | null;
    after_lean: number | null;
    headline_lb_loss: number | null;
    headline_lean_kept_pct: number | null;
    headline_bf_delta_pts: number | null;
    takeaway_text: string | null;
    display_order: number;
  };

  const root = document.getElementById('edit-root')!;
  const base = import.meta.env.BASE_URL;
  const params = new URLSearchParams(window.location.search);
  const slug = params.get('slug');
  const key = params.get('key');


  function fmtDate(s: string | null): string {
    if (!s) return '—';
    const parts = s.split('-');
    if (parts.length < 2) return s;
    const y = parts[0];
    const m = parseInt(parts[1], 10);
    const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    if (!Number.isFinite(m) || m < 1 || m > 12) return s;
    return `${months[m - 1]} ${y}`;
  }

  function dateToMonth(s: string | null): string {
    return s ? s.slice(0, 7) : '';
  }

  function photoSlotHtml(slot: 'before' | 'after', label: string, url: string | null): string {
    return `
      <div class="photo-slot" data-slot="${slot}">
        <span class="slot-label">${label}</span>
        <div class="photo-preview">
          ${url ? `<img src="${escapeHtml(url)}" alt="" />` : '<div class="empty">No photo</div>'}
        </div>
        <label class="upload-btn">
          <input type="file" accept="image/*" data-slot="${slot}" hidden />
          <span class="upload-label">${url ? 'Replace photo' : 'Upload photo'}</span>
        </label>
        <span class="upload-status" data-slot="${slot}"></span>
      </div>
    `;
  }

  function transformationFormHtml(t?: Transformation): string {
    const v = t || ({} as Partial<Transformation>);
    const mode = t ? 'edit' : 'add';
    const idAttr = t ? `data-id="${t.id}"` : '';
    // Photo slots show in both Add and Edit modes. In Add mode the user can
    // pick photos before clicking Create; we'll queue them in memory and
    // upload right after the row is inserted so the new transformation lands
    // with photos already attached.
    const photos = `
        <div class="photos-grid">
          ${photoSlotHtml('before', 'Before photo', t?.before_photo_url ?? null)}
          ${photoSlotHtml('after', 'After photo', t?.after_photo_url ?? null)}
        </div>`;
    const biometrics = t ? `
        <div class="biometrics">
          <span class="slot-label">Biometric data</span>
          <p class="bio-hint">
            Paste from a spreadsheet. First row = headers (date, weight, bf, lean — at least one metric).
            Tab- or comma-separated. Date format: YYYY-MM-DD or M/D/YYYY.
          </p>
          <textarea class="bio-textarea" rows="8" placeholder="date,weight,bf,lean&#10;2025-08-17,217,,&#10;2025-10-13,212,52,101.4"></textarea>
          <div class="bio-status"></div>
          <svg class="bio-chart" preserveAspectRatio="none"></svg>
          <div class="row">
            <button type="button" class="bio-save">Save data points</button>
            <button type="button" class="bio-clear">Clear</button>
            <span class="bio-result" role="status" aria-live="polite"></span>
          </div>
        </div>` : '';
    return `
      <form class="t-form" data-mode="${mode}" ${idAttr} novalidate>
        <h3>${t ? 'Edit transformation' : 'New transformation'}</h3>
        <label>
          Client name
          <input name="name" required maxlength="80" value="${escapeHtml(v.name || '')}" placeholder="Enter your client's name here" />
        </label>
        <div class="ba-grid">
          <fieldset class="ba-block">
            <legend>Before</legend>
            <label>
              Date <span class="opt">(month / year)</span>
              <input type="month" name="before_date" value="${escapeHtml(dateToMonth(v.before_date || null))}" placeholder="Enter month and year" />
            </label>
            <label>
              Weight (lb)
              <input type="number" step="0.1" name="before_weight" value="${v.before_weight ?? ''}" />
            </label>
            <label>
              Body fat (%)
              <input type="number" step="0.1" name="before_bf" value="${v.before_bf ?? ''}" />
            </label>
            <label>
              Lean mass (lb)
              <input type="number" step="0.1" name="before_lean" value="${v.before_lean ?? ''}" />
            </label>
          </fieldset>
          <fieldset class="ba-block">
            <legend>After</legend>
            <label>
              Date <span class="opt">(month / year)</span>
              <input type="month" name="after_date" value="${escapeHtml(dateToMonth(v.after_date || null))}" placeholder="Enter month and year" />
            </label>
            <label>
              Weight (lb)
              <input type="number" step="0.1" name="after_weight" value="${v.after_weight ?? ''}" />
            </label>
            <label>
              Body fat (%)
              <input type="number" step="0.1" name="after_bf" value="${v.after_bf ?? ''}" />
            </label>
            <label>
              Lean mass (lb)
              <input type="number" step="0.1" name="after_lean" value="${v.after_lean ?? ''}" />
            </label>
          </fieldset>
        </div>
        <div class="computed-stats">
          <span class="cstat"><span class="num" data-stat="lb">—</span><span class="lbl">lb lost</span></span>
          <span class="cstat"><span class="num" data-stat="lean">—</span><span class="lbl">% lean kept</span></span>
          <span class="cstat"><span class="num" data-stat="bf">—</span><span class="lbl">BF % drop</span></span>
        </div>
        <label>
          Takeaway <span class="opt">(short paragraph shown beneath the chart)</span>
          <textarea name="takeaway_text" rows="3" placeholder="Most weight-loss attempts melt fat and muscle…">${escapeHtml(v.takeaway_text || '')}</textarea>
        </label>
        ${photos}
        ${biometrics}
        <div class="row">
          <button type="submit">${t ? 'Save changes' : 'Create'}</button>
          <button type="button" class="cancel">${t ? 'Done' : 'Cancel'}</button>
          <span class="t-status" role="status" aria-live="polite"></span>
        </div>
      </form>
    `;
  }

  function transformationRowHtml(t: Transformation): string {
    const stats: string[] = [];
    if (t.headline_lb_loss != null) stats.push(`−${t.headline_lb_loss} lb`);
    if (t.headline_lean_kept_pct != null) stats.push(`${t.headline_lean_kept_pct}% lean`);
    if (t.headline_bf_delta_pts != null) stats.push(`−${t.headline_bf_delta_pts} BF`);
    const thumb = t.before_photo_url || t.after_photo_url;
    return `
      <li class="t-row" data-id="${t.id}">
        ${dragHandleHtml()}
        ${thumb ? `<img class="t-thumb" src="${escapeHtml(thumb)}" alt="" />` : '<div class="t-thumb empty"></div>'}
        <div class="t-info">
          <strong>${escapeHtml(t.name)}</strong>
          <span class="t-meta">${fmtDate(t.before_date)} → ${fmtDate(t.after_date)}</span>
          ${stats.length ? `<span class="t-meta accent">${stats.join(' · ')}</span>` : ''}
        </div>
        <div class="t-actions">
          <button class="edit" data-id="${t.id}">Edit</button>
          <button class="del" data-id="${t.id}">Delete</button>
        </div>
      </li>
    `;
  }

  if (!slug || !key) {
    root.innerHTML =
      '<p class="loading err">Missing slug or key. Use the edit URL you saved at Build time.</p>';
  } else {
    (async () => {
      // Page-level save indicator: a small pill in the status bar that
      // reflects whether any save is in flight, settled, or errored.
      // Wraps callFunction so every edge-function write call increments
      // the inflight counter; reads (get-* and the list/list_prizes
      // actions) pass through untouched.
      let inflight = 0;
      let lastError: string | null = null;
      function updateSavePill() {
        const pill = document.getElementById('save-pill');
        if (!pill) return;
        if (inflight > 0) {
          pill.textContent = '💾 Saving…';
          pill.className = 'stat-pill saving';
          pill.title = '';
        } else if (lastError) {
          pill.textContent = '⚠️ Save error';
          pill.className = 'stat-pill error';
          pill.title = lastError;
        } else {
          pill.textContent = '✓ All saved';
          pill.className = 'stat-pill saved';
          pill.title = '';
        }
      }
      // deno-lint-ignore no-explicit-any
      const callFunction = (name: string, body: any): Promise<any> => {
        const action = body?.action;
        const isRead =
          name.startsWith('get-') ||
          action === 'list' ||
          action === 'list_prizes';
        if (isRead) return baseCallFunction(name, body);
        inflight++;
        lastError = null;
        updateSavePill();
        return baseCallFunction(name, body).then(
          (res) => { inflight--; updateSavePill(); return res; },
          (err) => {
            inflight--;
            lastError = (err as Error).message || String(err);
            updateSavePill();
            throw err;
          },
        );
      };

