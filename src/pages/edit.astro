        // ---------- Event details form ----------
        const form = document.getElementById('event-form') as HTMLFormElement;
        const status = document.getElementById('save-status')!;
        const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;

        form.addEventListener('submit', async (submitEv) => {
          submitEv.preventDefault();
          saveBtn.disabled = true;
          status.textContent = 'Saving…';
          status.className = '';
          const fd = new FormData(form);
          try {
            await callFunction('update-event', {
              slug,
              edit_token: key,
              name: fd.get('name'),
              host_line: fd.get('host_line') || null,
              accent_color: fd.get('accent_color'),
              event_date: fd.get('event_date') || null,
            });
            status.textContent = 'Saved ✓';
            status.className = 'ok';
            const newName = String(fd.get('name') || '').trim();
            if (newName) document.getElementById('page-title')!.textContent = newName;
          } catch (err) {
            const msg = (err as Error).message;
            status.textContent = fmtError(err);
            status.className = 'err';
          } finally {
            saveBtn.disabled = false;
          }
        });

        // ---------- Transformations section ----------
        const list = document.getElementById('t-list')!;
        const formHost = document.getElementById('t-form-host')!;
        const addBtn = document.getElementById('add-t-btn') as HTMLButtonElement;

        function updateStatusPills() {
          const sPill = document.getElementById('pill-stories');
          if (sPill) {
            const n = transformations.length;
            sPill.innerHTML = `🎯 ${n} ${n === 1 ? 'story' : 'stories'}`;
            sPill.classList.toggle('filled', n > 0);
          }
          const spPill = document.getElementById('pill-speakers');
          if (spPill && typeof speakers !== 'undefined') {
            const n = speakers.length;
            spPill.innerHTML = `🎤 ${n} ${n === 1 ? 'speaker' : 'speakers'}`;
            spPill.classList.toggle('filled', n > 0);
          }
        }

        let tSortable: Sortable | null = null;
        function renderList() {
          if (tSortable) { tSortable.destroy(); tSortable = null; }
          if (transformations.length === 0) {
            list.innerHTML = `<li class="t-empty">
              <strong>No transformation stories yet.</strong>
              These are before/after journeys with photos, weight + body-fat data, and a takeaway. They show on the public event page and can be pushed live to attendee phones during a coach-impact moment.
              <span class="empty-hint">Tip: even with just before/after snapshots (no weekly data), the chart synthesizes a realistic curve. Add one above to see it.</span>
            </li>`;
          } else {
            list.innerHTML = transformations.map(transformationRowHtml).join('');
            tSortable = wireSortable(list, (order) => applyReorder({
              order,
              items: transformations,
              setItems: (next) => { transformations = next; },
              patchOne: (o) => callFunction('manage-transformation', {
                slug, edit_token: key, action: 'update',
                transformation: { id: o.id, display_order: o.display_order },
              }),
              onFailure: async () => {
                transformations = await fetchTransformations(ev.id);
                renderList();
              },
            }));
          }
          updateStatusPills();
        }

        // Photos selected before a brand-new transformation has been Created
        // need to wait for the row to exist before we can upload them. Hold
        // them here keyed by slot; handleSubmit drains this map after insert.
        let pendingPhotos: Map<'before' | 'after', File> = new Map();

        function showForm(t?: Transformation) {
          formHost.innerHTML = transformationFormHtml(t);
          addBtn.style.display = 'none';
          pendingPhotos = new Map();
          const newForm = formHost.querySelector('form.t-form') as HTMLFormElement;
          newForm.addEventListener('submit', (e) => handleSubmit(e, t));
          newForm.querySelector('button.cancel')!.addEventListener('click', hideForm);
          setupComputedStats(newForm);
          newForm.querySelectorAll('input[type=file][data-slot]').forEach((input) => {
            input.addEventListener('change', (changeEv) => {
              if (t) {
                handlePhotoUpload(changeEv as Event, t);
              } else {
                handlePendingPhoto(changeEv as Event);
              }
            });
          });
          if (t) {
            setupBiometrics(newForm, t);
          } else {
            (newForm.querySelector('input[name=name]') as HTMLInputElement).focus();
          }
        }

        // Add-mode photo selection: open crop modal, then stash the cropped
        // blob + show a local preview. Actual upload happens after Create.
        async function handlePendingPhoto(changeEv: Event) {
          const input = changeEv.target as HTMLInputElement;
          const file = input.files?.[0];
          if (!file) return;
          const slot = input.dataset.slot as 'before' | 'after';
          const slotEl = input.closest('.photo-slot') as HTMLElement;
          const previewEl = slotEl.querySelector('.photo-preview') as HTMLElement;
          const labelEl = slotEl.querySelector('.upload-label') as HTMLElement;
          const statusEl = slotEl.querySelector('.upload-status') as HTMLElement;
          input.value = '';

          statusEl.textContent = 'Opening crop tool…';
          statusEl.className = 'upload-status';

          const cropped = await openCropModal(
            file, 3 / 4, slot === 'before' ? 'Crop the before photo' : 'Crop the after photo',
            { freeZoom: true },
          );
          if (!cropped) {
            statusEl.textContent = '';
            return;
          }
          // Wrap the cropped Blob as a File-like for the queue (uploadOnePhoto
          // takes File). Filename arbitrary — server doesn't trust it.
          const fileLike = new File([cropped], 'photo.jpg', { type: 'image/jpeg' });
          pendingPhotos.set(slot, fileLike);
          const reader = new FileReader();
          reader.onload = () => {
            previewEl.innerHTML = `<img src="${reader.result}" alt="" />`;
            labelEl.textContent = 'Replace photo';
            statusEl.textContent = 'Will upload after Create';
            statusEl.className = 'upload-status';
          };
          reader.readAsDataURL(cropped);
        }

        async function blobToBase64(blob: Blob): Promise<string> {
          return new Promise<string>((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = () => {
              const result = reader.result as string;
              resolve(result.split(',')[1] || result);
            };
            reader.onerror = () => reject(new Error('Failed to read file'));
            reader.readAsDataURL(blob);
          });
        }

        async function uploadOnePhoto(transformationId: string, slot: 'before' | 'after', file: File): Promise<string> {
          const compressed = await compressImage(file, 1200, 0.82);
          const data_b64 = await blobToBase64(compressed);
          const res = await callFunction('upload-photo', {
            slug,
            edit_token: key,
            transformation_id: transformationId,
            slot,
            filename: 'photo.jpg',
            data: data_b64,
          });
          return res.url as string;
        }

        function setupComputedStats(formEl: HTMLFormElement) {
          const lbEl = formEl.querySelector('[data-stat=lb]') as HTMLElement;
          const leanEl = formEl.querySelector('[data-stat=lean]') as HTMLElement;
          const bfEl = formEl.querySelector('[data-stat=bf]') as HTMLElement;
          const num = (v: FormDataEntryValue | null): number | null => {
            if (v == null || v === '') return null;
            const n = Number(v);
            return Number.isFinite(n) ? n : null;
          };
          const round1 = (n: number) => Math.round(n * 10) / 10;
          const recompute = () => {
            const fd = new FormData(formEl);
            const bw = num(fd.get('before_weight'));
            const aw = num(fd.get('after_weight'));
            const bbf = num(fd.get('before_bf'));
            const abf = num(fd.get('after_bf'));
            const bln = num(fd.get('before_lean'));
            const aln = num(fd.get('after_lean'));
            lbEl.textContent = bw != null && aw != null ? `−${round1(bw - aw)}` : '—';
            bfEl.textContent = bbf != null && abf != null ? `−${round1(bbf - abf)}` : '—';
            leanEl.textContent =
              bln != null && aln != null && bln > 0 ? `${round1((aln / bln) * 100)}%` : '—';
          };
          formEl.querySelectorAll<HTMLInputElement>(
            'input[name^=before_], input[name^=after_]'
          ).forEach((input) => input.addEventListener('input', recompute));
          recompute();
        }

        async function setupBiometrics(formEl: HTMLFormElement, t: Transformation) {
          const textarea = formEl.querySelector('textarea.bio-textarea') as HTMLTextAreaElement;
          const statusEl = formEl.querySelector('.bio-status') as HTMLElement;
          const svg = formEl.querySelector('svg.bio-chart') as unknown as SVGSVGElement;
          const saveBtn = formEl.querySelector('button.bio-save') as HTMLButtonElement;
          const clearBtn = formEl.querySelector('button.bio-clear') as HTMLButtonElement;
          const resultEl = formEl.querySelector('.bio-result') as HTMLElement;

          function renderPreview() {
            const text = textarea.value.trim();
            while (svg.firstChild) svg.removeChild(svg.firstChild);
            if (!text) {
              statusEl.textContent = '';
              statusEl.className = 'bio-status';
              return;
            }
            const { points, errors } = parsePastedData(text);
            if (errors.length > 0) {
              statusEl.textContent = errors.slice(0, 3).join(' · ');
              statusEl.className = 'bio-status err';
            } else {
              const counts = {
                weight: points.filter((p) => p.metric === 'weight').length,
                bf: points.filter((p) => p.metric === 'bf').length,
                lean: points.filter((p) => p.metric === 'lean').length,
              };
              statusEl.textContent = `${points.length} points · ${counts.weight} weight, ${counts.bf} BF, ${counts.lean} lean`;
              statusEl.className = 'bio-status ok';
            }
            const byMetric: Record<string, Array<[string, number]>> = { weight: [], bf: [], lean: [] };
            for (const p of points) byMetric[p.metric].push([p.date, p.value]);
            const series: Array<{ name: string; color: string; suffix: string; axis: 'left' | 'right'; data: Array<[string, number]> }> = [];
            if (byMetric.weight.length) series.push({ name: 'Weight', color: '#f39c12', suffix: ' lb', axis: 'left',  data: byMetric.weight });
            if (byMetric.lean.length)   series.push({ name: 'Lean',   color: '#2ecc71', suffix: ' lb', axis: 'left',  data: byMetric.lean });
            if (byMetric.bf.length)     series.push({ name: 'BF',     color: '#e74c3c', suffix: '%',   axis: 'right', data: byMetric.bf });
            if (series.length) drawMultiChart(svg, series);
          }

          try {
            const existing = await fetchDataPoints(t.id);
            if (existing.length > 0) {
              const dp: DataPoint[] = existing.map((p: { metric: 'weight'|'bf'|'lean'; date: string; value: number | string }) => ({
                metric: p.metric,
                date: p.date,
                value: Number(p.value),
              }));
              textarea.value = pointsToCsv(dp);
            } else {
              textarea.value = 'date,weight,bf,lean\n';
            }
            requestAnimationFrame(renderPreview);
          } catch (err) {
            statusEl.textContent = 'Could not load existing data: ' + (err as Error).message;
            statusEl.className = 'bio-status err';
          }

          textarea.addEventListener('input', renderPreview);

          saveBtn.addEventListener('click', async () => {
            const text = textarea.value.trim();
            const { points, errors } = parsePastedData(text);
            if (errors.length > 0) {
              resultEl.textContent = errors[0];
              resultEl.className = 'bio-result err';
              return;
            }
            saveBtn.disabled = true;
            resultEl.textContent = 'Saving…';
            resultEl.className = 'bio-result';
            try {
              const res = await callFunction('set-data-points', {
                slug,
                edit_token: key,
                transformation_id: t.id,
                points,
              });
              resultEl.textContent = `Saved ${res.count} points ✓`;
              resultEl.className = 'bio-result ok';
            } catch (err) {
              const msg = (err as Error).message;
              resultEl.textContent = fmtError(err);
              resultEl.className = 'bio-result err';
            } finally {
              saveBtn.disabled = false;
            }
          });

          clearBtn.addEventListener('click', () => {
            textarea.value = 'date,weight,bf,lean\n';
            renderPreview();
          });
        }

        function hideForm() {
          formHost.innerHTML = '';
          addBtn.style.display = '';
        }

        async function handleSubmit(submitEv: Event, editing?: Transformation) {
          submitEv.preventDefault();
          const formEl = submitEv.target as HTMLFormElement;
          const fd = new FormData(formEl);
          const tStatus = formEl.querySelector('.t-status') as HTMLSpanElement;
          const submit = formEl.querySelector('button[type=submit]') as HTMLButtonElement;
          submit.disabled = true;
          tStatus.textContent = 'Saving…';
          tStatus.className = 't-status';

          // <input type="month"> emits YYYY-MM in Chrome/Edge with a native
          // picker. In Safari and Firefox the input degrades to a plain text
          // box and the user types whatever format they want. Accept the
          // common ones and normalize to YYYY-MM-01 for the DB date column.
          const monthOrNull = (v: FormDataEntryValue | null): string | null => {
            const s = String(v || '').trim();
            if (!s) return null;
            let m: RegExpMatchArray | null;
            if ((m = s.match(/^(\d{4})-(\d{1,2})$/))) {
              return `${m[1]}-${m[2].padStart(2, '0')}-01`;
            }
            if ((m = s.match(/^(\d{4})-(\d{1,2})-(\d{1,2})$/))) {
              return `${m[1]}-${m[2].padStart(2, '0')}-${m[3].padStart(2, '0')}`;
            }
            if ((m = s.match(/^(\d{1,2})\/(\d{4})$/))) {
              return `${m[2]}-${m[1].padStart(2, '0')}-01`;
            }
            if ((m = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})$/))) {
              let y = +m[3];
              if (y < 100) y += 2000;
              return `${y}-${m[1].padStart(2, '0')}-${m[2].padStart(2, '0')}`;
            }
            return null;
          };
          const transformation: Record<string, unknown> = {
            name: fd.get('name'),
            before_date: monthOrNull(fd.get('before_date')),
            after_date: monthOrNull(fd.get('after_date')),
            before_weight: fd.get('before_weight') || null,
            after_weight: fd.get('after_weight') || null,
            before_bf: fd.get('before_bf') || null,
            after_bf: fd.get('after_bf') || null,
            before_lean: fd.get('before_lean') || null,
            after_lean: fd.get('after_lean') || null,
            takeaway_text: fd.get('takeaway_text') || null,
          };
          if (editing) transformation.id = editing.id;

          try {
            const res = await callFunction('manage-transformation', {
              action: editing ? 'update' : 'add',
              slug,
              edit_token: key,
              transformation,
            });
            let saved = res.transformation as Transformation;

            // Drain any photos the user picked before clicking Create.
            if (!editing && pendingPhotos.size > 0) {
              tStatus.textContent = `Uploading photo${pendingPhotos.size > 1 ? 's' : ''}…`;
              for (const [slot, file] of pendingPhotos) {
                try {
                  const url = await uploadOnePhoto(saved.id, slot, file);
                  saved = {
                    ...saved,
                    [slot === 'before' ? 'before_photo_url' : 'after_photo_url']: url,
                  };
                } catch (err) {
                  console.error(`Failed to upload ${slot} photo:`, err);
                }
              }
              pendingPhotos = new Map();
            }

            if (editing) {
              transformations = transformations.map((t) => (t.id === saved.id ? saved : t));
            } else {
              transformations = [...transformations, saved];
            }
            renderList();

            if (editing) {
              tStatus.textContent = 'Saved ✓';
              tStatus.className = 't-status ok';
              submit.disabled = false;
            } else {
              // Re-show the form in edit mode so the user can keep tweaking
              // (replace photos, add biometric data, etc.) without leaving.
              showForm(saved);
              const reopenStatus = formHost.querySelector('.t-status') as HTMLSpanElement;
              if (reopenStatus) {
                reopenStatus.textContent = 'Created ✓';
                reopenStatus.className = 't-status ok';
              }
            }
          } catch (err) {
            const msg = (err as Error).message;
            tStatus.textContent = fmtError(err);
            tStatus.className = 't-status err';
            submit.disabled = false;
          }
        }

        async function handlePhotoUpload(changeEv: Event, t: Transformation) {
          const input = changeEv.target as HTMLInputElement;
          const file = input.files?.[0];
          if (!file) return;
          const slot = (input.dataset.slot as 'before' | 'after');
          const slotEl = input.closest('.photo-slot') as HTMLElement;
          const statusEl = slotEl.querySelector('.upload-status') as HTMLElement;
          const previewEl = slotEl.querySelector('.photo-preview') as HTMLElement;
          const labelEl = slotEl.querySelector('.upload-label') as HTMLElement;

          statusEl.textContent = 'Opening crop tool…';
          statusEl.className = 'upload-status';
          input.value = ''; // allow re-pick of the same file later

          try {
            const cropped = await openCropModal(
              file, 3 / 4, slot === 'before' ? 'Crop the before photo' : 'Crop the after photo',
              { freeZoom: true },
            );
            if (!cropped) {
              statusEl.textContent = '';
              return;
            }
            statusEl.textContent = 'Uploading…';
            const data_b64 = await blobToBase64(cropped);
            const res = await callFunction('upload-photo', {
              slug, edit_token: key,
              transformation_id: t.id, slot,
              filename: 'photo.jpg', data: data_b64,
            });
            const url = res.url as string;

            transformations = transformations.map((x) =>
              x.id === t.id
                ? { ...x, [slot === 'before' ? 'before_photo_url' : 'after_photo_url']: url }
                : x
            );
            if (slot === 'before') (t as Transformation).before_photo_url = url;
            else (t as Transformation).after_photo_url = url;

            previewEl.innerHTML = `<img src="${escapeHtml(url)}" alt="" />`;
            labelEl.textContent = 'Replace photo';
            statusEl.textContent = 'Uploaded ✓';
            statusEl.className = 'upload-status ok';
            renderList();
          } catch (err) {
            const msg = (err as Error).message;
            statusEl.textContent = fmtError(err);
            statusEl.className = 'upload-status err';
          }
        }

        async function handleDelete(id: string) {
          const t = transformations.find((x) => x.id === id);
          if (!t) return;
          if (!confirm(`Delete "${t.name}" and all its biometric data?\n\nThis can't be undone.`)) return;
          try {
            await callFunction('manage-transformation', {
              action: 'delete',
              slug,
              edit_token: key,
              transformation_id: id,
            });
            transformations = transformations.filter((x) => x.id !== id);
            renderList();
          } catch (err) {
            alert('Could not delete: ' + (err as Error).message);
          }
        }

        // ---------- Raffle settings + entries ----------
        const raffleForm = document.getElementById('raffle-form') as HTMLFormElement;
        const raffleSaveBtn = document.getElementById('raffle-save') as HTMLButtonElement;
        const raffleSaveStatus = document.getElementById('raffle-save-status')!;
        const entryCountEl = document.getElementById('entry-count')!;
        const entriesWrap = document.getElementById('entries-list-wrap')!;
        let raffleStatus: 'open' | 'closed' = (ev.raffle_status === 'open' ? 'open' : 'closed');

        // ---------- Prize list ----------
        // Multi-prize raffle: one entry pool, multiple distinct prizes, one
        // optional grand. Add/edit/remove flow mirrors the speakers section.
        // Photos upload to event-photos via upload-event-photo with
        // kind=prize_item, prize_id=<id> after the prize row exists.
        type Prize = {
          id: string;
          name: string;
          description: string | null;
          photo_url: string | null;
          display_order: number;
          is_grand: boolean;
          quantity: number;
          drawn_count: number;
          drawn_winner_id: string | null;
          drawn_at: string | null;
          created_at: string;
        };
        let prizes: Prize[] = [];
        const prizeList = document.getElementById('prize-list')!;
        const prizeFormHost = document.getElementById('prize-form-host')!;
        const addPrizeBtn = document.getElementById('add-prize-btn') as HTMLButtonElement;
        // Holds a queued photo blob during the new-prize flow — uploaded
        // after the prize row exists (uploads need prize_id). Mirrors
        // pendingSpeakerPhoto in the Speakers section.
        let pendingPrizePhoto: File | null = null;

        function prizeFormHtml(p?: Prize): string {
          const v = p || ({} as Partial<Prize>);
          // Photo slot renders in BOTH new and edit modes. New-prize
          // uploads queue into pendingPrizePhoto (in-memory blob) and
          // upload via upload-event-photo as soon as the row exists.
          // Edit-prize uploads go straight through (the prize_id is known).
          const slotIdAttr = p ? `data-prize-slot="${escapeHtml(p.id)}"` : 'data-prize-slot="new"';
          const photoBlock = `
              <div class="photo-slot prize-slot" ${slotIdAttr}>
                <span class="slot-label">
                  Prize photo <span class="opt">(optional)</span>
                </span>
                <p class="opt" style="font-size:11px;color:#95a5a6;font-style:italic;line-height:1.45;margin:-2px 0 4px;">
                  💡 If this is the <strong style="color:var(--accent);">GRAND PRIZE</strong>, this photo
                  appears on the <strong>raffle entry page</strong> (the QR sign-up sheet attendees scan).
                  Spot prizes don't need a photo if you'll be showing them in the room.
                </p>
                <div class="photo-preview prize-preview">
                  ${v.photo_url
                    ? `<img src="${escapeHtml(v.photo_url)}" alt="" />`
                    : '<div class="empty">No photo</div>'}
                </div>
                <label class="upload-btn">
                  <input type="file" accept="image/*" ${slotIdAttr} hidden />
                  <span class="upload-label">${v.photo_url ? 'Replace photo' : 'Upload photo'}</span>
                </label>
                <span class="upload-status" ${slotIdAttr}></span>
              </div>`;
          const qtyValue = v.quantity || 1;
          return `
            <form class="t-form prize-form" ${p ? `data-id="${p.id}"` : ''} novalidate>
              <h3>${p ? 'Edit prize' : 'New prize'}</h3>
              <label>
                Name
                <input name="name" required maxlength="120" value="${escapeHtml(v.name || '')}" placeholder="FitBit Charge / 90-day program" />
              </label>
              <label>
                Description <span class="opt">(optional)</span>
                <textarea name="description" rows="2" maxlength="500" placeholder="What is it, how is it delivered, any restrictions">${escapeHtml(v.description || '')}</textarea>
              </label>
              <label class="prize-qty">
                Quantity <span class="opt">(how many of this prize you have)</span>
                <input type="number" name="quantity" min="1" max="999" step="1" value="${qtyValue}" ${v.is_grand ? 'disabled' : ''} />
                <span class="qty-hint">${v.is_grand ? 'Locked to 1 — grand prizes are singular.' : 'Each draw stamps one. The wheel keeps drawing until all are gone.'}</span>
              </label>
              <label class="checkbox-line">
                <input type="checkbox" name="is_grand" ${v.is_grand ? 'checked' : ''} />
                <span>This is the <strong>GRAND PRIZE</strong> (max one per event)</span>
              </label>
              ${photoBlock}
              <div class="row">
                <button type="submit">${p ? 'Save changes' : 'Create'}</button>
                <button type="button" class="cancel">${p ? 'Done' : 'Cancel'}</button>
                <span class="t-status" role="status" aria-live="polite"></span>
              </div>
            </form>`;
        }

        function prizeRowHtml(p: Prize): string {
          const qty = p.quantity || 1;
          const drawn = p.drawn_count || 0;
          const latestWinner = p.drawn_winner_id
            ? (entriesCache.find((e) => e.id === p.drawn_winner_id)?.name || '(winner)')
            : null;
          // Drawn-status line: "✓ Sara (1 of 3 drawn)" when multi, just
          // "✓ Sara" when quantity is 1, "— not drawn yet" when none.
          let drawnLine = '<span class="prize-meta dim">— not drawn yet</span>';
          if (drawn > 0) {
            const progress = qty > 1 ? ` (${drawn} of ${qty} drawn)` : '';
            drawnLine = `<span class="prize-meta">✓ ${escapeHtml(latestWinner || '(winner)')}${progress}</span>`;
          }
          // Grand prize without a photo is a soft warning — that photo
          // is what shows on the raffle entry page (QR sign-up sheet).
          // Empty spot prize photos are fine; those are shown live.
          const grandNoPhotoWarn = p.is_grand && !p.photo_url
            ? '<span class="prize-meta warn">⚠️ No photo for the entry page — tap Edit to add one</span>'
            : '';
          return `
            <li class="prize-row ${p.is_grand ? 'is-grand' : ''}" data-id="${p.id}">
              ${p.photo_url
                ? `<img class="prize-thumb" src="${escapeHtml(p.photo_url)}" alt="" />`
                : '<div class="prize-thumb empty"></div>'}
              <div class="prize-info">
                <strong>
                  ${escapeHtml(p.name)}
                  ${qty > 1 ? `<span class="prize-badge qty">× ${qty}</span>` : ''}
                </strong>
                ${p.is_grand ? '<span class="prize-badge grand">🏆 GRAND</span>' : ''}
                ${drawnLine}
                ${p.description ? `<span class="prize-meta">${escapeHtml(p.description.slice(0, 80))}${p.description.length > 80 ? '…' : ''}</span>` : ''}
                ${grandNoPhotoWarn}
              </div>
              <div class="prize-actions">
                <button type="button" class="edit" data-id="${p.id}">Edit</button>
                <button type="button" class="del" data-id="${p.id}">Delete</button>
              </div>
            </li>`;
        }

        function renderPrizeList() {
          if (prizes.length === 0) {
            prizeList.innerHTML = `<li class="prize-empty">
              <strong>No prizes yet.</strong>
              Add the grand prize plus any spot prizes you'll draw during the event. Each prize has a name, optional photo, and quantity (set quantity 3 if you have three identical mugs).
              <span class="empty-hint">Tip: the <strong>grand prize photo</strong> appears on the public QR sign-up page — make it the showstopper.</span>
            </li>`;
          } else {
            prizeList.innerHTML = prizes.map(prizeRowHtml).join('');
          }
        }

        function showPrizeForm(p?: Prize) {
          prizeFormHost.innerHTML = prizeFormHtml(p);
          addPrizeBtn.style.display = 'none';
          pendingPrizePhoto = null;
          const form = prizeFormHost.querySelector('form.prize-form') as HTMLFormElement;
          form.addEventListener('submit', (e) => handlePrizeSubmit(e, p));
          form.querySelector('button.cancel')!.addEventListener('click', hidePrizeForm);
          const fileInput = form.querySelector('input[type=file][data-prize-slot]') as HTMLInputElement | null;
          if (fileInput) {
            fileInput.addEventListener('change', (e) => {
              if (p) handlePrizePhotoUpload(e, p);
              else handlePendingPrizePhoto(e);
            });
          }
          // Toggle the quantity input live when GRAND PRIZE is checked,
          // since grand is always singular.
          const grandCb = form.querySelector('input[name=is_grand]') as HTMLInputElement | null;
          const qtyInput = form.querySelector('input[name=quantity]') as HTMLInputElement | null;
          const qtyHint = form.querySelector('.qty-hint') as HTMLElement | null;
          if (grandCb && qtyInput && qtyHint) {
            grandCb.addEventListener('change', () => {
              if (grandCb.checked) {
                qtyInput.value = '1';
                qtyInput.disabled = true;
                qtyHint.textContent = 'Locked to 1 — grand prizes are singular.';
              } else {
                qtyInput.disabled = false;
                qtyHint.textContent = 'Each draw stamps one. The wheel keeps drawing until all are gone.';
              }
            });
          }
          if (!p) (form.querySelector('input[name=name]') as HTMLInputElement).focus();
        }

        function hidePrizeForm() {
          prizeFormHost.innerHTML = '';
          addPrizeBtn.style.display = '';
          pendingPrizePhoto = null;
        }

        // New-prize photo flow: queue the file in memory, show a preview,
        // upload after the prize row is saved (we need the prize_id first).
        function handlePendingPrizePhoto(changeEv: Event) {
          const input = changeEv.target as HTMLInputElement;
          const file = input.files?.[0];
          if (!file) return;
          const slotEl = input.closest('.prize-slot') as HTMLElement;
          const previewEl = slotEl.querySelector('.photo-preview') as HTMLElement;
          const labelEl = slotEl.querySelector('.upload-label') as HTMLElement;
          const statusEl = slotEl.querySelector('.upload-status') as HTMLElement;
          input.value = '';
          pendingPrizePhoto = file;
          const reader = new FileReader();
          reader.onload = () => {
            previewEl.innerHTML = `<img src="${reader.result}" alt="" />`;
            labelEl.textContent = 'Replace photo';
            statusEl.textContent = 'Will upload after Create';
            statusEl.className = 'upload-status';
          };
          reader.readAsDataURL(file);
        }

        async function handlePrizeSubmit(submitEv: Event, editing?: Prize) {
          submitEv.preventDefault();
          const formEl = submitEv.target as HTMLFormElement;
          const fd = new FormData(formEl);
          const tStatus = formEl.querySelector('.t-status') as HTMLSpanElement;
          const submit = formEl.querySelector('button[type=submit]') as HTMLButtonElement;
          submit.disabled = true;
          tStatus.textContent = 'Saving…';
          tStatus.className = 't-status';

          try {
            const action = editing ? 'update_prize' : 'add_prize';
            const rawQty = Number(fd.get('quantity'));
            const qty = Number.isFinite(rawQty) && rawQty >= 1 ? Math.floor(rawQty) : 1;
            const payload: Record<string, unknown> = {
              slug, edit_token: key, action,
              name: fd.get('name'),
              description: fd.get('description') || null,
              is_grand: fd.get('is_grand') === 'on',
              quantity: qty,
            };
            if (editing) payload.prize_id = editing.id;

            const res = await callFunction('manage-raffle', payload);
            let saved = res.prize as Prize;

            // If the new-prize form had a queued photo, upload it now
            // that the prize row exists. Failure here is non-fatal — the
            // prize is still saved; user can retry the upload from the
            // edit-mode form.
            if (!editing && pendingPrizePhoto) {
              tStatus.textContent = 'Uploading photo…';
              try {
                const compressed = await compressImage(pendingPrizePhoto, 1200, 0.82);
                const data_b64 = await blobToBase64(compressed);
                const upRes = await callFunction('upload-event-photo', {
                  slug, edit_token: key,
                  kind: 'prize_item',
                  prize_id: saved.id,
                  filename: 'photo.jpg',
                  data: data_b64,
                });
                saved = { ...saved, photo_url: upRes.url as string };
              } catch (err) {
                console.error('Failed to upload prize photo:', err);
              }
              pendingPrizePhoto = null;
            }

            if (editing) {
              prizes = prizes.map((x) => (x.id === saved.id ? { ...x, ...saved } : x));
            } else {
              prizes = [...prizes, saved];
            }
            // If the saved prize is now grand, clear is_grand on others
            // locally so the list reflects the server state immediately.
            if (saved.is_grand) {
              prizes = prizes.map((x) => x.id === saved.id ? x : { ...x, is_grand: false });
            }
            renderPrizeList();

            if (editing) {
              tStatus.textContent = 'Saved ✓';
              tStatus.className = 't-status ok';
              submit.disabled = false;
            } else {
              // Re-open the form in edit mode so the user can replace the
              // photo or tweak the row without losing context.
              showPrizeForm(saved);
              const reopen = prizeFormHost.querySelector('.t-status') as HTMLSpanElement;
              if (reopen) {
                reopen.textContent = saved.photo_url ? 'Created ✓' : 'Created ✓ — add a photo if you want';
                reopen.className = 't-status ok';
              }
            }
          } catch (err) {
            const msg = (err as Error).message;
            tStatus.textContent = fmtError(err);
            tStatus.className = 't-status err';
            submit.disabled = false;
          }
        }

        async function handlePrizePhotoUpload(changeEv: Event, p: Prize) {
          const input = changeEv.target as HTMLInputElement;
          const file = input.files?.[0];
          if (!file) return;
          const slotEl = input.closest('.prize-slot') as HTMLElement;
          const previewEl = slotEl.querySelector('.photo-preview') as HTMLElement;
          const labelEl = slotEl.querySelector('.upload-label') as HTMLElement;
          const statusEl = slotEl.querySelector('.upload-status') as HTMLElement;
          input.value = '';
          statusEl.textContent = 'Compressing…';
          statusEl.className = 'upload-status';
          try {
            const compressed = await compressImage(file, 1200, 0.82);
            statusEl.textContent = 'Uploading…';
            const data_b64 = await blobToBase64(compressed);
            const res = await callFunction('upload-event-photo', {
              slug, edit_token: key,
              kind: 'prize_item',
              prize_id: p.id,
              filename: 'photo.jpg',
              data: data_b64,
            });
            const url = res.url as string;
            prizes = prizes.map((x) => (x.id === p.id ? { ...x, photo_url: url } : x));
            p.photo_url = url;
            previewEl.innerHTML = `<img src="${escapeHtml(url)}" alt="" />`;
            labelEl.textContent = 'Replace photo';
            statusEl.textContent = 'Uploaded ✓';
            statusEl.className = 'upload-status ok';
            renderPrizeList();
          } catch (err) {
            const msg = (err as Error).message;
            statusEl.textContent = fmtError(err);
            statusEl.className = 'upload-status err';
          }
        }

        async function handlePrizeDelete(id: string) {
          const p = prizes.find((x) => x.id === id);
          if (!p) return;
          if (p.drawn_count > 0) {
            const noun = p.drawn_count === 1 ? 'winner' : 'winners';
            if (!confirm(`"${p.name}" already has ${p.drawn_count} ${noun}. Deleting it will clear their prize attribution. Delete anyway?`)) return;
          } else {
            if (!confirm(`Delete the "${p.name}" prize?`)) return;
          }
          try {
            await callFunction('manage-raffle', {
              slug, edit_token: key, action: 'remove_prize', prize_id: id,
            });
            prizes = prizes.filter((x) => x.id !== id);
            renderPrizeList();
          } catch (err) {
            alert('Could not delete: ' + (err as Error).message);
          }
        }

        async function loadPrizes() {
          try {
            const res = await callFunction('manage-raffle', {
              slug, edit_token: key, action: 'list_prizes',
            });
            prizes = (res.prizes || []) as Prize[];
            renderPrizeList();
            // Multi-prize mode: hide the legacy single-prize "🎲 Draw winner"
            // button on this page. Drawing happens from the Raffle control
            // page (per-prize ladder) instead. Without this, the button
            // sits in the header looking actionable but does the wrong
            // thing when prizes are defined.
            const legacyDraw = document.getElementById('draw-btn');
            if (legacyDraw) legacyDraw.style.display = prizes.length > 0 ? 'none' : '';
          } catch (err) {
            prizeList.innerHTML =
              `<li class="prize-empty err">Could not load prizes: ${escapeHtml((err as Error).message)}</li>`;
          }
        }

        addPrizeBtn.addEventListener('click', () => showPrizeForm());
        prizeList.addEventListener('click', (clickEv) => {
          const target = clickEv.target as HTMLElement;
          if (target.tagName !== 'BUTTON') return;
          const id = target.getAttribute('data-id');
          if (!id) return;
          if (target.classList.contains('edit')) {
            const p = prizes.find((x) => x.id === id);
            if (p) showPrizeForm(p);
          } else if (target.classList.contains('del')) {
            handlePrizeDelete(id);
          }
        });
        loadPrizes();

        raffleForm.addEventListener('submit', async (submitEv) => {
          submitEv.preventDefault();
          raffleSaveBtn.disabled = true;
          raffleSaveStatus.textContent = 'Saving…';
          raffleSaveStatus.className = '';
          const fd = new FormData(raffleForm);
          try {
            await callFunction('update-event', {
              slug,
              edit_token: key,
              raffle_status: fd.get('raffle_status'),
            });
            raffleStatus = String(fd.get('raffle_status')) === 'open' ? 'open' : 'closed';
            raffleSaveStatus.textContent = 'Saved ✓';
            raffleSaveStatus.className = 'ok';
          } catch (err) {
            const msg = (err as Error).message;
            raffleSaveStatus.textContent = fmtError(err);
            raffleSaveStatus.className = 'err';
          } finally {
            raffleSaveBtn.disabled = false;
          }
        });

        function renderEntries(entries: Array<{
          id: string; name: string; email: string; phone: string | null;
          invited_by: string | null;
          risk_score: number | null;
          quiz_answers: Record<string, string | number | null> | null;
          goal_text: string | null;
          newsletter_optin: boolean | null;
          apprentice_optin: boolean | null;
          drawn: boolean; prize_won: string | null;
          submitted_at: string;
        }>) {
          entryCountEl.textContent = String(entries.length);
          if (entries.length === 0) {
            entriesWrap.innerHTML =
              `<p class="entries-empty">No entries yet. Open the raffle and share <code>${escapeHtml(raffleUrl(base, slug || ''))}</code>.</p>`;
            return;
          }
          const flagLabels: Record<string, string> = {
            has_diabetes: 'Diabetes',
            has_high_bp: 'High BP',
            has_high_cholesterol: 'High chol',
          };
          const ratingLabels: Record<string, string> = {
            rate_energy: 'Energy',
            rate_sleep: 'Sleep',
            rate_weight: 'Weight',
            rate_cravings: 'Cravings',
            rate_mood: 'Mood',
            rate_digestion: 'Digestion',
            rate_community: 'Community',
          };
          entriesWrap.innerHTML = `
            <ul class="entry-list">
              ${entries.map((e) => {
                const q = e.quiz_answers || {};
                const flags = Object.entries(flagLabels)
                  .filter(([k]) => q[k] === 'yes')
                  .map(([, lbl]) => `<span class="flag">${lbl}</span>`)
                  .join('');
                const ratings = Object.entries(ratingLabels)
                  .filter(([k]) => typeof q[k] === 'number')
                  .map(([k, lbl]) => `<span class="rate">${lbl} ${q[k]}</span>`)
                  .join('');
                const optins: string[] = [];
                if (e.apprentice_optin) optins.push('<span class="optin apprentice">⚑ Apprentice interest</span>');
                if (e.newsletter_optin) optins.push('<span class="optin">Newsletter</span>');
                const submitted = new Date(e.submitted_at);
                const submittedTxt = isNaN(submitted.getTime())
                  ? e.submitted_at
                  : submitted.toLocaleString(undefined, { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });
                return `
                  <li class="entry-item">
                    <div class="entry-head">
                      <strong>${escapeHtml(e.name)}</strong>
                      <span class="entry-score">${e.risk_score ?? 0}/3</span>
                    </div>
                    <div class="entry-meta">
                      ${escapeHtml(e.email)}${e.phone ? ` · ${escapeHtml(e.phone)}` : ''}<br />
                      ${e.invited_by ? `Invited by ${escapeHtml(e.invited_by)} · ` : ''}entered ${escapeHtml(submittedTxt)}
                    </div>
                    ${flags ? `<div class="entry-flags">${flags}</div>` : ''}
                    ${ratings ? `<div class="entry-ratings">${ratings}</div>` : ''}
                    ${optins.length ? `<div class="entry-optins">${optins.join(' ')}</div>` : ''}
                    ${e.goal_text ? `<p class="entry-goal">${escapeHtml(e.goal_text)}</p>` : ''}
                    ${e.drawn ? `<p class="entry-drawn">🏆 Winner${e.prize_won ? ` — ${escapeHtml(e.prize_won)}` : ''}</p>` : ''}
                  </li>`;
              }).join('')}
            </ul>
          `;
        }

        const drawBtn = document.getElementById('draw-btn') as HTMLButtonElement;
        const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
        const exportBtn = document.getElementById('export-btn') as HTMLButtonElement;
        const drawStatus = document.getElementById('draw-status')!;
        let entriesCache: any[] = [];

        async function loadEntries() {
          try {
            const res = await callFunction('manage-raffle', {
              slug,
              edit_token: key,
              action: 'list',
            });
            entriesCache = res.entries || [];
            renderEntries(entriesCache);
            // Prize rows show the winner's name inline ("✓ Sarah J.") which
            // looks up entriesCache. Re-render the prize list each time
            // entries refresh so the lookup picks up newly loaded entries.
            renderPrizeList();
            const total = entriesCache.length;
            const eligible = entriesCache.filter((e: { drawn: boolean }) => !e.drawn).length;
            const ePill = document.getElementById('pill-entries');
            if (ePill) {
              ePill.innerHTML = `${total} ${total === 1 ? 'entry' : 'entries'}`;
              ePill.classList.toggle('filled', total > 0);
            }
            drawBtn.disabled = eligible === 0;
            drawBtn.title = eligible === 0
              ? 'No entries left to draw'
              : `${eligible} eligible entries`;
            clearBtn.disabled = total === 0;
            clearBtn.title = total === 0 ? 'Nothing to clear' : `Delete all ${total} entries`;
            exportBtn.disabled = total === 0;
            exportBtn.title = total === 0 ? 'Nothing to export' : `Download ${total} entries as CSV`;
          } catch (err) {
            entriesWrap.innerHTML = `<p class="entries-empty err">${escapeHtml((err as Error).message)}</p>`;
          }
        }
        loadEntries();
        // Light polling so a host watching the dashboard sees new entries
        // come in during an event without having to refresh manually.
        // Visibility-gated: don't poll while the tab is hidden.
        window.setInterval(() => {
          if (document.visibilityState === 'visible') loadEntries();
        }, 10000);
        document.addEventListener('visibilitychange', () => {
          if (document.visibilityState === 'visible') loadEntries();
        });

        exportBtn.addEventListener('click', () => {
          const csv = buildRaffleEntriesCsv(entriesCache);
          const stamp = new Date().toISOString().slice(0, 10);
          downloadCsv(`raffle-entries-${slug}-${stamp}.csv`, csv);
        });

        clearBtn.addEventListener('click', async () => {
          if (!confirm('Delete ALL raffle entries for this event?\n\nThis cannot be undone. The raffle settings (status, prize, photo) stay as they are — only the entries themselves are wiped.')) return;
          if (!confirm('Are you sure? Type-confirm has no take-backs.')) return;
          clearBtn.disabled = true;
          drawStatus.textContent = 'Clearing entries…';
          drawStatus.className = 'draw-status';
          try {
            const res = await callFunction('manage-raffle', {
              slug, edit_token: key, action: 'clear',
            });
            drawStatus.textContent = `Deleted ${res.deleted} entr${res.deleted === 1 ? 'y' : 'ies'}.`;
            drawStatus.className = 'draw-status ok';
            await loadEntries();
          } catch (err) {
            drawStatus.textContent = (err as Error).message;
            drawStatus.className = 'draw-status err';
            clearBtn.disabled = false;
          }
        });

        drawBtn.addEventListener('click', async () => {
          if (!confirm('Pick a random winner from the eligible entries?')) return;
          drawBtn.disabled = true;
          drawStatus.textContent = 'Drawing…';
          drawStatus.className = 'draw-status';
          try {
            const res = await callFunction('manage-raffle', {
              slug,
              edit_token: key,
              action: 'draw',
            });
            const winner = res.winner;
            drawStatus.textContent = `🏆 Winner: ${winner.name}${winner.prize_won ? ` — ${winner.prize_won}` : ''}`;
            drawStatus.className = 'draw-status ok';
            await loadEntries();
          } catch (err) {
            drawStatus.textContent = (err as Error).message;
            drawStatus.className = 'draw-status err';
            drawBtn.disabled = false;
          }
        });

        // ---------- Speakers ----------
        type Speaker = {
          id: string;
          name: string;
          photo_url: string | null;
          bio: string | null;
          phone: string | null;
          email: string | null;
          display_order: number;
        };
        let speakers: Speaker[] = await fetchSpeakers(ev.id);

        const sList = document.getElementById('s-list')!;
        const sFormHost = document.getElementById('s-form-host')!;
        const addSBtn = document.getElementById('add-s-btn') as HTMLButtonElement;
        let pendingSpeakerPhoto: File | null = null;

        function speakerFormHtml(sp?: Speaker): string {
          const v = sp || ({} as Partial<Speaker>);
          // Re-crop is only meaningful when there's already a saved photo
          // AND we're editing an existing speaker (the new-speaker flow has
          // a pendingSpeakerPhoto blob in memory, not yet uploaded — for
          // that case the user can just re-pick the file).
          const showRecrop = !!(sp && v.photo_url);
          const photoBlock = `
            <div class="photo-slot speaker-slot" data-speaker-slot>
              <span class="slot-label">Photo</span>
              <div class="photo-preview speaker-preview">
                ${v.photo_url
                  ? `<img src="${escapeHtml(v.photo_url)}" alt="" />`
                  : '<div class="empty">No photo</div>'}
              </div>
              <div class="photo-actions">
                <label class="upload-btn">
                  <input type="file" accept="image/*" data-speaker-slot hidden />
                  <span class="upload-label">${v.photo_url ? 'Replace photo' : 'Upload photo'}</span>
                </label>
                ${showRecrop
                  ? `<button type="button" class="upload-btn recrop-btn" data-recrop-speaker>✂️ Re-crop current</button>`
                  : ''}
              </div>
              ${showRecrop
                ? '<span class="recrop-hint">Re-crop adjusts the saved photo (1200px wide). To recover area outside the original crop, use Replace photo with the original file.</span>'
                : ''}
              <span class="upload-status" data-speaker-slot></span>
            </div>`;
          return `
            <form class="t-form" ${sp ? `data-id="${sp.id}"` : ''} novalidate>
              <h3>${sp ? 'Edit speaker' : 'New speaker'}</h3>
              <label>
                Name
                <input name="name" required maxlength="120" value="${escapeHtml(v.name || '')}" placeholder="Enter speaker name" />
              </label>
              <label>
                Bio
                <textarea name="bio" rows="4" maxlength="2000" placeholder="A few sentences about this speaker">${escapeHtml(v.bio || '')}</textarea>
              </label>
              <div class="grid-2">
                <label>
                  Phone <span class="opt">(optional, public)</span>
                  <input type="tel" name="phone" value="${escapeHtml(v.phone || '')}" placeholder="555-123-4567" />
                </label>
                <label>
                  Email <span class="opt">(optional, public)</span>
                  <input type="email" name="email" value="${escapeHtml(v.email || '')}" />
                </label>
              </div>
              ${photoBlock}
              <div class="row">
                <button type="submit">${sp ? 'Save changes' : 'Create'}</button>
                <button type="button" class="cancel">${sp ? 'Done' : 'Cancel'}</button>
                <span class="t-status" role="status" aria-live="polite"></span>
              </div>
            </form>`;
        }

        function speakerRowHtml(sp: Speaker): string {
          const contactBits: string[] = [];
          if (sp.phone) contactBits.push(`📞 ${escapeHtml(sp.phone)}`);
          if (sp.email) contactBits.push(`✉️ ${escapeHtml(sp.email)}`);
          return `
            <li class="t-row" data-id="${sp.id}">
              ${dragHandleHtml()}
              ${sp.photo_url
                ? `<img class="t-thumb" src="${escapeHtml(sp.photo_url)}" alt="" style="border-radius:50%;width:56px;height:56px;" />`
                : '<div class="t-thumb empty" style="border-radius:50%;width:56px;height:56px;"></div>'}
              <div class="t-info">
                <strong>${escapeHtml(sp.name)}</strong>
                ${contactBits.length ? `<span class="t-meta">${contactBits.join(' · ')}</span>` : ''}
                ${sp.bio ? `<span class="t-meta">${escapeHtml(sp.bio.slice(0, 60))}${sp.bio.length > 60 ? '…' : ''}</span>` : ''}
              </div>
              <div class="t-actions">
                <button class="edit" data-id="${sp.id}">Edit</button>
                <button class="del" data-id="${sp.id}">Delete</button>
              </div>
            </li>`;
        }

        let sSortable: Sortable | null = null;
        function renderSpeakerList() {
          if (sSortable) { sSortable.destroy(); sSortable = null; }
          if (speakers.length === 0) {
            sList.innerHTML = `<li class="t-empty">
              <strong>No speakers yet.</strong>
              Each speaker has a name, photo, bio, and topic. They auto-appear on the public Today's Speakers page and on the projector slide deck when an agenda item names them.
              <span class="empty-hint">Tip: enter speakers with their <strong>full first + last name</strong> — the agenda's autocomplete will pick that up so slides resolve to photos automatically.</span>
            </li>`;
          } else {
            sList.innerHTML = speakers.map(speakerRowHtml).join('');
            sSortable = wireSortable(sList, (order) => applyReorder({
              order,
              items: speakers,
              setItems: (next) => { speakers = next; },
              patchOne: (o) => callFunction('manage-speakers', {
                slug, edit_token: key, action: 'update',
                speaker: { id: o.id, display_order: o.display_order },
              }),
              onFailure: async () => {
                speakers = await fetchSpeakers(ev.id);
                renderSpeakerList();
              },
            }));
          }
          updateStatusPills();
        }

        function showSpeakerForm(sp?: Speaker) {
          sFormHost.innerHTML = speakerFormHtml(sp);
          addSBtn.style.display = 'none';
          pendingSpeakerPhoto = null;
          const newForm = sFormHost.querySelector('form.t-form') as HTMLFormElement;
          newForm.addEventListener('submit', (e) => handleSpeakerSubmit(e, sp));
          newForm.querySelector('button.cancel')!.addEventListener('click', hideSpeakerForm);
          const fileInput = newForm.querySelector('input[type=file][data-speaker-slot]') as HTMLInputElement;
          fileInput.addEventListener('change', (e) => {
            if (sp) handleSpeakerPhotoUpload(e, sp);
            else handlePendingSpeakerPhoto(e);
          });
          // Wire the re-crop button (only present when editing a speaker
          // that already has a saved photo).
          const recropBtn = newForm.querySelector('[data-recrop-speaker]') as HTMLButtonElement | null;
          if (recropBtn && sp) {
            recropBtn.addEventListener('click', () => handleSpeakerRecrop(sp));
          }
          if (!sp) (newForm.querySelector('input[name=name]') as HTMLInputElement).focus();
        }

        function hideSpeakerForm() {
          sFormHost.innerHTML = '';
          addSBtn.style.display = '';
          pendingSpeakerPhoto = null;
        }

        async function handlePendingSpeakerPhoto(changeEv: Event) {
          const input = changeEv.target as HTMLInputElement;
          const file = input.files?.[0];
          if (!file) return;
          const slotEl = input.closest('.speaker-slot') as HTMLElement;
          const previewEl = slotEl.querySelector('.photo-preview') as HTMLElement;
          const labelEl = slotEl.querySelector('.upload-label') as HTMLElement;
          const statusEl = slotEl.querySelector('.upload-status') as HTMLElement;
          input.value = '';
          statusEl.textContent = 'Opening crop tool…';
          statusEl.className = 'upload-status';
          const cropped = await openCropModal(file, 1, 'Crop the speaker photo');
          if (!cropped) {
            statusEl.textContent = '';
            return;
          }
          pendingSpeakerPhoto = new File([cropped], 'photo.jpg', { type: 'image/jpeg' });
          const reader = new FileReader();
          reader.onload = () => {
            previewEl.innerHTML = `<img src="${reader.result}" alt="" />`;
            labelEl.textContent = 'Replace photo';
            statusEl.textContent = 'Will upload after Create';
            statusEl.className = 'upload-status';
          };
          reader.readAsDataURL(cropped);
        }

        async function uploadSpeakerPhoto(speakerId: string, file: File): Promise<string> {
          const compressed = await compressImage(file, 1200, 0.82);
          const data_b64 = await blobToBase64(compressed);
          const res = await callFunction('upload-speaker-photo', {
            slug, edit_token: key,
            speaker_id: speakerId,
            filename: 'photo.jpg',
            data: data_b64,
          });
          return res.url as string;
        }

        // Re-crop the already-saved speaker photo without re-uploading
        // the original. We fetch the storage URL → blob → File, feed it
        // back through the cropper, then upload the new crop. The
        // original (un-cropped) image isn't kept anywhere, so each
        // re-crop is from the previously cropped 1200px JPEG — fine for
        // nudges and tighter framing, but the user can't recover area
        // outside the original crop. The hint under the button explains
        // this trade-off.
        async function handleSpeakerRecrop(sp: Speaker) {
          if (!sp.photo_url) return;
          const slotEl = sFormHost.querySelector('.speaker-slot') as HTMLElement;
          const newUrl = await recropFromUrl(
            sp.photo_url, `Re-crop ${sp.name}'s photo`, 1,
            async (cropped) => {
              const data_b64 = await blobToBase64(cropped);
              const res = await callFunction('upload-speaker-photo', {
                slug, edit_token: key, speaker_id: sp.id,
                filename: 'photo.jpg', data: data_b64,
              });
              return res.url as string;
            },
            slotEl,
          );
          if (newUrl) {
            speakers = speakers.map((x) => (x.id === sp.id ? { ...x, photo_url: newUrl } : x));
            sp.photo_url = newUrl;
            renderSpeakerList();
          }
        }

        async function handleSpeakerPhotoUpload(changeEv: Event, sp: Speaker) {
          const input = changeEv.target as HTMLInputElement;
          const file = input.files?.[0];
          if (!file) return;
          const slotEl = input.closest('.speaker-slot') as HTMLElement;
          const previewEl = slotEl.querySelector('.photo-preview') as HTMLElement;
          const labelEl = slotEl.querySelector('.upload-label') as HTMLElement;
          const statusEl = slotEl.querySelector('.upload-status') as HTMLElement;
          input.value = '';
          statusEl.textContent = 'Opening crop tool…';
          statusEl.className = 'upload-status';
          try {
            const cropped = await openCropModal(file, 1, `Crop ${sp.name}'s photo`);
            if (!cropped) {
              statusEl.textContent = '';
              return;
            }
            statusEl.textContent = 'Uploading…';
            const data_b64 = await blobToBase64(cropped);
            const res = await callFunction('upload-speaker-photo', {
              slug, edit_token: key,
              speaker_id: sp.id,
              filename: 'photo.jpg', data: data_b64,
            });
            const url = res.url as string;
            speakers = speakers.map((x) => (x.id === sp.id ? { ...x, photo_url: url } : x));
            sp.photo_url = url;
            previewEl.innerHTML = `<img src="${escapeHtml(url)}" alt="" />`;
            labelEl.textContent = 'Replace photo';
            statusEl.textContent = 'Uploaded ✓';
            statusEl.className = 'upload-status ok';
            renderSpeakerList();
          } catch (err) {
            const msg = (err as Error).message;
            statusEl.textContent = fmtError(err);
            statusEl.className = 'upload-status err';
          }
        }

        async function handleSpeakerSubmit(submitEv: Event, editing?: Speaker) {
          submitEv.preventDefault();
          const formEl = submitEv.target as HTMLFormElement;
          const fd = new FormData(formEl);
          const tStatus = formEl.querySelector('.t-status') as HTMLSpanElement;
          const submit = formEl.querySelector('button[type=submit]') as HTMLButtonElement;
          submit.disabled = true;
          tStatus.textContent = 'Saving…';
          tStatus.className = 't-status';
          const speaker: Record<string, unknown> = {
            name: fd.get('name'),
            bio: fd.get('bio') || null,
            phone: fd.get('phone') || null,
            email: fd.get('email') || null,
          };
          if (editing) speaker.id = editing.id;

          try {
            const res = await callFunction('manage-speakers', {
              action: editing ? 'update' : 'add',
              slug, edit_token: key, speaker,
            });
            let saved = res.speaker as Speaker;

            if (!editing && pendingSpeakerPhoto) {
              tStatus.textContent = 'Uploading photo…';
              try {
                const url = await uploadSpeakerPhoto(saved.id, pendingSpeakerPhoto);
                saved = { ...saved, photo_url: url };
              } catch (err) {
                console.error('Failed to upload speaker photo:', err);
              }
              pendingSpeakerPhoto = null;
            }

            if (editing) {
              speakers = speakers.map((s) => (s.id === saved.id ? saved : s));
            } else {
              speakers = [...speakers, saved];
            }
            renderSpeakerList();

            if (editing) {
              tStatus.textContent = 'Saved ✓';
              tStatus.className = 't-status ok';
              submit.disabled = false;
            } else {
              showSpeakerForm(saved);
              const reopenStatus = sFormHost.querySelector('.t-status') as HTMLSpanElement;
              if (reopenStatus) {
                reopenStatus.textContent = 'Created ✓';
                reopenStatus.className = 't-status ok';
              }
            }
          } catch (err) {
            const msg = (err as Error).message;
            tStatus.textContent = fmtError(err);
            tStatus.className = 't-status err';
            submit.disabled = false;
          }
        }

        async function handleSpeakerDelete(id: string) {
          const sp = speakers.find((x) => x.id === id);
          if (!sp) return;
          if (!confirm(`Delete ${sp.name}'s bio?\n\nThis can't be undone.`)) return;
          try {
            await callFunction('manage-speakers', {
              action: 'delete', slug, edit_token: key, speaker_id: id,
            });
            speakers = speakers.filter((x) => x.id !== id);
            renderSpeakerList();
          } catch (err) {
            alert('Could not delete: ' + (err as Error).message);
          }
        }

        addSBtn.addEventListener('click', () => showSpeakerForm());
        sList.addEventListener('click', (clickEv) => {
          const target = clickEv.target as HTMLElement;
          if (target.tagName !== 'BUTTON') return;
          const id = target.getAttribute('data-id');
          if (!id) return;
          if (target.classList.contains('edit')) {
            const sp = speakers.find((x) => x.id === id);
            if (sp) showSpeakerForm(sp);
          } else if (target.classList.contains('del')) {
            handleSpeakerDelete(id);
          }
        });
        renderSpeakerList();

        // ---------- Hosts card: master organizer form ----------
        // Lives in the same card as the co-host list now (was buried in
        // Event details). Saves through update-event with just the
        // organizer_* + show_organizer_badge fields — partial updates are
        // supported server-side, so this doesn't touch event name/date/etc.
        const organizerForm = document.getElementById('organizer-form') as HTMLFormElement;
        const organizerSaveBtn = document.getElementById('organizer-save-btn') as HTMLButtonElement;
        const organizerSaveStatus = document.getElementById('organizer-save-status')!;
        organizerForm.addEventListener('submit', async (submitEv) => {
          submitEv.preventDefault();
          organizerSaveBtn.disabled = true;
          organizerSaveStatus.textContent = 'Saving…';
          organizerSaveStatus.className = '';
          const fd = new FormData(organizerForm);
          try {
            await callFunction('update-event', {
              slug, edit_token: key,
              organizer_name: fd.get('organizer_name') || null,
              organizer_bio: fd.get('organizer_bio') || null,
              organizer_email: fd.get('organizer_email') || null,
              organizer_phone: fd.get('organizer_phone') || null,
              organizer_website: fd.get('organizer_website') || null,
              show_organizer_badge: fd.get('show_organizer_badge') === 'on',
            });
            organizerSaveStatus.textContent = 'Saved ✓';
            organizerSaveStatus.className = 'ok';
          } catch (err) {
            const msg = (err as Error).message;
            organizerSaveStatus.textContent = fmtError(err);
            organizerSaveStatus.className = 'err';
          } finally {
            organizerSaveBtn.disabled = false;
          }
        });

        // Organizer photo — uploaded inline (not gated on the Save button)
        // so the user can fix a crop without committing every text field.
        // Patches events.organizer_photo_url via upload-event-photo kind=organizer.
        let organizerPhotoUrl: string | null = ev.organizer_photo_url || null;
        const organizerSlot = organizerForm.querySelector('.organizer-slot') as HTMLElement;
        async function uploadOrganizerCrop(file: File, statusEl: HTMLElement, previewEl: HTMLElement, labelEl: HTMLElement, recropExisting: boolean): Promise<void> {
          statusEl.textContent = 'Opening crop tool…';
          statusEl.className = 'upload-status';
          const cropped = await openCropModal(file, 1, recropExisting ? `Re-crop your photo` : `Crop your photo`);
          if (!cropped) { statusEl.textContent = ''; return; }
          statusEl.textContent = 'Uploading…';
          const compressed = await compressImage(new File([cropped], 'photo.jpg', { type: 'image/jpeg' }), 1200, 0.82);
          const data_b64 = await blobToBase64(compressed);
          const res = await callFunction('upload-event-photo', {
            slug, edit_token: key, kind: 'organizer',
            filename: 'photo.jpg', data: data_b64,
          });
          const url = res.url as string;
          organizerPhotoUrl = url;
          // Cache-bust so a re-crop renders the new image immediately.
          previewEl.innerHTML = `<img src="${escapeHtml(appendCacheBust(url))}" alt="" />`;
          labelEl.textContent = 'Replace photo';
          statusEl.textContent = recropExisting ? 'Re-cropped ✓' : 'Uploaded ✓';
          statusEl.className = 'upload-status ok';
          // Surface the re-crop button now that a saved photo exists.
          if (!organizerSlot.querySelector('[data-recrop-organizer]')) {
            const actions = organizerSlot.querySelector('.photo-actions');
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'upload-btn recrop-btn';
            btn.setAttribute('data-recrop-organizer', '');
            btn.textContent = '✂️ Re-crop current';
            btn.addEventListener('click', handleOrganizerRecrop);
            actions?.appendChild(btn);
          }
        }
        const organizerFileInput = organizerSlot.querySelector('input[type=file][data-organizer-slot]') as HTMLInputElement;
        organizerFileInput.addEventListener('change', async (changeEv) => {
          const file = (changeEv.target as HTMLInputElement).files?.[0];
          if (!file) return;
          (changeEv.target as HTMLInputElement).value = '';
          const previewEl = organizerSlot.querySelector('.photo-preview') as HTMLElement;
          const labelEl = organizerSlot.querySelector('.upload-label') as HTMLElement;
          const statusEl = organizerSlot.querySelector('.upload-status') as HTMLElement;
          try {
            await uploadOrganizerCrop(file, statusEl, previewEl, labelEl, false);
          } catch (err) {
            const msg = (err as Error).message;
            statusEl.textContent = fmtError(err);
            statusEl.className = 'upload-status err';
          }
        });
        async function handleOrganizerRecrop(): Promise<void> {
          if (!organizerPhotoUrl) return;
          const previewEl = organizerSlot.querySelector('.photo-preview') as HTMLElement;
          const labelEl = organizerSlot.querySelector('.upload-label') as HTMLElement;
          const statusEl = organizerSlot.querySelector('.upload-status') as HTMLElement;
          const recropBtn = organizerSlot.querySelector('[data-recrop-organizer]') as HTMLButtonElement | null;
          if (recropBtn) recropBtn.disabled = true;
          statusEl.textContent = 'Fetching current photo…';
          statusEl.className = 'upload-status';
          try {
            const fetched = await fetch(appendCacheBust(organizerPhotoUrl));
            if (!fetched.ok) throw new Error('Could not load the saved photo (HTTP ' + fetched.status + ')');
            const blob = await fetched.blob();
            const file = new File([blob], 'photo.jpg', { type: blob.type || 'image/jpeg' });
            await uploadOrganizerCrop(file, statusEl, previewEl, labelEl, true);
          } catch (err) {
            const msg = (err as Error).message;
            statusEl.textContent = fmtError(err);
            statusEl.className = 'upload-status err';
          } finally {
            if (recropBtn) recropBtn.disabled = false;
          }
        }
        const initialRecropBtn = organizerSlot.querySelector('[data-recrop-organizer]') as HTMLButtonElement | null;
        if (initialRecropBtn) initialRecropBtn.addEventListener('click', handleOrganizerRecrop);

        // ---------- Coaching Program card ----------
        // Title/body/image save through update-event partials, hero image
        // uploads via upload-event-photo kind=coaching (parallels the
        // organizer/prize photo flow above).
        const coachingForm = document.getElementById('coaching-form') as HTMLFormElement;
        const coachingSaveBtn = document.getElementById('coaching-save-btn') as HTMLButtonElement;
        const coachingSaveStatus = document.getElementById('coaching-save-status')!;
        coachingForm.addEventListener('submit', async (submitEv) => {
          submitEv.preventDefault();
          coachingSaveBtn.disabled = true;
          coachingSaveStatus.textContent = 'Saving…';
          coachingSaveStatus.className = '';
          const fd = new FormData(coachingForm);
          try {
            await callFunction('update-event', {
              slug, edit_token: key,
              coaching_title: (fd.get('coaching_title') as string)?.trim() || null,
              coaching_body: (fd.get('coaching_body') as string)?.trim() || null,
            });
            coachingSaveStatus.textContent = 'Saved ✓';
            coachingSaveStatus.className = 'ok';
          } catch (err) {
            coachingSaveStatus.textContent = fmtError(err);
            coachingSaveStatus.className = 'err';
          } finally {
            coachingSaveBtn.disabled = false;
          }
        });

        // Coaching hero image — free aspect ratio so the user can pick
        // landscape (banner) or portrait (poster) depending on the source.
        // The public page displays whatever shape they choose.
        let coachingImageUrl: string | null = ev.coaching_image_url || null;
        const coachingSlot = coachingForm.querySelector('.coaching-slot') as HTMLElement;
        async function uploadCoachingCrop(file: File, statusEl: HTMLElement, previewEl: HTMLElement, labelEl: HTMLElement, recropExisting: boolean): Promise<void> {
          statusEl.textContent = 'Opening crop tool…';
          statusEl.className = 'upload-status';
          // NaN = free aspect (cropperjs convention); freeZoom lets them
          // pull the crop box to any size relative to the source image.
          const cropped = await openCropModal(file, NaN, recropExisting ? `Re-crop hero image` : `Crop hero image (landscape or portrait)`, { freeZoom: true });
          if (!cropped) { statusEl.textContent = ''; return; }
          statusEl.textContent = 'Uploading…';
          const compressed = await compressImage(new File([cropped], 'hero.jpg', { type: 'image/jpeg' }), 1600, 0.82);
          const data_b64 = await blobToBase64(compressed);
          const res = await callFunction('upload-event-photo', {
            slug, edit_token: key, kind: 'coaching',
            filename: 'hero.jpg', data: data_b64,
          });
          const url = res.url as string;
          coachingImageUrl = url;
          previewEl.innerHTML = `<img src="${escapeHtml(appendCacheBust(url))}" alt="" />`;
          labelEl.textContent = 'Replace image';
          statusEl.textContent = recropExisting ? 'Re-cropped ✓' : 'Uploaded ✓';
          statusEl.className = 'upload-status ok';
          const actions = coachingSlot.querySelector('.photo-actions');
          if (actions && !coachingSlot.querySelector('[data-recrop-coaching]')) {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'upload-btn recrop-btn';
            btn.setAttribute('data-recrop-coaching', '');
            btn.textContent = '✂️ Re-crop current';
            btn.addEventListener('click', handleCoachingRecrop);
            actions.appendChild(btn);
          }
          if (actions && !coachingSlot.querySelector('[data-remove-coaching]')) {
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'upload-btn';
            btn.setAttribute('data-remove-coaching', '');
            btn.textContent = 'Remove image';
            btn.addEventListener('click', handleCoachingRemove);
            actions.appendChild(btn);
          }
        }
        const coachingFileInput = coachingSlot.querySelector('input[type=file][data-coaching-slot]') as HTMLInputElement;
        coachingFileInput.addEventListener('change', async (changeEv) => {
          const file = (changeEv.target as HTMLInputElement).files?.[0];
          if (!file) return;
          (changeEv.target as HTMLInputElement).value = '';
          const previewEl = coachingSlot.querySelector('.photo-preview') as HTMLElement;
          const labelEl = coachingSlot.querySelector('.upload-label') as HTMLElement;
          const statusEl = coachingSlot.querySelector('.upload-status') as HTMLElement;
          try {
            await uploadCoachingCrop(file, statusEl, previewEl, labelEl, false);
          } catch (err) {
            statusEl.textContent = fmtError(err);
            statusEl.className = 'upload-status err';
          }
        });
        async function handleCoachingRecrop(): Promise<void> {
          if (!coachingImageUrl) return;
          const previewEl = coachingSlot.querySelector('.photo-preview') as HTMLElement;
          const labelEl = coachingSlot.querySelector('.upload-label') as HTMLElement;
          const statusEl = coachingSlot.querySelector('.upload-status') as HTMLElement;
          const recropBtn = coachingSlot.querySelector('[data-recrop-coaching]') as HTMLButtonElement | null;
          if (recropBtn) recropBtn.disabled = true;
          statusEl.textContent = 'Fetching current image…';
          statusEl.className = 'upload-status';
          try {
            const fetched = await fetch(appendCacheBust(coachingImageUrl));
            if (!fetched.ok) throw new Error('Could not load the saved image (HTTP ' + fetched.status + ')');
            const blob = await fetched.blob();
            const file = new File([blob], 'hero.jpg', { type: blob.type || 'image/jpeg' });
            await uploadCoachingCrop(file, statusEl, previewEl, labelEl, true);
          } catch (err) {
            statusEl.textContent = fmtError(err);
            statusEl.className = 'upload-status err';
          } finally {
            if (recropBtn) recropBtn.disabled = false;
          }
        }
        async function handleCoachingRemove(): Promise<void> {
          const previewEl = coachingSlot.querySelector('.photo-preview') as HTMLElement;
          const labelEl = coachingSlot.querySelector('.upload-label') as HTMLElement;
          const statusEl = coachingSlot.querySelector('.upload-status') as HTMLElement;
          statusEl.textContent = 'Removing…';
          statusEl.className = 'upload-status';
          try {
            await callFunction('update-event', {
              slug, edit_token: key, coaching_image_url: null,
            });
            coachingImageUrl = null;
            previewEl.innerHTML = '<div class="empty">No image</div>';
            labelEl.textContent = 'Upload image';
            coachingSlot.querySelector('[data-recrop-coaching]')?.remove();
            coachingSlot.querySelector('[data-remove-coaching]')?.remove();
            statusEl.textContent = 'Removed ✓';
            statusEl.className = 'upload-status ok';
          } catch (err) {
            statusEl.textContent = fmtError(err);
            statusEl.className = 'upload-status err';
          }
        }
        const initialCoachingRecrop = coachingSlot.querySelector('[data-recrop-coaching]') as HTMLButtonElement | null;
        if (initialCoachingRecrop) initialCoachingRecrop.addEventListener('click', handleCoachingRecrop);
        const initialCoachingRemove = coachingSlot.querySelector('[data-remove-coaching]') as HTMLButtonElement | null;
        if (initialCoachingRemove) initialCoachingRemove.addEventListener('click', handleCoachingRemove);

        // ---------- Co-hosts ----------
        type Host = {
          id: string;
          name: string | null;
          email: string | null;
          phone: string | null;
          bio: string | null;
          website: string | null;
          photo_url: string | null;
          display_order: number;
          host_token: string | null; // null when the viewer isn't the master
          created_at: string;
        };
        const hostsList = document.getElementById('hosts-list')!;
        const hostsAddSection = document.getElementById('hosts-add-host')!;
        const hostsBlurb = document.getElementById('hosts-blurb')!;
        const organizerStatus = document.getElementById('organizer-status') as HTMLDivElement | null;
        let isMaster = false;
        let primaryHostId: string | null = null;
        let hostsCache: Host[] = [];
        let pendingHostPhoto: File | null = null;
        let hostsSortable: Sortable | null = null;

        function hostUrl(token: string): string {
          return window.location.origin + editUrlOf(base, slug!, token);
        }

        // Photo slot HTML for the host add/edit form. Mirrors speakerFormHtml's
        // photo block — same data attributes (data-host-slot) so the form
        // wiring stays parallel.
        function hostPhotoSlotHtml(h?: Host): string {
          const url = h?.photo_url || null;
          const showRecrop = !!(h && url);
          return `
            <div class="photo-slot host-slot" data-host-slot>
              <span class="slot-label">Photo</span>
              <div class="photo-preview speaker-preview">
                ${url
                  ? `<img src="${escapeHtml(url)}" alt="" />`
                  : '<div class="empty">No photo</div>'}
              </div>
              <div class="photo-actions">
                <label class="upload-btn">
                  <input type="file" accept="image/*" data-host-slot hidden />
                  <span class="upload-label">${url ? 'Replace photo' : 'Upload photo'}</span>
                </label>
                ${showRecrop
                  ? `<button type="button" class="upload-btn recrop-btn" data-recrop-host>✂️ Re-crop current</button>`
                  : ''}
              </div>
              ${showRecrop
                ? '<span class="recrop-hint">Re-crop adjusts the saved photo (1200px wide). To recover area outside the original crop, use Replace photo with the original file.</span>'
                : ''}
              <span class="upload-status" data-host-slot></span>
            </div>`;
        }

        async function uploadHostPhoto(hostId: string, file: File): Promise<string> {
          const compressed = await compressImage(file, 1200, 0.82);
          const data_b64 = await blobToBase64(compressed);
          const res = await callFunction('upload-host-photo', {
            slug, edit_token: key,
            host_id: hostId,
            filename: 'photo.jpg',
            data: data_b64,
          });
          return res.url as string;
        }

        async function handlePendingHostPhoto(changeEv: Event) {
          const input = changeEv.target as HTMLInputElement;
          const file = input.files?.[0];
          if (!file) return;
          const slotEl = input.closest('.host-slot') as HTMLElement;
          const previewEl = slotEl.querySelector('.photo-preview') as HTMLElement;
          const labelEl = slotEl.querySelector('.upload-label') as HTMLElement;
          const statusEl = slotEl.querySelector('.upload-status') as HTMLElement;
          input.value = '';
          statusEl.textContent = 'Opening crop tool…';
          statusEl.className = 'upload-status';
          const cropped = await openCropModal(file, 1, 'Crop the co-host photo');
          if (!cropped) {
            statusEl.textContent = '';
            return;
          }
          pendingHostPhoto = new File([cropped], 'photo.jpg', { type: 'image/jpeg' });
          const reader = new FileReader();
          reader.onload = () => {
            previewEl.innerHTML = `<img src="${reader.result}" alt="" />`;
            labelEl.textContent = 'Replace photo';
            statusEl.textContent = 'Will upload after Generate co-host link';
            statusEl.className = 'upload-status';
          };
          reader.readAsDataURL(cropped);
        }

        async function handleHostPhotoUpload(changeEv: Event, h: Host) {
          const input = changeEv.target as HTMLInputElement;
          const file = input.files?.[0];
          if (!file) return;
          const slotEl = input.closest('.host-slot') as HTMLElement;
          const previewEl = slotEl.querySelector('.photo-preview') as HTMLElement;
          const labelEl = slotEl.querySelector('.upload-label') as HTMLElement;
          const statusEl = slotEl.querySelector('.upload-status') as HTMLElement;
          input.value = '';
          statusEl.textContent = 'Opening crop tool…';
          statusEl.className = 'upload-status';
          try {
            const cropped = await openCropModal(file, 1, `Crop ${h.name || 'co-host'}'s photo`);
            if (!cropped) {
              statusEl.textContent = '';
              return;
            }
            statusEl.textContent = 'Uploading…';
            const data_b64 = await blobToBase64(cropped);
            const res = await callFunction('upload-host-photo', {
              slug, edit_token: key,
              host_id: h.id,
              filename: 'photo.jpg', data: data_b64,
            });
            const url = res.url as string;
            hostsCache = hostsCache.map((x) => (x.id === h.id ? { ...x, photo_url: url } : x));
            h.photo_url = url;
            previewEl.innerHTML = `<img src="${escapeHtml(url)}" alt="" />`;
            labelEl.textContent = 'Replace photo';
            statusEl.textContent = 'Uploaded ✓';
            statusEl.className = 'upload-status ok';
            renderHosts(hostsCache);
          } catch (err) {
            const msg = (err as Error).message;
            statusEl.textContent = fmtError(err);
            statusEl.className = 'upload-status err';
          }
        }

        // Same trade-off as handleSpeakerRecrop — re-crops from the saved
        // 1200px JPEG, so framing can be tightened but area outside the
        // original crop can't be recovered.
        async function handleHostRecrop(h: Host) {
          if (!h.photo_url) return;
          const slotEl = hostsAddSection.querySelector('.host-slot') as HTMLElement;
          const newUrl = await recropFromUrl(
            h.photo_url, `Re-crop ${h.name || 'co-host'}'s photo`, 1,
            async (cropped) => {
              const data_b64 = await blobToBase64(cropped);
              const res = await callFunction('upload-host-photo', {
                slug, edit_token: key, host_id: h.id,
                filename: 'photo.jpg', data: data_b64,
              });
              return res.url as string;
            },
            slotEl,
          );
          if (newUrl) {
            hostsCache = hostsCache.map((x) => (x.id === h.id ? { ...x, photo_url: newUrl } : x));
            h.photo_url = newUrl;
            renderHosts(hostsCache);
          }
        }

        function renderHosts(hosts: Host[]) {
          // Role-correct blurb. Master sees the "add other people" pitch
          // and the form. Co-hosts see a clear "you can't manage hosts"
          // explainer instead — and no form. The misleading master-only
          // copy used to render for everyone.
          if (isMaster) {
            hostsBlurb.textContent = 'Add other people who should be able to edit this event. Each co-host gets their own private edit URL. Only you (the original host) can add or remove.';
            hostsBlurb.style.fontStyle = '';
          } else {
            hostsBlurb.textContent = 'You are a co-host on this event. You can edit everything else, but only the original host can add or remove co-hosts.';
            hostsBlurb.style.fontStyle = 'italic';
          }
          if (isMaster) {
            renderAddHostForm();
          } else {
            // Co-host: no add form. The blurb above already says why.
            hostsAddSection.innerHTML = '';
          }

          if (hosts.length === 0) {
            hostsList.innerHTML = `<li class="hosts-empty">
              <strong>No co-hosts yet.</strong>
              Co-hosts get their own private edit link so they can update their bio, photo, and contact info without touching anything else. They appear alongside you on the public hosts page.
              <span class="empty-hint">Tip: only the master organizer (you) can add or remove co-hosts. Once added, share their personal link via the Copy button next to their row.</span>
            </li>`;
            return;
          }
          hostsList.innerHTML = hosts.map((h) => {
            const created = new Date(h.created_at);
            const createdTxt = isNaN(created.getTime())
              ? h.created_at
              : created.toLocaleDateString();
            const isCurrentOrganizer = primaryHostId === h.id;
            const contactBits: string[] = [];
            if (h.phone) contactBits.push(`📞 ${escapeHtml(h.phone)}`);
            if (h.email) contactBits.push(`✉️ ${escapeHtml(h.email)}`);
            if (h.website) contactBits.push(`🌐 ${escapeHtml(h.website)}`);
            return `
              <li class="t-row host-row ${isCurrentOrganizer ? 'is-organizer' : ''}" data-id="${h.id}">
                ${isMaster ? dragHandleHtml() : ''}
                ${h.photo_url
                  ? `<img class="t-thumb" src="${escapeHtml(h.photo_url)}" alt="" style="border-radius:50%;width:56px;height:56px;" />`
                  : '<div class="t-thumb empty" style="border-radius:50%;width:56px;height:56px;"></div>'}
                <div class="t-info">
                  <strong>
                    ${escapeHtml(h.name || 'Unnamed co-host')}
                    ${isCurrentOrganizer ? '<span class="host-organizer-badge">organizer</span>' : ''}
                  </strong>
                  ${contactBits.length ? `<span class="t-meta">${contactBits.join(' · ')}</span>` : ''}
                  ${h.bio ? `<span class="t-meta">${escapeHtml(h.bio.slice(0, 80))}${h.bio.length > 80 ? '…' : ''}</span>` : ''}
                  <span class="t-meta">added ${escapeHtml(createdTxt)}</span>
                  ${h.host_token
                    ? `<div class="host-link">
                        <input type="text" readonly value="${escapeHtml(hostUrl(h.host_token))}" />
                        <button type="button" class="copy-host" data-url="${escapeHtml(hostUrl(h.host_token))}">Copy</button>
                      </div>`
                    : ''}
                </div>
                ${isMaster
                  ? `<div class="t-actions host-actions">
                      ${isCurrentOrganizer
                        ? '<button type="button" class="organizer-btn current" disabled>Organizer ✓</button>'
                        : `<button type="button" class="organizer-btn make" data-id="${h.id}">Make organizer</button>`}
                      <button type="button" class="edit-host" data-id="${h.id}">Edit</button>
                      <button type="button" class="remove-host" data-id="${h.id}" data-name="${escapeHtml(h.name || 'this co-host')}">Remove</button>
                    </div>`
                  : ''}
              </li>`;
          }).join('');
          // Drag-to-reorder is master-only. Co-host viewers see no handle
          // and no Sortable instance gets wired on this list.
          if (hostsSortable) { hostsSortable.destroy(); hostsSortable = null; }
          if (isMaster && hosts.length > 1) {
            hostsSortable = wireSortable(hostsList as HTMLElement, (order) => applyReorder({
              order,
              items: hostsCache,
              setItems: (next) => { hostsCache = next; },
              patchOne: (o) => callFunction('manage-hosts', {
                slug, edit_token: key, action: 'update',
                host_id: o.id, display_order: o.display_order,
              }),
              onFailure: loadHosts,
            }));
          }
        }

        async function loadHosts() {
          try {
            const res = await callFunction('manage-hosts', {
              slug,
              edit_token: key,
              action: 'list',
            });
            isMaster = !!res.you_are_master;
            primaryHostId = (res.primary_host_id ?? null) as string | null;
            hostsCache = res.hosts as Host[];
            renderHosts(hostsCache);
            renderOrganizerBanner();
          } catch (err) {
            hostsList.innerHTML =
              `<li class="hosts-empty err">Could not load co-hosts: ${escapeHtml((err as Error).message)}</li>`;
          }
        }

        function renderOrganizerBanner() {
          if (!organizerStatus) return;
          const currentCohost = primaryHostId
            ? hostsCache.find((h) => h.id === primaryHostId)
            : null;
          if (!isMaster) {
            organizerStatus.innerHTML = '';
            return;
          }
          if (currentCohost) {
            organizerStatus.innerHTML = `
              <div class="org-banner">
                <span class="org-banner-line">
                  Public-page <strong>organizer</strong>:
                  <strong class="who">${escapeHtml(currentCohost.name || 'co-host')}</strong>
                </span>
                <button type="button" id="organizer-reset" class="organizer-btn make">Take it back</button>
              </div>`;
            document.getElementById('organizer-reset')!.addEventListener('click', () => setPrimary(null));
          } else {
            organizerStatus.innerHTML = `
              <div class="org-banner">
                <span class="org-banner-line">
                  Public-page <strong>organizer</strong>: <strong class="who">You</strong>
                  <span class="org-banner-hint">(tap "Make organizer" on a co-host to pass it on)</span>
                </span>
              </div>`;
          }
        }

        async function setPrimary(targetId: string | null) {
          try {
            await callFunction('manage-hosts', {
              slug, edit_token: key, action: 'set_primary',
              host_id: targetId,
            });
            primaryHostId = targetId;
            renderHosts(hostsCache);
            renderOrganizerBanner();
          } catch (err) {
            alert('Could not change organizer: ' + (err as Error).message);
          }
        }

        function renderAddHostForm() {
          pendingHostPhoto = null;
          hostsAddSection.innerHTML = `
            <form id="add-host-form" class="add-host-form" novalidate>
              <label>
                Co-host name
                <input name="name" maxlength="120" placeholder="Host Sam" />
              </label>
              <label>
                Short bio <span class="opt">(2–3 sentences, public)</span>
                <textarea name="bio" rows="3" maxlength="500" placeholder="What attendees should know about this co-host."></textarea>
              </label>
              <div class="grid-2">
                <label>
                  Phone <span class="opt">(public)</span>
                  <input type="tel" name="phone" placeholder="555-123-4567" />
                </label>
                <label>
                  Email <span class="opt">(private)</span>
                  <input type="email" name="email" />
                </label>
              </div>
              <label>
                Website <span class="opt">(public)</span>
                <input type="url" name="website" placeholder="https://example.com" />
              </label>
              ${hostPhotoSlotHtml()}
              <div class="row">
                <button type="submit">+ Generate co-host link</button>
                <span id="add-host-status" role="status" aria-live="polite"></span>
              </div>
            </form>`;
          const formEl = document.getElementById('add-host-form') as HTMLFormElement;
          formEl.addEventListener('submit', handleAddHost);
          const fileInput = formEl.querySelector('input[type=file][data-host-slot]') as HTMLInputElement;
          fileInput.addEventListener('change', handlePendingHostPhoto);
        }

        function showEditHostForm(h: Host) {
          pendingHostPhoto = null;
          hostsAddSection.innerHTML = `
            <form id="edit-host-form" class="add-host-form edit-mode" novalidate data-id="${escapeHtml(h.id)}">
              <p class="edit-host-title">Editing <strong>${escapeHtml(h.name || 'this co-host')}</strong></p>
              <label>
                Co-host name
                <input name="name" maxlength="120" value="${escapeHtml(h.name || '')}" />
              </label>
              <label>
                Short bio <span class="opt">(2–3 sentences, public)</span>
                <textarea name="bio" rows="3" maxlength="500" placeholder="What attendees should know about this co-host.">${escapeHtml(h.bio || '')}</textarea>
              </label>
              <div class="grid-2">
                <label>
                  Phone <span class="opt">(public)</span>
                  <input type="tel" name="phone" value="${escapeHtml(h.phone || '')}" />
                </label>
                <label>
                  Email <span class="opt">(private)</span>
                  <input type="email" name="email" value="${escapeHtml(h.email || '')}" />
                </label>
              </div>
              <label>
                Website <span class="opt">(public)</span>
                <input type="url" name="website" value="${escapeHtml(h.website || '')}" placeholder="https://example.com" />
              </label>
              ${hostPhotoSlotHtml(h)}
              <div class="row">
                <button type="submit">Save changes</button>
                <button type="button" id="cancel-edit-host">Cancel</button>
                <span id="edit-host-status" role="status" aria-live="polite"></span>
              </div>
            </form>`;
          const formEl = document.getElementById('edit-host-form') as HTMLFormElement;
          formEl.addEventListener('submit', (e) => handleUpdateHost(e, h.id));
          document.getElementById('cancel-edit-host')!
            .addEventListener('click', () => renderAddHostForm());
          const fileInput = formEl.querySelector('input[type=file][data-host-slot]') as HTMLInputElement;
          fileInput.addEventListener('change', (e) => handleHostPhotoUpload(e, h));
          const recropBtn = formEl.querySelector('[data-recrop-host]') as HTMLButtonElement | null;
          if (recropBtn) recropBtn.addEventListener('click', () => handleHostRecrop(h));
          hostsAddSection.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        async function handleUpdateHost(submitEv: Event, hostId: string) {
          submitEv.preventDefault();
          const formEl = submitEv.target as HTMLFormElement;
          const fd = new FormData(formEl);
          const statusEl = document.getElementById('edit-host-status')!;
          const submitBtn = formEl.querySelector('button[type=submit]') as HTMLButtonElement;
          submitBtn.disabled = true;
          statusEl.textContent = 'Saving…';
          statusEl.className = '';
          try {
            await callFunction('manage-hosts', {
              slug, edit_token: key, action: 'update',
              host_id: hostId,
              name: fd.get('name') || null,
              phone: fd.get('phone') || null,
              email: fd.get('email') || null,
              bio: fd.get('bio') || null,
              website: fd.get('website') || null,
            });
            await loadHosts();
            renderAddHostForm();
          } catch (err) {
            const msg = (err as Error).message;
            statusEl.textContent = fmtError(err);
            statusEl.className = 'err';
            submitBtn.disabled = false;
          }
        }

        async function handleAddHost(submitEv: Event) {
          submitEv.preventDefault();
          const formEl = submitEv.target as HTMLFormElement;
          const fd = new FormData(formEl);
          const statusEl = document.getElementById('add-host-status')!;
          const submitBtn = formEl.querySelector('button[type=submit]') as HTMLButtonElement;
          submitBtn.disabled = true;
          statusEl.textContent = 'Adding…';
          statusEl.className = '';
          try {
            const addRes = await callFunction('manage-hosts', {
              slug,
              edit_token: key,
              action: 'add',
              name: fd.get('name') || null,
              email: fd.get('email') || null,
              phone: fd.get('phone') || null,
              bio: fd.get('bio') || null,
              website: fd.get('website') || null,
            });
            const newHostId = addRes?.host?.id as string | undefined;
            if (pendingHostPhoto && newHostId) {
              statusEl.textContent = 'Uploading photo…';
              try {
                await uploadHostPhoto(newHostId, pendingHostPhoto);
              } catch (err) {
                console.error('Failed to upload host photo:', err);
              }
              pendingHostPhoto = null;
            }
            statusEl.textContent = 'Added ✓';
            statusEl.className = 'ok';
            formEl.reset();
            await loadHosts();
            renderAddHostForm();
          } catch (err) {
            statusEl.textContent = (err as Error).message;
            statusEl.className = 'err';
          } finally {
            submitBtn.disabled = false;
          }
        }

        hostsList.addEventListener('click', async (ev) => {
          const target = ev.target as HTMLElement;
          if (target.classList.contains('remove-host')) {
            const id = target.getAttribute('data-id')!;
            const name = target.getAttribute('data-name')!;
            if (!confirm(`Remove ${name}? Their edit link will stop working immediately.`)) return;
            try {
              await callFunction('manage-hosts', {
                slug, edit_token: key, action: 'remove', host_id: id,
              });
              await loadHosts();
            } catch (err) {
              alert('Could not remove: ' + (err as Error).message);
            }
          } else if (target.classList.contains('copy-host')) {
            const url = target.getAttribute('data-url')!;
            await navigator.clipboard.writeText(url);
            const orig = target.textContent;
            target.textContent = 'Copied!';
            setTimeout(() => (target.textContent = orig), 1200);
          } else if (target.classList.contains('organizer-btn') && target.classList.contains('make')) {
            const id = target.getAttribute('data-id');
            if (id) await setPrimary(id);
          } else if (target.classList.contains('edit-host')) {
            const id = target.getAttribute('data-id');
            const h = hostsCache.find((x) => x.id === id);
            if (h) showEditHostForm(h);
          }
        });

        // After both speakers (already fetched above) and hosts load, sync
        // host photos → speaker photos when a person is both. Hosts are
        // where the master typically adds a nicely cropped headshot; the
        // matching Speaker row often gets filled in without one. Copying
        // it over means the /speakers page, agenda slide photos, and the
        // coaching grid all show the same face. Match is case-insensitive
        // on trimmed full name; we only fill, never overwrite. Idempotent
        // — re-runs every page load but only does work on mismatches.
        async function syncHostPhotosToSpeakers() {
          const hostByName = new Map<string, Host>();
          for (const h of hostsCache) {
            if (!h.name || !h.photo_url) continue;
            hostByName.set(h.name.trim().toLowerCase(), h);
          }
          if (hostByName.size === 0) return;
          const targets = speakers.filter((s) => {
            if (s.photo_url || !s.name) return false;
            return hostByName.has(s.name.trim().toLowerCase());
          });
          if (targets.length === 0) return;
          let updated = 0;
          for (const sp of targets) {
            const host = hostByName.get(sp.name.trim().toLowerCase())!;
            try {
              await callFunction('manage-speakers', {
                slug, edit_token: key, action: 'update',
                speaker: { id: sp.id, photo_url: host.photo_url },
              });
              speakers = speakers.map((x) => x.id === sp.id ? { ...x, photo_url: host.photo_url } : x);
              updated++;
            } catch (err) {
              console.warn('[host→speaker photo sync] failed for', sp.name, err);
            }
          }
          if (updated > 0) {
            renderSpeakerList();
            console.log(`[host→speaker photo sync] copied ${updated} photo${updated === 1 ? '' : 's'}`);
          }
        }
        loadHosts().then(() => syncHostPhotosToSpeakers());

        // ---------- Agenda / cue sheet ----------
        type AgendaItem = {
          id: string;
          time_label: string;
          segment: string;
          speaker: string | null;
          details: string | null;
          duration_minutes: number;
          display_order: number;
        };
        type AgendaSlide = {
          id: string;
          agenda_item_id: string;
          title: string;
          body: string | null;
          image_url: string | null;
          display_order: number;
          created_at: string;
        };
        let agenda: AgendaItem[] = await fetchAgendaItems(ev.id);
        // Sub-slides keyed by parent agenda_item_id. Loaded once at init,
        // mutated locally on add/edit/delete, refetched only on errors.
        let slidesByItem: Record<string, AgendaSlide[]> = {};
        try {
          const sRes = await callFunction('manage-agenda-slides', {
            slug, edit_token: key, action: 'list',
          });
          for (const s of ((sRes.slides as AgendaSlide[]) || [])) {
            (slidesByItem[s.agenda_item_id] ||= []).push(s);
          }
        } catch (err) {
          console.error('Failed to load agenda sub-slides:', err);
        }

        const aList = document.getElementById('a-list')!;
        const aFormHost = document.getElementById('a-form-host')!;
        const addABtn = document.getElementById('add-a-btn') as HTMLButtonElement;

        function agendaFormHtml(it?: AgendaItem): string {
          const v = it || ({} as Partial<AgendaItem>);
          // Speaker / Lead is a free-text input with a native <datalist>
          // populated from the Speakers section. Users get autocomplete
          // suggestions when they focus the field, but can still type a
          // co-host or organizer name that's not in the Speakers list.
          const speakerOptions = speakers
            .map((sp) => `<option value="${escapeHtml(sp.name)}"></option>`)
            .join('');
          const durValue = (v.duration_minutes ?? 15);
          return `
            <form class="t-form" ${it ? `data-id="${it.id}"` : ''} novalidate>
              <h3>${it ? 'Edit agenda item' : 'New agenda item'}</h3>
              <div class="grid-3">
                <label>
                  Time
                  <input name="time_label" required maxlength="40" value="${escapeHtml(v.time_label || '')}" placeholder="9:00 AM" />
                </label>
                <label>
                  Duration <span class="opt">(min)</span>
                  <input type="number" name="duration_minutes" min="0" max="240" step="5" value="${durValue}" />
                </label>
                <label>
                  Speaker / Lead
                  <input name="speaker" list="agenda-speaker-options" maxlength="120" value="${escapeHtml(v.speaker || '')}" placeholder="Matt" autocomplete="off" />
                  <datalist id="agenda-speaker-options">${speakerOptions}</datalist>
                </label>
              </div>
              <label>
                Segment
                <input name="segment" required maxlength="200" value="${escapeHtml(v.segment || '')}" placeholder="Welcome & MC Kickoff" />
              </label>
              <label>
                Details
                <textarea name="details" rows="3" maxlength="2000" placeholder="What happens during this segment.">${escapeHtml(v.details || '')}</textarea>
              </label>
              <p class="cascade-hint">
                💡 Changing the <strong>duration</strong> shifts every later item by the same amount. Changing the <strong>time</strong> only moves this row.
              </p>
              <div class="row">
                <button type="submit">${it ? 'Save changes' : 'Create'}</button>
                <button type="button" class="cancel">${it ? 'Done' : 'Cancel'}</button>
                <span class="t-status" role="status" aria-live="polite"></span>
              </div>
            </form>`;
        }

        function agendaRowHtml(it: AgendaItem): string {
          const subs = slidesByItem[it.id] || [];
          const subCount = subs.length;
          const dur = it.duration_minutes ?? 15;
          return `
            <li class="t-row" data-id="${it.id}">
              <div class="t-thumb empty" style="background:rgba(243,156,18,0.18);color:var(--accent,#f39c12);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:11px;border-radius:6px;width:56px;height:auto;min-height:44px;padding:4px;text-align:center;line-height:1.1;border:none;">${escapeHtml(it.time_label)}</div>
              <div class="t-info">
                <strong>${escapeHtml(it.segment)}</strong>
                ${it.speaker ? `<span class="t-meta">${escapeHtml(it.speaker)}</span>` : ''}
                ${it.details ? `<span class="t-meta">${escapeHtml(it.details.slice(0, 90))}${it.details.length > 90 ? '…' : ''}</span>` : ''}
                <span class="duration-stepper" title="Each − or + shifts every later item by 5 min">
                  <button type="button" class="dur-minus" data-id="${it.id}" aria-label="5 minutes shorter">−</button>
                  <span class="dur-value">⏱ ${dur} min</span>
                  <button type="button" class="dur-plus" data-id="${it.id}" aria-label="5 minutes longer">+</button>
                </span>
                <details class="sub-slides-expander" data-parent="${it.id}" ${subCount > 0 ? 'open' : ''}>
                  <summary class="sub-slides-summary">💡 ${subCount} sub-slide${subCount === 1 ? '' : 's'}</summary>
                  <div class="sub-slides-body">
                    <ol class="sub-slides-list">${subs.map(subSlideRowHtml).join('')}</ol>
                    <div class="sub-slide-form-host" data-parent="${it.id}"></div>
                    <button type="button" class="add-sub-slide" data-parent="${it.id}">+ Add sub-slide</button>
                  </div>
                </details>
              </div>
              <div class="t-actions">
                <button class="edit" data-id="${it.id}">Edit</button>
                <button class="del" data-id="${it.id}">Delete</button>
              </div>
            </li>`;
        }

        function subSlideRowHtml(s: AgendaSlide): string {
          const bodyPreview = s.body
            ? `<span class="sub-slide-body-preview">${escapeHtml(s.body.slice(0, 80))}${s.body.length > 80 ? '…' : ''}</span>`
            : '';
          const thumb = s.image_url
            ? `<img class="sub-slide-thumb" src="${escapeHtml(s.image_url)}" alt="" />`
            : '<div class="sub-slide-thumb empty">—</div>';
          // Title is optional. When absent, use a dim placeholder so the
          // row still has a heading — preferring body preview if it
          // exists, otherwise an image-only marker, otherwise "(untitled)".
          const titleText = s.title?.trim();
          const heading = titleText
            ? `<strong>${escapeHtml(titleText)}</strong>`
            : (s.body
              ? `<strong class="dim">${escapeHtml(s.body.slice(0, 40))}${s.body.length > 40 ? '…' : ''}</strong>`
              : (s.image_url
                ? '<strong class="dim">(image-only slide)</strong>'
                : '<strong class="dim">(untitled)</strong>'));
          // Don't duplicate the body in the preview if it's already in the heading.
          const showBodyPreview = titleText && bodyPreview;
          return `
            <li class="sub-slide-row" data-slide-id="${s.id}">
              ${thumb}
              <div class="sub-slide-info">
                ${heading}
                ${showBodyPreview ? bodyPreview : ''}
              </div>
              <div class="sub-slide-actions">
                <button type="button" class="sub-slide-edit" data-slide-id="${s.id}">Edit</button>
                <button type="button" class="sub-slide-del" data-slide-id="${s.id}">×</button>
              </div>
            </li>`;
        }

        // Renders either an add-new form (no slide arg) or an edit form
        // (slide arg pre-fills the fields). Same fields in both cases;
        // submit handler checks slide?.id to decide add vs update.
        function subSlideFormHtml(parentId: string, slide?: AgendaSlide): string {
          const v = slide || ({} as Partial<AgendaSlide>);
          const showRecrop = !!(slide && v.image_url);
          return `
            <form class="sub-slide-form" data-parent="${parentId}" ${slide ? `data-slide-id="${slide.id}"` : ''} novalidate>
              <h4>${slide ? 'Edit sub-slide' : 'New sub-slide'}</h4>
              <label>
                Title <span class="opt">(optional)</span>
                <input name="title" maxlength="160" value="${escapeHtml(v.title || '')}" placeholder="Why metabolic health matters" />
              </label>
              <label>
                Body <span class="opt">(optional)</span>
                <textarea name="body" rows="3" maxlength="1000" placeholder="Supporting text under the title.">${escapeHtml(v.body || '')}</textarea>
              </label>
              <div class="photo-slot sub-slide-slot" data-sub-slide-slot>
                <span class="slot-label">Image <span class="opt">(optional)</span></span>
                <div class="photo-preview sub-slide-preview">
                  ${v.image_url
                    ? `<img src="${escapeHtml(v.image_url)}" alt="" />`
                    : '<div class="empty">No image</div>'}
                </div>
                <div class="photo-actions">
                  <label class="upload-btn">
                    <input type="file" accept="image/*" data-sub-slide-slot hidden ${slide ? '' : 'disabled'} />
                    <span class="upload-label">${v.image_url ? 'Replace image' : (slide ? 'Upload image' : 'Save the slide first, then upload')}</span>
                  </label>
                </div>
                <span class="upload-status" data-sub-slide-slot></span>
              </div>
              <div class="row">
                <button type="submit">${slide ? 'Save changes' : 'Create'}</button>
                <button type="button" class="cancel-sub-slide">Cancel</button>
                <span class="t-status" role="status" aria-live="polite"></span>
              </div>
            </form>`;
        }

        function renderAgendaList() {
          aList.innerHTML = agenda.length === 0
            ? `<li class="t-empty">
                <strong>No agenda items yet.</strong>
                The agenda drives the run sheet, the printed cue sheet, AND the slide deck — each item becomes one slide on the projector. Add items with a time, segment title, and speaker name.
                <span class="empty-hint">Tip: bulk-paste from a TSV (time<span style="opacity:.6">⇥</span>segment<span style="opacity:.6">⇥</span>speaker<span style="opacity:.6">⇥</span>details, one row per line) using the form above.</span>
              </li>`
            : agenda.map(agendaRowHtml).join('');
        }

        function showAgendaForm(it?: AgendaItem) {
          aFormHost.innerHTML = agendaFormHtml(it);
          addABtn.style.display = 'none';
          const pBtn = document.getElementById('paste-a-btn') as HTMLButtonElement | null;
          if (pBtn) pBtn.style.display = 'none';
          const f = aFormHost.querySelector('form.t-form') as HTMLFormElement;
          f.addEventListener('submit', (e) => handleAgendaSubmit(e, it));
          f.querySelector('button.cancel')!.addEventListener('click', hideAgendaForm);
          if (!it) (f.querySelector('input[name=time_label]') as HTMLInputElement).focus();
        }
        function hideAgendaForm() {
          aFormHost.innerHTML = '';
          addABtn.style.display = '';
          const pBtn = document.getElementById('paste-a-btn') as HTMLButtonElement | null;
          if (pBtn) pBtn.style.display = '';
        }

        // Formats minutes-since-midnight back to a time label. Preserves
        // the AM/PM suffix only if the original label used one — so a
        // host who typed "10:05" gets "10:15" back, not "10:15 AM".
        function formatTimeFromMinutes(mins: number, hadAMPM: boolean): string {
          // Wrap into [0, 24h) — shifting past midnight is unusual but
          // shouldn't crash the formatter.
          const wrap = ((mins % 1440) + 1440) % 1440;
          const h24 = Math.floor(wrap / 60);
          const m = wrap % 60;
          if (hadAMPM) {
            let h12 = h24 % 12;
            if (h12 === 0) h12 = 12;
            const ampm = h24 < 12 ? 'AM' : 'PM';
            return `${h12}:${String(m).padStart(2, '0')} ${ampm}`;
          }
          return `${h24}:${String(m).padStart(2, '0')}`;
        }

        // Shift a single time_label by N minutes, preserving the original
        // format. Returns the label unchanged if it can't parse — keeps
        // human-edited oddities ("TBD", "right after lunch") intact.
        function shiftTimeLabel(label: string | null, deltaMin: number): string {
          if (!label) return '';
          const current = parseTimeMinutes(label);
          if (!Number.isFinite(current)) return label;
          const hadAMPM = /[ap]\.?m\.?/i.test(label);
          return formatTimeFromMinutes(current + deltaMin, hadAMPM);
        }

        // Cascading shift: bumps the time_label of every agenda item that
        // comes AFTER pivotItemId in display_order by deltaMin, then fires
        // PATCH calls in parallel. Display-order-based (not parsed-time-
        // based) so items at the same time as the pivot still shift —
        // crucial when two items share a time label (e.g. Snack and Muscle
        // Build both at 10:05).
        async function cascadeTimeShift(pivotItemId: string, deltaMin: number) {
          if (!Number.isFinite(deltaMin) || deltaMin === 0) return;
          const sorted = [...agenda].sort((a, b) => a.display_order - b.display_order);
          const pivotIdx = sorted.findIndex((x) => x.id === pivotItemId);
          if (pivotIdx < 0) return;
          const updates: Array<{ id: string; time_label: string }> = [];
          for (let i = pivotIdx + 1; i < sorted.length; i++) {
            const it = sorted[i];
            const newLabel = shiftTimeLabel(it.time_label, deltaMin);
            if (newLabel !== it.time_label) {
              updates.push({ id: it.id, time_label: newLabel });
              it.time_label = newLabel;
            }
          }
          if (updates.length === 0) return;
          renderAgendaList();
          try {
            await Promise.all(updates.map((u) =>
              callFunction('manage-agenda', {
                slug, edit_token: key, action: 'update',
                item: { id: u.id, time_label: u.time_label },
              })
            ));
          } catch (err) {
            console.error('Cascade time shift failed:', err);
            agenda = await fetchAgendaItems(ev.id);
            renderAgendaList();
          }
        }

        // Parses agenda time labels into minutes-since-midnight so we can
        // sort the agenda chronologically. Accepts "9:00 AM", "10:05",
        // "12:00 PM" etc. Unparseable / empty → sorts to the end so the
        // host can still keep an item without a time at the bottom.
        function parseTimeMinutes(label: string | null): number {
          if (!label) return Number.POSITIVE_INFINITY;
          const m = label.trim().match(/^(\d{1,2}):?(\d{0,2})\s*(am|pm|a|p)?/i);
          if (!m) return Number.POSITIVE_INFINITY;
          let h = parseInt(m[1], 10);
          const mins = parseInt(m[2] || '0', 10);
          const ampm = (m[3] || '').toLowerCase();
          if (Number.isNaN(h) || h < 0 || h > 23) return Number.POSITIVE_INFINITY;
          if (Number.isNaN(mins) || mins < 0 || mins > 59) return Number.POSITIVE_INFINITY;
          if (ampm.startsWith('p') && h < 12) h += 12;
          if (ampm.startsWith('a') && h === 12) h = 0;
          return h * 60 + mins;
        }

        // After add/edit, re-sort the agenda by time_label and push
        // display_order updates for any item whose position shifted.
        // Time labels themselves are not changed — this only reorders.
        async function autoSortAgendaByTime() {
          const sorted = [...agenda].sort((a, b) => {
            const ta = parseTimeMinutes(a.time_label);
            const tb = parseTimeMinutes(b.time_label);
            if (ta !== tb) return ta - tb;
            // Stable tiebreak: keep prior display_order on equal times.
            return a.display_order - b.display_order;
          });
          // Detect which items need a display_order patch.
          const updates: Array<{ id: string; display_order: number }> = [];
          sorted.forEach((it, idx) => {
            if (it.display_order !== idx) {
              updates.push({ id: it.id, display_order: idx });
              it.display_order = idx;
            }
          });
          agenda = sorted;
          renderAgendaList();
          if (updates.length === 0) return;
          // Fire patches in parallel — small set even for a full re-sort.
          try {
            await Promise.all(updates.map((u) =>
              callFunction('manage-agenda', {
                slug, edit_token: key, action: 'update',
                item: { id: u.id, display_order: u.display_order },
              })
            ));
          } catch (err) {
            console.error('Auto-sort agenda failed:', err);
            // Refetch on failure so local state matches server.
            agenda = await fetchAgendaItems(ev.id);
            renderAgendaList();
          }
        }

        async function handleAgendaSubmit(submitEv: Event, editing?: AgendaItem) {
          submitEv.preventDefault();
          const formEl = submitEv.target as HTMLFormElement;
          const fd = new FormData(formEl);
          const tStatus = formEl.querySelector('.t-status') as HTMLSpanElement;
          const submit = formEl.querySelector('button[type=submit]') as HTMLButtonElement;
          submit.disabled = true;
          tStatus.textContent = 'Saving…';
          tStatus.className = 't-status';
          // Pull duration off the form; default to 15.
          const rawDur = Number(fd.get('duration_minutes'));
          const newDuration = Number.isFinite(rawDur) ? Math.max(0, Math.min(240, Math.floor(rawDur))) : 15;
          const item: Record<string, unknown> = {
            time_label: fd.get('time_label'),
            segment: fd.get('segment'),
            speaker: fd.get('speaker') || null,
            details: fd.get('details') || null,
            duration_minutes: newDuration,
          };
          if (editing) item.id = editing.id;
          const oldDuration = editing ? (editing.duration_minutes ?? 15) : 0;
          try {
            const res = await callFunction('manage-agenda', {
              action: editing ? 'update' : 'add',
              slug, edit_token: key, item,
            });
            const saved = res.item as AgendaItem;
            agenda = editing
              ? agenda.map((x) => (x.id === saved.id ? saved : x))
              : [...agenda, saved];
            agenda.sort((a, b) => a.display_order - b.display_order);
            renderAgendaList();
            hideAgendaForm();
            // Step 1: reposition by time (handles new-item insertion and
            // explicit time edits). The new item may have been appended
            // with the highest display_order — auto-sort gives it its
            // proper time-slot position before we cascade past it.
            await autoSortAgendaByTime();
            // Step 2: cascade the duration delta. For an ADD, oldDuration
            // is 0 and delta = newDuration, so items after the new item
            // shift by +newDuration to make room. For an UPDATE, the
            // delta is the change in duration (zero if only the time/
            // segment/etc. was edited, in which case cascade is a no-op).
            const delta = newDuration - oldDuration;
            if (delta !== 0) {
              await cascadeTimeShift(saved.id, delta);
            }
          } catch (err) {
            tStatus.textContent = fmtError(err);
            tStatus.className = 't-status err';
            submit.disabled = false;
          }
        }

        // Stepper click handler — ±5 min on an agenda item's duration,
        // with the same cascade rules as the form's duration field.
        async function handleStepperClick(itemId: string, deltaMin: number) {
          const it = agenda.find((x) => x.id === itemId);
          if (!it) return;
          const oldDur = it.duration_minutes ?? 15;
          const newDur = Math.max(0, Math.min(240, oldDur + deltaMin));
          if (newDur === oldDur) return; // already at the limit
          it.duration_minutes = newDur;
          renderAgendaList();
          try {
            await callFunction('manage-agenda', {
              slug, edit_token: key, action: 'update',
              item: { id: itemId, duration_minutes: newDur },
            });
            // Cascade by display_order so items at the same time label
            // as this one still shift — fixes the "stuck at 11:15" bug
            // when several agenda items share a start time.
            await cascadeTimeShift(itemId, newDur - oldDur);
          } catch (err) {
            console.error('Stepper update failed:', err);
            it.duration_minutes = oldDur;
            renderAgendaList();
          }
        }

        async function handleAgendaDelete(id: string) {
          const it = agenda.find((x) => x.id === id);
          if (!it) return;
          if (!confirm(`Delete the "${it.segment}" agenda item?`)) return;
          try {
            await callFunction('manage-agenda', {
              action: 'delete', slug, edit_token: key, item_id: id,
            });
            agenda = agenda.filter((x) => x.id !== id);
            renderAgendaList();
          } catch (err) {
            alert('Could not delete: ' + (err as Error).message);
          }
        }

        // CSV is the canonical agenda paste format. We still accept a
        // TSV fallback (per-line) when the first row has tabs but no
        // commas, so people who copy straight from Google Sheets aren't
        // stuck — but the headline format, the placeholder, and the
        // export are all CSV.
        function csvEscape(v: string): string {
          const s = String(v ?? '');
          // Quote the cell if it contains a comma, double-quote, or newline.
          // Inside a quoted cell, double-quotes are escaped by doubling.
          if (/[",\n\r]/.test(s)) return `"${s.replace(/"/g, '""')}"`;
          return s;
        }

        function agendaToCsv(items: AgendaItem[]): string {
          const lines = ['Time,Segment,Speaker / Lead,Details'];
          for (const it of items) {
            const row = [
              it.time_label || '',
              it.segment || '',
              it.speaker || '',
              (it.details || '').replace(/\s*\n+\s*/g, ' '), // flatten newlines so each row stays on one line
            ];
            lines.push(row.map(csvEscape).join(','));
          }
          return lines.join('\n');
        }

        function parseCsvLine(line: string): string[] {
          // Single-row CSV tokenizer. Handles quoted cells, commas inside
          // quotes, and "" escapes. Doesn't try to handle quoted newlines
          // spanning rows — agendaToCsv flattens newlines inside cells, so
          // round-trip pastes from this UI never produce them.
          const cells: string[] = [];
          let cur = '';
          let inQuotes = false;
          let i = 0;
          while (i < line.length) {
            const ch = line[i];
            if (inQuotes) {
              if (ch === '"') {
                if (line[i + 1] === '"') { cur += '"'; i += 2; continue; }
                inQuotes = false; i++; continue;
              }
              cur += ch; i++;
            } else {
              if (ch === ',') { cells.push(cur); cur = ''; i++; continue; }
              if (ch === '"' && cur.length === 0) { inQuotes = true; i++; continue; }
              cur += ch; i++;
            }
          }
          cells.push(cur);
          return cells.map((c) => c.trim());
        }

        function parseAgendaCsv(text: string): Array<{
          time_label: string; segment: string; speaker: string; details: string;
        }> {
          const rawRows = text.split(/\r?\n/)
            .map((l) => l.replace(/^\s+|\s+$/g, ''))
            .filter(Boolean);
          if (rawRows.length === 0) return [];

          // Pick a per-line tokenizer. CSV is the headline format; if the
          // first line has tabs but no commas we fall back to splitting on
          // tabs so a Google Sheets paste still works.
          const useTsvFallback = rawRows[0].includes('\t') && !rawRows[0].includes(',');
          const splitRow = (line: string): string[] =>
            useTsvFallback
              ? line.split('\t').map((c) => c.trim())
              : parseCsvLine(line);

          const headerCells = splitRow(rawRows[0]).map((c) => c.toLowerCase());
          const isHeader = ['time', 'time_label', 'time / segment'].includes(headerCells[0]);
          const start = isHeader ? 1 : 0;
          const items: Array<{
            time_label: string; segment: string; speaker: string; details: string;
          }> = [];
          for (let i = start; i < rawRows.length; i++) {
            const cells = splitRow(rawRows[i]);
            if (cells.length < 2 || !cells[0] || !cells[1]) continue;
            items.push({
              time_label: cells[0],
              segment: cells[1],
              speaker: cells[2] || '',
              details: cells[3] || '',
            });
          }
          return items;
        }

        function showAgendaPasteForm() {
          const initial = agendaToCsv(agenda);
          aFormHost.innerHTML = `
            <form class="t-form paste-form" novalidate>
              <h3>Paste agenda</h3>
              <p class="paste-hint">
                Paste 4 comma-separated columns: <strong>Time, Segment, Speaker, Details</strong>.
                One row per line. First row can be a header (we'll skip it). Saving replaces
                <strong>all</strong> existing rows.
              </p>
              <p class="paste-hint">
                Wrap any cell that contains a comma in double-quotes — e.g.
                <code>9:00 AM,Welcome,Matt,"Intro, QR scan, and intentions"</code>.
                Exporting your sheet as CSV (Google Sheets: <em>File → Download → CSV</em>) handles this for you.
              </p>
              <textarea name="csv" rows="14" class="paste-csv" placeholder="9:00 AM,Welcome,Matt,Intro and QR scan instructions">${escapeHtml(initial)}</textarea>
              <p class="paste-preview" id="paste-preview"></p>
              <div class="row">
                <button type="submit">Save all rows</button>
                <button type="button" class="cancel">Cancel</button>
                <span class="t-status" role="status" aria-live="polite"></span>
              </div>
            </form>`;
          addABtn.style.display = 'none';
          pasteABtn.style.display = 'none';

          const f = aFormHost.querySelector('form.paste-form') as HTMLFormElement;
          const textarea = f.querySelector('textarea[name=csv]') as HTMLTextAreaElement;
          const preview = document.getElementById('paste-preview')!;

          const updatePreview = () => {
            const parsed = parseAgendaCsv(textarea.value);
            preview.textContent = parsed.length
              ? `${parsed.length} row${parsed.length === 1 ? '' : 's'} detected.`
              : 'No rows detected yet. Make sure cells are separated by commas (quote any cell that contains a comma).';
            preview.className = 'paste-preview ' + (parsed.length ? 'ok' : '');
          };
          textarea.addEventListener('input', updatePreview);
          updatePreview();

          f.addEventListener('submit', async (e) => handleAgendaPasteSubmit(e));
          f.querySelector('button.cancel')!.addEventListener('click', hideAgendaForm);
        }

        async function handleAgendaPasteSubmit(submitEv: Event) {
          submitEv.preventDefault();
          const formEl = submitEv.target as HTMLFormElement;
          const textarea = formEl.querySelector('textarea[name=csv]') as HTMLTextAreaElement;
          const tStatus = formEl.querySelector('.t-status') as HTMLSpanElement;
          const submit = formEl.querySelector('button[type=submit]') as HTMLButtonElement;
          const items = parseAgendaCsv(textarea.value);

          if (items.length === 0) {
            if (!confirm('No rows detected — this will delete every existing agenda item. Continue?')) return;
          } else if (agenda.length > 0) {
            if (!confirm(`Replace all ${agenda.length} existing agenda items with these ${items.length}? This cannot be undone.`)) return;
          }

          submit.disabled = true;
          tStatus.textContent = 'Saving…';
          tStatus.className = 't-status';
          try {
            const res = await callFunction('manage-agenda', {
              slug, edit_token: key, action: 'replace_all', items,
            });
            agenda = (res.items as AgendaItem[]) || [];
            renderAgendaList();
            hideAgendaForm();
          } catch (err) {
            const msg = (err as Error).message;
            tStatus.textContent = fmtError(err);
            tStatus.className = 't-status err';
            submit.disabled = false;
          }
        }

        addABtn.addEventListener('click', () => showAgendaForm());
        const pasteABtn = document.getElementById('paste-a-btn') as HTMLButtonElement;
        pasteABtn.addEventListener('click', () => showAgendaPasteForm());

        // ---------- Agenda sub-slides ----------
        // Mounts the add-or-edit form into the slot under the parent
        // agenda row. Saving the form re-renders just that row (cheap
        // since renderAgendaList rebuilds the whole list once).
        function openSubSlideForm(parentId: string, slide?: AgendaSlide) {
          const host = aList.querySelector(`.sub-slide-form-host[data-parent="${parentId}"]`) as HTMLElement | null;
          if (!host) return;
          host.innerHTML = subSlideFormHtml(parentId, slide);
          const form = host.querySelector('form.sub-slide-form') as HTMLFormElement;
          form.addEventListener('submit', (e) => handleSubSlideSubmit(e, parentId, slide));
          form.querySelector('.cancel-sub-slide')!.addEventListener('click', () => { host.innerHTML = ''; });
          // Image upload only works after the slide row exists (we need
          // a slide_id). For the new-slide form the file input is
          // disabled in the template; for edit mode wire the change.
          if (slide) {
            const fileInput = form.querySelector('input[type=file][data-sub-slide-slot]') as HTMLInputElement;
            fileInput.addEventListener('change', (e) => handleSubSlideImageUpload(e, slide));
          }
          (form.querySelector('input[name=title]') as HTMLInputElement).focus();
        }

        async function handleSubSlideSubmit(submitEv: Event, parentId: string, editing?: AgendaSlide) {
          submitEv.preventDefault();
          const form = submitEv.target as HTMLFormElement;
          const fd = new FormData(form);
          const statusEl = form.querySelector('.t-status') as HTMLSpanElement;
          const submitBtn = form.querySelector('button[type=submit]') as HTMLButtonElement;
          submitBtn.disabled = true;
          statusEl.textContent = 'Saving…';
          statusEl.className = 't-status';
          const slide: Record<string, unknown> = {
            title: String(fd.get('title') || '').trim(),
            body: String(fd.get('body') || '').trim() || null,
          };
          if (editing) slide.id = editing.id;
          else slide.agenda_item_id = parentId;
          try {
            const res = await callFunction('manage-agenda-slides', {
              slug, edit_token: key,
              action: editing ? 'update' : 'add',
              slide,
            });
            const saved = res.slide as AgendaSlide;
            const list = slidesByItem[parentId] || (slidesByItem[parentId] = []);
            if (editing) {
              const idx = list.findIndex((x) => x.id === saved.id);
              if (idx >= 0) list[idx] = saved; else list.push(saved);
            } else {
              list.push(saved);
            }
            renderAgendaList();
          } catch (err) {
            statusEl.textContent = fmtError(err);
            statusEl.className = 't-status err';
            submitBtn.disabled = false;
          }
        }

        async function handleSubSlideImageUpload(changeEv: Event, slide: AgendaSlide) {
          const input = changeEv.target as HTMLInputElement;
          const file = input.files?.[0];
          if (!file) return;
          const slotEl = input.closest('.sub-slide-slot') as HTMLElement;
          const previewEl = slotEl.querySelector('.photo-preview') as HTMLElement;
          const labelEl = slotEl.querySelector('.upload-label') as HTMLElement;
          const statusEl = slotEl.querySelector('.upload-status') as HTMLElement;
          input.value = '';
          statusEl.textContent = 'Compressing…';
          statusEl.className = 'upload-status';
          try {
            const compressed = await compressImage(file, 1600, 0.85);
            statusEl.textContent = 'Uploading…';
            const data_b64 = await blobToBase64(compressed);
            const res = await callFunction('upload-event-photo', {
              slug, edit_token: key,
              kind: 'agenda_slide',
              slide_id: slide.id,
              filename: 'photo.jpg', data: data_b64,
            });
            const url = res.url as string;
            slide.image_url = url;
            const list = slidesByItem[slide.agenda_item_id] || [];
            const idx = list.findIndex((x) => x.id === slide.id);
            if (idx >= 0) list[idx].image_url = url;
            previewEl.innerHTML = `<img src="${escapeHtml(url)}" alt="" />`;
            labelEl.textContent = 'Replace image';
            statusEl.textContent = 'Uploaded ✓';
            statusEl.className = 'upload-status ok';
            renderAgendaList();
          } catch (err) {
            statusEl.textContent = fmtError(err);
            statusEl.className = 'upload-status err';
          }
        }

        async function handleSubSlideDelete(slideId: string) {
          // Find the slide first so we can show its title in the confirm.
          let parentId = '', title = '(this slide)';
          for (const pid of Object.keys(slidesByItem)) {
            const found = slidesByItem[pid].find((s) => s.id === slideId);
            if (found) { parentId = pid; title = found.title; break; }
          }
          if (!confirm(`Delete sub-slide "${title}"? Can't be undone.`)) return;
          try {
            await callFunction('manage-agenda-slides', {
              slug, edit_token: key, action: 'delete', slide_id: slideId,
            });
            slidesByItem[parentId] = (slidesByItem[parentId] || []).filter((s) => s.id !== slideId);
            renderAgendaList();
          } catch (err) {
            alert('Could not delete: ' + fmtError(err));
          }
        }

        aList.addEventListener('click', (clickEv) => {
          const target = clickEv.target as HTMLElement;
          if (target.tagName !== 'BUTTON') return;
          // Sub-slide actions take priority — they have more specific
          // classes. Fall through to the agenda item actions otherwise.
          const slideId = target.getAttribute('data-slide-id');
          const parentId = target.getAttribute('data-parent');
          if (target.classList.contains('add-sub-slide') && parentId) {
            openSubSlideForm(parentId);
            return;
          }
          // Duration steppers (±5 min) on each agenda row.
          if (target.classList.contains('dur-minus') || target.classList.contains('dur-plus')) {
            const itemId = target.getAttribute('data-id');
            if (itemId) handleStepperClick(itemId, target.classList.contains('dur-plus') ? 5 : -5);
            return;
          }
          if (target.classList.contains('sub-slide-edit') && slideId) {
            // Locate the slide in any parent bucket.
            for (const pid of Object.keys(slidesByItem)) {
              const found = slidesByItem[pid].find((s) => s.id === slideId);
              if (found) { openSubSlideForm(pid, found); break; }
            }
            return;
          }
          if (target.classList.contains('sub-slide-del') && slideId) {
            handleSubSlideDelete(slideId);
            return;
          }
          const id = target.getAttribute('data-id');
          if (!id) return;
          if (target.classList.contains('edit')) {
            const it = agenda.find((x) => x.id === id);
            if (it) showAgendaForm(it);
          } else if (target.classList.contains('del')) {
            handleAgendaDelete(id);
          }
        });
        renderAgendaList();
        // One-shot pass to clean up any out-of-order items left from
        // before the auto-sort existed (or from manual reordering that
        // drifted from the time labels). No-ops when the order already
        // matches the chronological flow.
        autoSortAgendaByTime();

        // ---------- Share & save links section ----------
        const origin = window.location.origin;
        const publicUrl = origin + eventUrl(base, slug);
        const editUrl = origin + editUrlOf(base, slug, key);
        (document.getElementById('public-url') as HTMLInputElement).value = publicUrl;
        (document.getElementById('edit-url') as HTMLInputElement).value = editUrl;

        const qrCanvas = document.getElementById('public-qr') as HTMLCanvasElement;
        QRCode.toCanvas(qrCanvas, publicUrl, {
          width: 200, margin: 1,
          color: { dark: '#ffffff', light: '#1a252f' },
        }).catch(() => {});

        document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
          btn.addEventListener('click', async () => {
            const sel = btn.getAttribute('data-copy')!;
            const input = document.querySelector<HTMLInputElement>(sel)!;
            await navigator.clipboard.writeText(input.value);
            const orig = btn.textContent;
            btn.textContent = 'Copied!';
            setTimeout(() => (btn.textContent = orig), 1200);
          });
        });

        document.getElementById('public-qr-dl')?.addEventListener('click', () => {
          const a = document.createElement('a');
          a.href = qrCanvas.toDataURL('image/png');
          a.download = `${slug}-qr.png`;
          a.click();
        });

        document.getElementById('email-edit')?.addEventListener('click', () => {
          const subj = encodeURIComponent('Edit link for my event');
          const mailBody = encodeURIComponent(
            `Save this — it's the only way back into your event admin page.\n\nEdit URL:\n${editUrl}\n\nPublic URL:\n${publicUrl}\n`
          );
          window.location.href = `mailto:?subject=${subj}&body=${mailBody}`;
        });

        document.getElementById('download-edit')?.addEventListener('click', () => {
          const txt = `Metabolic Reset Event — edit link\n\nEdit URL (KEEP SECRET):\n${editUrl}\n\nPublic URL (share):\n${publicUrl}\n`;
          const blob = new Blob([txt], { type: 'text/plain' });
          const a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = `event-${slug}-edit-link.txt`;
          a.click();
        });

        addBtn.addEventListener('click', () => showForm());
        list.addEventListener('click', (clickEv) => {
          const target = clickEv.target as HTMLElement;
          if (target.tagName !== 'BUTTON') return;
          const id = target.getAttribute('data-id');
          if (!id) return;
          if (target.classList.contains('edit')) {
            const t = transformations.find((x) => x.id === id);
            if (t) showForm(t);
          } else if (target.classList.contains('del')) {
            handleDelete(id);
          }
        });

        renderList();

        // ---------- Collapsible cards ----------
        // Wraps each `<section class="card">` in a `<details>` shell so the
        // initial view stays compact — host taps the section header to
        // expand. Done at runtime (instead of in the HTML) so existing
        // event handlers and DOM references inside each card keep working
        // unchanged. Setup checklist is left alone (always visible).
        function collapsifyCards() {
          const cards = document.querySelectorAll<HTMLElement>('section.card');
          // Sections that open by default; the rest collapse to save scroll.
          const openByDefault = new Set(['day-of-toolkit', 'event-details']);
          cards.forEach((card) => {
            if (card.id === 'setup-checklist') return;
            if (card.querySelector(':scope > details.card-shell')) return;
            const h2 = card.querySelector(':scope > h2') as HTMLElement | null;
            if (!h2) return;
            const details = document.createElement('details');
            details.className = 'card-shell';
            const tour = card.getAttribute('data-tour') || '';
            if (openByDefault.has(tour)) details.open = true;
            const summary = document.createElement('summary');
            summary.className = 'card-summary';
            // Move the h2 into the summary; preserves its existing styling
            // (font, audience-tag chip) without any text-content gymnastics.
            summary.appendChild(h2);
            details.appendChild(summary);
            // Move everything else in the card into the details body.
            while (card.firstChild) details.appendChild(card.firstChild);
            card.appendChild(details);
          });
        }

        // Expand a card-shell if it's collapsed — used by the checklist
        // click handler and the tour so users land on the right section
        // visibly opened. No-op for sections that aren't collapsible
        // (setup-checklist, or any other card we leave alone).
        function ensureCardOpen(target: Element | null) {
          if (!target) return;
          const shell = target.querySelector(':scope > details.card-shell') as HTMLDetailsElement | null;
          if (shell && !shell.open) shell.open = true;
        }

        collapsifyCards();

        // ---------- Setup checklist + first-time tour ----------
        // Both live at the bottom of the IIFE so they can see every
        // local data array (speakers, transformations, agenda, prizes,
        // hostsCache) for the checklist's progress derivation.
        const checklistCard = document.getElementById('setup-checklist') as HTMLElement;
        const tourBtn = document.getElementById('start-tour') as HTMLButtonElement;

        // Reads from live form inputs first, falls back to `ev` snapshot —
        // means a value the user typed but hasn't saved still counts.
        function checklistState() {
          const nameInput = document.querySelector('input[name=name]') as HTMLInputElement | null;
          const dateInput = document.querySelector('input[name=event_date]') as HTMLInputElement | null;
          const orgInput = document.querySelector('input[name=organizer_name]') as HTMLInputElement | null;
          return {
            name: !!(nameInput?.value?.trim() || ev.name),
            date: !!(dateInput?.value?.trim() || ev.event_date),
            organizer: !!(orgInput?.value?.trim() || ev.organizer_name),
            speakers: speakers.length > 0,
            transformations: transformations.length > 0,
            agenda: agenda.length > 0,
            raffle: prizes.length > 0,
          };
        }

        function updateChecklist() {
          if (localStorage.getItem('checklist-dismissed-v1') === '1') {
            checklistCard.style.display = 'none';
            return;
          }
          checklistCard.style.display = '';
          const st = checklistState();
          const items = [
            { label: 'Event name', done: st.name, target: 'event-details' },
            { label: 'Event date', done: st.date, target: 'event-details' },
            { label: 'Your name + bio (organizer)', done: st.organizer, target: 'hosts' },
            { label: 'At least 1 speaker', done: st.speakers, target: 'speakers' },
            { label: 'At least 1 transformation story', done: st.transformations, target: 'transformations' },
            { label: 'Agenda items added', done: st.agenda, target: 'agenda' },
            { label: 'Raffle prize(s) added', done: st.raffle, target: 'raffle' },
          ];
          const done = items.filter((i) => i.done).length;
          const pct = Math.round((done / items.length) * 100);
          const allDone = done === items.length;
          checklistCard.innerHTML = `
            <div class="checklist-head">
              <h2>${allDone ? '🎉 Setup complete!' : '🎓 Setup checklist'} <span class="audience-tag host-only">Host only</span> <span class="checklist-count">${done} of ${items.length} done</span></h2>
              <button type="button" class="checklist-dismiss" id="checklist-dismiss" title="${allDone ? 'Close' : 'Hide for good. Re-open via Take a tour button up top.'}">${allDone ? '✕ Close' : 'Hide'}</button>
            </div>
            <div class="checklist-bar"><div class="checklist-bar-fill" style="width:${pct}%"></div></div>
            <ul class="checklist-items">
              ${items.map((i) => `
                <li class="checklist-item ${i.done ? 'done' : ''}">
                  <span class="checklist-mark">${i.done ? '✓' : '○'}</span>
                  <button type="button" class="checklist-label" data-target="${i.target}">${escapeHtml(i.label)}</button>
                </li>
              `).join('')}
            </ul>
            ${allDone ? '<p class="checklist-celebrate">Your event is ready to go live. The Day-of toolkit above has everything you need on event day.</p>' : ''}
          `;
        }

        checklistCard.addEventListener('click', (clickEv) => {
          const target = clickEv.target as HTMLElement;
          if (target.id === 'checklist-dismiss') {
            try { localStorage.setItem('checklist-dismissed-v1', '1'); } catch { /* private mode */ }
            checklistCard.style.display = 'none';
          } else if (target.classList.contains('checklist-label')) {
            const sel = `[data-tour="${target.getAttribute('data-target')}"]`;
            const section = document.querySelector(sel);
            // Expand the target card before scrolling so the user lands
            // on actual content, not just a collapsed header.
            ensureCardOpen(section);
            section?.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });

        // Re-render on relevant state changes. MutationObserver covers
        // list re-renders (add/edit/delete); input listeners cover the
        // event-details + organizer forms typing changes.
        const checklistObserver = new MutationObserver(() => updateChecklist());
        ['#t-list', '#s-list', '#a-list', '#prize-list', '#hosts-list'].forEach((sel) => {
          const el = document.querySelector(sel);
          if (el) checklistObserver.observe(el, { childList: true, subtree: true });
        });
        document.getElementById('event-form')?.addEventListener('input', () => updateChecklist());
        document.getElementById('organizer-form')?.addEventListener('input', () => updateChecklist());
        updateChecklist();

        // ---------- Tour engine ----------
        // Spotlight overlay + step-through tooltip. Each step targets an
        // element by [data-tour="…"] attribute on the page. localStorage
        // remembers completion so it auto-opens once for a new user but
        // never nags an existing one.
        // Tour steps live in DOM order so the user scrolls cleanly top
        // → bottom and the tour never has to jump back up the page.
        // Keep this list in sync with the data-tour attribute order in
        // the page HTML; rearranging cards above means rearranging here.
        const tourSteps: Array<{ selector: string; title: string; body: string }> = [
          { selector: '[data-tour="save-pill"]', title: 'Save status', body: 'This pill in the top bar tells you what state your edits are in. "All saved" means everything you typed has hit the database. It flips to "Saving…" while a write is in flight and shows a red error if anything fails.' },
          { selector: '[data-tour="checklist"]', title: 'Setup checklist', body: 'These are the milestones to get your event ready. Tap any incomplete item to jump to that section. Once everything\'s done, you can hide the checklist for good.' },
          { selector: '[data-tour="day-of-toolkit"]', title: 'Day-of toolkit', body: 'These buttons get heavy use during the event itself. Raffle control runs the draws from your phone; the slide deck + presenter console pair drives what shows on the projector. Print materials live here too.' },
          { selector: '[data-tour="event-details"]', title: 'Event details', body: 'Name, date, location, and accent color. The accent color drives every public page\'s highlight color — pick the brand color that matches your venue or theme.' },
          { selector: '[data-tour="transformations"]', title: 'Transformation stories', body: 'Before/after journeys with photos and metrics. The chart synthesizes a realistic curve even if you only have snapshot data. During the event, the presenter can push these stories to audience phones from the console.' },
          { selector: '[data-tour="speakers"]', title: 'Speakers', body: 'Anyone giving a talk. Enter full first + last names so the agenda\'s autocomplete picks the same name — the projector slide deck then auto-resolves photos and bios for each speaker slot.' },
          { selector: '[data-tour="agenda"]', title: 'Agenda / run of show', body: 'The minute-by-minute schedule. Each item becomes one slide on the projector — speaker slides get a face, "Snack Break" stays a clean title slide. Drag the ⋮⋮ handle to reorder.' },
          { selector: '[data-tour="raffle"]', title: 'Raffle setup', body: 'Add the grand prize and any spot prizes. Quantity > 1 means multiple winners of the same item. Raffle control (on your phone during the event) runs the draws, and the wheel spins for the audience.' },
          { selector: '[data-tour="hosts"]', title: 'You + your co-hosts', body: 'You\'re the master (the original creator). Add co-hosts to share editing — each gets their own private edit link. The "Organizer" badge can be passed to a co-host if they\'re the public face of the event.' },
          { selector: '[data-tour="coaching"]', title: 'Coaching Program', body: 'The audience-facing 🥳 Metabolic Coaching Program page. Edit the title, pitch, and hero image here; the list of coaches builds itself from your speakers and hosts, with one-tap text/call/email/website buttons for each.' },
          { selector: '[data-tour="share"]', title: 'Share & save your links', body: 'Bookmark the edit URL — it\'s the only way back into this admin page. The public event link goes on flyers and QR codes; the raffle entry link is what attendees scan at the venue.' },
        ];

        let tourIdx = 0;
        let tourOverlay: HTMLDivElement | null = null;

        function mountTour() {
          tourOverlay = document.createElement('div');
          tourOverlay.className = 'tour-overlay';
          tourOverlay.innerHTML = `
            <div class="tour-spotlight"></div>
            <div class="tour-tooltip" role="dialog">
              <p class="tour-step-meta"><span class="tour-step-num">1</span> of <span class="tour-step-total">${tourSteps.length}</span></p>
              <h3 class="tour-title"></h3>
              <p class="tour-body"></p>
              <div class="tour-actions">
                <button type="button" class="tour-skip">Skip tour</button>
                <button type="button" class="tour-prev">← Back</button>
                <button type="button" class="tour-next">Next →</button>
              </div>
            </div>`;
          document.body.appendChild(tourOverlay);
          tourOverlay.querySelector('.tour-prev')!.addEventListener('click', () => stepTour(-1));
          tourOverlay.querySelector('.tour-next')!.addEventListener('click', () => stepTour(+1));
          tourOverlay.querySelector('.tour-skip')!.addEventListener('click', () => endTour());
          // ESC dismisses
          document.addEventListener('keydown', tourKeydown);
        }

        function tourKeydown(kev: KeyboardEvent) {
          if (kev.key === 'Escape') endTour();
          else if (kev.key === 'ArrowRight') stepTour(+1);
          else if (kev.key === 'ArrowLeft') stepTour(-1);
        }

        function endTour() {
          if (!tourOverlay) return;
          tourOverlay.remove();
          tourOverlay = null;
          document.removeEventListener('keydown', tourKeydown);
          try { localStorage.setItem('edit-tour-completed-v1', '1'); } catch { /* private mode */ }
        }

        function showTourStep() {
          if (!tourOverlay) return;
          const step = tourSteps[tourIdx];
          const target = document.querySelector(step.selector) as HTMLElement | null;
          if (!target) { stepTour(+1); return; }
          // Expand the target's card-shell if collapsed so the spotlight
          // lands on real content, not an unexpanded header.
          ensureCardOpen(target.closest('section.card'));
          // Use the section heading as the visual anchor when the section
          // is bigger than the viewport (e.g. Hosts card with 7 rows): the
          // whole-card spotlight is then 2000+px tall and swallows the
          // viewport. Snap-scroll for those so the rect is settled by the
          // time we measure it in positionTour — smooth scroll's ~500ms
          // exceeds our paint timeout and breaks the next step's position.
          const tall = target.getBoundingClientRect().height > window.innerHeight * 0.75;
          const heading = tall ? (target.querySelector('h2') as HTMLElement | null) : null;
          const visualAnchor = heading || target;
          visualAnchor.scrollIntoView({
            behavior: tall ? 'auto' : 'smooth',
            block: tall ? 'start' : 'center',
          });
          (tourOverlay.querySelector('.tour-step-num') as HTMLElement).textContent = String(tourIdx + 1);
          (tourOverlay.querySelector('.tour-title') as HTMLElement).textContent = step.title;
          (tourOverlay.querySelector('.tour-body') as HTMLElement).textContent = step.body;
          const prevBtn = tourOverlay.querySelector('.tour-prev') as HTMLButtonElement;
          const nextBtn = tourOverlay.querySelector('.tour-next') as HTMLButtonElement;
          prevBtn.disabled = tourIdx === 0;
          nextBtn.textContent = tourIdx === tourSteps.length - 1 ? 'Finish' : 'Next →';
          // Smooth scroll resolves in ~300ms; snap scroll resolves
          // immediately so we can position right away.
          setTimeout(() => positionTour(visualAnchor), tall ? 30 : 360);
        }

        function positionTour(target: HTMLElement) {
          if (!tourOverlay) return;
          const rect = target.getBoundingClientRect();
          const spotlight = tourOverlay.querySelector('.tour-spotlight') as HTMLElement;
          // Clamp spotlight height so a tall section doesn't outline the
          // whole document. The visual anchor (heading) is short anyway,
          // but defensively clamp in case showTourStep handed us the whole
          // section.
          const maxH = Math.min(rect.height, window.innerHeight * 0.7);
          spotlight.style.top = rect.top + 'px';
          spotlight.style.left = rect.left + 'px';
          spotlight.style.width = rect.width + 'px';
          spotlight.style.height = maxH + 'px';
          const tooltip = tourOverlay.querySelector('.tour-tooltip') as HTMLElement;
          const ttHeight = tooltip.offsetHeight || 220;
          const ttWidth = tooltip.offsetWidth || 360;
          const spotBottom = rect.top + maxH;
          const below = spotBottom + 16;
          const above = rect.top - ttHeight - 16;
          if (below + ttHeight < window.innerHeight) {
            tooltip.style.top = below + 'px';
          } else if (above > 8) {
            tooltip.style.top = above + 'px';
          } else {
            tooltip.style.top = Math.max(8, window.innerHeight - ttHeight - 16) + 'px';
          }
          tooltip.style.left = Math.max(12, Math.min(rect.left, window.innerWidth - ttWidth - 12)) + 'px';
        }

        function stepTour(delta: number) {
          tourIdx += delta;
          if (tourIdx < 0) tourIdx = 0;
          if (tourIdx >= tourSteps.length) return endTour();
          showTourStep();
        }

        function startTour() {
          // Re-show the checklist if the user dismissed it — the tour
          // points at it on step 2.
          try { localStorage.removeItem('checklist-dismissed-v1'); } catch { /* private mode */ }
          updateChecklist();
          tourIdx = 0;
          mountTour();
          showTourStep();
        }

        tourBtn.addEventListener('click', startTour);

        // No auto-open: the setup checklist is the primary first-load
        // surface; the tour is available via the "🎓 Take a tour" button
        // whenever the user wants the spotlight walkthrough. Two
        // didactic surfaces fighting for first-impression attention
        // confused new users more than it helped.
      } catch (err) {
        root.innerHTML = `<p class="loading err">${escapeHtml((err as Error).message)}</p>`;
      }
    })();
  }
</script>

<style is:global>
  /* Most of this page is rendered into root.innerHTML at runtime, so the
     stylesheet has to be global — Astro's default scoping would hash the
     class selectors and miss the dynamically inserted DOM. */
  :root { --accent: #f39c12; }
  * { box-sizing: border-box; }
  html, body {
    background: #1a252f; color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
    margin: 0;
  }
  body { padding: 30px 18px 60px; }
  main.edit { max-width: 620px; margin: 0 auto; }

  .head { margin-bottom: 22px; }
