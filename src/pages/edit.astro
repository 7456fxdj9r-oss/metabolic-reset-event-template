---
import Base from '../layouts/Base.astro';
---
<Base title="Edit your event">
  <main class="edit" id="edit-root">
    <p class="loading">Loading edit form…</p>
  </main>
</Base>

<script>
  import { fetchEventBySlug, fetchTransformations, fetchDataPoints, callFunction } from '../lib/supabase.js';
  import { drawMultiChart } from '../lib/chart.js';
  import QRCode from 'qrcode';

  type DataPoint = { metric: 'weight' | 'bf' | 'lean'; date: string; value: number };

  // Parse a pasted CSV/TSV blob into structured data points.
  // Format expected:
  //   First row: column headers (must include "date" plus at least one of
  //   weight/bf/lean — synonyms accepted).
  //   Following rows: date in the date column, numeric values in the metric
  //   columns. Empty cells are skipped (a row may report only weight, etc.).
  function parsePastedData(text: string): { points: DataPoint[]; errors: string[] } {
    const errors: string[] = [];
    const points: DataPoint[] = [];
    const rawLines = text.split(/\r?\n/).map((l) => l.trim()).filter(Boolean);
    if (rawLines.length === 0) return { points, errors };

    const sep = rawLines[0].includes('\t') ? '\t' : ',';
    const headers = rawLines[0].split(sep).map((h) => h.trim().toLowerCase());
    const dateIdx = headers.findIndex((h) => h === 'date' || h === 'day');
    if (dateIdx < 0) {
      errors.push('First row must include a "date" column header.');
      return { points, errors };
    }

    const metricCols: Array<{ metric: 'weight' | 'bf' | 'lean'; idx: number }> = [];
    headers.forEach((h, i) => {
      const norm = h.replace(/[\s%_-]/g, '');
      if (norm === 'weight' || norm === 'wt' || norm === 'lb' || norm === 'lbs') {
        metricCols.push({ metric: 'weight', idx: i });
      } else if (norm === 'bf' || norm === 'bodyfat' || norm === 'fat' || norm === 'bfpct') {
        metricCols.push({ metric: 'bf', idx: i });
      } else if (norm === 'lean' || norm === 'leanmass' || norm === 'lbm') {
        metricCols.push({ metric: 'lean', idx: i });
      }
    });
    if (metricCols.length === 0) {
      errors.push('No metric column found. Add at least one of: weight, bf, lean.');
      return { points, errors };
    }

    for (let i = 1; i < rawLines.length; i++) {
      const cols = rawLines[i].split(sep).map((c) => c.trim());
      const dateStr = cols[dateIdx] || '';
      const date = parseDate(dateStr);
      if (!date) {
        errors.push(`Row ${i + 1}: invalid date "${dateStr}"`);
        continue;
      }
      for (const { metric, idx } of metricCols) {
        const raw = cols[idx];
        if (!raw) continue;
        const num = Number(raw.replace('%', '').replace(/,/g, ''));
        if (!Number.isFinite(num)) {
          errors.push(`Row ${i + 1}, ${metric}: invalid number "${raw}"`);
          continue;
        }
        points.push({ metric, date, value: num });
      }
    }
    return { points, errors };
  }

  function parseDate(s: string): string | null {
    let m = s.match(/^(\d{4})-(\d{1,2})-(\d{1,2})$/);
    let y: number, mo: number, d: number;
    if (m) {
      y = +m[1]; mo = +m[2]; d = +m[3];
    } else if ((m = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})$/))) {
      mo = +m[1]; d = +m[2]; y = +m[3];
      if (y < 100) y += 2000;
    } else {
      return null;
    }
    if (mo < 1 || mo > 12 || d < 1 || d > 31) return null;
    return `${y}-${String(mo).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
  }

  function pointsToCsv(points: DataPoint[]): string {
    if (points.length === 0) return 'date,weight,bf,lean\n';
    const dates = Array.from(new Set(points.map((p) => p.date))).sort();
    const lookup = new Map<string, Record<string, number>>();
    for (const d of dates) lookup.set(d, {});
    for (const p of points) lookup.get(p.date)![p.metric] = p.value;
    const lines = ['date,weight,bf,lean'];
    for (const d of dates) {
      const row = lookup.get(d)!;
      lines.push([d, row.weight ?? '', row.bf ?? '', row.lean ?? ''].join(','));
    }
    return lines.join('\n') + '\n';
  }

  // Inline canvas-based image compressor. Reads the file, scales the longest
  // edge to maxDim, encodes JPEG at the given quality. Returns a Blob.
  // Avoids the browser-image-compression npm package and its web-worker setup.
  async function compressImage(file: File, maxDim = 1200, quality = 0.82): Promise<Blob> {
    const dataUrl = await new Promise<string>((resolve, reject) => {
      const r = new FileReader();
      r.onload = () => resolve(r.result as string);
      r.onerror = () => reject(new Error('Could not read file'));
      r.readAsDataURL(file);
    });
    const img = await new Promise<HTMLImageElement>((resolve, reject) => {
      const i = new Image();
      i.onload = () => resolve(i);
      i.onerror = () => reject(new Error('Could not decode image'));
      i.src = dataUrl;
    });
    const scale = Math.min(1, maxDim / Math.max(img.width, img.height));
    const w = Math.round(img.width * scale);
    const h = Math.round(img.height * scale);
    const canvas = document.createElement('canvas');
    canvas.width = w;
    canvas.height = h;
    const ctx = canvas.getContext('2d')!;
    ctx.drawImage(img, 0, 0, w, h);
    return new Promise<Blob>((resolve, reject) => {
      canvas.toBlob(
        (blob) => (blob ? resolve(blob) : reject(new Error('Compression failed'))),
        'image/jpeg',
        quality
      );
    });
  }

  type Transformation = {
    id: string;
    slug: string;
    name: string;
    before_date: string | null;
    after_date: string | null;
    before_photo_url: string | null;
    after_photo_url: string | null;
    before_weight: number | null;
    after_weight: number | null;
    before_bf: number | null;
    after_bf: number | null;
    before_lean: number | null;
    after_lean: number | null;
    headline_lb_loss: number | null;
    headline_lean_kept_pct: number | null;
    headline_bf_delta_pts: number | null;
    takeaway_text: string | null;
    display_order: number;
  };

  const root = document.getElementById('edit-root')!;
  const base = import.meta.env.BASE_URL;
  const params = new URLSearchParams(window.location.search);
  const slug = params.get('slug');
  const key = params.get('key');

  function escapeHtml(s: unknown): string {
    return String(s ?? '').replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!)
    );
  }

  function fmtDate(s: string | null): string {
    if (!s) return '—';
    const parts = s.split('-');
    if (parts.length < 2) return s;
    const y = parts[0];
    const m = parseInt(parts[1], 10);
    const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    if (!Number.isFinite(m) || m < 1 || m > 12) return s;
    return `${months[m - 1]} ${y}`;
  }

  function dateToMonth(s: string | null): string {
    return s ? s.slice(0, 7) : '';
  }

  function photoSlotHtml(slot: 'before' | 'after', label: string, url: string | null): string {
    return `
      <div class="photo-slot" data-slot="${slot}">
        <span class="slot-label">${label}</span>
        <div class="photo-preview">
          ${url ? `<img src="${escapeHtml(url)}" alt="" />` : '<div class="empty">No photo</div>'}
        </div>
        <label class="upload-btn">
          <input type="file" accept="image/jpeg,image/png,image/webp" data-slot="${slot}" hidden />
          <span class="upload-label">${url ? 'Replace photo' : 'Upload photo'}</span>
        </label>
        <span class="upload-status" data-slot="${slot}"></span>
      </div>
    `;
  }

  function transformationFormHtml(t?: Transformation): string {
    const v = t || ({} as Partial<Transformation>);
    const mode = t ? 'edit' : 'add';
    const idAttr = t ? `data-id="${t.id}"` : '';
    const photos = t ? `
        <div class="photos-grid">
          ${photoSlotHtml('before', 'Before photo', t.before_photo_url)}
          ${photoSlotHtml('after', 'After photo', t.after_photo_url)}
        </div>` : '';
    const biometrics = t ? `
        <div class="biometrics">
          <span class="slot-label">Biometric data</span>
          <p class="bio-hint">
            Paste from a spreadsheet. First row = headers (date, weight, bf, lean — at least one metric).
            Tab- or comma-separated. Date format: YYYY-MM-DD or M/D/YYYY.
          </p>
          <textarea class="bio-textarea" rows="8" placeholder="date,weight,bf,lean&#10;2025-08-17,217,,&#10;2025-10-13,212,52,101.4"></textarea>
          <div class="bio-status"></div>
          <svg class="bio-chart" preserveAspectRatio="none"></svg>
          <div class="row">
            <button type="button" class="bio-save">Save data points</button>
            <button type="button" class="bio-clear">Clear</button>
            <span class="bio-result" role="status" aria-live="polite"></span>
          </div>
        </div>` : '';
    return `
      <form class="t-form" data-mode="${mode}" ${idAttr} novalidate>
        <h3>${t ? 'Edit transformation' : 'New transformation'}</h3>
        <label>
          Client name
          <input name="name" required maxlength="80" value="${escapeHtml(v.name || '')}" placeholder="Cearra's Story" />
        </label>
        <div class="ba-grid">
          <fieldset class="ba-block">
            <legend>Before</legend>
            <label>
              Date <span class="opt">(month / year)</span>
              <input type="month" name="before_date" value="${escapeHtml(dateToMonth(v.before_date || null))}" placeholder="2025-09" />
            </label>
            <label>
              Weight (lb)
              <input type="number" step="0.1" name="before_weight" value="${v.before_weight ?? ''}" placeholder="217" />
            </label>
            <label>
              Body fat (%)
              <input type="number" step="0.1" name="before_bf" value="${v.before_bf ?? ''}" placeholder="52" />
            </label>
            <label>
              Lean mass (lb)
              <input type="number" step="0.1" name="before_lean" value="${v.before_lean ?? ''}" placeholder="101.4" />
            </label>
          </fieldset>
          <fieldset class="ba-block">
            <legend>After</legend>
            <label>
              Date <span class="opt">(month / year)</span>
              <input type="month" name="after_date" value="${escapeHtml(dateToMonth(v.after_date || null))}" placeholder="2026-04" />
            </label>
            <label>
              Weight (lb)
              <input type="number" step="0.1" name="after_weight" value="${v.after_weight ?? ''}" placeholder="172" />
            </label>
            <label>
              Body fat (%)
              <input type="number" step="0.1" name="after_bf" value="${v.after_bf ?? ''}" placeholder="40.6" />
            </label>
            <label>
              Lean mass (lb)
              <input type="number" step="0.1" name="after_lean" value="${v.after_lean ?? ''}" placeholder="103" />
            </label>
          </fieldset>
        </div>
        <div class="computed-stats">
          <span class="cstat"><span class="num" data-stat="lb">—</span><span class="lbl">lb lost</span></span>
          <span class="cstat"><span class="num" data-stat="lean">—</span><span class="lbl">% lean kept</span></span>
          <span class="cstat"><span class="num" data-stat="bf">—</span><span class="lbl">BF % drop</span></span>
        </div>
        <label>
          Takeaway <span class="opt">(short paragraph shown beneath the chart)</span>
          <textarea name="takeaway_text" rows="3" placeholder="Most weight-loss attempts melt fat and muscle…">${escapeHtml(v.takeaway_text || '')}</textarea>
        </label>
        ${photos}
        ${biometrics}
        <div class="row">
          <button type="submit">${t ? 'Save changes' : 'Create'}</button>
          <button type="button" class="cancel">${t ? 'Done' : 'Cancel'}</button>
          <span class="t-status" role="status" aria-live="polite"></span>
        </div>
      </form>
    `;
  }

  function transformationRowHtml(t: Transformation): string {
    const stats: string[] = [];
    if (t.headline_lb_loss != null) stats.push(`−${t.headline_lb_loss} lb`);
    if (t.headline_lean_kept_pct != null) stats.push(`${t.headline_lean_kept_pct}% lean`);
    if (t.headline_bf_delta_pts != null) stats.push(`−${t.headline_bf_delta_pts} BF`);
    const thumb = t.before_photo_url || t.after_photo_url;
    return `
      <li class="t-row" data-id="${t.id}">
        ${thumb ? `<img class="t-thumb" src="${escapeHtml(thumb)}" alt="" />` : '<div class="t-thumb empty"></div>'}
        <div class="t-info">
          <strong>${escapeHtml(t.name)}</strong>
          <span class="t-meta">${fmtDate(t.before_date)} → ${fmtDate(t.after_date)}</span>
          ${stats.length ? `<span class="t-meta accent">${stats.join(' · ')}</span>` : ''}
        </div>
        <div class="t-actions">
          <button class="edit" data-id="${t.id}">Edit</button>
          <button class="del" data-id="${t.id}">Delete</button>
        </div>
      </li>
    `;
  }

  if (!slug || !key) {
    root.innerHTML =
      '<p class="loading err">Missing slug or key. Use the edit URL you saved at Build time.</p>';
  } else {
    (async () => {
      try {
        const ev = await fetchEventBySlug(slug);
        if (!ev) {
          root.innerHTML = '<p class="loading err">Event not found.</p>';
          return;
        }
        let transformations: Transformation[] = await fetchTransformations(ev.id);

        const publicHref = `${base}event?slug=${encodeURIComponent(slug)}`;
        root.innerHTML = `
          <header class="head">
            <p class="eyebrow">Edit · ${escapeHtml(ev.slug)}</p>
            <h1 id="page-title">${escapeHtml(ev.name)}</h1>
            <p class="hint">
              Public URL:
              <a href="${publicHref}" target="_blank">${publicHref}</a>
            </p>
          </header>

          <section class="card">
            <h2>Event details</h2>
            <form id="event-form" novalidate>
              <label>
                Event name
                <input name="name" required maxlength="80" value="${escapeHtml(ev.name)}" />
              </label>
              <label>
                Host line <span class="opt">(shown under the title)</span>
                <input name="host_line" maxlength="120" value="${escapeHtml(ev.host_line || '')}" />
              </label>
              <label>
                Accent color
                <input type="color" name="accent_color" value="${escapeHtml(ev.accent_color || '#f39c12')}" />
              </label>
              <label>
                Email <span class="opt">(only used to recover your edit link)</span>
                <input type="email" name="email" value="${escapeHtml(ev.email || '')}" />
              </label>
              <div class="row">
                <button type="submit" id="save-btn">Save changes</button>
                <span id="save-status" role="status" aria-live="polite"></span>
              </div>
            </form>
          </section>

          <section class="card">
            <h2>Transformations</h2>
            <button id="add-t-btn" type="button" class="add-btn">+ Add transformation</button>
            <div id="t-form-host"></div>
            <ul id="t-list" class="t-list"></ul>
          </section>

          <section class="card">
            <h2>Raffle</h2>
            <form id="raffle-form" novalidate>
              <label>
                Status
                <select name="raffle_status">
                  <option value="closed" ${ev.raffle_status !== 'open' ? 'selected' : ''}>Closed</option>
                  <option value="open" ${ev.raffle_status === 'open' ? 'selected' : ''}>Open for entries</option>
                </select>
              </label>
              <label>
                Prize description <span class="opt">(shown on the entry page; leave blank if generic)</span>
                <input name="raffle_prize" maxlength="200" value="${escapeHtml(ev.raffle_prize || '')}" placeholder="Free 30-min consult" />
              </label>
              <div class="row">
                <button type="submit" id="raffle-save">Save raffle settings</button>
                <span id="raffle-save-status" role="status" aria-live="polite"></span>
              </div>
            </form>

            <h3 class="raffle-entries-h">
              Entries <span class="entry-count" id="entry-count">—</span>
            </h3>
            <div id="entries-list-wrap">
              <p class="entries-loading">Loading entries…</p>
            </div>
          </section>

          <section class="card">
            <h2>Share &amp; save your links</h2>
            <p class="link-blurb">
              Bookmark the edit URL — it's the only way back into this admin page.
              Share the public URL with anyone you want to scan or visit.
            </p>

            <div class="link-block">
              <h3>Public URL <span class="link-tag ok">share this</span></h3>
              <div class="link-row">
                <input type="text" id="public-url" readonly />
                <button type="button" data-copy="#public-url">Copy</button>
              </div>
              <canvas id="public-qr"></canvas>
              <button type="button" id="public-qr-dl" class="link-secondary">Download QR</button>
            </div>

            <div class="link-block private">
              <h3>Private edit URL <span class="link-tag warn">keep secret</span></h3>
              <div class="link-row">
                <input type="text" id="edit-url" readonly />
                <button type="button" data-copy="#edit-url">Copy</button>
              </div>
              <div class="link-row">
                <button type="button" id="email-edit" class="link-secondary">Email me this link</button>
                <button type="button" id="download-edit" class="link-secondary">Download as .txt</button>
              </div>
            </div>
          </section>
        `;

        // ---------- Event details form ----------
        const form = document.getElementById('event-form') as HTMLFormElement;
        const status = document.getElementById('save-status')!;
        const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;

        form.addEventListener('submit', async (submitEv) => {
          submitEv.preventDefault();
          saveBtn.disabled = true;
          status.textContent = 'Saving…';
          status.className = '';
          const fd = new FormData(form);
          try {
            await callFunction('update-event', {
              slug,
              edit_token: key,
              name: fd.get('name'),
              host_line: fd.get('host_line') || null,
              accent_color: fd.get('accent_color'),
              email: fd.get('email') || null,
            });
            status.textContent = 'Saved ✓';
            status.className = 'ok';
            const newName = String(fd.get('name') || '').trim();
            if (newName) document.getElementById('page-title')!.textContent = newName;
          } catch (err) {
            const msg = (err as Error).message;
            status.textContent = msg.includes('403') ? 'Invalid edit link.' : msg;
            status.className = 'err';
          } finally {
            saveBtn.disabled = false;
          }
        });

        // ---------- Transformations section ----------
        const list = document.getElementById('t-list')!;
        const formHost = document.getElementById('t-form-host')!;
        const addBtn = document.getElementById('add-t-btn') as HTMLButtonElement;

        function renderList() {
          if (transformations.length === 0) {
            list.innerHTML = '<li class="t-empty">No transformations yet. Add one above.</li>';
            return;
          }
          list.innerHTML = transformations.map(transformationRowHtml).join('');
        }

        function showForm(t?: Transformation) {
          formHost.innerHTML = transformationFormHtml(t);
          addBtn.style.display = 'none';
          const newForm = formHost.querySelector('form.t-form') as HTMLFormElement;
          newForm.addEventListener('submit', (e) => handleSubmit(e, t));
          newForm.querySelector('button.cancel')!.addEventListener('click', hideForm);
          setupComputedStats(newForm);
          if (t) {
            newForm.querySelectorAll('input[type=file][data-slot]').forEach((input) => {
              input.addEventListener('change', (e) => handlePhotoUpload(e as Event, t));
            });
            setupBiometrics(newForm, t);
          } else {
            (newForm.querySelector('input[name=name]') as HTMLInputElement).focus();
          }
        }

        function setupComputedStats(formEl: HTMLFormElement) {
          const lbEl = formEl.querySelector('[data-stat=lb]') as HTMLElement;
          const leanEl = formEl.querySelector('[data-stat=lean]') as HTMLElement;
          const bfEl = formEl.querySelector('[data-stat=bf]') as HTMLElement;
          const num = (v: FormDataEntryValue | null): number | null => {
            if (v == null || v === '') return null;
            const n = Number(v);
            return Number.isFinite(n) ? n : null;
          };
          const round1 = (n: number) => Math.round(n * 10) / 10;
          const recompute = () => {
            const fd = new FormData(formEl);
            const bw = num(fd.get('before_weight'));
            const aw = num(fd.get('after_weight'));
            const bbf = num(fd.get('before_bf'));
            const abf = num(fd.get('after_bf'));
            const bln = num(fd.get('before_lean'));
            const aln = num(fd.get('after_lean'));
            lbEl.textContent = bw != null && aw != null ? `−${round1(bw - aw)}` : '—';
            bfEl.textContent = bbf != null && abf != null ? `−${round1(bbf - abf)}` : '—';
            leanEl.textContent =
              bln != null && aln != null && bln > 0 ? `${round1((aln / bln) * 100)}%` : '—';
          };
          formEl.querySelectorAll<HTMLInputElement>(
            'input[name^=before_], input[name^=after_]'
          ).forEach((input) => input.addEventListener('input', recompute));
          recompute();
        }

        async function setupBiometrics(formEl: HTMLFormElement, t: Transformation) {
          const textarea = formEl.querySelector('textarea.bio-textarea') as HTMLTextAreaElement;
          const statusEl = formEl.querySelector('.bio-status') as HTMLElement;
          const svg = formEl.querySelector('svg.bio-chart') as unknown as SVGSVGElement;
          const saveBtn = formEl.querySelector('button.bio-save') as HTMLButtonElement;
          const clearBtn = formEl.querySelector('button.bio-clear') as HTMLButtonElement;
          const resultEl = formEl.querySelector('.bio-result') as HTMLElement;

          function renderPreview() {
            const text = textarea.value.trim();
            while (svg.firstChild) svg.removeChild(svg.firstChild);
            if (!text) {
              statusEl.textContent = '';
              statusEl.className = 'bio-status';
              return;
            }
            const { points, errors } = parsePastedData(text);
            if (errors.length > 0) {
              statusEl.textContent = errors.slice(0, 3).join(' · ');
              statusEl.className = 'bio-status err';
            } else {
              const counts = {
                weight: points.filter((p) => p.metric === 'weight').length,
                bf: points.filter((p) => p.metric === 'bf').length,
                lean: points.filter((p) => p.metric === 'lean').length,
              };
              statusEl.textContent = `${points.length} points · ${counts.weight} weight, ${counts.bf} BF, ${counts.lean} lean`;
              statusEl.className = 'bio-status ok';
            }
            const byMetric: Record<string, Array<[string, number]>> = { weight: [], bf: [], lean: [] };
            for (const p of points) byMetric[p.metric].push([p.date, p.value]);
            const series: Array<{ name: string; color: string; suffix: string; axis: 'left' | 'right'; data: Array<[string, number]> }> = [];
            if (byMetric.weight.length) series.push({ name: 'Weight', color: '#f39c12', suffix: ' lb', axis: 'left',  data: byMetric.weight });
            if (byMetric.lean.length)   series.push({ name: 'Lean',   color: '#2ecc71', suffix: ' lb', axis: 'left',  data: byMetric.lean });
            if (byMetric.bf.length)     series.push({ name: 'BF',     color: '#e74c3c', suffix: '%',   axis: 'right', data: byMetric.bf });
            if (series.length) drawMultiChart(svg, series);
          }

          try {
            const existing = await fetchDataPoints(t.id);
            if (existing.length > 0) {
              const dp: DataPoint[] = existing.map((p: { metric: 'weight'|'bf'|'lean'; date: string; value: number | string }) => ({
                metric: p.metric,
                date: p.date,
                value: Number(p.value),
              }));
              textarea.value = pointsToCsv(dp);
            } else {
              textarea.value = 'date,weight,bf,lean\n';
            }
            requestAnimationFrame(renderPreview);
          } catch (err) {
            statusEl.textContent = 'Could not load existing data: ' + (err as Error).message;
            statusEl.className = 'bio-status err';
          }

          textarea.addEventListener('input', renderPreview);

          saveBtn.addEventListener('click', async () => {
            const text = textarea.value.trim();
            const { points, errors } = parsePastedData(text);
            if (errors.length > 0) {
              resultEl.textContent = errors[0];
              resultEl.className = 'bio-result err';
              return;
            }
            saveBtn.disabled = true;
            resultEl.textContent = 'Saving…';
            resultEl.className = 'bio-result';
            try {
              const res = await callFunction('set-data-points', {
                slug,
                edit_token: key,
                transformation_id: t.id,
                points,
              });
              resultEl.textContent = `Saved ${res.count} points ✓`;
              resultEl.className = 'bio-result ok';
            } catch (err) {
              const msg = (err as Error).message;
              resultEl.textContent = msg.includes('403') ? 'Invalid edit link.' : msg;
              resultEl.className = 'bio-result err';
            } finally {
              saveBtn.disabled = false;
            }
          });

          clearBtn.addEventListener('click', () => {
            textarea.value = 'date,weight,bf,lean\n';
            renderPreview();
          });
        }

        function hideForm() {
          formHost.innerHTML = '';
          addBtn.style.display = '';
        }

        async function handleSubmit(submitEv: Event, editing?: Transformation) {
          submitEv.preventDefault();
          const formEl = submitEv.target as HTMLFormElement;
          const fd = new FormData(formEl);
          const tStatus = formEl.querySelector('.t-status') as HTMLSpanElement;
          const submit = formEl.querySelector('button[type=submit]') as HTMLButtonElement;
          submit.disabled = true;
          tStatus.textContent = 'Saving…';
          tStatus.className = 't-status';

          // <input type="month"> emits YYYY-MM in Chrome/Edge with a native
          // picker. In Safari and Firefox the input degrades to a plain text
          // box and the user types whatever format they want. Accept the
          // common ones and normalize to YYYY-MM-01 for the DB date column.
          const monthOrNull = (v: FormDataEntryValue | null): string | null => {
            const s = String(v || '').trim();
            if (!s) return null;
            let m: RegExpMatchArray | null;
            if ((m = s.match(/^(\d{4})-(\d{1,2})$/))) {
              return `${m[1]}-${m[2].padStart(2, '0')}-01`;
            }
            if ((m = s.match(/^(\d{4})-(\d{1,2})-(\d{1,2})$/))) {
              return `${m[1]}-${m[2].padStart(2, '0')}-${m[3].padStart(2, '0')}`;
            }
            if ((m = s.match(/^(\d{1,2})\/(\d{4})$/))) {
              return `${m[2]}-${m[1].padStart(2, '0')}-01`;
            }
            if ((m = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})$/))) {
              let y = +m[3];
              if (y < 100) y += 2000;
              return `${y}-${m[1].padStart(2, '0')}-${m[2].padStart(2, '0')}`;
            }
            return null;
          };
          const transformation: Record<string, unknown> = {
            name: fd.get('name'),
            before_date: monthOrNull(fd.get('before_date')),
            after_date: monthOrNull(fd.get('after_date')),
            before_weight: fd.get('before_weight') || null,
            after_weight: fd.get('after_weight') || null,
            before_bf: fd.get('before_bf') || null,
            after_bf: fd.get('after_bf') || null,
            before_lean: fd.get('before_lean') || null,
            after_lean: fd.get('after_lean') || null,
            takeaway_text: fd.get('takeaway_text') || null,
          };
          if (editing) transformation.id = editing.id;

          try {
            const res = await callFunction('manage-transformation', {
              action: editing ? 'update' : 'add',
              slug,
              edit_token: key,
              transformation,
            });
            const saved = res.transformation as Transformation;
            if (editing) {
              transformations = transformations.map((t) => (t.id === saved.id ? saved : t));
            } else {
              transformations = [...transformations, saved];
            }
            renderList();

            if (editing) {
              tStatus.textContent = 'Saved ✓';
              tStatus.className = 't-status ok';
              submit.disabled = false;
            } else {
              // Re-show the form in edit mode so the user can immediately add photos.
              showForm(saved);
              const reopenStatus = formHost.querySelector('.t-status') as HTMLSpanElement;
              if (reopenStatus) {
                reopenStatus.textContent = 'Created ✓ — add photos below';
                reopenStatus.className = 't-status ok';
              }
            }
          } catch (err) {
            const msg = (err as Error).message;
            tStatus.textContent = msg.includes('403') ? 'Invalid edit link.' : msg;
            tStatus.className = 't-status err';
            submit.disabled = false;
          }
        }

        async function handlePhotoUpload(changeEv: Event, t: Transformation) {
          const input = changeEv.target as HTMLInputElement;
          const file = input.files?.[0];
          if (!file) return;
          const slot = (input.dataset.slot as 'before' | 'after');
          const slotEl = input.closest('.photo-slot') as HTMLElement;
          const statusEl = slotEl.querySelector('.upload-status') as HTMLElement;
          const previewEl = slotEl.querySelector('.photo-preview') as HTMLElement;
          const labelEl = slotEl.querySelector('.upload-label') as HTMLElement;

          statusEl.textContent = 'Compressing…';
          statusEl.className = 'upload-status';

          try {
            const compressed = await compressImage(file, 1200, 0.82);

            statusEl.textContent = 'Uploading…';

            const data_b64 = await new Promise<string>((resolve, reject) => {
              const reader = new FileReader();
              reader.onload = () => {
                const result = reader.result as string;
                resolve(result.split(',')[1] || result);
              };
              reader.onerror = () => reject(new Error('Failed to read file'));
              reader.readAsDataURL(compressed);
            });

            // compressImage always emits JPEG, so the extension is fixed.
            const res = await callFunction('upload-photo', {
              slug,
              edit_token: key,
              transformation_id: t.id,
              slot,
              filename: 'photo.jpg',
              data: data_b64,
            });

            const url = res.url as string;
            transformations = transformations.map((x) =>
              x.id === t.id
                ? { ...x, [slot === 'before' ? 'before_photo_url' : 'after_photo_url']: url }
                : x
            );
            if (slot === 'before') (t as Transformation).before_photo_url = url;
            else (t as Transformation).after_photo_url = url;

            previewEl.innerHTML = `<img src="${escapeHtml(url)}" alt="" />`;
            labelEl.textContent = 'Replace photo';
            statusEl.textContent = 'Uploaded ✓';
            statusEl.className = 'upload-status ok';
            input.value = '';
            renderList();
          } catch (err) {
            const msg = (err as Error).message;
            statusEl.textContent = msg.includes('403') ? 'Invalid edit link.' : msg;
            statusEl.className = 'upload-status err';
          }
        }

        async function handleDelete(id: string) {
          const t = transformations.find((x) => x.id === id);
          if (!t) return;
          if (!confirm(`Delete "${t.name}" and all its biometric data?\n\nThis can't be undone.`)) return;
          try {
            await callFunction('manage-transformation', {
              action: 'delete',
              slug,
              edit_token: key,
              transformation_id: id,
            });
            transformations = transformations.filter((x) => x.id !== id);
            renderList();
          } catch (err) {
            alert('Could not delete: ' + (err as Error).message);
          }
        }

        // ---------- Raffle settings + entries ----------
        const raffleForm = document.getElementById('raffle-form') as HTMLFormElement;
        const raffleSaveBtn = document.getElementById('raffle-save') as HTMLButtonElement;
        const raffleSaveStatus = document.getElementById('raffle-save-status')!;
        const entryCountEl = document.getElementById('entry-count')!;
        const entriesWrap = document.getElementById('entries-list-wrap')!;
        let raffleStatus: 'open' | 'closed' = (ev.raffle_status === 'open' ? 'open' : 'closed');

        raffleForm.addEventListener('submit', async (submitEv) => {
          submitEv.preventDefault();
          raffleSaveBtn.disabled = true;
          raffleSaveStatus.textContent = 'Saving…';
          raffleSaveStatus.className = '';
          const fd = new FormData(raffleForm);
          try {
            await callFunction('update-event', {
              slug,
              edit_token: key,
              raffle_status: fd.get('raffle_status'),
              raffle_prize: fd.get('raffle_prize') || null,
            });
            raffleStatus = String(fd.get('raffle_status')) === 'open' ? 'open' : 'closed';
            raffleSaveStatus.textContent = 'Saved ✓';
            raffleSaveStatus.className = 'ok';
          } catch (err) {
            const msg = (err as Error).message;
            raffleSaveStatus.textContent = msg.includes('403') ? 'Invalid edit link.' : msg;
            raffleSaveStatus.className = 'err';
          } finally {
            raffleSaveBtn.disabled = false;
          }
        });

        function renderEntries(entries: Array<{
          id: string; name: string; email: string; phone: string | null;
          invited_by: string | null;
          risk_score: number | null;
          quiz_answers: Record<string, string | number | null> | null;
          goal_text: string | null;
          newsletter_optin: boolean | null;
          apprentice_optin: boolean | null;
          drawn: boolean; prize_won: string | null;
          submitted_at: string;
        }>) {
          entryCountEl.textContent = String(entries.length);
          if (entries.length === 0) {
            entriesWrap.innerHTML =
              `<p class="entries-empty">No entries yet. Open the raffle and share <code>${base}raffle?slug=${escapeHtml(slug || '')}</code>.</p>`;
            return;
          }
          const flagLabels: Record<string, string> = {
            has_diabetes: 'Diabetes',
            has_high_bp: 'High BP',
            has_high_cholesterol: 'High chol',
          };
          const ratingLabels: Record<string, string> = {
            rate_energy: 'Energy',
            rate_sleep: 'Sleep',
            rate_weight: 'Weight',
            rate_cravings: 'Cravings',
            rate_mood: 'Mood',
            rate_digestion: 'Digestion',
            rate_community: 'Community',
          };
          entriesWrap.innerHTML = `
            <ul class="entry-list">
              ${entries.map((e) => {
                const q = e.quiz_answers || {};
                const flags = Object.entries(flagLabels)
                  .filter(([k]) => q[k] === 'yes')
                  .map(([, lbl]) => `<span class="flag">${lbl}</span>`)
                  .join('');
                const ratings = Object.entries(ratingLabels)
                  .filter(([k]) => typeof q[k] === 'number')
                  .map(([k, lbl]) => `<span class="rate">${lbl} ${q[k]}</span>`)
                  .join('');
                const optins: string[] = [];
                if (e.apprentice_optin) optins.push('<span class="optin apprentice">⚑ Apprentice interest</span>');
                if (e.newsletter_optin) optins.push('<span class="optin">Newsletter</span>');
                const submitted = new Date(e.submitted_at);
                const submittedTxt = isNaN(submitted.getTime())
                  ? e.submitted_at
                  : submitted.toLocaleString(undefined, { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });
                return `
                  <li class="entry-item">
                    <div class="entry-head">
                      <strong>${escapeHtml(e.name)}</strong>
                      <span class="entry-score">${e.risk_score ?? 0}/3</span>
                    </div>
                    <div class="entry-meta">
                      ${escapeHtml(e.email)}${e.phone ? ` · ${escapeHtml(e.phone)}` : ''}<br />
                      ${e.invited_by ? `Invited by ${escapeHtml(e.invited_by)} · ` : ''}entered ${escapeHtml(submittedTxt)}
                    </div>
                    ${flags ? `<div class="entry-flags">${flags}</div>` : ''}
                    ${ratings ? `<div class="entry-ratings">${ratings}</div>` : ''}
                    ${optins.length ? `<div class="entry-optins">${optins.join(' ')}</div>` : ''}
                    ${e.goal_text ? `<p class="entry-goal">${escapeHtml(e.goal_text)}</p>` : ''}
                    ${e.drawn ? `<p class="entry-drawn">🏆 Winner${e.prize_won ? ` — ${escapeHtml(e.prize_won)}` : ''}</p>` : ''}
                  </li>`;
              }).join('')}
            </ul>
          `;
        }

        async function loadEntries() {
          try {
            const res = await callFunction('manage-raffle', {
              slug,
              edit_token: key,
              action: 'list',
            });
            renderEntries(res.entries);
          } catch (err) {
            entriesWrap.innerHTML = `<p class="entries-empty err">${escapeHtml((err as Error).message)}</p>`;
          }
        }
        loadEntries();
        // Light polling so a host watching the dashboard sees new entries
        // come in during an event without having to refresh manually.
        window.setInterval(loadEntries, 10000);

        // ---------- Share & save links section ----------
        const origin = window.location.origin;
        const publicUrl = `${origin}${base}event?slug=${encodeURIComponent(slug)}`;
        const editUrl = `${origin}${base}edit?slug=${encodeURIComponent(slug)}&key=${encodeURIComponent(key)}`;
        (document.getElementById('public-url') as HTMLInputElement).value = publicUrl;
        (document.getElementById('edit-url') as HTMLInputElement).value = editUrl;

        const qrCanvas = document.getElementById('public-qr') as HTMLCanvasElement;
        QRCode.toCanvas(qrCanvas, publicUrl, {
          width: 200, margin: 1,
          color: { dark: '#ffffff', light: '#1a252f' },
        }).catch(() => {});

        document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
          btn.addEventListener('click', async () => {
            const sel = btn.getAttribute('data-copy')!;
            const input = document.querySelector<HTMLInputElement>(sel)!;
            await navigator.clipboard.writeText(input.value);
            const orig = btn.textContent;
            btn.textContent = 'Copied!';
            setTimeout(() => (btn.textContent = orig), 1200);
          });
        });

        document.getElementById('public-qr-dl')?.addEventListener('click', () => {
          const a = document.createElement('a');
          a.href = qrCanvas.toDataURL('image/png');
          a.download = `${slug}-qr.png`;
          a.click();
        });

        document.getElementById('email-edit')?.addEventListener('click', () => {
          const subj = encodeURIComponent('Edit link for my event');
          const mailBody = encodeURIComponent(
            `Save this — it's the only way back into your event admin page.\n\nEdit URL:\n${editUrl}\n\nPublic URL:\n${publicUrl}\n`
          );
          window.location.href = `mailto:?subject=${subj}&body=${mailBody}`;
        });

        document.getElementById('download-edit')?.addEventListener('click', () => {
          const txt = `Metabolic Reset Event — edit link\n\nEdit URL (KEEP SECRET):\n${editUrl}\n\nPublic URL (share):\n${publicUrl}\n`;
          const blob = new Blob([txt], { type: 'text/plain' });
          const a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = `event-${slug}-edit-link.txt`;
          a.click();
        });

        addBtn.addEventListener('click', () => showForm());
        list.addEventListener('click', (clickEv) => {
          const target = clickEv.target as HTMLElement;
          if (target.tagName !== 'BUTTON') return;
          const id = target.getAttribute('data-id');
          if (!id) return;
          if (target.classList.contains('edit')) {
            const t = transformations.find((x) => x.id === id);
            if (t) showForm(t);
          } else if (target.classList.contains('del')) {
            handleDelete(id);
          }
        });

        renderList();
      } catch (err) {
        root.innerHTML = `<p class="loading err">${escapeHtml((err as Error).message)}</p>`;
      }
    })();
  }
</script>

<style is:global>
