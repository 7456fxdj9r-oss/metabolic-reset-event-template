    background: transparent; border: none;
    color: #ecf0f1; font-size: 13px; font-family: inherit;
    cursor: pointer; padding: 6px 0;
  }
  .checklist-label:hover { color: var(--accent); }
  .checklist-item.done .checklist-label {
    color: #95a5a6; text-decoration: line-through;
    cursor: default;
  }
  .checklist-item.done .checklist-label:hover { color: #95a5a6; }
  .checklist-celebrate {
    margin-top: 10px;
    padding: 10px 12px;
    background: rgba(46,204,113,0.10);
    border: 1px solid rgba(46,204,113,0.4);
    border-radius: 8px;
