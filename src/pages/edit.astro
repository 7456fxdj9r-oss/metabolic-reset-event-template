  .organizer-btn.current {
    background: var(--accent); color: #1a252f;
    border-color: var(--accent);
    cursor: default; opacity: 0.95;
  }
  .organizer-btn:hover:not([disabled]) { background: rgba(243,156,18,0.30); }

  .host-organizer-badge {
