  .edit-host-title { font-size: 12px; color: #95a5a6; margin-bottom: 10px; }
  .edit-host-title strong { color: var(--accent); }
  #cancel-edit-host {
    background: transparent; color: #ecf0f1;
    border: 1px solid rgba(255,255,255,0.20); font-weight: 600;
  }
  #edit-host-status { font-size: 13px; color: #95a5a6; }
  #edit-host-status.err { color: #e74c3c; font-weight: 600; }
  .host-actions { display: flex; gap: 6px; flex-wrap: wrap; }
  .organizer-btn {
    padding: 6px 12px; font-size: 12px; font-weight: 700;
    border-radius: 6px; cursor: pointer;
    background: rgba(243,156,18,0.18); color: var(--accent);
    border: 1px solid rgba(243,156,18,0.5);
