        // ---------- Event details form ----------
        const form = document.getElementById('event-form') as HTMLFormElement;
        const status = document.getElementById('save-status')!;
        const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;

        form.addEventListener('submit', async (submitEv) => {
          submitEv.preventDefault();
          saveBtn.disabled = true;
          status.textContent = 'Saving…';
          status.className = '';
          const fd = new FormData(form);
          try {
            await callFunction('update-event', {
              slug,
              edit_token: key,
              name: fd.get('name'),
              host_line: fd.get('host_line') || null,
              accent_color: fd.get('accent_color'),
              event_date: fd.get('event_date') || null,
              organizer_name: fd.get('organizer_name') || null,
              organizer_bio: fd.get('organizer_bio') || null,
              organizer_email: fd.get('organizer_email') || null,
              organizer_phone: fd.get('organizer_phone') || null,
              organizer_website: fd.get('organizer_website') || null,
            });
            status.textContent = 'Saved ✓';
            status.className = 'ok';
            const newName = String(fd.get('name') || '').trim();
            if (newName) document.getElementById('page-title')!.textContent = newName;
          } catch (err) {
            const msg = (err as Error).message;
            status.textContent = msg.includes('403') ? 'Invalid edit link.' : msg;
            status.className = 'err';
          } finally {
            saveBtn.disabled = false;
          }
        });

        // ---------- Transformations section ----------
        const list = document.getElementById('t-list')!;
        const formHost = document.getElementById('t-form-host')!;
        const addBtn = document.getElementById('add-t-btn') as HTMLButtonElement;

        function updateStatusPills() {
          const sPill = document.getElementById('pill-stories');
          if (sPill) {
            const n = transformations.length;
            sPill.innerHTML = `📊 ${n} ${n === 1 ? 'story' : 'stories'}`;
            sPill.classList.toggle('filled', n > 0);
          }
          const spPill = document.getElementById('pill-speakers');
          if (spPill && typeof speakers !== 'undefined') {
            const n = speakers.length;
            spPill.innerHTML = `🎤 ${n} ${n === 1 ? 'speaker' : 'speakers'}`;
            spPill.classList.toggle('filled', n > 0);
          }
        }

        function renderList() {
          if (transformations.length === 0) {
            list.innerHTML = '<li class="t-empty">No transformations yet. Add one above.</li>';
          } else {
            list.innerHTML = transformations.map(transformationRowHtml).join('');
          }
          updateStatusPills();
        }

        // Photos selected before a brand-new transformation has been Created
        // need to wait for the row to exist before we can upload them. Hold
        // them here keyed by slot; handleSubmit drains this map after insert.
        let pendingPhotos: Map<'before' | 'after', File> = new Map();

        function showForm(t?: Transformation) {
          formHost.innerHTML = transformationFormHtml(t);
          addBtn.style.display = 'none';
          pendingPhotos = new Map();
          const newForm = formHost.querySelector('form.t-form') as HTMLFormElement;
          newForm.addEventListener('submit', (e) => handleSubmit(e, t));
          newForm.querySelector('button.cancel')!.addEventListener('click', hideForm);
          setupComputedStats(newForm);
          newForm.querySelectorAll('input[type=file][data-slot]').forEach((input) => {
            input.addEventListener('change', (changeEv) => {
              if (t) {
                handlePhotoUpload(changeEv as Event, t);
              } else {
                handlePendingPhoto(changeEv as Event);
              }
            });
          });
          if (t) {
            setupBiometrics(newForm, t);
          } else {
            (newForm.querySelector('input[name=name]') as HTMLInputElement).focus();
          }
        }

        // Add-mode photo selection: open crop modal, then stash the cropped
        // blob + show a local preview. Actual upload happens after Create.
        async function handlePendingPhoto(changeEv: Event) {
          const input = changeEv.target as HTMLInputElement;
          const file = input.files?.[0];
          if (!file) return;
          const slot = input.dataset.slot as 'before' | 'after';
          const slotEl = input.closest('.photo-slot') as HTMLElement;
          const previewEl = slotEl.querySelector('.photo-preview') as HTMLElement;
          const labelEl = slotEl.querySelector('.upload-label') as HTMLElement;
          const statusEl = slotEl.querySelector('.upload-status') as HTMLElement;
          input.value = '';

          statusEl.textContent = 'Opening crop tool…';
          statusEl.className = 'upload-status';

          const cropped = await openCropModal(
            file, 3 / 4, slot === 'before' ? 'Crop the before photo' : 'Crop the after photo',
          );
          if (!cropped) {
            statusEl.textContent = '';
            return;
          }
          // Wrap the cropped Blob as a File-like for the queue (uploadOnePhoto
          // takes File). Filename arbitrary — server doesn't trust it.
          const fileLike = new File([cropped], 'photo.jpg', { type: 'image/jpeg' });
          pendingPhotos.set(slot, fileLike);
          const reader = new FileReader();
          reader.onload = () => {
            previewEl.innerHTML = `<img src="${reader.result}" alt="" />`;
            labelEl.textContent = 'Replace photo';
            statusEl.textContent = 'Will upload after Create';
            statusEl.className = 'upload-status';
          };
          reader.readAsDataURL(cropped);
        }

        async function blobToBase64(blob: Blob): Promise<string> {
          return new Promise<string>((resolve, reject) => {
            const reader = new FileReader();
            reader.onload = () => {
              const result = reader.result as string;
              resolve(result.split(',')[1] || result);
            };
            reader.onerror = () => reject(new Error('Failed to read file'));
            reader.readAsDataURL(blob);
          });
        }

        async function uploadOnePhoto(transformationId: string, slot: 'before' | 'after', file: File): Promise<string> {
          const compressed = await compressImage(file, 1200, 0.82);
          const data_b64 = await blobToBase64(compressed);
          const res = await callFunction('upload-photo', {
            slug,
            edit_token: key,
            transformation_id: transformationId,
            slot,
            filename: 'photo.jpg',
            data: data_b64,
          });
          return res.url as string;
        }

        function setupComputedStats(formEl: HTMLFormElement) {
          const lbEl = formEl.querySelector('[data-stat=lb]') as HTMLElement;
          const leanEl = formEl.querySelector('[data-stat=lean]') as HTMLElement;
          const bfEl = formEl.querySelector('[data-stat=bf]') as HTMLElement;
          const num = (v: FormDataEntryValue | null): number | null => {
            if (v == null || v === '') return null;
            const n = Number(v);
            return Number.isFinite(n) ? n : null;
          };
          const round1 = (n: number) => Math.round(n * 10) / 10;
          const recompute = () => {
            const fd = new FormData(formEl);
            const bw = num(fd.get('before_weight'));
            const aw = num(fd.get('after_weight'));
            const bbf = num(fd.get('before_bf'));
            const abf = num(fd.get('after_bf'));
            const bln = num(fd.get('before_lean'));
            const aln = num(fd.get('after_lean'));
            lbEl.textContent = bw != null && aw != null ? `−${round1(bw - aw)}` : '—';
            bfEl.textContent = bbf != null && abf != null ? `−${round1(bbf - abf)}` : '—';
            leanEl.textContent =
              bln != null && aln != null && bln > 0 ? `${round1((aln / bln) * 100)}%` : '—';
          };
          formEl.querySelectorAll<HTMLInputElement>(
            'input[name^=before_], input[name^=after_]'
          ).forEach((input) => input.addEventListener('input', recompute));
          recompute();
        }

        async function setupBiometrics(formEl: HTMLFormElement, t: Transformation) {
          const textarea = formEl.querySelector('textarea.bio-textarea') as HTMLTextAreaElement;
          const statusEl = formEl.querySelector('.bio-status') as HTMLElement;
          const svg = formEl.querySelector('svg.bio-chart') as unknown as SVGSVGElement;
          const saveBtn = formEl.querySelector('button.bio-save') as HTMLButtonElement;
          const clearBtn = formEl.querySelector('button.bio-clear') as HTMLButtonElement;
          const resultEl = formEl.querySelector('.bio-result') as HTMLElement;

          function renderPreview() {
            const text = textarea.value.trim();
            while (svg.firstChild) svg.removeChild(svg.firstChild);
            if (!text) {
              statusEl.textContent = '';
              statusEl.className = 'bio-status';
              return;
            }
            const { points, errors } = parsePastedData(text);
            if (errors.length > 0) {
              statusEl.textContent = errors.slice(0, 3).join(' · ');
              statusEl.className = 'bio-status err';
            } else {
              const counts = {
                weight: points.filter((p) => p.metric === 'weight').length,
                bf: points.filter((p) => p.metric === 'bf').length,
                lean: points.filter((p) => p.metric === 'lean').length,
              };
              statusEl.textContent = `${points.length} points · ${counts.weight} weight, ${counts.bf} BF, ${counts.lean} lean`;
              statusEl.className = 'bio-status ok';
            }
            const byMetric: Record<string, Array<[string, number]>> = { weight: [], bf: [], lean: [] };
            for (const p of points) byMetric[p.metric].push([p.date, p.value]);
            const series: Array<{ name: string; color: string; suffix: string; axis: 'left' | 'right'; data: Array<[string, number]> }> = [];
            if (byMetric.weight.length) series.push({ name: 'Weight', color: '#f39c12', suffix: ' lb', axis: 'left',  data: byMetric.weight });
            if (byMetric.lean.length)   series.push({ name: 'Lean',   color: '#2ecc71', suffix: ' lb', axis: 'left',  data: byMetric.lean });
            if (byMetric.bf.length)     series.push({ name: 'BF',     color: '#e74c3c', suffix: '%',   axis: 'right', data: byMetric.bf });
            if (series.length) drawMultiChart(svg, series);
          }

          try {
            const existing = await fetchDataPoints(t.id);
            if (existing.length > 0) {
              const dp: DataPoint[] = existing.map((p: { metric: 'weight'|'bf'|'lean'; date: string; value: number | string }) => ({
                metric: p.metric,
                date: p.date,
                value: Number(p.value),
              }));
              textarea.value = pointsToCsv(dp);
            } else {
              textarea.value = 'date,weight,bf,lean\n';
            }
            requestAnimationFrame(renderPreview);
          } catch (err) {
            statusEl.textContent = 'Could not load existing data: ' + (err as Error).message;
            statusEl.className = 'bio-status err';
          }

          textarea.addEventListener('input', renderPreview);

          saveBtn.addEventListener('click', async () => {
            const text = textarea.value.trim();
            const { points, errors } = parsePastedData(text);
            if (errors.length > 0) {
              resultEl.textContent = errors[0];
              resultEl.className = 'bio-result err';
              return;
            }
            saveBtn.disabled = true;
            resultEl.textContent = 'Saving…';
            resultEl.className = 'bio-result';
            try {
              const res = await callFunction('set-data-points', {
                slug,
                edit_token: key,
                transformation_id: t.id,
                points,
              });
              resultEl.textContent = `Saved ${res.count} points ✓`;
              resultEl.className = 'bio-result ok';
            } catch (err) {
              const msg = (err as Error).message;
              resultEl.textContent = msg.includes('403') ? 'Invalid edit link.' : msg;
              resultEl.className = 'bio-result err';
            } finally {
              saveBtn.disabled = false;
            }
          });

          clearBtn.addEventListener('click', () => {
            textarea.value = 'date,weight,bf,lean\n';
            renderPreview();
          });
        }

        function hideForm() {
          formHost.innerHTML = '';
          addBtn.style.display = '';
        }

        async function handleSubmit(submitEv: Event, editing?: Transformation) {
          submitEv.preventDefault();
          const formEl = submitEv.target as HTMLFormElement;
          const fd = new FormData(formEl);
          const tStatus = formEl.querySelector('.t-status') as HTMLSpanElement;
          const submit = formEl.querySelector('button[type=submit]') as HTMLButtonElement;
          submit.disabled = true;
          tStatus.textContent = 'Saving…';
          tStatus.className = 't-status';

          // <input type="month"> emits YYYY-MM in Chrome/Edge with a native
          // picker. In Safari and Firefox the input degrades to a plain text
          // box and the user types whatever format they want. Accept the
          // common ones and normalize to YYYY-MM-01 for the DB date column.
          const monthOrNull = (v: FormDataEntryValue | null): string | null => {
            const s = String(v || '').trim();
            if (!s) return null;
            let m: RegExpMatchArray | null;
            if ((m = s.match(/^(\d{4})-(\d{1,2})$/))) {
              return `${m[1]}-${m[2].padStart(2, '0')}-01`;
            }
            if ((m = s.match(/^(\d{4})-(\d{1,2})-(\d{1,2})$/))) {
              return `${m[1]}-${m[2].padStart(2, '0')}-${m[3].padStart(2, '0')}`;
            }
            if ((m = s.match(/^(\d{1,2})\/(\d{4})$/))) {
              return `${m[2]}-${m[1].padStart(2, '0')}-01`;
            }
            if ((m = s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})$/))) {
              let y = +m[3];
              if (y < 100) y += 2000;
              return `${y}-${m[1].padStart(2, '0')}-${m[2].padStart(2, '0')}`;
            }
            return null;
          };
          const transformation: Record<string, unknown> = {
            name: fd.get('name'),
            before_date: monthOrNull(fd.get('before_date')),
            after_date: monthOrNull(fd.get('after_date')),
            before_weight: fd.get('before_weight') || null,
            after_weight: fd.get('after_weight') || null,
            before_bf: fd.get('before_bf') || null,
            after_bf: fd.get('after_bf') || null,
            before_lean: fd.get('before_lean') || null,
            after_lean: fd.get('after_lean') || null,
            takeaway_text: fd.get('takeaway_text') || null,
          };
          if (editing) transformation.id = editing.id;

          try {
            const res = await callFunction('manage-transformation', {
              action: editing ? 'update' : 'add',
              slug,
              edit_token: key,
              transformation,
            });
            let saved = res.transformation as Transformation;

            // Drain any photos the user picked before clicking Create.
            if (!editing && pendingPhotos.size > 0) {
              tStatus.textContent = `Uploading photo${pendingPhotos.size > 1 ? 's' : ''}…`;
              for (const [slot, file] of pendingPhotos) {
                try {
                  const url = await uploadOnePhoto(saved.id, slot, file);
                  saved = {
                    ...saved,
                    [slot === 'before' ? 'before_photo_url' : 'after_photo_url']: url,
                  };
                } catch (err) {
                  console.error(`Failed to upload ${slot} photo:`, err);
                }
              }
              pendingPhotos = new Map();
            }

            if (editing) {
              transformations = transformations.map((t) => (t.id === saved.id ? saved : t));
            } else {
              transformations = [...transformations, saved];
            }
            renderList();

            if (editing) {
              tStatus.textContent = 'Saved ✓';
              tStatus.className = 't-status ok';
              submit.disabled = false;
            } else {
              // Re-show the form in edit mode so the user can keep tweaking
              // (replace photos, add biometric data, etc.) without leaving.
              showForm(saved);
              const reopenStatus = formHost.querySelector('.t-status') as HTMLSpanElement;
              if (reopenStatus) {
                reopenStatus.textContent = 'Created ✓';
                reopenStatus.className = 't-status ok';
              }
            }
          } catch (err) {
            const msg = (err as Error).message;
            tStatus.textContent = msg.includes('403') ? 'Invalid edit link.' : msg;
            tStatus.className = 't-status err';
            submit.disabled = false;
          }
        }

        async function handlePhotoUpload(changeEv: Event, t: Transformation) {
          const input = changeEv.target as HTMLInputElement;
          const file = input.files?.[0];
          if (!file) return;
          const slot = (input.dataset.slot as 'before' | 'after');
          const slotEl = input.closest('.photo-slot') as HTMLElement;
          const statusEl = slotEl.querySelector('.upload-status') as HTMLElement;
          const previewEl = slotEl.querySelector('.photo-preview') as HTMLElement;
          const labelEl = slotEl.querySelector('.upload-label') as HTMLElement;

          statusEl.textContent = 'Opening crop tool…';
          statusEl.className = 'upload-status';
          input.value = ''; // allow re-pick of the same file later

          try {
            const cropped = await openCropModal(
              file, 3 / 4, slot === 'before' ? 'Crop the before photo' : 'Crop the after photo',
            );
            if (!cropped) {
              statusEl.textContent = '';
              return;
            }
            statusEl.textContent = 'Uploading…';
            const data_b64 = await blobToBase64(cropped);
            const res = await callFunction('upload-photo', {
              slug, edit_token: key,
              transformation_id: t.id, slot,
              filename: 'photo.jpg', data: data_b64,
            });
            const url = res.url as string;

            transformations = transformations.map((x) =>
              x.id === t.id
                ? { ...x, [slot === 'before' ? 'before_photo_url' : 'after_photo_url']: url }
                : x
            );
            if (slot === 'before') (t as Transformation).before_photo_url = url;
            else (t as Transformation).after_photo_url = url;

            previewEl.innerHTML = `<img src="${escapeHtml(url)}" alt="" />`;
            labelEl.textContent = 'Replace photo';
            statusEl.textContent = 'Uploaded ✓';
            statusEl.className = 'upload-status ok';
            renderList();
          } catch (err) {
            const msg = (err as Error).message;
            statusEl.textContent = msg.includes('403') ? 'Invalid edit link.' : msg;
            statusEl.className = 'upload-status err';
          }
        }

        async function handleDelete(id: string) {
          const t = transformations.find((x) => x.id === id);
          if (!t) return;
          if (!confirm(`Delete "${t.name}" and all its biometric data?\n\nThis can't be undone.`)) return;
          try {
            await callFunction('manage-transformation', {
              action: 'delete',
              slug,
              edit_token: key,
              transformation_id: id,
            });
            transformations = transformations.filter((x) => x.id !== id);
            renderList();
          } catch (err) {
            alert('Could not delete: ' + (err as Error).message);
          }
        }

        // ---------- Raffle settings + entries ----------
        const raffleForm = document.getElementById('raffle-form') as HTMLFormElement;
        const raffleSaveBtn = document.getElementById('raffle-save') as HTMLButtonElement;
        const raffleSaveStatus = document.getElementById('raffle-save-status')!;
        const entryCountEl = document.getElementById('entry-count')!;
        const entriesWrap = document.getElementById('entries-list-wrap')!;
        let raffleStatus: 'open' | 'closed' = (ev.raffle_status === 'open' ? 'open' : 'closed');

        // Prize photo: separate upload flow (event-level, not transformation-level).
        const prizePhotoInput = raffleForm.querySelector(
          'input[type=file][data-event-slot="prize"]'
        ) as HTMLInputElement | null;
        if (prizePhotoInput) {
          prizePhotoInput.addEventListener('change', async (changeEv) => {
            const file = (changeEv.target as HTMLInputElement).files?.[0];
            if (!file) return;
            const slotEl = prizePhotoInput.closest('.prize-photo-slot') as HTMLElement;
            const previewEl = slotEl.querySelector('.photo-preview') as HTMLElement;
            const labelEl = slotEl.querySelector('.upload-label') as HTMLElement;
            const statusEl = slotEl.querySelector('.upload-status') as HTMLElement;

            statusEl.textContent = 'Compressing…';
            statusEl.className = 'upload-status';

            try {
              const compressed = await compressImage(file, 1200, 0.82);
              statusEl.textContent = 'Uploading…';
              const data_b64 = await blobToBase64(compressed);
              const res = await callFunction('upload-event-photo', {
                slug,
                edit_token: key,
                kind: 'prize',
                filename: 'photo.jpg',
                data: data_b64,
              });
              const url = res.url as string;
              previewEl.innerHTML = `<img src="${escapeHtml(url)}" alt="" />`;
              labelEl.textContent = 'Replace photo';
              statusEl.textContent = 'Uploaded ✓';
              statusEl.className = 'upload-status ok';
              prizePhotoInput.value = '';
            } catch (err) {
              const msg = (err as Error).message;
              statusEl.textContent = msg.includes('403') ? 'Invalid edit link.' : msg;
              statusEl.className = 'upload-status err';
            }
          });
        }

        raffleForm.addEventListener('submit', async (submitEv) => {
          submitEv.preventDefault();
          raffleSaveBtn.disabled = true;
          raffleSaveStatus.textContent = 'Saving…';
          raffleSaveStatus.className = '';
          const fd = new FormData(raffleForm);
          try {
            await callFunction('update-event', {
              slug,
              edit_token: key,
              raffle_status: fd.get('raffle_status'),
              raffle_prize: fd.get('raffle_prize') || null,
            });
            raffleStatus = String(fd.get('raffle_status')) === 'open' ? 'open' : 'closed';
            raffleSaveStatus.textContent = 'Saved ✓';
            raffleSaveStatus.className = 'ok';
          } catch (err) {
            const msg = (err as Error).message;
            raffleSaveStatus.textContent = msg.includes('403') ? 'Invalid edit link.' : msg;
            raffleSaveStatus.className = 'err';
          } finally {
            raffleSaveBtn.disabled = false;
          }
        });

        function renderEntries(entries: Array<{
          id: string; name: string; email: string; phone: string | null;
          invited_by: string | null;
          risk_score: number | null;
          quiz_answers: Record<string, string | number | null> | null;
          goal_text: string | null;
          newsletter_optin: boolean | null;
          apprentice_optin: boolean | null;
          drawn: boolean; prize_won: string | null;
          submitted_at: string;
        }>) {
          entryCountEl.textContent = String(entries.length);
          if (entries.length === 0) {
            entriesWrap.innerHTML =
              `<p class="entries-empty">No entries yet. Open the raffle and share <code>${base}raffle?slug=${escapeHtml(slug || '')}</code>.</p>`;
            return;
          }
          const flagLabels: Record<string, string> = {
            has_diabetes: 'Diabetes',
            has_high_bp: 'High BP',
            has_high_cholesterol: 'High chol',
          };
          const ratingLabels: Record<string, string> = {
            rate_energy: 'Energy',
            rate_sleep: 'Sleep',
            rate_weight: 'Weight',
            rate_cravings: 'Cravings',
            rate_mood: 'Mood',
            rate_digestion: 'Digestion',
            rate_community: 'Community',
          };
          entriesWrap.innerHTML = `
            <ul class="entry-list">
              ${entries.map((e) => {
                const q = e.quiz_answers || {};
                const flags = Object.entries(flagLabels)
                  .filter(([k]) => q[k] === 'yes')
                  .map(([, lbl]) => `<span class="flag">${lbl}</span>`)
                  .join('');
                const ratings = Object.entries(ratingLabels)
                  .filter(([k]) => typeof q[k] === 'number')
                  .map(([k, lbl]) => `<span class="rate">${lbl} ${q[k]}</span>`)
                  .join('');
                const optins: string[] = [];
                if (e.apprentice_optin) optins.push('<span class="optin apprentice">⚑ Apprentice interest</span>');
                if (e.newsletter_optin) optins.push('<span class="optin">Newsletter</span>');
                const submitted = new Date(e.submitted_at);
                const submittedTxt = isNaN(submitted.getTime())
                  ? e.submitted_at
                  : submitted.toLocaleString(undefined, { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' });
                return `
                  <li class="entry-item">
                    <div class="entry-head">
                      <strong>${escapeHtml(e.name)}</strong>
                      <span class="entry-score">${e.risk_score ?? 0}/3</span>
                    </div>
                    <div class="entry-meta">
                      ${escapeHtml(e.email)}${e.phone ? ` · ${escapeHtml(e.phone)}` : ''}<br />
                      ${e.invited_by ? `Invited by ${escapeHtml(e.invited_by)} · ` : ''}entered ${escapeHtml(submittedTxt)}
                    </div>
                    ${flags ? `<div class="entry-flags">${flags}</div>` : ''}
                    ${ratings ? `<div class="entry-ratings">${ratings}</div>` : ''}
                    ${optins.length ? `<div class="entry-optins">${optins.join(' ')}</div>` : ''}
                    ${e.goal_text ? `<p class="entry-goal">${escapeHtml(e.goal_text)}</p>` : ''}
                    ${e.drawn ? `<p class="entry-drawn">🏆 Winner${e.prize_won ? ` — ${escapeHtml(e.prize_won)}` : ''}</p>` : ''}
                  </li>`;
              }).join('')}
            </ul>
          `;
        }

        const drawBtn = document.getElementById('draw-btn') as HTMLButtonElement;
        const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
        const exportBtn = document.getElementById('export-btn') as HTMLButtonElement;
        const drawStatus = document.getElementById('draw-status')!;
        let entriesCache: any[] = [];

        async function loadEntries() {
          try {
            const res = await callFunction('manage-raffle', {
              slug,
              edit_token: key,
              action: 'list',
            });
            entriesCache = res.entries || [];
            renderEntries(entriesCache);
            const total = entriesCache.length;
            const eligible = entriesCache.filter((e: { drawn: boolean }) => !e.drawn).length;
            const ePill = document.getElementById('pill-entries');
            if (ePill) {
              ePill.innerHTML = `${total} ${total === 1 ? 'entry' : 'entries'}`;
              ePill.classList.toggle('filled', total > 0);
            }
            drawBtn.disabled = eligible === 0;
            drawBtn.title = eligible === 0
              ? 'No entries left to draw'
              : `${eligible} eligible entries`;
            clearBtn.disabled = total === 0;
            clearBtn.title = total === 0 ? 'Nothing to clear' : `Delete all ${total} entries`;
            exportBtn.disabled = total === 0;
            exportBtn.title = total === 0 ? 'Nothing to export' : `Download ${total} entries as CSV`;
          } catch (err) {
            entriesWrap.innerHTML = `<p class="entries-empty err">${escapeHtml((err as Error).message)}</p>`;
          }
        }
        loadEntries();
        // Light polling so a host watching the dashboard sees new entries
        // come in during an event without having to refresh manually.
        window.setInterval(loadEntries, 10000);

        exportBtn.addEventListener('click', () => {
          const csv = buildRaffleEntriesCsv(entriesCache);
          const stamp = new Date().toISOString().slice(0, 10);
          downloadCsv(`raffle-entries-${slug}-${stamp}.csv`, csv);
        });

        clearBtn.addEventListener('click', async () => {
          if (!confirm('Delete ALL raffle entries for this event?\n\nThis cannot be undone. The raffle settings (status, prize, photo) stay as they are — only the entries themselves are wiped.')) return;
          if (!confirm('Are you sure? Type-confirm has no take-backs.')) return;
          clearBtn.disabled = true;
          drawStatus.textContent = 'Clearing entries…';
          drawStatus.className = 'draw-status';
          try {
            const res = await callFunction('manage-raffle', {
              slug, edit_token: key, action: 'clear',
            });
            drawStatus.textContent = `Deleted ${res.deleted} entr${res.deleted === 1 ? 'y' : 'ies'}.`;
            drawStatus.className = 'draw-status ok';
            await loadEntries();
          } catch (err) {
            drawStatus.textContent = (err as Error).message;
            drawStatus.className = 'draw-status err';
            clearBtn.disabled = false;
          }
        });

        drawBtn.addEventListener('click', async () => {
          if (!confirm('Pick a random winner from the eligible entries?')) return;
          drawBtn.disabled = true;
          drawStatus.textContent = 'Drawing…';
          drawStatus.className = 'draw-status';
          try {
            const res = await callFunction('manage-raffle', {
              slug,
              edit_token: key,
              action: 'draw',
            });
            const winner = res.winner;
            drawStatus.textContent = `🏆 Winner: ${winner.name}${winner.prize_won ? ` — ${winner.prize_won}` : ''}`;
            drawStatus.className = 'draw-status ok';
            await loadEntries();
          } catch (err) {
            drawStatus.textContent = (err as Error).message;
            drawStatus.className = 'draw-status err';
            drawBtn.disabled = false;
          }
        });

        // ---------- Speakers ----------
        type Speaker = {
          id: string;
          name: string;
          photo_url: string | null;
          bio: string | null;
          phone: string | null;
          email: string | null;
          display_order: number;
        };
        let speakers: Speaker[] = await fetchSpeakers(ev.id);

        const sList = document.getElementById('s-list')!;
        const sFormHost = document.getElementById('s-form-host')!;
        const addSBtn = document.getElementById('add-s-btn') as HTMLButtonElement;
        let pendingSpeakerPhoto: File | null = null;

        function speakerFormHtml(sp?: Speaker): string {
          const v = sp || ({} as Partial<Speaker>);
          const photoBlock = `
            <div class="photo-slot speaker-slot" data-speaker-slot>
              <span class="slot-label">Photo</span>
              <div class="photo-preview speaker-preview">
                ${v.photo_url
                  ? `<img src="${escapeHtml(v.photo_url)}" alt="" />`
                  : '<div class="empty">No photo</div>'}
              </div>
              <label class="upload-btn">
                <input type="file" accept="image/*" data-speaker-slot hidden />
                <span class="upload-label">${v.photo_url ? 'Replace photo' : 'Upload photo'}</span>
              </label>
              <span class="upload-status" data-speaker-slot></span>
            </div>`;
          return `
            <form class="t-form" ${sp ? `data-id="${sp.id}"` : ''} novalidate>
              <h3>${sp ? 'Edit speaker' : 'New speaker'}</h3>
              <label>
                Name
                <input name="name" required maxlength="120" value="${escapeHtml(v.name || '')}" placeholder="Enter speaker name" />
              </label>
              <label>
                Bio
                <textarea name="bio" rows="4" maxlength="2000" placeholder="A few sentences about this speaker">${escapeHtml(v.bio || '')}</textarea>
              </label>
              <div class="grid-2">
                <label>
                  Phone <span class="opt">(optional, public)</span>
                  <input type="tel" name="phone" value="${escapeHtml(v.phone || '')}" placeholder="555-123-4567" />
                </label>
                <label>
                  Email <span class="opt">(optional, public)</span>
                  <input type="email" name="email" value="${escapeHtml(v.email || '')}" />
                </label>
              </div>
              ${photoBlock}
              <div class="row">
                <button type="submit">${sp ? 'Save changes' : 'Create'}</button>
                <button type="button" class="cancel">${sp ? 'Done' : 'Cancel'}</button>
                <span class="t-status" role="status" aria-live="polite"></span>
              </div>
            </form>`;
        }

        function speakerRowHtml(sp: Speaker): string {
          const contactBits: string[] = [];
          if (sp.phone) contactBits.push(`📞 ${escapeHtml(sp.phone)}`);
          if (sp.email) contactBits.push(`✉️ ${escapeHtml(sp.email)}`);
          return `
            <li class="t-row" data-id="${sp.id}">
              ${sp.photo_url
                ? `<img class="t-thumb" src="${escapeHtml(sp.photo_url)}" alt="" style="border-radius:50%;width:56px;height:56px;" />`
                : '<div class="t-thumb empty" style="border-radius:50%;width:56px;height:56px;"></div>'}
              <div class="t-info">
                <strong>${escapeHtml(sp.name)}</strong>
                ${contactBits.length ? `<span class="t-meta">${contactBits.join(' · ')}</span>` : ''}
                ${sp.bio ? `<span class="t-meta">${escapeHtml(sp.bio.slice(0, 60))}${sp.bio.length > 60 ? '…' : ''}</span>` : ''}
              </div>
              <div class="t-actions">
                <button class="edit" data-id="${sp.id}">Edit</button>
                <button class="del" data-id="${sp.id}">Delete</button>
              </div>
            </li>`;
        }

        function renderSpeakerList() {
          if (speakers.length === 0) {
            sList.innerHTML = '<li class="t-empty">No speakers yet.</li>';
          } else {
            sList.innerHTML = speakers.map(speakerRowHtml).join('');
          }
          updateStatusPills();
        }

        function showSpeakerForm(sp?: Speaker) {
          sFormHost.innerHTML = speakerFormHtml(sp);
          addSBtn.style.display = 'none';
          pendingSpeakerPhoto = null;
          const newForm = sFormHost.querySelector('form.t-form') as HTMLFormElement;
          newForm.addEventListener('submit', (e) => handleSpeakerSubmit(e, sp));
          newForm.querySelector('button.cancel')!.addEventListener('click', hideSpeakerForm);
          const fileInput = newForm.querySelector('input[type=file][data-speaker-slot]') as HTMLInputElement;
          fileInput.addEventListener('change', (e) => {
            if (sp) handleSpeakerPhotoUpload(e, sp);
            else handlePendingSpeakerPhoto(e);
          });
          if (!sp) (newForm.querySelector('input[name=name]') as HTMLInputElement).focus();
        }

        function hideSpeakerForm() {
          sFormHost.innerHTML = '';
          addSBtn.style.display = '';
          pendingSpeakerPhoto = null;
        }

        async function handlePendingSpeakerPhoto(changeEv: Event) {
          const input = changeEv.target as HTMLInputElement;
          const file = input.files?.[0];
          if (!file) return;
          const slotEl = input.closest('.speaker-slot') as HTMLElement;
          const previewEl = slotEl.querySelector('.photo-preview') as HTMLElement;
          const labelEl = slotEl.querySelector('.upload-label') as HTMLElement;
          const statusEl = slotEl.querySelector('.upload-status') as HTMLElement;
          input.value = '';
          statusEl.textContent = 'Opening crop tool…';
          statusEl.className = 'upload-status';
          const cropped = await openCropModal(file, 1, 'Crop the speaker photo');
          if (!cropped) {
            statusEl.textContent = '';
            return;
          }
          pendingSpeakerPhoto = new File([cropped], 'photo.jpg', { type: 'image/jpeg' });
          const reader = new FileReader();
          reader.onload = () => {
            previewEl.innerHTML = `<img src="${reader.result}" alt="" />`;
            labelEl.textContent = 'Replace photo';
            statusEl.textContent = 'Will upload after Create';
            statusEl.className = 'upload-status';
          };
          reader.readAsDataURL(cropped);
        }

        async function uploadSpeakerPhoto(speakerId: string, file: File): Promise<string> {
          const compressed = await compressImage(file, 1200, 0.82);
          const data_b64 = await blobToBase64(compressed);
          const res = await callFunction('upload-speaker-photo', {
            slug, edit_token: key,
            speaker_id: speakerId,
            filename: 'photo.jpg',
            data: data_b64,
          });
          return res.url as string;
        }

        async function handleSpeakerPhotoUpload(changeEv: Event, sp: Speaker) {
          const input = changeEv.target as HTMLInputElement;
          const file = input.files?.[0];
          if (!file) return;
          const slotEl = input.closest('.speaker-slot') as HTMLElement;
          const previewEl = slotEl.querySelector('.photo-preview') as HTMLElement;
          const labelEl = slotEl.querySelector('.upload-label') as HTMLElement;
          const statusEl = slotEl.querySelector('.upload-status') as HTMLElement;
          input.value = '';
          statusEl.textContent = 'Opening crop tool…';
          statusEl.className = 'upload-status';
          try {
            const cropped = await openCropModal(file, 1, `Crop ${sp.name}'s photo`);
            if (!cropped) {
              statusEl.textContent = '';
              return;
            }
            statusEl.textContent = 'Uploading…';
            const data_b64 = await blobToBase64(cropped);
            const res = await callFunction('upload-speaker-photo', {
              slug, edit_token: key,
              speaker_id: sp.id,
              filename: 'photo.jpg', data: data_b64,
            });
            const url = res.url as string;
            speakers = speakers.map((x) => (x.id === sp.id ? { ...x, photo_url: url } : x));
            sp.photo_url = url;
            previewEl.innerHTML = `<img src="${escapeHtml(url)}" alt="" />`;
            labelEl.textContent = 'Replace photo';
            statusEl.textContent = 'Uploaded ✓';
            statusEl.className = 'upload-status ok';
            renderSpeakerList();
          } catch (err) {
            const msg = (err as Error).message;
            statusEl.textContent = msg.includes('403') ? 'Invalid edit link.' : msg;
            statusEl.className = 'upload-status err';
          }
        }

        async function handleSpeakerSubmit(submitEv: Event, editing?: Speaker) {
          submitEv.preventDefault();
          const formEl = submitEv.target as HTMLFormElement;
          const fd = new FormData(formEl);
          const tStatus = formEl.querySelector('.t-status') as HTMLSpanElement;
          const submit = formEl.querySelector('button[type=submit]') as HTMLButtonElement;
          submit.disabled = true;
          tStatus.textContent = 'Saving…';
          tStatus.className = 't-status';
          const speaker: Record<string, unknown> = {
            name: fd.get('name'),
            bio: fd.get('bio') || null,
            phone: fd.get('phone') || null,
            email: fd.get('email') || null,
          };
          if (editing) speaker.id = editing.id;

          try {
            const res = await callFunction('manage-speakers', {
              action: editing ? 'update' : 'add',
              slug, edit_token: key, speaker,
            });
            let saved = res.speaker as Speaker;

            if (!editing && pendingSpeakerPhoto) {
              tStatus.textContent = 'Uploading photo…';
              try {
                const url = await uploadSpeakerPhoto(saved.id, pendingSpeakerPhoto);
                saved = { ...saved, photo_url: url };
              } catch (err) {
                console.error('Failed to upload speaker photo:', err);
              }
              pendingSpeakerPhoto = null;
            }

            if (editing) {
              speakers = speakers.map((s) => (s.id === saved.id ? saved : s));
            } else {
              speakers = [...speakers, saved];
            }
            renderSpeakerList();

            if (editing) {
              tStatus.textContent = 'Saved ✓';
              tStatus.className = 't-status ok';
              submit.disabled = false;
            } else {
              showSpeakerForm(saved);
              const reopenStatus = sFormHost.querySelector('.t-status') as HTMLSpanElement;
              if (reopenStatus) {
                reopenStatus.textContent = 'Created ✓';
                reopenStatus.className = 't-status ok';
              }
            }
          } catch (err) {
            const msg = (err as Error).message;
            tStatus.textContent = msg.includes('403') ? 'Invalid edit link.' : msg;
            tStatus.className = 't-status err';
            submit.disabled = false;
          }
        }

        async function handleSpeakerDelete(id: string) {
          const sp = speakers.find((x) => x.id === id);
          if (!sp) return;
          if (!confirm(`Delete ${sp.name}'s bio?\n\nThis can't be undone.`)) return;
          try {
            await callFunction('manage-speakers', {
              action: 'delete', slug, edit_token: key, speaker_id: id,
            });
            speakers = speakers.filter((x) => x.id !== id);
            renderSpeakerList();
          } catch (err) {
            alert('Could not delete: ' + (err as Error).message);
          }
        }

        addSBtn.addEventListener('click', () => showSpeakerForm());
        sList.addEventListener('click', (clickEv) => {
          const target = clickEv.target as HTMLElement;
          if (target.tagName !== 'BUTTON') return;
          const id = target.getAttribute('data-id');
          if (!id) return;
          if (target.classList.contains('edit')) {
            const sp = speakers.find((x) => x.id === id);
            if (sp) showSpeakerForm(sp);
          } else if (target.classList.contains('del')) {
            handleSpeakerDelete(id);
          }
        });
        renderSpeakerList();

        // ---------- Co-hosts ----------
        type Host = {
          id: string;
          name: string | null;
          email: string | null;
          phone: string | null;
          host_token: string | null; // null when the viewer isn't the master
          created_at: string;
        };
        const hostsList = document.getElementById('hosts-list')!;
        const hostsAddSection = document.getElementById('hosts-add-host')!;
        const hostsBlurb = document.getElementById('hosts-blurb')!;
        let isMaster = false;

        function hostUrl(token: string): string {
          const params = new URLSearchParams({ slug: slug!, key: token });
          return `${window.location.origin}${base}edit?${params.toString()}`;
        }

        function renderHosts(hosts: Host[]) {
          // Role-correct blurb. Master sees the "add other people" pitch
          // and the form. Co-hosts see a clear "you can't manage hosts"
          // explainer instead — and no form. The misleading master-only
          // copy used to render for everyone.
          if (isMaster) {
            hostsBlurb.textContent = 'Add other people who should be able to edit this event. Each co-host gets their own private edit URL. Only you (the original host) can add or remove.';
            hostsBlurb.style.fontStyle = '';
          } else {
            hostsBlurb.textContent = 'You are a co-host on this event. You can edit everything else, but only the original host can add or remove co-hosts.';
            hostsBlurb.style.fontStyle = 'italic';
          }
          if (isMaster) {
            hostsAddSection.innerHTML = `
              <form id="add-host-form" class="add-host-form" novalidate>
                <label>
                  Co-host name
                  <input name="name" maxlength="120" placeholder="Coach Sam" />
                </label>
                <div class="grid-2">
                  <label>
                    Phone <span class="opt">(public)</span>
                    <input type="tel" name="phone" placeholder="555-123-4567" />
                  </label>
                  <label>
                    Email <span class="opt">(private)</span>
                    <input type="email" name="email" />
                  </label>
                </div>
                <div class="row">
                  <button type="submit">+ Generate co-host link</button>
                  <span id="add-host-status" role="status" aria-live="polite"></span>
                </div>
              </form>`;
            const addForm = document.getElementById('add-host-form') as HTMLFormElement;
            addForm.addEventListener('submit', handleAddHost);
          } else {
            // Co-host: no add form. The blurb above already says why.
            hostsAddSection.innerHTML = '';
          }

          if (hosts.length === 0) {
            hostsList.innerHTML = '<li class="hosts-empty">No co-hosts yet.</li>';
            return;
          }
          hostsList.innerHTML = hosts.map((h) => {
            const created = new Date(h.created_at);
            const createdTxt = isNaN(created.getTime())
              ? h.created_at
              : created.toLocaleDateString();
            return `
              <li class="host-item" data-id="${h.id}">
                <div class="host-info">
                  <strong>${escapeHtml(h.name || 'Unnamed co-host')}</strong>
                  ${h.phone ? `<span class="host-meta">📞 ${escapeHtml(h.phone)}</span>` : ''}
                  ${h.email ? `<span class="host-meta">✉️ ${escapeHtml(h.email)}</span>` : ''}
                  <span class="host-meta">added ${escapeHtml(createdTxt)}</span>
                </div>
                ${h.host_token
                  ? `<div class="host-link">
                      <input type="text" readonly value="${escapeHtml(hostUrl(h.host_token))}" />
                      <button type="button" class="copy-host" data-url="${escapeHtml(hostUrl(h.host_token))}">Copy</button>
                    </div>`
                  : ''}
                ${isMaster
                  ? `<button type="button" class="remove-host" data-id="${h.id}" data-name="${escapeHtml(h.name || 'this co-host')}">Remove</button>`
                  : ''}
              </li>`;
          }).join('');
        }

        async function loadHosts() {
          try {
            const res = await callFunction('manage-hosts', {
              slug,
              edit_token: key,
              action: 'list',
            });
            isMaster = !!res.you_are_master;
            renderHosts(res.hosts as Host[]);
          } catch (err) {
            hostsList.innerHTML =
              `<li class="hosts-empty err">Could not load co-hosts: ${escapeHtml((err as Error).message)}</li>`;
          }
        }

        async function handleAddHost(submitEv: Event) {
          submitEv.preventDefault();
          const formEl = submitEv.target as HTMLFormElement;
          const fd = new FormData(formEl);
          const statusEl = document.getElementById('add-host-status')!;
          const submitBtn = formEl.querySelector('button[type=submit]') as HTMLButtonElement;
          submitBtn.disabled = true;
          statusEl.textContent = 'Adding…';
          statusEl.className = '';
          try {
            await callFunction('manage-hosts', {
              slug,
              edit_token: key,
              action: 'add',
              name: fd.get('name') || null,
              email: fd.get('email') || null,
              phone: fd.get('phone') || null,
            });
            statusEl.textContent = 'Added ✓';
            statusEl.className = 'ok';
            formEl.reset();
            await loadHosts();
          } catch (err) {
            statusEl.textContent = (err as Error).message;
            statusEl.className = 'err';
          } finally {
            submitBtn.disabled = false;
          }
        }

        hostsList.addEventListener('click', async (ev) => {
          const target = ev.target as HTMLElement;
          if (target.classList.contains('remove-host')) {
            const id = target.getAttribute('data-id')!;
            const name = target.getAttribute('data-name')!;
            if (!confirm(`Remove ${name}? Their edit link will stop working immediately.`)) return;
            try {
              await callFunction('manage-hosts', {
                slug, edit_token: key, action: 'remove', host_id: id,
              });
              await loadHosts();
            } catch (err) {
              alert('Could not remove: ' + (err as Error).message);
            }
          } else if (target.classList.contains('copy-host')) {
            const url = target.getAttribute('data-url')!;
            await navigator.clipboard.writeText(url);
            const orig = target.textContent;
            target.textContent = 'Copied!';
            setTimeout(() => (target.textContent = orig), 1200);
          }
        });

        loadHosts();

        // ---------- Share & save links section ----------
        const origin = window.location.origin;
        const publicUrl = `${origin}${base}event?slug=${encodeURIComponent(slug)}`;
        const editUrl = `${origin}${base}edit?slug=${encodeURIComponent(slug)}&key=${encodeURIComponent(key)}`;
        (document.getElementById('public-url') as HTMLInputElement).value = publicUrl;
        (document.getElementById('edit-url') as HTMLInputElement).value = editUrl;

        const qrCanvas = document.getElementById('public-qr') as HTMLCanvasElement;
        QRCode.toCanvas(qrCanvas, publicUrl, {
          width: 200, margin: 1,
          color: { dark: '#ffffff', light: '#1a252f' },
        }).catch(() => {});

        document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
          btn.addEventListener('click', async () => {
            const sel = btn.getAttribute('data-copy')!;
            const input = document.querySelector<HTMLInputElement>(sel)!;
            await navigator.clipboard.writeText(input.value);
            const orig = btn.textContent;
            btn.textContent = 'Copied!';
            setTimeout(() => (btn.textContent = orig), 1200);
          });
        });

        document.getElementById('public-qr-dl')?.addEventListener('click', () => {
          const a = document.createElement('a');
          a.href = qrCanvas.toDataURL('image/png');
          a.download = `${slug}-qr.png`;
          a.click();
        });

        document.getElementById('email-edit')?.addEventListener('click', () => {
          const subj = encodeURIComponent('Edit link for my event');
          const mailBody = encodeURIComponent(
            `Save this — it's the only way back into your event admin page.\n\nEdit URL:\n${editUrl}\n\nPublic URL:\n${publicUrl}\n`
          );
          window.location.href = `mailto:?subject=${subj}&body=${mailBody}`;
        });

        document.getElementById('download-edit')?.addEventListener('click', () => {
          const txt = `Metabolic Reset Event — edit link\n\nEdit URL (KEEP SECRET):\n${editUrl}\n\nPublic URL (share):\n${publicUrl}\n`;
          const blob = new Blob([txt], { type: 'text/plain' });
          const a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = `event-${slug}-edit-link.txt`;
          a.click();
        });

        addBtn.addEventListener('click', () => showForm());
        list.addEventListener('click', (clickEv) => {
          const target = clickEv.target as HTMLElement;
          if (target.tagName !== 'BUTTON') return;
          const id = target.getAttribute('data-id');
          if (!id) return;
          if (target.classList.contains('edit')) {
            const t = transformations.find((x) => x.id === id);
            if (t) showForm(t);
          } else if (target.classList.contains('del')) {
            handleDelete(id);
          }
        });

        renderList();
      } catch (err) {
