    background: rgba(255,255,255,0.06); color: #ecf0f1;
    border: 1px solid rgba(255,255,255,0.15);
  }
  a.wheel-link.live {
    background: rgba(46,204,113,0.18); color: #2ecc71;
    border: 1px solid rgba(46,204,113,0.5);
  }
  a.wheel-link.poster {
    background: rgba(255,255,255,0.06); color: #ecf0f1;
