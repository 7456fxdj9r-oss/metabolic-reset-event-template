---
// Presenter's phone controller for the slide deck. Pairs with deck.astro
// over a Supabase realtime channel (deck:<slug>). Shows a thumbnail-style
// preview of the current slide, big Next/Prev buttons, and a tap-to-jump
// agenda list. Same auth model as the rest of the day-of toolkit: needs
// the master/cohost edit key.
import Base from '../layouts/Base.astro';
---
<Base title="Presenter console">
  <main class="console" id="console-root">
    <p class="loading">Loading console…</p>
  </main>
</Base>

<script>
  import { fetchEventBySlug, fetchSpeakers, fetchAgendaItems, fetchTransformations, callFunction, getConfig } from '../lib/supabase.js';
  import { createClient } from '@supabase/supabase-js';
  import { editUrl } from '../lib/urls.js';
  import { escapeHtml } from '../lib/html.js';

  type Speaker = {
    id: string; name: string;
    photo_url: string | null;
  };
  type AgendaItem = {
    id: string;
    time_label: string;
    segment: string;
    speaker: string | null;
    details: string | null;
    duration_minutes: number;
    display_order: number;
  };
  type Transformation = {
    id: string;
    name: string;
    before_photo_url: string | null;
    after_photo_url: string | null;
    headline_lb_loss: number | null;
    headline_bf_delta_pts: number | null;
    headline_lean_kept_pct: number | null;
    takeaway_text: string | null;
    display_order: number;
  };

  const root = document.getElementById('console-root')!;
  const base = import.meta.env.BASE_URL;
  const params = new URLSearchParams(window.location.search);
  const slug = params.get('slug');
  const key = params.get('key');


  // TODO: promote to a per-event (or per-agenda-item) `presenter_notes`
  // schema column when a second event needs different references.
  // Hardcoded for the May 2026 Portland event for now.
  const PRESENTER_NOTES: Array<{ label: string; url: string; hint?: string }> = [
    {
      label: 'Metabolic Dysfunction',
      url: 'https://7456fxdj9r-oss.github.io/Spokane-MREvent/notes/metabolic-dysfunction.html',
      hint: 'Background notes — opens in a new tab',
    },
    {
      label: 'Arterburn 2019',
      url: 'https://7456fxdj9r-oss.github.io/Spokane-MREvent/notes/arterburn-2019.html',
      hint: 'Study reference — opens in a new tab',
    },
  ];

  if (!slug || !key) {
    root.innerHTML = '<p class="loading err">Missing slug or key — open this from the edit page.</p>';
  } else {
    (async () => {
      try {
        const event = await fetchEventBySlug(slug);
        if (!event) {
          root.innerHTML = '<p class="loading err">Event not found.</p>';
          return;
        }
        document.title = `Console — ${event.name}`;
        const accent = event.accent_color || '#f39c12';
        document.documentElement.style.setProperty('--accent', accent);

        type AgendaSlide = {
          id: string;
          agenda_item_id: string;
          title: string;
          body: string | null;
          image_url: string | null;
          display_order: number;
        };
        const [speakers, agenda, transformations, subSlidesRes] = await Promise.all([
          fetchSpeakers(event.id) as Promise<Speaker[]>,
          fetchAgendaItems(event.id) as Promise<AgendaItem[]>,
          fetchTransformations(event.id) as Promise<Transformation[]>,
          callFunction('manage-agenda-slides', { slug, edit_token: key, action: 'list' })
            .catch(() => ({ slides: [] as AgendaSlide[] })),
        ]);
        const subSlidesByParent: Record<string, AgendaSlide[]> = {};
        for (const s of ((subSlidesRes.slides as AgendaSlide[]) || [])) {
          (subSlidesByParent[s.agenda_item_id] ||= []).push(s);
        }
        for (const arr of Object.values(subSlidesByParent)) {
          arr.sort((a, b) => a.display_order - b.display_order);
        }

        // Same speaker-lookup rule as deck.astro: exact-full-name first,
        // then per-speaker first-name word match so multi-speaker agenda
        // items (e.g. "Sarah & Nicole") resolve to a list of speakers.
        // Keep this rule in sync with deck.astro's findMatchingSpeakers.
        function findMatchingSpeakers(agendaText: string | null): Speaker[] {
          if (!agendaText) return [];
          const text = agendaText.toLowerCase();
          for (const sp of speakers) {
            if (sp.name && sp.name.trim().toLowerCase() === text.trim()) return [sp];
          }
          const matches: Speaker[] = [];
          const seen = new Set<string>();
          for (const sp of speakers) {
            if (!sp.name) continue;
            const firstWord = sp.name.trim().split(/\s+/)[0]?.replace(/[^a-zA-Z0-9]/g, '') || '';
            if (!firstWord) continue;
            const re = new RegExp(`\\b${firstWord.toLowerCase()}\\b`, 'i');
            if (re.test(text) && !seen.has(sp.id)) {
              matches.push(sp);
              seen.add(sp.id);
            }
          }
          return matches;
        }

        // Slide model — flat list matching what deck.astro builds:
        //   cover (index 0)
        //   for each agenda item: the auto-built primary slide,
        //   then its sub-slides (kind: 'sub') in display_order.
        type SlideEntry =
          | { kind: 'cover' }
          | { kind: 'item'; item: AgendaItem; speakers: Speaker[] }
          | { kind: 'sub'; slide: AgendaSlide; parent: AgendaItem };
        const slides: SlideEntry[] = [{ kind: 'cover' }];
        for (const it of agenda) {
          slides.push({
            kind: 'item',
            item: it,
            speakers: findMatchingSpeakers(it.speaker),
          });
          for (const sub of (subSlidesByParent[it.id] || [])) {
            slides.push({ kind: 'sub', slide: sub, parent: it });
          }
        }

        let currentIndex = 0;
        // Audience-hub control state. Master toggle gates whether anything
        // reaches attendees' phones (deck:<slug> 'audience' events).
        // `activeTransformationId`, when set, overrides the current slide
        // for the audience — presenter pushed a transformation on top of
        // the running flow.
        let audienceMode = false;
        let activeTransformationId: string | null = null;

        // Realtime: sender. Open the channel first so the broadcast fires
        // even if it's the first message of the session.
        const cfg = getConfig();
        let channel: ReturnType<ReturnType<typeof createClient>['channel']> | null = null;
        if (cfg.url && cfg.anonKey) {
          const client = createClient(cfg.url, cfg.anonKey);
          channel = client.channel(`deck:${slug}`, {
            config: { broadcast: { self: false } },
          });
          channel.subscribe();
        }

        function broadcast(): void {
          if (!channel) return;
          channel.send({
            type: 'broadcast', event: 'advance',
            payload: { index: currentIndex },
          });
        }

        // Build the audience-payload for whatever's currently in focus —
        // active transformation if pinned, otherwise the current slide.
        // Returns null when there's nothing to show (cover, section slide,
        // or no matched speakers).
        type AudiencePayload =
          | { show: true; kind: 'speaker'; speaker: { name: string; photo_url: string | null }; topic: string }
          | { show: true; kind: 'multi'; speakers: Array<{ name: string; photo_url: string | null }>; segment: string }
          | { show: true; kind: 'transformation'; transformation: Transformation }
          | { show: false };

        function computeAudiencePayload(): AudiencePayload {
          if (activeTransformationId) {
            const t = transformations.find((x) => x.id === activeTransformationId);
            if (t) return { show: true, kind: 'transformation', transformation: t };
          }
          const slide = slides[currentIndex];
          if (slide.kind === 'cover') return { show: false };
          const sps = slide.speakers;
          if (sps.length === 1) {
            return {
              show: true, kind: 'speaker',
              speaker: { name: sps[0].name, photo_url: sps[0].photo_url },
              topic: slide.item.segment,
            };
          }
          if (sps.length >= 2) {
            return {
              show: true, kind: 'multi',
              speakers: sps.map((sp) => ({ name: sp.name, photo_url: sp.photo_url })),
              segment: slide.item.segment,
            };
          }
          return { show: false };
        }

        function broadcastAudience(): void {
          if (!channel) return;
          const payload = audienceMode
            ? computeAudiencePayload()
            : { show: false } as AudiencePayload;
          channel.send({
            type: 'broadcast', event: 'audience',
            payload,
          });
        }

        function previewHtml(idx: number): string {
          const slide = slides[idx];
          if (slide.kind === 'cover') {
            return `
              <div class="preview cover">
                <p class="preview-kicker">Welcome to</p>
                <p class="preview-title">${escapeHtml(event.name)}</p>
                ${event.event_date ? `<p class="preview-date">${escapeHtml(event.event_date)}</p>` : ''}
              </div>`;
          }
          if (slide.kind === 'sub') {
            const ss = slide.slide;
            const thumb = ss.image_url
              ? `<img class="preview-photo" src="${escapeHtml(ss.image_url)}" alt="" />`
              : '<div class="preview-photo empty">💡</div>';
            // Title optional. Fall back to body snippet or "(image-only)"
            // so the preview always has a heading line.
            const titleText = ss.title?.trim();
            const heading = titleText
              ? escapeHtml(titleText)
              : (ss.body
                ? escapeHtml(ss.body.slice(0, 40)) + (ss.body.length > 40 ? '…' : '')
                : '(image-only slide)');
            const showBodySnippet = titleText && ss.body;
            return `
              <div class="preview speaker">
                ${thumb}
                <div class="preview-meta">
                  <p class="preview-time">Sub-slide · under ${escapeHtml(slide.parent.segment.slice(0, 40))}${slide.parent.segment.length > 40 ? '…' : ''}</p>
                  <p class="preview-name">${heading}</p>
                  ${showBodySnippet ? `<p class="preview-topic">${escapeHtml(ss.body!.slice(0, 80))}${ss.body!.length > 80 ? '…' : ''}</p>` : ''}
                </div>
              </div>`;
          }
          const it = slide.item;
          const sps = slide.speakers;
          if (sps.length === 1) {
            const sp = sps[0];
            const photo = sp.photo_url
              ? `<img class="preview-photo" src="${escapeHtml(sp.photo_url)}" alt="" />`
              : '<div class="preview-photo empty">📷</div>';
            return `
              <div class="preview speaker">
                ${photo}
                <div class="preview-meta">
                  <p class="preview-time">${escapeHtml(it.time_label)}</p>
                  <p class="preview-name">${escapeHtml(sp.name)}</p>
                  <p class="preview-topic">${escapeHtml(it.segment)}</p>
                </div>
              </div>`;
          }
          if (sps.length >= 2) {
            const avatars = sps.slice(0, 4).map((sp) => sp.photo_url
              ? `<img class="preview-avatar" src="${escapeHtml(sp.photo_url)}" alt="" title="${escapeHtml(sp.name)}" />`
              : `<div class="preview-avatar empty" title="${escapeHtml(sp.name)}">📷</div>`
            ).join('');
            const extra = sps.length > 4 ? `<span class="preview-extra">+${sps.length - 4}</span>` : '';
            return `
              <div class="preview multi">
                <p class="preview-time">${escapeHtml(it.time_label)}</p>
                <div class="preview-avatars">${avatars}${extra}</div>
                <p class="preview-title">${escapeHtml(it.segment)}</p>
                ${it.speaker ? `<p class="preview-lead">${escapeHtml(it.speaker)}</p>` : ''}
              </div>`;
          }
          return `
            <div class="preview section">
              <p class="preview-time">${escapeHtml(it.time_label)}</p>
              <p class="preview-title">${escapeHtml(it.segment)}</p>
              ${it.speaker ? `<p class="preview-lead">${escapeHtml(it.speaker)}</p>` : ''}
            </div>`;
        }

        function agendaListHtml(): string {
          return slides.map((s, i) => {
            const active = i === currentIndex ? ' active' : '';
            if (s.kind === 'cover') {
              return `<li class="agenda-row${active}" data-idx="0">
                <span class="row-time">Cover</span>
                <span class="row-info"><strong>${escapeHtml(event.name)}</strong></span>
              </li>`;
            }
            if (s.kind === 'sub') {
              // Sub-slides are indented under their parent agenda item.
              // Title is optional — fall back to body or "(image-only)".
              const titleText = s.slide.title?.trim();
              const heading = titleText
                ? escapeHtml(titleText)
                : (s.slide.body
                  ? escapeHtml(s.slide.body.slice(0, 40)) + (s.slide.body.length > 40 ? '…' : '')
                  : '(image-only slide)');
              const showBodySnippet = titleText && s.slide.body;
              return `<li class="agenda-row sub${active}" data-idx="${i}">
                <span class="row-time">💡</span>
                <span class="row-info">
                  <strong${!titleText ? ' class="dim"' : ''}>${heading}</strong>
                  ${showBodySnippet ? `<span class="row-speaker">${escapeHtml(s.slide.body!.slice(0, 60))}${s.slide.body!.length > 60 ? '…' : ''}</span>` : ''}
                </span>
              </li>`;
            }
            // Agenda list shows the raw speaker text (what the host typed)
            // not the resolved speaker name(s) — keeps the editor mental
            // model intact ("Sarah & Nicole" stays "Sarah & Nicole").
            const speakerText = s.item.speaker || '';
            // Surface duration on the row so the presenter can pace
            // without flipping back to the edit page.
            const dur = s.item.duration_minutes;
            const durBadge = (dur != null && Number.isFinite(dur))
              ? `<span class="row-duration">${dur} min</span>`
              : '';
            return `<li class="agenda-row${active}" data-idx="${i}">
              <span class="row-time">${escapeHtml(s.item.time_label)}${durBadge}</span>
              <span class="row-info">
                <strong>${escapeHtml(s.item.segment)}</strong>
                ${speakerText ? `<span class="row-speaker">${escapeHtml(speakerText)}</span>` : ''}
              </span>
            </li>`;
          }).join('');
        }

        function render(): void {
          const total = slides.length;
          const atStart = currentIndex === 0;
          const atEnd = currentIndex === total - 1;
          root.innerHTML = `
            <a class="back" href="${escapeHtml(editUrl(base, slug!, key!))}">← Back to edit</a>
            <header class="head">
              <p class="eyebrow">Presenter console</p>
              <h1>${escapeHtml(event.name)}</h1>
              <p class="counter">Slide <strong>${currentIndex + 1}</strong> of ${total}</p>
            </header>
            <section class="preview-wrap">${previewHtml(currentIndex)}</section>
            <section class="controls">
              <button type="button" id="btn-prev" class="ctl prev" ${atStart ? 'disabled' : ''}>← Previous</button>
              <button type="button" id="btn-next" class="ctl next" ${atEnd ? 'disabled' : ''}>${atEnd ? 'End of deck' : 'Next ▶'}</button>
            </section>
            <section class="agenda-list">
              <h2>Tap to jump</h2>
              <ul>${agendaListHtml()}</ul>
            </section>
            <section class="audience-control">
              <h2>📲 Audience phones</h2>
              <label class="audience-toggle">
                <input type="checkbox" id="audience-toggle" ${audienceMode ? 'checked' : ''} />
                <span>Display to audience phones</span>
              </label>
              <p class="audience-hint">${audienceMode
                ? 'Phones mirror the projector. Section slides (breaks) clear the popup.'
                : "Off — nothing pops up on attendees' phones."}</p>
            </section>
            ${transformations.length === 0 ? '' : `
              <section class="transformations-list">
                <h2>📖 Push a story to audience</h2>
                <p class="tx-hint">${audienceMode
                  ? 'Tap to send a before/after to phones. Tap again to clear.'
                  : 'Turn on "Display to audience phones" above first.'}</p>
                <ul>
                  ${transformations.map((t) => {
                    const active = t.id === activeTransformationId;
                    const thumb = t.before_photo_url || t.after_photo_url;
                    const stats: string[] = [];
                    if (t.headline_lb_loss != null) stats.push(`−${t.headline_lb_loss} lb`);
                    if (t.headline_bf_delta_pts != null) stats.push(`−${t.headline_bf_delta_pts} BF`);
                    if (t.headline_lean_kept_pct != null) stats.push(`${t.headline_lean_kept_pct}% lean`);
                    return `
                      <li>
                        <button type="button" class="tx-row${active ? ' active' : ''}" data-tx-id="${escapeHtml(t.id)}" ${audienceMode ? '' : 'disabled'}>
                          ${thumb ? `<img class="tx-thumb" src="${escapeHtml(thumb)}" alt="" />` : '<div class="tx-thumb empty"></div>'}
                          <span class="tx-info">
                            <strong>${escapeHtml(t.name)}</strong>
                            ${stats.length ? `<span class="tx-stats">${stats.join(' · ')}</span>` : ''}
                          </span>
                          <span class="tx-status">${active ? '● Live' : '▶'}</span>
                        </button>
                      </li>`;
                  }).join('')}
                </ul>
              </section>`}
            ${PRESENTER_NOTES.length === 0 ? '' : `
              <section class="notes-list">
                <h2>📝 Presenter notes</h2>
                <ul>
                  ${PRESENTER_NOTES.map((n) => `
                    <li>
                      <a href="${escapeHtml(n.url)}" target="_blank" rel="noopener">
                        <strong>${escapeHtml(n.label)}</strong>
                        ${n.hint ? `<span class="note-hint">${escapeHtml(n.hint)}</span>` : ''}
                      </a>
                    </li>
                  `).join('')}
                </ul>
              </section>`}
            <p class="cx-hint" id="cx-hint">${channel ? 'Synced with projector' : "No realtime config — projector won't follow"}</p>`;
          (document.getElementById('btn-prev') as HTMLButtonElement).addEventListener('click', () => goTo(currentIndex - 1));
          (document.getElementById('btn-next') as HTMLButtonElement).addEventListener('click', () => goTo(currentIndex + 1));
          document.querySelectorAll('.agenda-row').forEach((row) => {
            row.addEventListener('click', () => {
              const i = Number((row as HTMLElement).getAttribute('data-idx') || '0');
              goTo(i);
            });
          });
          const toggleEl = document.getElementById('audience-toggle') as HTMLInputElement | null;
          if (toggleEl) {
            toggleEl.addEventListener('change', () => setAudienceMode(toggleEl.checked));
          }
          document.querySelectorAll('.tx-row').forEach((btn) => {
            btn.addEventListener('click', () => {
              const id = (btn as HTMLElement).getAttribute('data-tx-id');
              if (id) toggleTransformation(id);
            });
          });
        }

        function goTo(i: number): void {
          const clamped = Math.max(0, Math.min(slides.length - 1, i));
          if (clamped === currentIndex) return;
          currentIndex = clamped;
          // Advancing past a pushed transformation drops it — the new slide
          // is the implied "back to the running show" signal.
          activeTransformationId = null;
          render();
          broadcast();
          broadcastAudience();
        }

        function setAudienceMode(on: boolean): void {
          audienceMode = on;
          render();
          broadcastAudience();
        }

        function toggleTransformation(id: string): void {
          activeTransformationId = activeTransformationId === id ? null : id;
          render();
          broadcastAudience();
        }

        render();

        // Keyboard nav on the phone is unusual but harmless — supports a
        // laptop pretending to be the controller for testing / dry-runs.
        document.addEventListener('keydown', (ev) => {
          if (ev.key === 'ArrowRight' || ev.key === ' ' || ev.key === 'PageDown') {
            ev.preventDefault(); goTo(currentIndex + 1);
          } else if (ev.key === 'ArrowLeft' || ev.key === 'PageUp') {
            ev.preventDefault(); goTo(currentIndex - 1);
          } else if (ev.key === 'Home') {
            ev.preventDefault(); goTo(0);
          }
        });
      } catch (err) {
        root.innerHTML = `<p class="loading err">${escapeHtml((err as Error).message)}</p>`;
      }
    })();
  }
</script>

<style is:global>
  :root { --accent: #f39c12; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: #1a252f; color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  body { padding: 14px 12px 30px; line-height: 1.4; }
  main.console { max-width: 560px; margin: 0 auto; }

  a.back {
    display: inline-block;
    padding: 10px 14px;
    color: #95a5a6; text-decoration: none;
    font-size: 12px; font-weight: 600;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 6px;
    margin-bottom: 10px;
  }

  .head { text-align: center; margin-bottom: 14px; }
  .head .eyebrow {
    font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--accent); font-weight: 700; margin-bottom: 4px;
  }
  .head h1 { font-size: 18px; color: #ecf0f1; line-height: 1.25; }
  .head .counter {
    font-size: 12px; color: #95a5a6; margin-top: 6px;
  }
  .head .counter strong { color: #ecf0f1; font-weight: 800; }

  /* Slide preview card — compact mirror of what the projector shows */
  .preview-wrap {
    background: rgba(0,0,0,0.30);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 16px;
    margin-bottom: 12px;
    min-height: 130px;
  }
  .preview { display: flex; gap: 14px; align-items: center; }
  .preview.cover { flex-direction: column; align-items: stretch; text-align: center; }
  .preview.section { flex-direction: column; align-items: stretch; text-align: center; }
  .preview-kicker {
    font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--accent); font-weight: 700;
  }
  .preview-title { font-size: 18px; font-weight: 800; color: #ecf0f1; }
  .preview-date { font-size: 13px; color: #95a5a6; }
  .preview-photo {
    width: 92px; height: 92px;
    object-fit: cover; border-radius: 10px;
    background: rgba(255,255,255,0.05);
    flex-shrink: 0;
  }
  .preview-photo.empty {
    display: flex; align-items: center; justify-content: center;
    font-size: 28px; color: rgba(255,255,255,0.30);
    border: 1px dashed rgba(255,255,255,0.15);
  }
  /* Multi-speaker preview: row of small avatars + "+N more" badge */
  .preview-avatars {
    display: flex; gap: 6px; flex-wrap: wrap;
    align-items: center;
    margin: 4px 0;
  }
  .preview-avatar {
    width: 44px; height: 44px;
    object-fit: cover; border-radius: 8px;
    background: rgba(255,255,255,0.06);
  }
  .preview-avatar.empty {
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; color: rgba(255,255,255,0.30);
    border: 1px dashed rgba(255,255,255,0.15);
  }
  .preview-extra {
    font-size: 11px; font-weight: 700; color: #95a5a6;
    padding: 0 4px;
  }
  .preview-meta { min-width: 0; flex: 1; }
  .preview-time {
    font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--accent); font-weight: 700; margin-bottom: 4px;
  }
  .preview-name { font-size: 16px; font-weight: 800; color: #fff; line-height: 1.2; }
  .preview-topic { font-size: 14px; color: var(--accent); font-weight: 700; margin-top: 2px; line-height: 1.3; }
  .preview-lead { font-size: 13px; color: var(--accent); font-weight: 700; }

  /* Controls — big Next button, smaller Previous */
  .controls {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 10px;
    margin-bottom: 18px;
  }
  .ctl {
    padding: 18px 14px;
    border-radius: 10px;
    font-weight: 800; font-size: 15px;
    cursor: pointer; font-family: inherit;
    border: 1px solid rgba(255,255,255,0.10);
    background: rgba(255,255,255,0.06); color: #ecf0f1;
  }
  .ctl.next {
    background: var(--accent); color: #1a252f;
    border-color: var(--accent);
    font-size: 18px;
  }
  .ctl:disabled { opacity: 0.35; cursor: not-allowed; }

  /* Agenda list — tap to jump */
  .agenda-list h2 {
    font-size: 11px; letter-spacing: 2px; text-transform: uppercase;
