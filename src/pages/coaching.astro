---
// Public "Metabolic Coaching Program" page. Linked from the /event/
// hub. Renders the host's coaching pitch (title + body + optional hero
// image) and a grid of every coach in the event's curated coaches list
// — read straight from the `coaches` table, NOT auto-merged from
// speakers + hosts. The master adds/edits/removes coaches on the edit
// page (Coaching Program card) so compound speaker entries like
// "Annie and David Burgeson" can be split into a solo "Annie" coach.
// No login needed; one of the attendee-facing pages.
import Base from '../layouts/Base.astro';
---
<Base title="Coaching">
  <main class="coaching" id="coaching-root">
    <p class="loading">Loading…</p>
  </main>
</Base>

<script>
  import { fetchEventBySlug, fetchSpeakers, fetchCoachSpeakers, fetchCoaches, callFunction } from '../lib/supabase.js';
  import { eventUrl } from '../lib/urls.js';
  import { escapeHtml } from '../lib/html.js';

  type Coach = {
    name: string;
    photo_url: string | null;
    bio: string | null;
    phone: string | null;
    email: string | null;
    website: string | null;
    // For dedup ordering: lower numbers win. master=0, host=1,
    // speaker=2, custom=3. So if the same person is flagged in two
    // places (e.g., a host who's also a speaker, both is_coach=true),
    // the host card (with its website field) wins.
    _rank: number;
  };

  const root = document.getElementById('coaching-root')!;
  const base = import.meta.env.BASE_URL;
  const params = new URLSearchParams(window.location.search);
  const slug = params.get('slug');

  function sanitizePhone(raw: string): string {
    // Strip spaces / parens / dashes for the sms:/tel: target. Keep the
    // leading + if present so international numbers route correctly.
    return raw.trim().replace(/[\s()\-.]/g, '');
  }

  if (!slug) {
    root.innerHTML = '<p class="loading err">No event specified.</p>';
  } else {
    (async () => {
      try {
        const event = await fetchEventBySlug(slug);
        if (!event) {
          root.innerHTML = '<p class="loading err">Event not found.</p>';
          return;
        }
        document.title = `${event.coaching_title || 'Coaching'} — ${event.name}`;
        const accent = event.accent_color || '#f39c12';
        document.documentElement.style.setProperty('--accent', accent);

        // Pull all four sources in parallel:
        //   1. master organizer if organizer_is_coach
        //   2. co-hosts flagged is_coach
        //   3. speakers flagged is_coach
        //   4. fully custom coaches from the coaches table
        // Then merge into a single list, deduped by case-insensitive
        // name so a person flagged in multiple places doesn't show up
        // twice.
        type SpeakerRow = { name: string; photo_url: string | null; bio: string | null; phone: string | null; email: string | null };
        type HostRow = { name: string | null; phone: string | null; email?: string | null; website?: string | null; bio?: string | null; photo_url?: string | null; is_coach?: boolean; is_master?: boolean };
        type CustomRow = { name: string; photo_url: string | null; bio: string | null; phone: string | null; email: string | null; website: string | null };

        const [coachSpeakers, allSpeakers, hostsRes, customCoaches] = await Promise.all([
          fetchCoachSpeakers(event.id) as Promise<SpeakerRow[]>,
          // All speakers (regardless of is_coach) as a fallback source
          // for fields the host/master row left empty — most importantly
          // bio. Cheap: events have <15 speakers.
          fetchSpeakers(event.id) as Promise<SpeakerRow[]>,
          callFunction('get-event-hosts', { slug }).catch(() => ({ hosts: [] })),
          fetchCoaches(event.id) as Promise<CustomRow[]>,
        ]);
        const teamHosts = (hostsRes.hosts || []) as HostRow[];
        const speakerByName = new Map<string, SpeakerRow>();
        for (const sp of allSpeakers) {
          if (sp.name) speakerByName.set(sp.name.trim().toLowerCase(), sp);
        }

        const byName = new Map<string, Coach>();
        // Merge: the lowest-rank entry wins on identity/ordering (master
        // first, then host, then speaker, then custom), but per-field
        // fallback fills missing values from higher-rank records. So if
        // someone is both a co-host (rank 1, no bio) and a speaker
        // (rank 2, with a bio), the merged card sits in co-host position
        // and the speaker's bio fills in. Same idea for photo, phone,
        // email, website.
        function consider(c: Coach) {
          if (!c.name) return;
          const key = c.name.trim().toLowerCase();
          const prev = byName.get(key);
          if (!prev) {
            byName.set(key, c);
            return;
          }
          const winnerByRank = c._rank < prev._rank ? c : prev;
          const otherByRank = c._rank < prev._rank ? prev : c;
          byName.set(key, {
            name: winnerByRank.name,
            photo_url: winnerByRank.photo_url || otherByRank.photo_url,
            bio: winnerByRank.bio || otherByRank.bio,
            phone: winnerByRank.phone || otherByRank.phone,
            email: winnerByRank.email || otherByRank.email,
            website: winnerByRank.website || otherByRank.website,
            _rank: winnerByRank._rank,
          });
        }
        // Master first (rank 0)
        for (const h of teamHosts) {
          if (!h.is_master || !h.is_coach || !h.name) continue;
          consider({
            name: h.name, photo_url: h.photo_url || null,
            bio: h.bio || null, phone: h.phone || null,
            email: h.email || null, website: h.website || null,
            _rank: 0,
          });
        }
        // Co-hosts (rank 1)
        for (const h of teamHosts) {
          if (h.is_master || !h.is_coach || !h.name) continue;
          consider({
            name: h.name, photo_url: h.photo_url || null,
            bio: h.bio || null, phone: h.phone || null,
            email: h.email || null, website: h.website || null,
            _rank: 1,
          });
        }
        // Speakers (rank 2)
        for (const sp of coachSpeakers) {
          if (!sp.name) continue;
          consider({
            name: sp.name, photo_url: sp.photo_url,
            bio: sp.bio, phone: sp.phone, email: sp.email,
            website: null, _rank: 2,
          });
        }
        // Custom coaches (rank 3)
        for (const c of customCoaches) {
          if (!c.name) continue;
          consider({
            name: c.name, photo_url: c.photo_url,
            bio: c.bio, phone: c.phone, email: c.email,
            website: c.website, _rank: 3,
          });
        }
        // Render in rank order, then by their natural source order
        // (already sorted in the source arrays). Simplest is to
        // iterate the sources again and skip any name already taken
        // by a lower rank.
        const used = new Set<string>();
        const coaches: Coach[] = [];
        const sources: Coach[] = [];
        for (const h of teamHosts) {
          if (!h.is_master || !h.is_coach || !h.name) continue;
          sources.push({ name: h.name, photo_url: h.photo_url || null, bio: h.bio || null, phone: h.phone || null, email: h.email || null, website: h.website || null, _rank: 0 });
        }
        for (const h of teamHosts) {
          if (h.is_master || !h.is_coach || !h.name) continue;
          sources.push({ name: h.name, photo_url: h.photo_url || null, bio: h.bio || null, phone: h.phone || null, email: h.email || null, website: h.website || null, _rank: 1 });
        }
        for (const sp of coachSpeakers) {
          if (!sp.name) continue;
          sources.push({ name: sp.name, photo_url: sp.photo_url, bio: sp.bio, phone: sp.phone, email: sp.email, website: null, _rank: 2 });
        }
        for (const c of customCoaches) {
          if (!c.name) continue;
          sources.push({ name: c.name, photo_url: c.photo_url, bio: c.bio, phone: c.phone, email: c.email, website: c.website, _rank: 3 });
        }
        for (const c of sources) {
          const key = c.name.trim().toLowerCase();
          if (used.has(key)) continue;
          // Use the lowest-rank entry we found for this name (computed
          // earlier in byName), then top-up any missing fields from a
          // same-named speaker row — covers the common case where a
          // host is flagged is_coach but their host record has no bio,
          // and the same person's speaker record does.
          const winner = byName.get(key)!;
          const sp = speakerByName.get(key);
          if (sp) {
            coaches.push({
              ...winner,
              photo_url: winner.photo_url || sp.photo_url,
              bio: winner.bio || sp.bio,
              phone: winner.phone || sp.phone,
              email: winner.email || sp.email,
            });
          } else {
            coaches.push(winner);
          }
          used.add(key);
        }

        const heroImg = event.coaching_image_url
          ? `<img class="hero-image" src="${escapeHtml(event.coaching_image_url)}" alt="" />`
          : '';
        const bodyHtml = event.coaching_body
          ? `<p class="pitch-body">${escapeHtml(event.coaching_body)}</p>`
          : '';

        const coachCards = coaches.map((c) => {
          const thumb = c.photo_url
            ? `<img class="coach-photo" src="${escapeHtml(c.photo_url)}" alt="" />`
            : '<div class="coach-photo empty" aria-hidden="true"></div>';
          const actions: string[] = [];
          if (c.phone) {
            const target = sanitizePhone(c.phone);
            actions.push(
              `<a class="coach-action primary" href="sms:${escapeHtml(target)}">📱 Text me now</a>`,
              `<a class="coach-action" href="tel:${escapeHtml(target)}">📞 Call</a>`,
            );
          }
          if (c.email) {
            actions.push(`<a class="coach-action" href="mailto:${escapeHtml(c.email)}">✉️ Email</a>`);
          }
          if (c.website) {
            actions.push(`<a class="coach-action" href="${escapeHtml(c.website)}" target="_blank" rel="noopener">🌐 Website</a>`);
          }
          return `
            <li class="coach-card">
              ${thumb}
              <div class="coach-info">
                <strong>${escapeHtml(c.name)}</strong>
                ${c.bio ? `<p class="coach-bio">${escapeHtml(c.bio)}</p>` : ''}
              </div>
              ${actions.length ? `<div class="coach-actions">${actions.join('')}</div>` : '<p class="coach-no-contact">No contact info available — ask any host at the event.</p>'}
            </li>`;
        }).join('');

        root.innerHTML = `
          <a class="back-link" href="${eventUrl(base, slug)}">← Back to the event</a>
          <header class="top">
            <p class="eyebrow">🥳 Coaching</p>
            <h1>${escapeHtml(event.coaching_title || 'Metabolic Coaching Program')}</h1>
          </header>
          ${heroImg}
          ${bodyHtml}
          ${coaches.length > 0
            ? `<section class="connect">
                <h2>Connect with a coach</h2>
                <p class="connect-hint">Tap any coach to send a text, call, or email — right now.</p>
                <ul class="coach-list">${coachCards}</ul>
              </section>`
            : '<p class="empty">No coaches listed yet. Check back at the event.</p>'}
          <div class="footer-cta">
            <a class="secondary" href="${eventUrl(base, slug)}">← Back to the event</a>
          </div>
        `;
      } catch (err) {
        root.innerHTML = `<p class="loading err">${escapeHtml((err as Error).message)}</p>`;
      }
    })();
  }
</script>

<style is:global>
  :root { --accent: #f39c12; }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: #1a252f; color: #fff;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  }
  body { padding: 20px 14px 50px; line-height: 1.45; }
  main.coaching { max-width: 540px; margin: 0 auto; }

  a.back-link {
    display: inline-block; padding: 8px 12px;
    color: #ecf0f1; text-decoration: none;
    font-size: 13px; font-weight: 600;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px; margin-bottom: 16px;
  }

  .top { text-align: center; margin-bottom: 18px; }
  .eyebrow {
    font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--accent); font-weight: 700; margin-bottom: 6px;
  }
  h1 { font-size: 26px; line-height: 1.2; overflow-wrap: anywhere; }

  .hero-image {
    /* Landscape or portrait — natural aspect, no forced crop.
       max-height caps tall portraits so they don't push the pitch
       too far down the page. */
    display: block;
    width: 100%;
    height: auto;
    max-height: 70vh;
    object-fit: contain;
    border-radius: 12px;
    margin-bottom: 16px;
  }
  .pitch-body {
    font-size: 15px; color: #ecf0f1; line-height: 1.55;
    margin-bottom: 22px;
    white-space: pre-wrap;
  }

  .connect h2 {
    font-size: 13px; letter-spacing: 1.5px; text-transform: uppercase;
    color: var(--accent); font-weight: 700; margin-bottom: 6px;
  }
  .connect-hint {
    font-size: 13px; color: #95a5a6; font-style: italic;
    margin-bottom: 12px;
  }
  ul.coach-list {
    list-style: none; padding: 0; margin: 0;
    display: grid; gap: 12px;
  }
  .coach-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.10);
    border-radius: 12px;
    padding: 14px;
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 12px;
    align-items: start;
  }
  .coach-photo {
    width: 72px; height: 72px;
    object-fit: cover; border-radius: 50%;
    background: rgba(0,0,0,0.30);
    flex-shrink: 0;
  }
  .coach-photo.empty { border: 1px dashed rgba(255,255,255,0.18); }
  .coach-info { min-width: 0; }
  .coach-info strong { font-size: 16px; color: #fff; display: block; margin-bottom: 4px; }
  .coach-bio {
    font-size: 13px; color: #bdc3c7; line-height: 1.45;
    overflow-wrap: anywhere;
  }
  .coach-actions {
    grid-column: 1 / -1;
    display: flex; flex-wrap: wrap; gap: 8px;
    margin-top: 4px;
  }
  .coach-action {
    display: inline-flex; align-items: center;
    padding: 10px 14px; min-height: 40px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    color: #ecf0f1; text-decoration: none;
    font-size: 13px; font-weight: 700;
    overflow-wrap: anywhere;
  }
  .coach-action.primary {
    background: color-mix(in srgb, var(--accent) 22%, transparent);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    color: var(--accent);
  }
  .coach-action:hover { background: rgba(255,255,255,0.10); }
  .coach-action.primary:hover { background: color-mix(in srgb, var(--accent) 32%, transparent); }
  .coach-no-contact {
    grid-column: 1 / -1;
    font-size: 12px; color: #95a5a6; font-style: italic;
    margin-top: 2px;
  }

  @media (max-width: 380px) {
    .coach-card { grid-template-columns: 56px 1fr; }
    .coach-photo { width: 56px; height: 56px; }
  }

  .empty { color: #95a5a6; font-style: italic; text-align: center; padding: 30px 0; }
  .loading { color: #95a5a6; text-align: center; padding: 40px 0; font-size: 14px; }
  .loading.err { color: #e74c3c; }

  .footer-cta { display: grid; gap: 10px; margin-top: 22px; }
  .footer-cta a {
    display: block; text-align: center; padding: 12px;
    background: transparent; color: #ecf0f1;
    border: 1px solid rgba(255,255,255,0.20); border-radius: 8px;
    text-decoration: none; font-weight: 600; font-size: 14px;
  }
</style>
