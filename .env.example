# Copy this file to `.env` and fill in your Supabase project values.
# `.env` is git-ignored. Do NOT commit real keys.
# `PUBLIC_*` vars are inlined into the client bundle at build time.

PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...

# Optional: Cloudflare Turnstile for the Build form.
# Leave blank for local dev. See docs/SUPABASE_SETUP.md.
PUBLIC_TURNSTILE_SITE_KEY=

# For GitHub Pages deploys at https://<user>.github.io/<repo>/
# set BASE to the repo path; leave as `/` for user/org Pages or custom domain.
BASE=/
SITE=https://your-user.github.io
